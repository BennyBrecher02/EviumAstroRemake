---
/**
 * Dev Mode toggle — floating Apple-Glass pill in the bottom-right.
 * ──────────────────────────────────────────────────────────────
 * Flips `body.dev-mode-off` on/off. When OFF (the default), the
 * dev-only nav items — AI BS, Testing, Other — collapse out of
 * the battery navbar via smooth width/opacity animations driven
 * by CSS transitions in Header.astro. When ON, those slots
 * animate back in and the battery extends in length.
 *
 * Persistence: the ON/OFF choice is stored under
 * `evium-dev-mode` in localStorage, so dev-mode state survives
 * page navigations and refreshes.
 *
 * Visibility: the "Toggle the toggle" item in the AI BS nav
 * dropdown hides THIS pill. That key persists separately under
 * `ev-devswitch-hidden`. Hidden means you can't toggle dev-mode
 * from the UI until you click "Toggle the toggle" again.
 *
 * Historical note: this component used to switch a dark/light
 * navbar theme (stored under `evium-theme`). The navbar's colors
 * are now locked to the light-nav palette in global.css. The
 * localStorage key `evium-theme` is no longer read, and the
 * `data-theme` attribute on <html> is no longer set by this file.
 */
---

<div id="dev-toggle" role="button" tabindex="0" aria-label="Toggle dev mode">
  <span class="track">
    <span class="thumb"></span>
  </span>
  <span class="label" id="dev-toggle-label">DEV MODE OFF</span>
</div>

<style>
  #dev-toggle {
    position: fixed;
    bottom: 28px;
    right: 28px;
    z-index: 99999;
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 14px 8px 10px;
    border-radius: 999px;
    cursor: pointer;
    user-select: none;

    background: rgba(255, 255, 255, 0.10);
    backdrop-filter: blur(24px) saturate(1.6);
    -webkit-backdrop-filter: blur(24px) saturate(1.6);
    border: 1px solid rgba(255, 255, 255, 0.18);
    box-shadow:
      0 4px 32px rgba(0, 0, 0, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);

    transition: box-shadow 0.2s ease, transform 0.15s ease;
  }

  #dev-toggle:hover {
    box-shadow:
      0 6px 40px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
    transform: translateY(-1px);
  }

  #dev-toggle:active { transform: translateY(0); }

  .track {
    position: relative;
    width: 34px;
    height: 18px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.22);
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  .thumb {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.55);
    box-shadow: 0 1px 4px rgba(0,0,0,0.4);
    transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
                background 0.3s ease;
  }

  .label {
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.70);
    transition: color 0.2s;
    min-width: 70px;
    white-space: nowrap;
  }

  /* Dev-mode-on state — thumb slides right, track + label brand-green. */
  #dev-toggle.is-dev-on .track {
    background: rgba(45, 200, 86, 0.28);
    border-color: rgba(45, 200, 86, 0.5);
  }
  #dev-toggle.is-dev-on .thumb {
    transform: translateX(16px);
    background: #2DC856;
  }
  #dev-toggle.is-dev-on .label {
    color: rgba(45, 200, 86, 0.9);
  }
</style>

<script>
  const toggle = document.getElementById('dev-toggle')!;
  const label  = document.getElementById('dev-toggle-label')!;
  const body   = document.body;

  /* Visibility of the pill itself — driven by the AI BS nav's
     "Toggle the toggle" item. If the `ev-devswitch-hidden` key is
     set to '1', this pill stays hidden across page navigations
     until the user explicitly toggles it back on. */
  try {
    if (localStorage.getItem('ev-devswitch-hidden') === '1') {
      toggle.style.display = 'none';
      toggle.setAttribute('data-hidden', 'true');
    }
  } catch {}

  /* ─── Dev-mode on/off ──────────────────────────────────
     Persisted under `evium-dev-mode`. Anything other than the
     literal string 'off' is treated as ON, so a fresh visitor
     (no key in localStorage) sees the full nav including
     Site v2. The pill below the rail still flips to OFF on
     demand and that choice persists.
  */
  function applyDevMode(mode: 'on' | 'off') {
    if (mode === 'on') {
      body.classList.remove('dev-mode-off');
      toggle.classList.add('is-dev-on');
      label.textContent = 'DEV MODE ON';
    } else {
      body.classList.add('dev-mode-off');
      toggle.classList.remove('is-dev-on');
      label.textContent = 'DEV MODE OFF';
    }
    try { localStorage.setItem('evium-dev-mode', mode); } catch {}
  }

  /* Initial apply. Default is ON now — Site v2 + the active
     iteration surfaces (Blog, Testing, Other) all live behind
     the dev-mode flag, and a fresh visitor with no key in
     localStorage was previously stuck on the public-only menu
     with no way to discover them. Switching the default makes
     them visible by default; an explicit OFF still persists. */
  let saved: string | null = null;
  try { saved = localStorage.getItem('evium-dev-mode'); } catch {}
  applyDevMode(saved === 'off' ? 'off' : 'on');

  toggle.addEventListener('click', () => {
    const current = body.classList.contains('dev-mode-off') ? 'off' : 'on';
    applyDevMode(current === 'off' ? 'on' : 'off');
  });

  toggle.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      toggle.click();
    }
  });
</script>
</content>
</invoke>