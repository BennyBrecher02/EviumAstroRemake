  /* Title — three-line stack. Bigger + bolder + tighter than
     the standard v2 section title to match v1's commanding
     close-out scale. text-wrap: pretty (not balance) so the
     explicit <br /> breaks drive the line structure. The
     gradient text-clip applies to the whole title; the green
     accent span overrides on its line for the white/green/white
     cadence. */
  .svc-final-title {
    margin: 0 auto clamp(20px, 2.2vw, 28px);
    max-width: 100%;
    font-size: clamp(2.2rem, 4.8vw, 3.6rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.028em;
    background: linear-gradient(180deg, #0a141b 0%, #1a2530 60%, #2a3640 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 0.12em;
    text-wrap: pretty;
  }
  /* Green word — "Electrified." is the emotional pivot of the
     three-line stack. Wrapped in :global() because the span is
     injected via set:html on the parent <h2> at runtime — Astro
     would otherwise scope these rules to a data-astro-cid the
     dynamic span doesn't carry.

     Reliable-supplier vibe (NOT flickery): the previous version
     had a real arc-flicker animation + white-hot inner core,
     but a flickering glow on a premium energy-supplier brand
     reads as "unreliable power." Same goes for the white core
     on a LIGHT card background — it gets washed out and the
     halo loses definition. Replaced with a steady, controlled,
     confident green glow:

       1) Solid brand-green text fill (#2DC856) — overrides
          the parent .svc-final-title's transparent fill via
          -webkit-text-fill-color so the green pierces through.
       2) Subtle 1px deep-green inner edge for letter-form
          definition on the light background.
       3) Three layered green halos (12px close, 32px mid,
          64px far) progressively softening — reads as a
          confident continuous green field around the word
          rather than a spotty effect.
       4) Slow, very subtle 4s breathing pulse (±15% intensity)
          so the word feels alive without ever jumping. No
          stutter, no flicker, no opacity drops. */
  :global(.svc-final-title-accent) {
    display: inline-block;
    background: none;
    -webkit-background-clip: initial;
    background-clip: initial;
    -webkit-text-fill-color: #2DC856;
    color: #2DC856;
    text-shadow:
      0 0 1px rgba(29, 153, 66, 0.55),
      0 0 12px rgba(45, 200, 86, 0.50),
      0 0 32px rgba(45, 200, 86, 0.32),
      0 0 64px rgba(45, 200, 86, 0.18);
    animation: svc-electric-breathe 4s ease-in-out infinite;
  }
  /* Slow, refined breathing pulse — a confident "this is on"
     signal. Halos shift between ~85% and ~115% of resting
     intensity over the 4s cycle; the text-fill color stays
     constant so the word never dims, only the surrounding
     field does. */
  @keyframes svc-electric-breathe {
    0%, 100% {
      text-shadow:
        0 0 1px rgba(29, 153, 66, 0.50),
        0 0 10px rgba(45, 200, 86, 0.42),
        0 0 28px rgba(45, 200, 86, 0.26),
        0 0 56px rgba(45, 200, 86, 0.14);
    }
    50% {
      text-shadow:
        0 0 1px rgba(29, 153, 66, 0.60),
        0 0 16px rgba(45, 200, 86, 0.58),
        0 0 38px rgba(45, 200, 86, 0.38),
        0 0 76px rgba(45, 200, 86, 0.22);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(.svc-final-title-accent) { animation: none; }
  }

