---
/**
 * ServicePageV2 — Shared service-page template.
 * ─────────────────────────────────────────────
 * Single template all v2 service pages render through. Takes a
 * `service` config prop that fully describes the page; template
 * renders Hero (always) + dynamic sections (in order, each
 * optional via the config) + Final CTA (always). Future edits
 * to the template propagate to every service that uses it.
 *
 * Visual style matches the v2 sandbox (home-v2, products-v2):
 * Apple-light theme — white card surfaces, neutral 3-layer
 * elevation, brand-green accents, glass UI for premium
 * elements. Uses HeaderV4 lefter rail via Layout's
 * `headerVariant="v4"`.
 *
 * Adding a new section type:
 *   1. extend `Section` union below
 *   2. add a render block in the `service.sections.map()` switch
 *   3. add scoped styles for the new section's classes
 *
 * Adding a new icon:
 *   1. add a new case in the inline IconSvg block
 *   2. cards reference it by `icon: 'name'`
 */
import Layout from '../../layouts/Layout.astro';
import SiteFooter from '../SiteFooter.astro';
import type { ServicePageConfig, IconName } from './types';

interface Props {
  service: ServicePageConfig;
}

const { service } = Astro.props;

/* ── Icon registry ───────────────────────────────────────────
   Each entry is { viewBox, body } so icons can mix viewBox sizes
   and use multi-path content. Body is the inner SVG markup
   (paths, circles, etc.) — rendered via set:html on an outer
   <svg viewBox={…}> in the template.

   Style convention: stroked, currentColor, 1.6–1.75 stroke-width,
   round caps + joins. Filled icons (the bolt is the exception)
   use fill="currentColor". */
const ICONS: Record<IconName, { viewBox: string; body: string }> = {
  /* check — small in-card affordance for feature-list bullets */
  check: {
    viewBox: '0 0 16 16',
    body: '<path d="M3 8.5l3.5 3.5L13 5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* x — pain-side glyph for problem statements (paired with
     `check` on the solution side for green/red contrast). */
  x: {
    viewBox: '0 0 16 16',
    body: '<path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* bolt — lightning, used for hardware-selection / electrical
     scope. Filled silhouette reads bolder than stroked at the
     scope-card icon size. */
  bolt: {
    viewBox: '0 0 24 24',
    body: '<path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="currentColor"/>',
  },
  /* shield — permits / compliance / liability protection. */
  shield: {
    viewBox: '0 0 24 24',
    body: '<path d="M12 2 4 5v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V5l-8-3z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* clock — 24/7 / ongoing operations. Kept v2's compact form. */
  clock: {
    viewBox: '0 0 16 16',
    body: '<path d="M8 4v4l3 2M8 1a7 7 0 100 14 7 7 0 000-14z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* chart — heroicons "chart-bar" silhouette ported from v1.
     Three rounded-rect bars of ascending height read more
     "investment / returns over time" than a simple line graph,
     which fits the financial-model "you finance, you keep 100%"
     framing better. */
  chart: {
    viewBox: '0 0 24 24',
    body: '<path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* wrench — kept for legacy compatibility. Use `hammer` for
     installation / construction iconography. */
  wrench: {
    viewBox: '0 0 16 16',
    body: '<path d="M11 4l3-3 1 1-3 3-1 1-1-1-1 1 5 5-1 1-5-5-5 5-2-2 5-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* hammer — ported from HeaderV4 nav menu. Better silhouette
     than `wrench` for "we install it" messaging. Multi-path
     so the hammer head, handle, and claw all render distinct. */
  hammer: {
    viewBox: '0 0 24 24',
    body: '<path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="m18 15 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  spark: {
    viewBox: '0 0 16 16',
    body: '<path d="M8 1v3m0 8v3M3 8h3m4 0h3M4 4l2 2m4 4l2 2m0-8l-2 2m-4 4l-2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* coin — dollar-in-circle for revenue / rebate processing.
     Rebuilt clean (the v1 version had the $ glyph slightly off-
     center): vertical bar runs through x=12 from y=6→18, S-curve
     stroked with round caps so the centering is exact in the
     circle. */
  coin: {
    viewBox: '0 0 24 24',
    body: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="M12 6v12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/><path d="M15 9c-.5-.7-1.5-1.2-2.7-1.2-1.6 0-2.8.8-2.8 2.1 0 1.2.7 1.7 2.4 2.1 1.7.4 2.6.8 2.6 2.1 0 1.4-1.2 2.2-2.8 2.2-1.2 0-2.2-.4-2.7-1.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  users: {
    viewBox: '0 0 16 16',
    body: '<path d="M11 7a3 3 0 11-6 0 3 3 0 016 0zM2 14c0-2.5 2-4 6-4s6 1.5 6 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  gear: {
    viewBox: '0 0 16 16',
    body: '<path d="M8 5a3 3 0 100 6 3 3 0 000-6zm0-4l1.5 2L12 2l1 2 2-.5L14 5l2 1.5L14 8l1 2-2-.5-1 2-2.5-1L8 14l-1.5-2L4 13l-1-2-2 .5L2 9 0 7.5 2 6 1 4l2 .5 1-2 2.5 1z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  pin: {
    viewBox: '0 0 16 16',
    body: '<path d="M8 1a5 5 0 00-5 5c0 4 5 9 5 9s5-5 5-9a5 5 0 00-5-5zm0 7a2 2 0 110-4 2 2 0 010 4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* map — folded paper-map silhouette ported from v1. The 3-fold
     panel layout reads more "site walk / locations" than a single
     pin-drop. Used for "Site Assessment & Engineering" scope. */
  map: {
    viewBox: '0 0 24 24',
    body: '<path d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6-3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* trend — upward arrow into chart, for market-shift / EV-
     adoption messaging in narrative sections. */
  trend: {
    viewBox: '0 0 24 24',
    body: '<path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* search — magnifying glass over a building, for renter-search
     / discovery narrative use. */
  search: {
    viewBox: '0 0 24 24',
    body: '<circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="m20 20-4.35-4.35" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/>',
  },
  /* compass — competitive direction / "neighbors are moving"
     market narrative. */
  compass: {
    viewBox: '0 0 24 24',
    body: '<circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6" fill="none"/><path d="m14.5 9.5-1.5 4.5-4.5 1.5 1.5-4.5z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  arrow: {
    viewBox: '0 0 16 16',
    body: '<path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* info — circle with lower-case `i`. Used as the glyph for
     financial-model highlight callouts. */
  info: {
    viewBox: '0 0 16 16',
    body: '<circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5" fill="none"/><path d="M8 7v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="5" r="0.8" fill="currentColor"/>',
  },
  /* home — heroicons "home" silhouette ported from v1's
     Market Reality "Tenants Search for Charging" card.
     Detailed roof + walls + door read more "this is a place
     to live" than the simpler pin/house outline used in the
     header lefter rail. Used in both the v2 narrative card
     AND HeaderV4's home-v2 lefter tile (single source of
     truth for the brand's "home" mark). */
  home: {
    viewBox: '0 0 24 24',
    body: '<path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* user — heroicons "user-circle" silhouette ported from v1.
     Single-person glyph used in the testimonial attribution
     avatar circle. */
  user: {
    viewBox: '0 0 24 24',
    body: '<path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* building — heroicons "office-building" silhouette ported
     from v1. Used in the social-proof "RJ Block Properties"
     callout to signal a multifamily portfolio reference. */
  building: {
    viewBox: '0 0 24 24',
    body: '<path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* phone — heroicons "device-mobile" silhouette ported from v1.
     Used in the Driver App card head — a phone outline that
     reads as "this is the resident-facing mobile experience"
     without ambiguity. */
  phone: {
    viewBox: '0 0 24 24',
    body: '<path d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
  /* stack — heroicons "duplicate" silhouette ported from v1.
     Two overlapping rounded squares (back square top-left,
     front square bottom-right) read as "hybrid / shared /
     copied" — fits the Hybrid Model card. */
  stack: {
    viewBox: '0 0 24 24',
    body: '<path d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
  },
};
---

<Layout
  title={service.meta.title}
  description={service.meta.description}
  headerVariant="v4"
  bodyClass="page-service-testing"
>
  <main class="svc-page">
    {/* ═══════════════════════════════════════════════════════════
         HERO — Cinematic full-bleed image hero.
         The hero photo (e.g. multifamily-realestate-service-hero.jpg)
         fills the entire hero as a background `<img>`. A diagonal
         gradient overlay weights heavier on the bottom-left where
         the copy sits and lets the upper-right of the image breathe
         (perfect for the warm-light multifamily building shot).

         Markup layers, bottom-up in z-order:
           1. <img> — full-cover hero photo
           2. .svc-hero-tint — diagonal dark gradient for legibility
           3. .svc-hero-content — copy + CTAs (bottom-left, max-width)
           4. .svc-stat-strip — glass row pinned to hero bottom
         ═══════════════════════════════════════════════════════════ */}
    <section
      class="svc-hero"
      id="service-hero"
      data-lv4-anchor="service-hero"
      class:list={[service.hero.image ? 'has-image' : 'no-image']}
    >
      {service.hero.image ? (
        <div class="svc-hero-bg" aria-hidden="true">
          <img
            src={service.hero.image.src}
            alt=""
            class="svc-hero-bg-img"
            loading="eager"
            fetchpriority="high"
          />
          <div class="svc-hero-tint"></div>
        </div>
      ) : (
        <div class="svc-hero-bg svc-hero-bg--gradient" aria-hidden="true">
          <div class="svc-hero-orb svc-hero-orb--green"></div>
          <div class="svc-hero-orb svc-hero-orb--soft"></div>
        </div>
      )}

      <div class="svc-hero-content">
        <p class="svc-hero-eyebrow">
          <span class="svc-eyebrow-dash" aria-hidden="true"></span>
          <span>{service.hero.eyebrow}</span>
        </p>
        <h1 class="svc-hero-title" set:html={service.hero.headline.replace(/\n/g, '<br />')} />
        <p class="svc-hero-sub">{service.hero.subhead}</p>
        <div class="svc-cta-row">
          <a class="svc-cta svc-cta--primary" href={service.hero.primaryCta.href}>
            <span>{service.hero.primaryCta.label}</span>
            <svg viewBox={ICONS.arrow.viewBox} aria-hidden="true" set:html={ICONS.arrow.body} />
          </a>
          {service.hero.secondaryCta && (
            <a class="svc-cta svc-cta--ghost-on-image" href={service.hero.secondaryCta.href}>
              <span>{service.hero.secondaryCta.label}</span>
            </a>
          )}
        </div>
      </div>

      {service.hero.stats && service.hero.stats.length > 0 && (
        <div class="svc-stat-strip">
          {service.hero.stats.map((s) => (
            s.href ? (
              <a class="svc-stat svc-stat--btn" href={s.href}>
                {s.icon && (
                  <span class="svc-stat-icon" aria-hidden="true">
                    <svg viewBox={ICONS[s.icon].viewBox} set:html={ICONS[s.icon].body} />
                  </span>
                )}
                <span class="svc-stat-text">
                  <span class="svc-stat-value">{s.value}</span>
                  <span class="svc-stat-label">{s.label}</span>
                </span>
                <span class="svc-stat-arrow" aria-hidden="true">
                  <svg viewBox={ICONS.arrow.viewBox} set:html={ICONS.arrow.body} />
                </span>
              </a>
            ) : (
              <div class="svc-stat">
                <span class="svc-stat-value">{s.value}</span>
                <span class="svc-stat-label">{s.label}</span>
              </div>
            )
          ))}
        </div>
      )}
    </section>

    {/* ═══════════════════════════════════════════════════════════
         DYNAMIC SECTIONS
         Iterates the `sections` array in config order. Each
         section is an isolated <section> with the same
         vertical rhythm and section-head pattern (eyebrow +
         title + optional subhead). The body markup varies by
         `type`.
         ═══════════════════════════════════════════════════════════ */}
    {service.sections.map((section, idx) => (
      <>
        {/* ── NARRATIVE — short market-context section between
             hero and detail sections. Left-aligned head (vs.
             centered everywhere else) + optional 3-up highlight
             card grid. The left-alignment differentiates it as
             a "context paragraph" rather than a detail block. */}
        {section.type === 'narrative' && (
          <section
            class:list={['svc-section', 'svc-section--narrative', idx % 2 === 1 ? 'is-alt' : '']}
            id={section.anchor ?? `service-${section.type}`}
            data-lv4-anchor={section.anchor ?? `service-${section.type}`}
          >
            <header class="svc-section-head svc-section-head--start">
              <span class="svc-section-num" aria-hidden="true">/ {String(idx + 1).padStart(2, '0')}</span>
              <p class="svc-eyebrow">
                <span class="svc-eyebrow-dash" aria-hidden="true"></span>
                <span>{section.eyebrow}</span>
              </p>
              <h2 class="svc-section-title">{section.title}</h2>
              {section.subhead && <p class="svc-section-sub">{section.subhead}</p>}
            </header>
            {section.highlights && section.highlights.length > 0 && (
              <div class="svc-narrative-grid">
                {section.highlights.map((h) => (
                  <article class="svc-narrative-card">
                    {h.icon && (
                      <span class="svc-narrative-icon" aria-hidden="true">
                        <svg viewBox={ICONS[h.icon].viewBox} set:html={ICONS[h.icon].body} />
                      </span>
                    )}
                    <h3 class="svc-narrative-title">{h.title}</h3>
                    <p class="svc-narrative-body">{h.body}</p>
                  </article>
                ))}
              </div>
            )}
          </section>
        )}

        {/* ── PAIN POINTS — sticky-left header + stacked-right
             cards. Each card shows the user's CONCERN on the
             left half (red ✗ + tinted bg) and Evium's HANDLING
             on the right half (green ✓ + tinted bg) — a literal
             before/after visual transformation per concern.

             The whole section is dark (brand teal #1A2F3A) so
             the red/green contrast pops. The number-of-items
             problem (5 didn't fit cleanly in a 2-col grid) is
             solved by the new layout: cards stack vertically on
             the right, no orphan, looks the same at any count. */}
        {section.type === 'painPoints' && (
          <section
            class:list={['svc-section', 'svc-section--dark', 'svc-section--pain']}
            id={section.anchor ?? `service-${section.type}`}
            data-lv4-anchor={section.anchor ?? `service-${section.type}`}
          >
            <div class="svc-pain-layout">
              <header class="svc-pain-header">
                <span class="svc-section-num" aria-hidden="true">/ {String(idx + 1).padStart(2, '0')}</span>
                <p class="svc-eyebrow">
                  <span class="svc-eyebrow-dash" aria-hidden="true"></span>
                  <span>{section.eyebrow}</span>
                </p>
                <h2 class="svc-section-title">{section.title}</h2>
                {section.subhead && <p class="svc-section-sub">{section.subhead}</p>}
                {section.cta && (
                  <a class="svc-cta svc-cta--primary svc-pain-cta" href={section.cta.href}>
                    <span>{section.cta.label}</span>
                    <svg viewBox={ICONS.arrow.viewBox} aria-hidden="true" set:html={ICONS.arrow.body} />
                  </a>
                )}
              </header>
              <div class="svc-pain-stack">
                {section.items.map((p, i) => (
                  <article class="svc-pain-card">
                    <span class="svc-pain-card-num" aria-hidden="true">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <div class="svc-pain-side svc-pain-side--problem">
                      <div class="svc-pain-side-head">
                        <span class="svc-pain-icon svc-pain-icon--x" aria-hidden="true">
                          <svg viewBox={ICONS.x.viewBox} set:html={ICONS.x.body} />
                        </span>
                        <span class="svc-pain-side-label svc-pain-side-label--problem">The concern</span>
                      </div>
                      <h3 class="svc-pain-problem">{p.problem}</h3>
                    </div>
                    <span class="svc-pain-arrow" aria-hidden="true">
                      <svg viewBox={ICONS.arrow.viewBox} set:html={ICONS.arrow.body} />
                    </span>
                    <div class="svc-pain-side svc-pain-side--solution">
                      <div class="svc-pain-side-head">
                        <span class="svc-pain-icon svc-pain-icon--check" aria-hidden="true">
                          <svg viewBox={ICONS.check.viewBox} set:html={ICONS.check.body} />
                        </span>
                        <span class="svc-pain-side-label svc-pain-side-label--solution">Evium handles it</span>
                      </div>
                      <p class="svc-pain-solution">{p.solution}</p>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </section>
        )}

        {/* ── SCOPE — icon + title + body cards in a 3-col grid ─ */}
        {section.type === 'scope' && (
          <section
            class:list={['svc-section', idx % 2 === 1 ? 'is-alt' : '']}
            id={section.anchor ?? `service-${section.type}`}
            data-lv4-anchor={section.anchor ?? `service-${section.type}`}
          >
            <header class="svc-section-head">
              <span class="svc-section-num" aria-hidden="true">/ {String(idx + 1).padStart(2, '0')}</span>
              <p class="svc-eyebrow">
                <span class="svc-eyebrow-dash" aria-hidden="true"></span>
                <span>{section.eyebrow}</span>
              </p>
              <h2 class="svc-section-title">{section.title}</h2>
              {section.subhead && <p class="svc-section-sub">{section.subhead}</p>}
            </header>
            <div class="svc-scope-grid">
              {section.items.map((item, i) => (
                <article class="svc-scope-card">
                  <span class="svc-scope-num" aria-hidden="true">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  {item.icon && (
                    <span class="svc-scope-icon" aria-hidden="true">
                      <svg viewBox={ICONS[item.icon].viewBox} set:html={ICONS[item.icon].body} />
                    </span>
                  )}
                  <h3 class="svc-scope-title">{item.title}</h3>
                  <p class="svc-scope-body">{item.body}</p>
                </article>
              ))}
            </div>
          </section>
        )}

        {/* ── HARDWARE — charger cards (image + name + features) ─ */}
        {section.type === 'hardware' && (
          <section
            class:list={['svc-section', 'svc-section--dark', 'svc-section--hardware']}
            id={section.anchor ?? `service-${section.type}`}
            data-lv4-anchor={section.anchor ?? `service-${section.type}`}
          >
            <header class="svc-section-head">
              <span class="svc-section-num" aria-hidden="true">/ {String(idx + 1).padStart(2, '0')}</span>
              <p class="svc-eyebrow">
                <span class="svc-eyebrow-dash" aria-hidden="true"></span>
                <span>{section.eyebrow}</span>
              </p>
              <h2 class="svc-section-title">{section.title}</h2>
              {section.subhead && <p class="svc-section-sub">{section.subhead}</p>}
            </header>
            <div class:list={['svc-hw-grid', `svc-hw-grid--${section.items.length}`]}>
              {section.items.map((item) => (
                <article class:list={['svc-hw-card', item.tier === 'l3' ? 'svc-hw-card--dc' : '']}>
                  <div class="svc-hw-stage">
                    {item.image ? (
                      <img src={item.image} alt={item.imageAlt ?? item.name} class="svc-hw-img" loading="lazy" />
                    ) : (
                      <span class="svc-hw-img-fallback" aria-hidden="true">
                        <svg viewBox={ICONS.bolt.viewBox} set:html={ICONS.bolt.body} />
                      </span>
                    )}
                  </div>
                  <div class="svc-hw-body">
                    {item.tier && (
                      <span class:list={['svc-hw-tag', item.tier === 'l3' ? 'svc-hw-tag--dc' : '']}>
                        {item.tier === 'l3' ? 'DC Fast' : 'Level 2'}
                      </span>
                    )}
                    <h3 class="svc-hw-name">{item.name}</h3>
                    <ul class="svc-hw-features">
                      {item.features.map((f) => (
                        <li>
                          <span class="svc-hw-tick" aria-hidden="true">
                            <svg viewBox={ICONS.check.viewBox} set:html={ICONS.check.body} />
                          </span>
                          <span>{f}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </article>
              ))}
            </div>
            {section.seeAllLink && (
              <div class="svc-hw-foot">
                <a class="svc-hw-seeall" href={section.seeAllLink.href}>
                  <span>{section.seeAllLink.label}</span>
                  <svg viewBox={ICONS.arrow.viewBox} aria-hidden="true" set:html={ICONS.arrow.body} />
                </a>
              </div>
            )}
          </section>
        )}

        {/* ── FINANCIAL MODELS — modern white/green v2 styling
             with v1's better composition. Featured card is wider
             (2fr vs 1fr), shows an icon block at top, a green
             tagline, body copy, and a glassy info-box highlight
             pinned to the card bottom. Non-featured cards use a
             muted small-caps tagline and skip the highlight. The
             "Most Popular" badge is a clean tab in the top-right
             corner of the featured card; on featured cards the
             green top accent rule is suppressed so it never
             crosses through the badge. Section ends with an
             optional muted footnote line for adjacent options
             (e.g. leasing). */}
        {section.type === 'financialModels' && (
          <section
            class:list={['svc-section', 'svc-section--fin', idx % 2 === 1 ? 'is-alt' : '']}
            id={section.anchor ?? `service-${section.type}`}
            data-lv4-anchor={section.anchor ?? `service-${section.type}`}
          >
            <header class="svc-section-head">
              <span class="svc-section-num" aria-hidden="true">/ {String(idx + 1).padStart(2, '0')}</span>
              <p class="svc-eyebrow">
                <span class="svc-eyebrow-dash" aria-hidden="true"></span>
                <span>{section.eyebrow}</span>
              </p>
              {/* set:html so a `\n` in the title string becomes a
                  <br /> at render time — used here to control the
                  line break on the financial-models title (e.g.
                  "You Choose How\nYou Want to Work With Us." so
                  each line starts with "You" like v1, instead of
                  letting `text-wrap: balance` push both Yous onto
                  the first line). */}
              <h2 class="svc-section-title" set:html={section.title.replace(/\n/g, '<br />')} />
              {section.subhead && <p class="svc-section-sub">{section.subhead}</p>}
            </header>
            <div
              class:list={[
                'svc-fin-grid',
                `svc-fin-grid--${section.models.length}`,
                section.models.some((m) => m.featured) ? 'svc-fin-grid--has-featured' : '',
              ]}
            >
              {section.models.map((m) => (
                <article class:list={['svc-fin-card', m.featured ? 'is-featured' : '']}>
                  {m.badge && <span class="svc-fin-badge">{m.badge}</span>}
                  {m.icon && (
                    <span class="svc-fin-icon" aria-hidden="true">
                      <svg viewBox={ICONS[m.icon].viewBox} set:html={ICONS[m.icon].body} />
                    </span>
                  )}
                  <h3 class="svc-fin-name">{m.name}</h3>
                  <p class="svc-fin-tagline">{m.tagline}</p>
                  <p class="svc-fin-body">{m.body}</p>
                  {m.bullets && m.bullets.length > 0 && (
                    <ul class="svc-fin-bullets">
                      {m.bullets.map((b) => (
                        <li>
                          <span class="svc-hw-tick" aria-hidden="true">
                            <svg viewBox={ICONS.check.viewBox} set:html={ICONS.check.body} />
                          </span>
                          <span>{b}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                  {m.highlight && (
                    <div class="svc-fin-highlight">
                      <span class="svc-fin-highlight-icon" aria-hidden="true">
                        <svg viewBox={ICONS.info.viewBox} set:html={ICONS.info.body} />
                      </span>
                      <span class="svc-fin-highlight-text">{m.highlight}</span>
                    </div>
                  )}
                </article>
              ))}
            </div>
            {section.footnote && (
              <p class="svc-fin-footnote">
                {section.footnote.before}
                {section.footnote.link && (
                  <a class="svc-fin-footnote-link" href={section.footnote.link.href}>
                    {section.footnote.link.label}
                  </a>
                )}
                {section.footnote.after}
              </p>
            )}
          </section>
        )}

        {/* ── SOFTWARE — v1's 2-col dark layout. LEFT column owns
             the section header (eyebrow + title + intro) and the
             Owner Portal block (green-dash header + bullet list).
             RIGHT column is offset down on desktop and stacks
             two cards: the Driver App card (phone icon, app
             title + platform subtitle, body, bullets) and the
             24/7 Support card (clock icon — kept from v2,
             swapped in for v1's busier life-buoy — title, body).
             The standard centered .svc-section-head is hidden via
             CSS in this section variant; the eyebrow + title
             are rendered inline inside the left column instead. */}
        {section.type === 'software' && (
          <section
            class:list={['svc-section', 'svc-section--dark', 'svc-section--sw']}
            id={section.anchor ?? `service-${section.type}`}
            data-lv4-anchor={section.anchor ?? `service-${section.type}`}
          >
            <div class="svc-sw-grid">
              {/* LEFT — section header + Owner Portal */}
              <div class="svc-sw-left">
                <p class="svc-sw-eyebrow">{section.eyebrow}</p>
                <h2
                  class="svc-sw-title"
                  set:html={section.title.replace(/\n/g, '<br />')}
                />
                <p class="svc-sw-intro">{section.config.intro}</p>
                <div class="svc-sw-portal">
                  <div class="svc-sw-portal-head">
                    <span class="svc-sw-portal-dash" aria-hidden="true"></span>
                    <h3 class="svc-sw-portal-title">
                      {section.config.portalTitle ?? 'Owner Portal'}
                    </h3>
                  </div>
                  <ul class="svc-sw-bullet-list">
                    {section.config.portalFeatures.map((f) => (
                      <li>
                        <span class="svc-sw-bullet-dot" aria-hidden="true"></span>
                        <span>{f}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              {/* RIGHT — Driver App card + Support card */}
              <div class="svc-sw-right">
                <article class="svc-sw-card">
                  <div class="svc-sw-card-head">
                    <span class="svc-sw-card-icon" aria-hidden="true">
                      <svg viewBox={ICONS.phone.viewBox} set:html={ICONS.phone.body} />
                    </span>
                    <div class="svc-sw-card-titles">
                      <h3 class="svc-sw-card-title">
                        {section.config.appTitle ?? 'Evium Driver App'}
                      </h3>
                      {section.config.appSubtitle && (
                        <p class="svc-sw-card-subtitle">{section.config.appSubtitle}</p>
                      )}
                    </div>
                  </div>
                  {section.config.appBody && (
                    <p class="svc-sw-card-body">{section.config.appBody}</p>
                  )}
                  <ul class="svc-sw-bullet-list">
                    {section.config.appFeatures.map((f) => (
                      <li>
                        <span class="svc-sw-bullet-dot" aria-hidden="true"></span>
                        <span>{f}</span>
                      </li>
                    ))}
                  </ul>
                </article>

                {section.config.support && (
                  <article class="svc-sw-support">
                    <span class="svc-sw-support-icon" aria-hidden="true">
                      <svg viewBox={ICONS.clock.viewBox} set:html={ICONS.clock.body} />
                    </span>
                    <div>
                      <h4 class="svc-sw-support-title">{section.config.support.title}</h4>
                      <p class="svc-sw-support-body">{section.config.support.body}</p>
                    </div>
                  </article>
                )}
              </div>
            </div>
          </section>
        )}

        {/* ── SOCIAL PROOF — v1's "Proven at Scale" section ported
             1:1. Dark teal bg + atmospheric center glow, centered
             header (eyebrow + 2-line title), 4-up stats grid,
             full-width testimonial card with green left bar +
             green oversize quote-mark + user-circle attribution,
             and a "RJ Block Properties" callout strip below
             with the building icon. */}
        {section.type === 'socialProof' && (
          <section
            class:list={['svc-section', 'svc-section--dark', 'svc-section--proof']}
            id={section.anchor ?? `service-${section.type}`}
            data-lv4-anchor={section.anchor ?? `service-${section.type}`}
          >
            <div class="svc-proof-glow" aria-hidden="true"></div>
            <div class="svc-proof-inner">
              <header class="svc-proof-head">
                <p class="svc-proof-eyebrow">{section.eyebrow}</p>
                <h2
                  class="svc-proof-title"
                  set:html={section.title.replace(/\n/g, '<br />')}
                />
              </header>
              <div class="svc-proof-stats">
                {section.config.stats.map((s) => (
                  <div class="svc-proof-stat">
                    <span class="svc-proof-stat-value">{s.value}</span>
                    <span class="svc-proof-stat-label">{s.label}</span>
                  </div>
                ))}
              </div>
              {section.config.testimonial && (
                <div class="svc-testimonial-wrap">
                  <article class="svc-testimonial">
                    <span class="svc-testimonial-bar" aria-hidden="true"></span>
                    <span class="svc-testimonial-quote-mark" aria-hidden="true">"</span>
                    <blockquote class="svc-testimonial-block">
                      <p class="svc-testimonial-quote">{section.config.testimonial.quote}</p>
                      <footer class="svc-testimonial-attr">
                        <span class="svc-testimonial-attr-icon" aria-hidden="true">
                          <svg viewBox={ICONS.user.viewBox} set:html={ICONS.user.body} />
                        </span>
                        <div class="svc-testimonial-attr-text">
                          <span class="svc-testimonial-attr-name">
                            {section.config.testimonial.attribution}
                          </span>
                          {(section.config.testimonial.company || section.config.testimonial.role) && (
                            <span class="svc-testimonial-attr-role">
                              {section.config.testimonial.company}
                              {section.config.testimonial.company && section.config.testimonial.role ? ' — ' : ''}
                              {section.config.testimonial.role}
                            </span>
                          )}
                        </div>
                      </footer>
                    </blockquote>
                  </article>
                </div>
              )}
              {section.config.callout && (
                <div class="svc-callout-wrap">
                  <article class="svc-callout">
                    <span class="svc-callout-icon" aria-hidden="true">
                      <svg viewBox={ICONS.building.viewBox} set:html={ICONS.building.body} />
                    </span>
                    <div class="svc-callout-text">
                      <h3 class="svc-callout-title">{section.config.callout.title}</h3>
                      <p class="svc-callout-body">{section.config.callout.body}</p>
                    </div>
                  </article>
                </div>
              )}
            </div>
          </section>
        )}

        {/* ─────────────────────────────────────────────────────────
             FUTURE WORK — per-service customer-review section.
             ─────────────────────────────────────────────────────────
             A `socialProofCarousel` section type was prototyped here
             (multi-testimonial scroll track sourced from
             `src/data/customers.ts`) and rolled back. Reviews will
             come back via a different mechanism — the section type
             will likely be opt-in on a per-service basis so services
             with no customer reviews don't render an empty proof
             zone, and services with reviews can choose between the
             single-testimonial `socialProof` block and a multi-card
             treatment.

             Current review inventory (from `src/data/customers.ts`,
             10 verified customers with edited reviews):
               ┌──────────────────────────────┬─────────────────┐
               │  Multifamily Residences      │  7 reviews      │
               │  Commercial (incl. Office)   │  3 reviews      │
               │  Retail                      │  1 review       │
               │  Fleets                      │  0 reviews      │
               │  Highway Fast Charging       │  0 reviews      │
               │  Parking                     │  0 reviews      │
               │  Medical                     │  0 reviews      │
               └──────────────────────────────┴─────────────────┘
             So whatever opt-in mechanism replaces the prototype
             needs to gracefully handle 0-review services (skip the
             section entirely or show a non-testimonial proof block
             like stats / partners / press logos instead).
             ───────────────────────────────────────────────────── */}

        {/* ── FAQ — v1's "Frequently Asked Questions" ported 1:1.
             Dark teal bg, centered header (eyebrow + 2-line title),
             stack of dark accordion cards with chevron toggles
             that rotate on open. <details>/<summary> for native
             keyboard + a11y; the chevron + open-state styling
             gives the v1 look. No question-number prefix. */}
        {section.type === 'faq' && (
          <section
            class:list={['svc-section', 'svc-section--dark', 'svc-section--faq']}
            id={section.anchor ?? `service-${section.type}`}
            data-lv4-anchor={section.anchor ?? `service-${section.type}`}
          >
            <div class="svc-faq-inner">
              <header class="svc-faq-head">
                <p class="svc-faq-eyebrow">{section.eyebrow}</p>
                <h2
                  class="svc-faq-title"
                  set:html={section.title.replace(/\n/g, '<br />')}
                />
              </header>
              <ul class="svc-faq-list">
                {section.items.map((q) => (
                  <li class="svc-faq-item">
                    <details>
                      <summary class="svc-faq-q">
                        <span class="svc-faq-q-text">{q.q}</span>
                        <span class="svc-faq-q-toggle" aria-hidden="true">
                          <svg viewBox="0 0 24 24">
                            <path d="M19 9l-7 7-7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                          </svg>
                        </span>
                      </summary>
                      <div class="svc-faq-a">{q.a}</div>
                    </details>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        )}
      </>
    ))}

    {/* ═══════════════════════════════════════════════════════════
         FINAL CTA — always rendered, centered glass card with
         eyebrow + headline + sub + CTAs + optional footnote.
         ═══════════════════════════════════════════════════════════ */}
    {/* ═══════════════════════════════════════════════════════════
         FINAL CTA — v2 white-bubble card with v1's composition:
         pulsing-pill eyebrow, three-line headline (white / green /
         white) with the middle "Electrified." line in brand green
         via an embedded <span class="svc-final-title-accent">,
         square v1-style buttons (border-radius 6px, big padding,
         font-black), and an atmospheric green glow behind the
         card for "background light depth blur."
         ═══════════════════════════════════════════════════════════ */}
    <section class="svc-final" id="service-cta" data-lv4-anchor="service-cta">
      <div class="svc-final-glow" aria-hidden="true"></div>
      <div class="svc-final-card">
        {service.finalCta.eyebrow && (
          <p class="svc-final-pill">
            <span class="svc-final-pill-dot" aria-hidden="true"></span>
            <span>{service.finalCta.eyebrow}</span>
          </p>
        )}
        <h2
          class="svc-final-title"
          set:html={service.finalCta.headline.replace(/\n/g, '<br />')}
        />
        {service.finalCta.subhead && (
          <p class="svc-final-sub">{service.finalCta.subhead}</p>
        )}
        <div class="svc-cta-row svc-cta-row--centered svc-final-actions">
          <a
            class="svc-cta svc-cta--primary svc-cta--final-btn"
            href={service.finalCta.primaryCta.href}
          >
            <span>{service.finalCta.primaryCta.label}</span>
            <svg viewBox={ICONS.arrow.viewBox} aria-hidden="true" set:html={ICONS.arrow.body} />
          </a>
          {service.finalCta.secondaryCta && (
            <a
              class="svc-cta svc-cta--ghost svc-cta--final-btn"
              href={service.finalCta.secondaryCta.href}
            >
              <span>{service.finalCta.secondaryCta.label}</span>
            </a>
          )}
        </div>
        {service.finalCta.footnote && (
          <p class="svc-final-footnote">{service.finalCta.footnote}</p>
        )}
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════
     SHARED SERVICE-PAGE TEMPLATE — STYLES
     ───────────────────────────────────────────────────────────
     Apple-light theme matching home-v2 / products-v2:
       background — soft top-down gradient (#f8f8fa → #efeff2)
       surfaces  — white cards with neutral 3-layer elevation
       accents   — brand-green (#2DC856) for eyebrows, CTAs,
                   icon tints, hover glow halos
       type      — Maven Pro family (loaded globally), dark-on-
                   light hierarchy with refined tracking

     Token-style elevation system mirrors products-v2's:
       --elev-1 / --elev-2 / --elev-3 (resting) and matching
       hover variants. Cards declare `box-shadow: var(--elev-2)`
       and override on hover.
     ═══════════════════════════════════════════════════════════ */
  .svc-page {
    /* elevation tokens */
    --shadow-rgb: 13, 28, 36;
    --elev-1:
      0 1px 1px rgba(var(--shadow-rgb), 0.04),
      0 2px 5px rgba(var(--shadow-rgb), 0.05),
      0 5px 11px rgba(var(--shadow-rgb), 0.05);
    --elev-2:
      0 1px 2px rgba(var(--shadow-rgb), 0.05),
      0 3px 6px rgba(var(--shadow-rgb), 0.05),
      0 7px 14px rgba(var(--shadow-rgb), 0.06),
      0 14px 26px rgba(var(--shadow-rgb), 0.04);
    --elev-3-hover:
      0 1px 2px rgba(var(--shadow-rgb), 0.05),
      0 4px 10px rgba(var(--shadow-rgb), 0.07),
      0 10px 20px rgba(var(--shadow-rgb), 0.09),
      0 18px 32px rgba(var(--shadow-rgb), 0.10),
      0 28px 44px rgba(var(--shadow-rgb), 0.04);
    --hairline: 1px solid rgba(0, 0, 0, 0.05);
    --hairline-hover: 1px solid rgba(0, 0, 0, 0.07);
    --ease: cubic-bezier(0.25, 0, 0, 1);

    /* Page background — cool blue-gray gradient (not pure white).
       Top is a soft Apple-blue-tinted off-white, mid is a touch
       cooler, bottom darkens toward a steely powder-blue gray.
       Brings brand presence without going saturated. */
    background:
      linear-gradient(180deg, #f4f7fb 0%, #eef2f7 45%, #e7edf4 100%);
    color: #1d1d1f;
    font-family: 'Maven Pro', sans-serif;
    min-height: 100vh;
  }
  /* Subtle full-page atmospheric orbs — barely-there brand-tinted
     washes that drift on the cool blue page bg. Adds depth
     without competing with content. */
  .svc-page::before {
    content: '';
    position: fixed;
    top: 8%;
    right: -10%;
    width: 720px;
    height: 720px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(45, 200, 86, 0.05) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .svc-page::after {
    content: '';
    position: fixed;
    bottom: -10%;
    left: -10%;
    width: 720px;
    height: 720px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(80, 140, 200, 0.07) 0%, transparent 70%);
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }
  .svc-page > * { position: relative; z-index: 1; }

  /* ── Eyebrow — small uppercase brand-green label with leading
       dash. Used in hero + section heads + final CTA. */
  .svc-eyebrow,
  .svc-hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: clamp(9px, 1vw, 14px);
    margin: 0 0 clamp(14px, 1.5vw, 20px);
    font-size: clamp(0.56rem, 0.7vw, 0.72rem);
    font-weight: 900;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: #2DC856;
    line-height: 1;
  }
  .svc-eyebrow--centered {
    justify-content: center;
  }
  .svc-eyebrow-dash {
    display: inline-block;
    flex: 0 0 auto;
    width: clamp(22px, 2.4vw, 32px);
    height: 1.5px;
    background: linear-gradient(90deg, #2DC856, rgba(45, 200, 86, 0));
    border-radius: 1px;
  }
  .svc-eyebrow--centered .svc-eyebrow-dash:last-child {
    background: linear-gradient(90deg, rgba(45, 200, 86, 0), #2DC856);
  }

  /* ── CTA pills — primary green / ghost outline ─────────── */
  .svc-cta {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 12px 24px;
    border-radius: 999px;
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.22s var(--ease),
      box-shadow 0.22s var(--ease),
      background 0.22s var(--ease),
      color 0.22s var(--ease),
      border-color 0.22s var(--ease),
      gap 0.22s var(--ease);
  }
  .svc-cta svg {
    width: 14px;
    height: 14px;
    display: block;
    flex-shrink: 0;
    transition: transform 0.22s var(--ease);
  }
  .svc-cta--lg { padding: 14px 28px; font-size: 0.78rem; }

  .svc-cta--primary {
    background: #2DC856;
    color: #ffffff;
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.25),
      0 6px 18px rgba(45, 200, 86, 0.32);
  }
  .svc-cta--primary:hover {
    background: #3DD667;
    transform: translateY(-2px);
    gap: 12px;
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.4),
      0 6px 16px rgba(45, 200, 86, 0.5),
      0 14px 32px rgba(45, 200, 86, 0.5),
      0 0 28px rgba(125, 250, 159, 0.55);
  }
  .svc-cta--primary:hover svg { transform: translateX(3px); }

  .svc-cta--ghost {
    background: transparent;
    border: 1.5px solid rgba(0, 0, 0, 0.18);
    color: #1d1d1f;
  }
  .svc-cta--ghost:hover {
    border-color: #2DC856;
    color: #2DC856;
    transform: translateY(-1px);
  }

  .svc-cta-row {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }
  .svc-cta-row--centered { justify-content: center; }

  /* ═══════════════════════════════════════════════════════════
     HERO — Cinematic full-bleed image hero
     ───────────────────────────────────────────────────────────
     Layout:
       - Hero is FULL-BLEED (no max-width). Background image
         covers the whole section.
       - Diagonal dark gradient overlay weights heavier on the
         bottom-left where the copy sits, lighter top-right
         where the image's natural light should breathe through.
       - Copy sits in the bottom-half of the hero in a
         max-width container. Magazine-cover layout: eyebrow
         → display headline → subhead → CTAs.
       - Stat strip is pinned to the BOTTOM EDGE of the hero
         (its bottom margin is negative so it overlaps slightly
         into the section below — gives the hero a definitive
         floor while letting the next section "rise" into it).
     Z-stack:
       z=0 — .svc-hero-bg (image + tint)
       z=1 — .svc-hero-content (copy)
       z=2 — .svc-stat-strip
     ═══════════════════════════════════════════════════════════ */
  .svc-hero {
    position: relative;
    width: 100%;
    /* Hero box height — flexible so content always fits without
       overflow. The lower bound (520) handles short laptop
       viewports; the vh-based middle gives the hero a magazine-
       cover scale on desktop; the upper cap (820) keeps it from
       feeling cavernous on tall monitors. */
    min-height: clamp(520px, 78vh, 820px);
    padding: clamp(48px, 6vw, 88px) clamp(20px, 4vw, 60px) clamp(64px, 7.5vw, 104px);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    /* Fallback color in case the image is slow to load — uses
       brand dark teal so the page never flashes a default
       browser bg. */
    background: #1A2F3A;
  }

  .svc-hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }
  .svc-hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    /* Subtle saturate boost makes the warm + cool tones in the
       multifamily photo pop, then the tint brings legibility
       back. The two work together — vivid image, controlled
       contrast. */
    filter: saturate(1.08);
    /* Slow zoom on hover-anchor scroll — disabled when
       prefers-reduced-motion. Adds editorial depth on landing. */
    transform: scale(1.04);
    transition: transform 1.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .svc-hero:hover .svc-hero-bg-img {
    transform: scale(1.06);
  }

  /* Diagonal dark gradient overlay — heavier bottom-left where
     copy sits, lighter top-right where the image's natural
     light source is. Plus a subtle bottom dark band for the
     stat strip's "tray" feel, and a barely-there green tint
     across the top so brand color is present even on dark. */
  .svc-hero-tint {
    position: absolute;
    inset: 0;
    background:
      /* dark band along the bottom for stat-strip seating */
      linear-gradient(0deg, rgba(13, 28, 36, 0.55) 0%, rgba(13, 28, 36, 0) 18%),
      /* main diagonal for copy legibility */
      linear-gradient(125deg,
        rgba(13, 28, 36, 0.80) 0%,
        rgba(13, 28, 36, 0.55) 30%,
        rgba(13, 28, 36, 0.18) 60%,
        rgba(13, 28, 36, 0.00) 100%
      ),
      /* subtle brand-green wash at the top edge */
      linear-gradient(180deg, rgba(45, 200, 86, 0.05) 0%, transparent 40%);
  }

  /* Fallback (no image): gradient bg with brand-tinted orbs.
     Mostly there so future services without a hero photo still
     get a respectable hero — but every service should ship
     with imagery if at all possible. */
  .svc-hero-bg--gradient {
    background:
      linear-gradient(180deg, #1A2F3A 0%, #243847 60%, #1A2F3A 100%);
  }
  .svc-hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.55;
  }
  .svc-hero-orb--green {
    width: 560px;
    height: 560px;
    top: -180px;
    right: -160px;
    background: radial-gradient(circle, rgba(45, 200, 86, 0.32) 0%, transparent 70%);
  }
  .svc-hero-orb--soft {
    width: 720px;
    height: 720px;
    bottom: -260px;
    left: -200px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.04) 0%, transparent 70%);
  }

  /* Content overlay — bottom-left positioned, max-width capped
     so long copy on wide screens stays readable. */
  .svc-hero-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1240px;
    margin: 0 auto;
    /* Copy sits left, with comfortable margin from screen edge
       on all viewports. The flex-end on the parent + this
       max-width gives a magazine-bottom-left layout that
       scales to any screen. */
  }

  .svc-hero .svc-hero-eyebrow {
    color: #2DC856;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
    margin-bottom: clamp(16px, 1.6vw, 22px);
  }
  .svc-hero .svc-hero-eyebrow .svc-eyebrow-dash {
    /* Dash on dark image needs more weight to read */
    background: linear-gradient(90deg, #2DC856, rgba(45, 200, 86, 0.25));
    box-shadow: 0 0 6px rgba(45, 200, 86, 0.5);
  }

  .svc-hero-title {
    margin: 0 0 clamp(18px, 1.8vw, 26px);
    /* max-width tuned so long-but-realistic service headlines
       (e.g. "The amenity your tenants are already asking for")
       wrap to 2 balanced lines on desktop without each line
       wrapping internally. Was 16ch (~640px at 5rem) — too
       tight for the multifamily copy and forced 4 visible
       lines that overflowed the hero. 22ch fits ~28-char
       lines comfortably; text-wrap: balance handles the break. */
    max-width: 22ch;
    font-size: clamp(2.2rem, 5.2vw, 4.4rem);
    font-weight: 900;
    line-height: 1.04;
    letter-spacing: -0.028em;
    color: #ffffff;
    text-shadow:
      0 2px 24px rgba(0, 0, 0, 0.45),
      0 1px 4px rgba(0, 0, 0, 0.35);
    text-wrap: balance;
  }

  .svc-hero-sub {
    margin: 0 0 clamp(24px, 2.4vw, 32px);
    max-width: 56ch;
    font-size: clamp(1rem, 1.2vw, 1.18rem);
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.88);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
    text-wrap: pretty;
  }

  /* Ghost CTA on the dark image — white outline + subtle
     translucent bg, brightens to brand green on hover. */
  .svc-cta--ghost-on-image {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1.5px solid rgba(255, 255, 255, 0.5);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 12px 24px;
    border-radius: 999px;
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.22s var(--ease),
      background 0.22s ease,
      border-color 0.22s ease,
      color 0.22s ease;
  }
  .svc-cta--ghost-on-image:hover {
    background: rgba(255, 255, 255, 0.16);
    border-color: #2DC856;
    color: #2DC856;
    transform: translateY(-1px);
  }

  /* Hero stat strip — pinned to the bottom of the hero,
     glass treatment so the image stays visible behind it.
     Negative bottom margin lets it overhang slightly into the
     next section, anchoring the hero's "floor". */
  .svc-hero .svc-stat-strip {
    position: relative;
    z-index: 2;
    margin: clamp(36px, 4.5vw, 60px) auto 0;
    /* Narrowed from 1240px so the 3 quick-nav buttons read as a
       compact action bar rather than a hero-spanning stat row.
       At 880px each tile is ~280px — tight enough that the icon
       + text + arrow content actually fills the button without
       the empty horizontal real estate the wider tiles had. */
    max-width: 880px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1px;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 22px;
    overflow: hidden;
    box-shadow:
      0 8px 24px rgba(13, 28, 36, 0.25),
      0 24px 60px rgba(13, 28, 36, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
    /* Softer negative bottom margin so the strip overhang
       feels like a deliberate editorial floor without eating
       into the next section's content. */
    margin-bottom: clamp(-72px, -5vw, -40px);
  }
  .svc-hero .svc-stat {
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(24px) saturate(170%);
    -webkit-backdrop-filter: blur(24px) saturate(170%);
    padding: clamp(20px, 2.4vw, 28px) clamp(20px, 2.4vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .svc-stat-value {
    font-size: clamp(1.7rem, 2.6vw, 2.3rem);
    font-weight: 900;
    letter-spacing: -0.022em;
    line-height: 1;
    color: #2DC856;
    font-variant-numeric: tabular-nums;
  }
  .svc-stat-label {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #4d5963;
  }

  /* Button variant — hero stats rendered as anchor buttons that
     jump to in-page sections. Layout: [icon | text | arrow] in
     a horizontal flex row. Icon block matches the green-tinted
     rounded-square vocabulary used elsewhere on the template.
     Sizes are scaled for the strip's wide tiles (~400px each at
     desktop) so the content actually fills the tile instead of
     reading as anemic.

     Tiles tighten their vertical padding (the base stat tile
     was sized for a tall 2.3rem stat number; buttons don't
     need that breathing room since the icon caps at 48px). */
  .svc-hero .svc-stat--btn {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: clamp(10px, 1.2vw, 14px);
    /* Tightened from clamp(16, 1.7, 20) / clamp(18, 2, 24) to
       a leaner button padding — the row now reads as a compact
       action bar, not three oversized cards. */
    padding: clamp(12px, 1.3vw, 16px) clamp(14px, 1.6vw, 18px);
    text-decoration: none;
    cursor: pointer;
    transition:
      transform 0.28s var(--ease),
      box-shadow 0.28s var(--ease),
      background 0.28s var(--ease);
  }
  /* Leading icon — green-tinted rounded square. Trimmed from
     clamp(44, 4.2, 52) to scale with the smaller buttons. */
  .svc-stat-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(36px, 3.4vw, 42px);
    height: clamp(36px, 3.4vw, 42px);
    border-radius: 10px;
    background: rgba(45, 200, 86, 0.16);
    color: #2DC856;
    transition:
      background 0.28s var(--ease),
      color 0.28s var(--ease),
      transform 0.28s var(--ease);
  }
  .svc-stat-icon svg {
    width: 18px;
    height: 18px;
    display: block;
  }
  /* Center text stack — primary label dominates the button. */
  .svc-stat-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1 1 auto;
    min-width: 0;
    text-align: left;
  }
  .svc-hero .svc-stat--btn .svc-stat-value {
    font-size: clamp(0.92rem, 1.05vw, 1.04rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.008em;
    color: #1d1d1f;
    text-transform: none;
    transition: color 0.22s var(--ease);
  }
  .svc-hero .svc-stat--btn .svc-stat-label {
    font-size: clamp(0.58rem, 0.66vw, 0.66rem);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #6e7780;
    transition: color 0.22s var(--ease);
  }
  /* Trailing arrow — visible at rest (low opacity) so the tile
     always reads as "this goes somewhere." Brightens + slides
     right on hover for the directional cue. */
  .svc-stat-arrow {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    color: #2DC856;
    opacity: 0.45;
    transition:
      opacity 0.22s var(--ease),
      transform 0.28s var(--ease);
  }
  .svc-stat-arrow svg { width: 14px; height: 14px; display: block; }

  /* Hover — lift, glow, brighten icon to solid green, reveal arrow. */
  .svc-hero .svc-stat--btn:hover {
    transform: translateY(-3px);
    background: #ffffff;
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.18),
      0 0 28px rgba(45, 200, 86, 0.22),
      0 16px 36px rgba(13, 28, 36, 0.16);
  }
  .svc-hero .svc-stat--btn:hover .svc-stat-icon {
    background: #2DC856;
    color: #ffffff;
    transform: scale(1.04);
  }
  .svc-hero .svc-stat--btn:hover .svc-stat-value {
    color: #1d9942;
  }
  .svc-hero .svc-stat--btn:hover .svc-stat-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  /* The first section after the hero gets extra top padding so
     the overhanging stat strip has room to land cleanly above
     the section header without clipping. Tuned to ≥ stat-strip
     height + overhang amount + breathing room. */
  .svc-hero + .svc-section {
    padding-top: clamp(96px, 11vw, 160px);
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-hero-bg-img,
    .svc-hero:hover .svc-hero-bg-img {
      transform: none;
      transition: none;
    }
  }

  /* ═══════════════════════════════════════════════════════════
     SECTION SHELL — vertical rhythm + section-head pattern
     ═══════════════════════════════════════════════════════════ */
  .svc-section {
    position: relative;
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(64px, 9vw, 130px) clamp(20px, 4vw, 60px);
    /* scroll-margin-top so anchor jumps (e.g. the hero CTA's
       href="#service-financialModels") land slightly above the
       section's eyebrow rather than at the very top of the
       padding band. Browser-side: when the URL hash matches the
       section id, the browser scrolls so the section's top is
       at scrollY = (section.offsetTop - scroll-margin-top). The
       40-80px buffer keeps the section header centered in
       view, not pinned at viewport top. */
    scroll-margin-top: clamp(40px, 6vw, 80px);
  }
  .svc-final {
    scroll-margin-top: clamp(40px, 6vw, 80px);
  }
  .svc-hero {
    scroll-margin-top: 0;
  }
  .svc-section-head {
    margin: 0 auto clamp(40px, 5vw, 68px);
    max-width: 720px;
    text-align: center;
  }
  /* Globally suppress the "/ 01" section-number marker AND the
     leading dash glyph in section-head eyebrows. The hero
     eyebrow uses .svc-hero-eyebrow (different class) and the
     final-CTA uses .svc-final-pill, so neither is affected.
     The render blocks still output these spans (kept for any
     future re-introduction or per-page override), but they
     never paint on the service-template by default. */
  .svc-section-head .svc-section-num,
  .svc-pain-header .svc-section-num,
  .svc-section-head .svc-eyebrow .svc-eyebrow-dash,
  .svc-pain-header .svc-eyebrow .svc-eyebrow-dash {
    display: none;
  }
  /* Magazine-spread section number marker — sits above the
     eyebrow as a small "Section 01" affordance. The slash glyph
     reads more editorial than a plain number; tabular-nums keeps
     consecutive sections (01 / 02 / 03 / …) aligning visually. */
  .svc-section-num {
    display: inline-block;
    margin-bottom: clamp(12px, 1.4vw, 18px);
    padding: 5px 12px 5px 14px;
    border: 1px solid rgba(45, 200, 86, 0.28);
    border-radius: 999px;
    background: rgba(45, 200, 86, 0.06);
    color: #2DC856;
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.32em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    text-transform: uppercase;
  }
  .svc-section-head .svc-eyebrow {
    justify-content: center;
  }
  .svc-section-head .svc-eyebrow .svc-eyebrow-dash {
    background: linear-gradient(90deg, rgba(45, 200, 86, 0), #2DC856);
  }
  /* Alternating section bg — odd-indexed sections get a subtle
     warmer wash so the page reads as a rhythm of distinct
     bands. The wash is created by a positioned ::before so it
     spans the section's full width while content stays
     constrained by the section's max-width. The decorative
     hairline divider at the top of every section is the second
     ::before child, made via box-shadow trick (top-only line). */
  .svc-section {
    isolation: isolate;
  }
  .svc-section.is-alt::before {
    content: '';
    position: absolute;
    inset: 0;
    /* Cool blue-tinted wash — replaces the previous white-only
       version. Adds a subtle "this is a different band" feel
       on alternating sections without the page going saturated.
       The brand-green hint mid-stop keeps the wash on-brand
       rather than pure cool. */
    background:
      linear-gradient(180deg,
        rgba(220, 232, 245, 0.55) 0%,
        rgba(220, 232, 245, 0.20) 60%,
        rgba(220, 232, 245, 0.00) 100%
      );
    pointer-events: none;
    z-index: -1;
  }
  /* Top hairline divider on every section — barely visible,
     gradient-faded so it reads as a refined editorial mark
     rather than a hard line. Skipped on the very first section
     (no divider above the page's first content block). */
  .svc-section::after {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: clamp(220px, 24vw, 380px);
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(45, 200, 86, 0.4) 30%,
      rgba(45, 200, 86, 0.6) 50%,
      rgba(45, 200, 86, 0.4) 70%,
      transparent 100%
    );
    opacity: 0.4;
    pointer-events: none;
  }
  .svc-hero + .svc-section::after {
    /* The hero already gives a clear visual end via its
       overhanging stat strip — no need for an extra hairline
       above the first content section. */
    display: none;
  }
  /* Left-aligned section head variant — used by narrative
     sections to differentiate them from centered detail
     sections. Eyebrow + title + sub all left-aligned, max-width
     applied to keep paragraphs readable but anchored to the
     left edge of the content column. */
  .svc-section-head--start {
    text-align: left;
    max-width: 880px;
    margin: 0 0 clamp(36px, 5vw, 60px);
  }
  .svc-section-head--start .svc-eyebrow {
    justify-content: flex-start;
  }
  .svc-section-head--start .svc-eyebrow .svc-eyebrow-dash {
    background: linear-gradient(90deg, #2DC856, rgba(45, 200, 86, 0));
  }
  .svc-section-head--start .svc-section-sub {
    margin-inline: 0;
  }

  /* Section CTA — used in painPoints header (e.g. "Talk to our
     team"). Sits below the subhead, centered, in the section's
     primary CTA pill style. */
  .svc-section-cta {
    margin-top: clamp(20px, 2vw, 28px);
  }
  .svc-section-title {
    margin: 0 0 clamp(14px, 1.5vw, 20px);
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.024em;
    color: #1d1d1f;
    text-wrap: balance;
  }
  .svc-section-sub {
    margin: 0;
    font-size: clamp(0.96rem, 1.1vw, 1.08rem);
    line-height: 1.6;
    color: #4d5963;
    max-width: 60ch;
    margin-inline: auto;
    text-wrap: pretty;
  }

  /* ═══════════════════════════════════════════════════════════
     DARK SECTION VARIANT — used by .svc-section--dark
     ───────────────────────────────────────────────────────────
     Section is brand dark teal end-to-end. Title and subhead
     switch to white; the gradient text-clip used on light
     sections doesn't render on dark, so we override to solid
     white. Section number marker stays brand green (it pops
     on dark teal). The decorative top hairline brightens for
     contrast against the dark bg.

     This treatment gives the page a strong light/dark rhythm
     using the brand palette directly — instead of the awkward
     blue washes the alt-section variant produced.
     ═══════════════════════════════════════════════════════════ */
  .svc-section--dark {
    background:
      radial-gradient(ellipse 90% 60% at 50% 0%, rgba(45, 200, 86, 0.08) 0%, transparent 70%),
      linear-gradient(180deg, #142631 0%, #1A2F3A 50%, #1f3845 100%);
    color: rgba(255, 255, 255, 0.92);
  }
  .svc-section--dark::before { display: none; }    /* no light alt-wash */
  .svc-section--dark::after {
    /* Brighter top divider on dark — the green hairline reads
       cleanly against the teal bg. */
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(45, 200, 86, 0.55) 30%,
      rgba(125, 250, 159, 0.85) 50%,
      rgba(45, 200, 86, 0.55) 70%,
      transparent 100%
    );
    opacity: 0.8;
  }
  .svc-section--dark .svc-section-title {
    background: none;
    -webkit-background-clip: initial;
    background-clip: initial;
    color: #ffffff;
    padding-bottom: 0;
  }
  .svc-section--dark .svc-section-sub {
    color: rgba(255, 255, 255, 0.7);
  }
  .svc-section--dark .svc-section-num {
    background: rgba(45, 200, 86, 0.14);
    border-color: rgba(45, 200, 86, 0.45);
    color: #7DFA9F;
  }
  .svc-section--dark .svc-eyebrow .svc-eyebrow-dash {
    background: linear-gradient(90deg, #2DC856, rgba(45, 200, 86, 0));
    box-shadow: 0 0 6px rgba(45, 200, 86, 0.45);
  }

  /* ═══════════════════════════════════════════════════════════
     PAIN POINTS — sticky-left header + stacked-right cards
     ───────────────────────────────────────────────────────────
     Layout is a 2-col grid: header (left, sticky as the cards
     scroll past) + card stack (right). On wide screens this
     reads as a magazine sidebar/article spread. On small
     screens the grid collapses to a single column with the
     header above the stack.

     Each pain card splits PROBLEM (left, red-tinted) from
     SOLUTION (right, green-tinted) with a green arrow between —
     a literal before→after visual on every card. */
  .svc-section--pain {
    /* Wider section so the sticky-left + stack-right layout has
       room to breathe at desktop sizes. */
    max-width: 1340px;
  }
  .svc-pain-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(36px, 4vw, 56px);
  }
  @media (min-width: 960px) {
    .svc-pain-layout {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr);
      gap: clamp(40px, 5vw, 80px);
    }
  }
  .svc-pain-header {
    text-align: left;
    align-self: start;
  }
  /* Sticky header — only on wide screens where the right
     column has enough cards to scroll past. The header sits
     at a comfortable top offset so the lefter rail and the
     section number marker don't collide. */
  @media (min-width: 960px) {
    .svc-pain-header {
      position: sticky;
      top: clamp(40px, 6vw, 80px);
    }
  }
  .svc-pain-header .svc-eyebrow {
    justify-content: flex-start;
  }
  .svc-pain-header .svc-eyebrow .svc-eyebrow-dash {
    background: linear-gradient(90deg, #2DC856, rgba(45, 200, 86, 0));
  }
  .svc-pain-header .svc-section-title {
    text-align: left;
    text-wrap: balance;
  }
  .svc-pain-header .svc-section-sub {
    margin: clamp(14px, 1.5vw, 18px) 0 0;
    text-align: left;
    max-width: 50ch;
  }
  .svc-pain-cta {
    margin-top: clamp(20px, 2.4vw, 28px);
  }

  /* Card stack — vertical column of cards, each card is
     full-width within the right grid track. */
  .svc-pain-stack {
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 1.6vw, 20px);
  }

  /* The card itself is a 3-track grid:
       [problem side] [arrow connector] [solution side]
     The arrow visualizes Evium's transformation of the
     concern into a solved state. On narrow screens we collapse
     to vertical stacking with the arrow rotating to point
     downward. */
  .svc-pain-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    background:
      linear-gradient(135deg, #243847 0%, #1f3340 100%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(13, 28, 36, 0.18),
      0 8px 22px rgba(13, 28, 36, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition:
      transform 0.4s var(--ease),
      box-shadow 0.4s var(--ease),
      border-color 0.4s var(--ease);
  }
  @media (min-width: 720px) {
    .svc-pain-card {
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    }
  }
  .svc-pain-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.10);
    box-shadow:
      0 1px 2px rgba(13, 28, 36, 0.22),
      0 14px 32px rgba(13, 28, 36, 0.42),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  /* Optional ordinal mark in the top-left of each card */
  .svc-pain-card-num {
    position: absolute;
    top: 12px;
    left: 16px;
    z-index: 2;
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.32);
    font-variant-numeric: tabular-nums;
  }

  /* Each side is half the card. Problem = warm red wash,
     solution = brand green wash. Subtle gradients keep the
     bg readable while signaling color meaning at a glance. */
  .svc-pain-side {
    padding: clamp(22px, 2.4vw, 30px) clamp(20px, 2.2vw, 28px);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .svc-pain-side--problem {
    background:
      radial-gradient(ellipse 70% 100% at 0% 0%, rgba(232, 90, 70, 0.20) 0%, transparent 70%),
      linear-gradient(135deg, rgba(232, 90, 70, 0.10) 0%, transparent 100%);
  }
  .svc-pain-side--solution {
    background:
      radial-gradient(ellipse 70% 100% at 100% 100%, rgba(45, 200, 86, 0.20) 0%, transparent 70%),
      linear-gradient(225deg, rgba(45, 200, 86, 0.10) 0%, transparent 100%);
  }
  /* Vertical divider between problem and solution — only on
     wide layouts where the sides sit side-by-side. */
  @media (min-width: 720px) {
    .svc-pain-side--problem {
      border-right: 1px solid rgba(255, 255, 255, 0.08);
    }
  }
  .svc-pain-side-head {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .svc-pain-icon {
    flex: 0 0 auto;
    width: 30px;
    height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }
  .svc-pain-icon svg { width: 56%; height: 56%; }
  .svc-pain-icon--x {
    background: rgba(232, 90, 70, 0.18);
    color: #ff8d7a;
  }
  .svc-pain-icon--check {
    background: rgba(45, 200, 86, 0.20);
    color: #7DFA9F;
  }
  .svc-pain-side-label {
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .svc-pain-side-label--problem { color: #ff8d7a; }
  .svc-pain-side-label--solution { color: #7DFA9F; }
  .svc-pain-problem {
    margin: 0;
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: rgba(255, 255, 255, 0.95);
  }
  .svc-pain-solution {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
  }

  /* Arrow connector — sits between problem and solution sides
     on wide layouts, transforms to point downward when the
     card stacks vertically on narrow viewports. */
  .svc-pain-arrow {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    color: #2DC856;
    background: rgba(45, 200, 86, 0.08);
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }
  @media (min-width: 720px) {
    .svc-pain-arrow {
      display: inline-flex;
    }
  }
  .svc-pain-arrow svg { width: 20px; height: 20px; }

  /* ═══════════════════════════════════════════════════════════
     SCOPE — numbered icon cards in a flex grid
     ═══════════════════════════════════════════════════════════ */
  .svc-scope-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: clamp(16px, 2vw, 24px);
  }
  .svc-scope-card {
    position: relative;
    overflow: hidden;
    background: #ffffff;
    border: var(--hairline);
    border-radius: 20px;
    padding: clamp(22px, 2.4vw, 30px);
    box-shadow: var(--elev-1);
    transition:
      transform 0.4s var(--ease),
      box-shadow 0.4s var(--ease),
      border-color 0.4s var(--ease);
  }
  .svc-scope-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: #2DC856;
    transform: scaleX(0);
    transform-origin: 50% 50%;
    transition: transform 0.45s var(--ease);
    z-index: 1;
    pointer-events: none;
  }
  .svc-scope-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--elev-2);
    border: var(--hairline-hover);
  }
  .svc-scope-card:hover::before {
    transform: scaleX(0.6);
  }
  .svc-scope-num {
    position: absolute;
    top: clamp(16px, 2vw, 22px);
    right: clamp(18px, 2.2vw, 24px);
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    color: #aeaeb2;
    font-variant-numeric: tabular-nums;
  }
  .svc-scope-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: rgba(45, 200, 86, 0.1);
    color: #2DC856;
    margin-bottom: 14px;
  }
  .svc-scope-icon svg { width: 56%; height: 56%; }
  .svc-scope-title {
    margin: 0 0 8px;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.012em;
    line-height: 1.25;
    color: #1d1d1f;
  }
  .svc-scope-body {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: #4d5963;
  }

  /* ═══════════════════════════════════════════════════════════
     HARDWARE — charger cards with image + name + features
     ═══════════════════════════════════════════════════════════ */
  .svc-hw-grid {
    display: grid;
    gap: clamp(18px, 2.2vw, 26px);
  }
  .svc-hw-grid--1 { grid-template-columns: 1fr; max-width: 720px; margin: 0 auto; }
  .svc-hw-grid--2 { grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); }
  .svc-hw-grid--3 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .svc-hw-grid--4 { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }

  .svc-hw-card {
    position: relative;
    background: #ffffff;
    border: var(--hairline);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: var(--elev-2);
    transition:
      transform 0.4s var(--ease),
      box-shadow 0.4s var(--ease),
      border-color 0.4s var(--ease);
    display: flex;
    flex-direction: column;
  }
  .svc-hw-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: #2DC856;
    transform: scaleX(0);
    transform-origin: 50% 50%;
    transition: transform 0.45s var(--ease);
    z-index: 2;
    pointer-events: none;
  }
  .svc-hw-card--dc::before { background: #68d8e8; }
  .svc-hw-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--elev-3-hover);
    border: var(--hairline-hover);
  }
  .svc-hw-card:hover::before { transform: scaleX(0.7); }
  .svc-hw-stage {
    position: relative;
    height: clamp(180px, 22vh, 240px);
    background: linear-gradient(180deg, #ffffff 0%, #f6f6f8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .svc-hw-stage::after {
    content: '';
    position: absolute;
    bottom: 6%;
    left: 12%;
    right: 12%;
    height: 24%;
    background: radial-gradient(ellipse 70% 100% at 50% 0%, rgba(0, 0, 0, 0.10) 0%, transparent 70%);
  }
  .svc-hw-img {
    position: relative;
    z-index: 1;
    max-width: 70%;
    max-height: 85%;
    object-fit: contain;
    filter: drop-shadow(0 8px 16px rgba(13, 28, 36, 0.15));
  }
  .svc-hw-img-fallback {
    color: rgba(45, 200, 86, 0.35);
    width: 60px;
    height: 60px;
    display: inline-flex;
  }
  .svc-hw-img-fallback svg { width: 100%; height: 100%; }
  .svc-hw-body {
    padding: clamp(18px, 2vw, 24px) clamp(20px, 2.2vw, 26px) clamp(20px, 2.4vw, 28px);
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .svc-hw-tag {
    align-self: flex-start;
    padding: 4px 11px;
    border: 1px solid rgba(45, 200, 86, 0.4);
    border-radius: 999px;
    background: rgba(45, 200, 86, 0.08);
    color: #2DC856;
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .svc-hw-tag--dc {
    border-color: rgba(80, 200, 220, 0.45);
    background: rgba(80, 200, 220, 0.12);
    color: #1d6d7a;
  }
  .svc-hw-name {
    margin: 0;
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    font-weight: 800;
    line-height: 1.25;
    letter-spacing: -0.014em;
    color: #1d1d1f;
  }
  .svc-hw-features {
    list-style: none;
    margin: 6px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .svc-hw-features li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 0.86rem;
    line-height: 1.5;
    color: #4d5963;
  }
  .svc-hw-tick {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(45, 200, 86, 0.14);
    color: #2DC856;
    margin-top: 1px;
  }
  .svc-hw-tick svg { width: 60%; height: 60%; }

  /* Hardware section's dark variant — cards stay white (the
     light card surfaces against the dark teal section bg
     reads as a "showroom" / studio-shoot vibe). The section
     stage gets a subtle gradient to suggest a lit floor. */
  .svc-section--hardware .svc-hw-card {
    /* Slightly tweaked shadow for white cards against dark bg
       so they read as floating, not flat. */
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.32),
      0 8px 22px rgba(0, 0, 0, 0.30),
      0 22px 50px rgba(0, 0, 0, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }
  .svc-section--hardware .svc-hw-card:hover {
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.32),
      0 14px 32px rgba(0, 0, 0, 0.40),
      0 34px 70px rgba(0, 0, 0, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  /* "See all Level 2 / Level 3" link — small uppercase link
     at the bottom of the hardware section pointing at the
     full product catalog (e.g. /products/level-2). On dark
     hardware bg, the brand-green pill stays readable; the
     hover state still fills solid green. */
  .svc-hw-foot {
    margin-top: clamp(28px, 3vw, 40px);
    text-align: center;
  }
  .svc-hw-seeall {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 18px;
    border-radius: 999px;
    border: 1.5px solid rgba(45, 200, 86, 0.5);
    background: rgba(45, 200, 86, 0.10);
    color: #7DFA9F;
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      transform 0.22s var(--ease),
      gap 0.22s var(--ease),
      background 0.22s ease,
      border-color 0.22s ease,
      color 0.22s ease,
      box-shadow 0.22s ease;
  }
  .svc-hw-seeall svg {
    width: 12px;
    height: 12px;
    display: block;
    color: currentColor;
    transition: transform 0.22s var(--ease);
  }
  .svc-hw-seeall:hover {
    transform: translateY(-1px);
    gap: 14px;
    background: #2DC856;
    color: #ffffff;
    border-color: #2DC856;
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.32),
      0 8px 22px rgba(45, 200, 86, 0.45);
  }
  .svc-hw-seeall:hover svg { transform: translateX(3px); }

  /* ═══════════════════════════════════════════════════════════
     NARRATIVE — left-aligned market-context section with
     optional 3-up highlight cards beneath the lead copy. The
     cards are LIGHTER than scope / pain cards (subtle elev,
     no LED rule) so the section reads as orientation, not
     a primary content block.
     ═══════════════════════════════════════════════════════════ */
  .svc-narrative-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: clamp(16px, 2vw, 22px);
  }
  .svc-narrative-card {
    position: relative;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(244, 248, 252, 0.94) 100%);
    border: var(--hairline);
    border-radius: 18px;
    padding: clamp(22px, 2.4vw, 28px);
    box-shadow: var(--elev-1);
    transition:
      transform 0.4s var(--ease),
      box-shadow 0.4s var(--ease),
      border-color 0.4s var(--ease);
  }
  .svc-narrative-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--elev-2);
    border: var(--hairline-hover);
  }
  .svc-narrative-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: rgba(45, 200, 86, 0.12);
    color: #2DC856;
    margin-bottom: 14px;
  }
  .svc-narrative-icon svg { width: 56%; height: 56%; }
  .svc-narrative-title {
    margin: 0 0 8px;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.012em;
    line-height: 1.25;
    color: #1d1d1f;
  }
  .svc-narrative-body {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: #4d5963;
  }

  /* ═══════════════════════════════════════════════════════════
     FINANCIAL MODELS — section shell + header treatment.
     ───────────────────────────────────────────────────────────
     Goal: the entire section (eyebrow + title + subhead + 3
     cards + footnote) fits comfortably inside a single 1080p
     viewport. To get there we (a) strip the chrome — section
     number marker + eyebrow dash — for a cleaner v1-style
     centered header, (b) tighten the section's vertical padding
     and the section-head bottom margin, (c) keep the title
     bold and confident with a vertical dark-teal → charcoal
     gradient (background-clip: text) so it reads with depth
     instead of flat black, and (d) widen the section past the
     base 1240px cap so the cards have more horizontal room
     and read shorter / wider.
     ═══════════════════════════════════════════════════════════ */
  .svc-section.svc-section--fin {
    max-width: 1340px;
    /* min-height: 100vh + flex centering anchors the section
       perfectly when the user scrolls to it (full screen takes
       the section, content sits centered vertically within).
       If a viewport is shorter than content, content overflows
       cleanly without breaking layout. The padding uses vh
       units so it scales with viewport height. */
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(40px, 5vh, 72px);
  }
  /* Depth layer — replaces the flat surface the v2 light theme
     was sitting on. A soft brand-green radial halo at the top-
     center suggests overhead lighting; the cool light-to-mid
     vertical gradient gives the surface itself dimension. The
     ::before is positioned absolutely behind the section
     content so cards float on top of the lit surface. */
  .svc-section.svc-section--fin::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 70% 60% at 50% 0%,
        rgba(45, 200, 86, 0.13) 0%,
        rgba(45, 200, 86, 0.05) 30%,
        transparent 60%
      ),
      linear-gradient(
        180deg,
        #f3f7fb 0%,
        #e8eef5 100%
      );
    pointer-events: none;
    z-index: -1;
  }
  /* If the fin section happens to land on an odd index (and so
     gets .is-alt), suppress the alt-wash so our depth treatment
     fully owns the bg. */
  .svc-section.svc-section--fin.is-alt::before {
    background:
      radial-gradient(
        ellipse 70% 60% at 50% 0%,
        rgba(45, 200, 86, 0.13) 0%,
        rgba(45, 200, 86, 0.05) 30%,
        transparent 60%
      ),
      linear-gradient(
        180deg,
        #f3f7fb 0%,
        #e8eef5 100%
      );
  }
  /* On viewports too short for min-height: 100vh to make sense
     (mobile landscape, low-height windows), drop the floor so
     the section grows naturally with its content. */
  @media (max-height: 720px), (max-width: 760px) {
    .svc-section.svc-section--fin {
      min-height: auto;
      justify-content: flex-start;
    }
  }
  /* Strip "/01"-style section-number marker on this section so
     the header reads as a tight 3-line stack: eyebrow / title /
     subhead. Also drop the eyebrow's leading dash so the
     "FINANCIAL MODELS" line reads centered + clean like v1. */
  .svc-section--fin .svc-section-num { display: none; }
  .svc-section--fin .svc-eyebrow .svc-eyebrow-dash { display: none; }
  .svc-section--fin .svc-section-head {
    margin-bottom: clamp(28px, 3vw, 44px);
    /* Widen past the base 720px cap so the second title line
       ("You Want to Work With Us.") doesn't wrap at the larger
       fin-section title font size. The two-line stack reads
       cleanly as: "You Choose How" / "You Want to Work With
       Us." with each line on a single row. */
    max-width: 940px;
  }
  .svc-section--fin .svc-eyebrow {
    margin-bottom: clamp(10px, 1vw, 14px);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
  }
  .svc-section--fin .svc-section-title {
    margin-bottom: clamp(10px, 1vw, 14px);
    font-size: clamp(2.2rem, 4.4vw, 3.4rem);
    line-height: 1.02;
    letter-spacing: -0.032em;
    background: linear-gradient(
      180deg,
      #0f1f28 0%,
      #1a2f3a 50%,
      #2c3f4a 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-bottom: 0.08em;
    /* Defer to the explicit <br /> in the data — `text-wrap:
       balance` from the base rule would override the data's
       intended break (each line starting with "You") and stack
       both "You"s on the first line. */
    text-wrap: pretty;
  }
  .svc-section--fin .svc-section-sub {
    font-size: clamp(0.94rem, 1.05vw, 1.05rem);
    line-height: 1.5;
    font-weight: 500;
    max-width: 60ch;
    color: #4d5963;
  }

  /* ═══════════════════════════════════════════════════════════
     FINANCIAL MODELS — comparison cards, optional `featured`.
     Featured card spans wider (2fr vs 1fr in a 3-card row) and
     gets a glassy info-box highlight at the bottom. The "Most
     Popular" badge sits as a clean tab in the top-right corner
     of the featured card.
     ═══════════════════════════════════════════════════════════ */
  .svc-fin-grid {
    display: grid;
    gap: clamp(16px, 2vw, 22px);
    align-items: stretch;
  }
  .svc-fin-grid--1 { grid-template-columns: 1fr; max-width: 520px; margin: 0 auto; }
  .svc-fin-grid--2 { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
  .svc-fin-grid--3 { grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .svc-fin-grid--4 { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
  /* When one of the three cards is `featured`, weight the layout
     toward the recommended option: featured ~50%, others ~25%
     each. Drops to single column at the same mobile breakpoint
     as the other auto-fit variants below. */
  .svc-fin-grid--3.svc-fin-grid--has-featured {
    grid-template-columns: 2fr 1fr 1fr;
  }

  .svc-fin-card {
    position: relative;
    background: #ffffff;
    border: var(--hairline);
    border-radius: 22px;
    /* Tightened from clamp(28px, 3vw, 40px) so the cards read
       shorter / wider. The internal element margins below are
       pulled in to match — combined effect: ~25-30% shorter. */
    padding: clamp(20px, 2.2vw, 28px);
    /* Custom 3-layer resting stack — replaces the generic
       --elev-2 with shadows tuned for the new lit surface
       (cool gradient + green halo). Layer 1 = 1px contact
       shadow; layer 2 = mid-distance soft drop; layer 3 = far
       atmospheric drop that ties the card to the surface. */
    box-shadow:
      0 1px 2px rgba(13, 28, 36, 0.04),
      0 6px 16px rgba(13, 28, 36, 0.06),
      0 22px 48px rgba(13, 28, 36, 0.10);
    display: flex;
    flex-direction: column;
    transition:
      transform 0.4s var(--ease),
      box-shadow 0.4s var(--ease),
      border-color 0.4s var(--ease);
  }
  .svc-fin-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: #2DC856;
    transform: scaleX(0);
    transform-origin: 50% 50%;
    transition: transform 0.45s var(--ease);
    z-index: 2;
    pointer-events: none;
    border-top-left-radius: 22px;
    border-top-right-radius: 22px;
  }
  .svc-fin-card:hover {
    transform: translateY(-9px);
    /* REAL GLOW — the previous stack used directional drops
       which read as "tinted shadow" not luminance. Glow needs
       symmetric blur halos with NO x/y offset so the card
       appears to emit light in all directions, paired with
       directional drops below for grounding. Three glow layers
       (tight outline, near halo, far bloom) + two drops (near
       + far) compose a card that genuinely looks lit, not
       just colored. */
    box-shadow:
      /* Pure-glow layers (no offset) */
      0 0 0 1px rgba(45, 200, 86, 0.32),
      0 0 22px rgba(45, 200, 86, 0.34),
      0 0 56px rgba(45, 200, 86, 0.22),
      /* Directional drops for grounding */
      0 12px 26px rgba(13, 28, 36, 0.10),
      0 32px 70px rgba(13, 28, 36, 0.16);
    border-color: rgba(45, 200, 86, 0.4);
  }
  .svc-fin-card:hover::before { transform: scaleX(0.7); }
  /* Featured card — reactive green top accent line, INSET from
     both edges so it never runs into the card's rounded corners
     (where a 2-3px stroke can't match the 22px curve and was
     visibly sticking past). Anchored at center so it scales
     symmetrically from the middle out, ending up visually
     centered under the top edge. Width capped at scaleX(0.5)
     so it terminates well clear of the corner curves AND the
     "Most Popular" tab on the right. Fully rounded ends. */
  .svc-fin-card.is-featured::before {
    left: 26px;
    right: 26px;
    height: 3px;
    border-radius: 999px;
    transform-origin: center center;
    transform: scaleX(0);
  }
  .svc-fin-card.is-featured:hover::before,
  .svc-fin-card.is-featured:focus-within::before,
  .svc-fin-card.is-featured:active::before {
    transform: scaleX(0.5);
  }
  .svc-fin-card.is-featured {
    border: 1.5px solid rgba(45, 200, 86, 0.45);
    background: linear-gradient(180deg, #ffffff 0%, #f0fff4 100%);
    /* Featured resting state — a subtle green-tinted halo
       (pure no-offset blur) layered with stronger directional
       drops, so the recommended card already glows softly at
       rest. Hover further amplifies these glow layers. */
    box-shadow:
      0 0 0 1px rgba(45, 200, 86, 0.18),
      0 0 22px rgba(45, 200, 86, 0.18),
      0 8px 22px rgba(45, 200, 86, 0.16),
      0 28px 60px rgba(13, 28, 36, 0.12);
  }
  .svc-fin-card.is-featured:hover {
    /* Featured card hover — same lift inherited from above,
       but with a stronger glow stack since this is the
       recommended path. Brighter pure-glow layers (no offset)
       paired with deeper directional drops. border-width
       pinned to 1.5px so only color animates — no layout
       flicker. */
    border-width: 1.5px;
    border-color: rgba(45, 200, 86, 0.7);
    box-shadow:
      /* Pure-glow layers — brighter + further bloom than default cards */
      0 0 0 1.5px rgba(45, 200, 86, 0.5),
      0 0 28px rgba(45, 200, 86, 0.5),
      0 0 72px rgba(45, 200, 86, 0.32),
      0 0 140px rgba(45, 200, 86, 0.16),
      /* Directional drops for grounding */
      0 16px 34px rgba(13, 28, 36, 0.12),
      0 40px 86px rgba(13, 28, 36, 0.18);
  }

  /* Badge — clean corner tab. Anchored at the very top-right of
     the card (top: 0, right: 0), with rounded BOTTOM-LEFT corner
     only and the top-right corner sharing the card's outer radius.
     Pulled slightly above to read as a tab tucked into the corner. */
  .svc-fin-badge {
    position: absolute;
    top: 0;
    right: 0;
    padding: 7px 14px 7px 16px;
    background: #2DC856;
    color: #ffffff;
    border-radius: 0 22px 0 14px;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    z-index: 3;
    box-shadow:
      0 2px 6px rgba(45, 200, 86, 0.32),
      0 6px 16px rgba(45, 200, 86, 0.28);
  }

  /* Icon block — small tinted rounded square at the top of each
     card. Subtle blue-gray on default cards; brand-green tint on
     the featured card to echo the card border + tagline color. */
  .svc-fin-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 11px;
    background: rgba(13, 28, 36, 0.05);
    color: rgba(13, 28, 36, 0.5);
    margin-bottom: clamp(12px, 1.2vw, 16px);
  }
  .svc-fin-icon svg {
    width: 20px;
    height: 20px;
    display: block;
  }
  .svc-fin-card.is-featured .svc-fin-icon {
    background: rgba(45, 200, 86, 0.14);
    color: #1d9942;
  }

  .svc-fin-name {
    margin: 0 0 4px;
    font-size: clamp(1.15rem, 1.4vw, 1.35rem);
    font-weight: 900;
    letter-spacing: -0.018em;
    color: #1d1d1f;
  }
  /* Featured tagline reads as a green selling line. Non-featured
     taglines use the muted small-caps style so they read as
     supporting positioning copy, not competing with the featured
     card's headline tagline. */
  .svc-fin-tagline {
    margin: 0 0 12px;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #2DC856;
  }
  .svc-fin-card:not(.is-featured) .svc-fin-tagline {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(13, 28, 36, 0.45);
  }
  .svc-fin-body {
    margin: 0 0 12px;
    font-size: 0.88rem;
    line-height: 1.55;
    color: #4d5963;
  }

  /* Bullets — supporting points under the body copy. Renders
     above the highlight callout so the highlight reads as the
     closing punch line. Uses `.svc-hw-tick` for the green check
     glyph (shared with hardware + software feature lists). */
  .svc-fin-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .svc-fin-bullets li {
    display: flex;
    gap: 9px;
    align-items: flex-start;
    font-size: 0.84rem;
    line-height: 1.45;
    color: #3a4753;
  }

  /* Highlight callout — glassy tinted info box anchored to the
     bottom of the card via `margin-top: auto` (so cards of
     different content lengths still align their callouts at the
     bottom edge when the row's tallest card sets the row height). */
  .svc-fin-highlight {
    margin: auto 0 0;
    margin-top: clamp(14px, 1.6vw, 20px);
    display: flex;
    gap: 11px;
    align-items: flex-start;
    padding: clamp(11px, 1.2vw, 14px) clamp(12px, 1.4vw, 16px);
    background: linear-gradient(
      180deg,
      rgba(45, 200, 86, 0.10) 0%,
      rgba(45, 200, 86, 0.05) 100%
    );
    border: 1px solid rgba(45, 200, 86, 0.28);
    border-radius: 12px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .svc-fin-highlight-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    color: #1d9942;
    margin-top: 2px;
  }
  .svc-fin-highlight-icon svg { width: 16px; height: 16px; display: block; }
  .svc-fin-highlight-text {
    font-size: 0.84rem;
    line-height: 1.5;
    font-weight: 500;
    color: #2c4150;
  }

  /* Footnote — centered muted line below the cards, with the
     inline link styled as the brand-green underlined accent.
     No max-width cap so the full sentence sits on one line at
     desktop (the section's 1340px max width is plenty). On
     narrow viewports the natural wrap kicks in. */
  .svc-fin-footnote {
    margin: clamp(20px, 2.2vw, 30px) auto 0;
    text-align: center;
    font-size: 0.88rem;
    line-height: 1.5;
    color: rgba(77, 89, 99, 0.9);
  }
  .svc-fin-footnote-link {
    color: #1d9942;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color 0.18s ease, text-decoration-thickness 0.18s ease;
  }
  .svc-fin-footnote-link:hover {
    color: #2DC856;
    text-decoration-thickness: 2px;
  }

  /* Mobile: collapse the weighted 2fr:1fr:1fr layout to a single
     column so each card can use its full width comfortably. */
  @media (max-width: 760px) {
    .svc-fin-grid--3.svc-fin-grid--has-featured {
      grid-template-columns: 1fr;
    }
  }

  /* ═══════════════════════════════════════════════════════════
     SOFTWARE — v1's 2-column dark layout. Section uses the
     dark teal variant (.svc-section--dark) and overrides the
     centered section-head pattern in favor of an inline left-
     column header (eyebrow + title + intro). The right column
     is offset down on desktop (`pt-20` in v1 ≈ 80px) so the
     two columns stagger visually. The standard centered
     .svc-section-head is hidden in this section variant.
     ═══════════════════════════════════════════════════════════ */
  .svc-section--sw .svc-section-head { display: none; }

  /* Section shell — full viewport width AND height. The dark
     gradient bg from .svc-section--dark (preserved as-is, not
     changed) now spans edge-to-edge instead of being capped at
     1240px, so the page-level orbs no longer bleed through on
     the sides. min-height: 100vh + flex centering anchors the
     section as a full-screen panel. The inner .svc-sw-grid
     keeps its 1120px max-width so content layout is unchanged. */
  .svc-section.svc-section--sw {
    max-width: none;
    margin-inline: 0;
    padding-block: clamp(72px, 8vw, 96px);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  @media (max-height: 720px), (max-width: 760px) {
    .svc-section.svc-section--sw {
      min-height: auto;
      justify-content: flex-start;
    }
  }

  .svc-sw-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 5vw, 72px);
    align-items: start;
    max-width: 1120px;
    margin: 0 auto;
  }

  /* LEFT column — eyebrow + title + intro + Owner Portal block. */
  .svc-sw-left { min-width: 0; }
  .svc-sw-eyebrow {
    margin: 0 0 clamp(14px, 1.5vw, 18px);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #2DC856;
  }
  .svc-sw-title {
    margin: 0 0 clamp(18px, 2vw, 26px);
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.028em;
    color: #ffffff;
    text-wrap: pretty;
  }
  .svc-sw-intro {
    margin: 0 0 clamp(28px, 3vw, 40px);
    font-size: clamp(1rem, 1.1vw, 1.1rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
  }
  .svc-sw-portal { /* container only */ }
  .svc-sw-portal-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }
  .svc-sw-portal-dash {
    width: 36px;
    height: 1.5px;
    background: #2DC856;
    border-radius: 1px;
    flex-shrink: 0;
  }
  .svc-sw-portal-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: -0.005em;
    color: #ffffff;
  }

  /* Shared green-dot bullet pattern — used in the Owner Portal
     list AND inside the Driver App card. Tiny green circle +
     muted-white text, generous gap so the lines breathe. */
  .svc-sw-bullet-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .svc-sw-bullet-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.92rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.65);
  }
  .svc-sw-bullet-dot {
    flex: 0 0 auto;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2DC856;
    margin-top: 8px;
  }

  /* RIGHT column — offset down on desktop to match v1's
     `lg:pt-20`. The two cards stack vertically with a
     consistent gap. */
  .svc-sw-right {
    padding-top: clamp(0px, 7vw, 80px);
    display: flex;
    flex-direction: column;
    gap: clamp(18px, 2vw, 24px);
    min-width: 0;
  }

  /* Driver App card — darker recessed surface than the section
     bg, faint white border, generous padding. */
  .svc-sw-card {
    background: rgba(8, 18, 24, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    padding: clamp(24px, 2.6vw, 32px);
    transition:
      border-color 0.35s var(--ease),
      box-shadow 0.35s var(--ease),
      transform 0.35s var(--ease);
  }
  .svc-sw-card:hover {
    transform: translateY(-2px);
    border-color: rgba(45, 200, 86, 0.32);
    box-shadow:
      0 0 0 1px rgba(45, 200, 86, 0.20),
      0 0 28px rgba(45, 200, 86, 0.18),
      0 18px 36px rgba(0, 0, 0, 0.30);
  }
  .svc-sw-card-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }
  .svc-sw-card-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(45, 200, 86, 0.15);
    color: #2DC856;
  }
  .svc-sw-card-icon svg { width: 20px; height: 20px; display: block; }
  .svc-sw-card-titles { min-width: 0; }
  .svc-sw-card-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.005em;
    color: #ffffff;
  }
  .svc-sw-card-subtitle {
    margin: 2px 0 0;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.4);
  }
  .svc-sw-card-body {
    margin: 0 0 20px;
    font-size: 0.9rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.6);
  }

  /* Support card — same dark surface as the app card but with
     a green-tinted outline so it reads as the "we've got you"
     reassurance card. Icon is inline (no tinted square) — sits
     to the left of the title block. */
  .svc-sw-support {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: rgba(8, 18, 24, 0.6);
    border: 1px solid rgba(45, 200, 86, 0.22);
    border-radius: 14px;
    padding: clamp(20px, 2.2vw, 26px);
    transition:
      border-color 0.35s var(--ease),
      box-shadow 0.35s var(--ease),
      transform 0.35s var(--ease);
  }
  .svc-sw-support:hover {
    transform: translateY(-2px);
    border-color: rgba(45, 200, 86, 0.45);
    box-shadow:
      0 0 0 1px rgba(45, 200, 86, 0.25),
      0 0 28px rgba(45, 200, 86, 0.22),
      0 18px 36px rgba(0, 0, 0, 0.30);
  }
  .svc-sw-support-icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: #2DC856;
    margin-top: 2px;
    /* No background — inline green glyph, matching v1's
       free-standing icon next to the support title. */
    background: transparent;
    border-radius: 0;
  }
  .svc-sw-support-icon svg { width: 22px; height: 22px; display: block; }
  .svc-sw-support-title {
    margin: 0 0 6px;
    font-size: 0.96rem;
    font-weight: 700;
    color: #ffffff;
  }
  .svc-sw-support-body {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.55);
  }

  /* Mobile: collapse to single column, drop the right-col
     desktop offset, and nudge the bullet gap a touch tighter. */
  @media (max-width: 760px) {
    .svc-sw-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .svc-sw-right {
      padding-top: 0;
    }
  }

  /* ═══════════════════════════════════════════════════════════
     SOCIAL PROOF — v1's "Proven at Scale" ported 1:1.
     ───────────────────────────────────────────────────────────
     - Section bg: solid #1A2F3A (`bg-evium-dark`), full viewport
       width via the box-shadow + clip-path technique (the
       section element keeps its layout box but the bg color
       paints all the way to the viewport edges).
     - Center atmospheric green glow behind content.
     - Top hairline: full-width 1px green/20.
     - Stat cards: solid #243847 (`bg-evium-dark-light`),
       rounded-12, p-28, border white/5. NO hover.
     - Testimonial card: solid #243847, rounded-16, p-40,
       border green/20, with a 4px green left bar + huge
       semi-transparent quote-mark.
     - Callout strip: solid #243847, rounded-12, p-28,
       border white/8.
     ═══════════════════════════════════════════════════════════ */
  .svc-section.svc-section--proof {
    /* Override .svc-section's max-width + .svc-section--dark's
       gradient. Section element keeps its layout, but bg color
       extends edge-to-edge via box-shadow/clip-path so the
       solid teal surface fully matches v1. */
    max-width: none;
    margin-inline: 0;
    padding-inline: 0;
    padding-block: clamp(72px, 8vw, 96px);
    background: #1A2F3A;
    box-shadow: 0 0 0 100vmax #1A2F3A;
    clip-path: inset(0 -100vmax);
  }
  /* Override the dark variant's centered hairline with a v1-
     style full-width 1px green/20 line at the top edge. */
  .svc-section--proof::after {
    background: rgba(45, 200, 86, 0.20);
    width: 100%;
    left: 0;
    right: 0;
    transform: none;
    height: 1px;
    opacity: 1;
  }
  /* Inner wrapper — picks up v1's max-w-6xl (1152px) + px. */
  .svc-proof-inner {
    max-width: 1152px;
    margin: 0 auto;
    padding-inline: clamp(24px, 4vw, 40px);
    position: relative;
    z-index: 1;
  }
  /* Atmospheric green glow centered behind the content. v1's
     exact spec: 600×300, opacity 0.07, blur 40px, radial green
     to transparent. */
  .svc-proof-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 300px;
    max-width: 90%;
    opacity: 0.07;
    background: radial-gradient(
      ellipse at 50% 50%,
      rgba(45, 200, 86, 1) 0%,
      transparent 70%
    );
    filter: blur(40px);
    pointer-events: none;
    z-index: 0;
  }

  .svc-proof-head {
    text-align: center;
    max-width: 576px;          /* max-w-xl */
    margin: 0 auto 64px;       /* mb-16 */
  }
  .svc-proof-eyebrow {
    margin: 0 0 16px;          /* mb-4 */
    font-size: 0.75rem;        /* text-xs */
    font-weight: 600;          /* font-semibold */
    letter-spacing: 0.1em;     /* tracking-widest */
    text-transform: uppercase;
    color: #2DC856;
  }
  .svc-proof-title {
    margin: 0;
    font-size: 2.25rem;        /* text-4xl */
    font-weight: 900;          /* font-black */
    line-height: 1.25;         /* leading-tight */
    color: #ffffff;
  }
  @media (min-width: 1024px) {
    .svc-proof-title { font-size: 3rem; }  /* lg:text-5xl */
  }

  /* Stats — 4-up dark cards on desktop, 2×2 on mobile.
     gap-5 = 20px. */
  .svc-proof-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin: 0 0 64px;          /* mb-16 */
    background: none;
    border: none;
    border-radius: 0;
    overflow: visible;
    box-shadow: none;
