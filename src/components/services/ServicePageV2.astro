     the middle line in brand green, square buttons with
     confident padding, atmospheric green halo behind the card
     for "background light depth blur."
     ═══════════════════════════════════════════════════════════ */
  .svc-final {
    position: relative;
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(40px, 6vw, 80px) clamp(20px, 4vw, 60px) clamp(80px, 10vw, 140px);
  }
  /* Depth glow — large soft brand-green bloom centered behind
     the card so the white bubble feels lit-from-behind without
     compromising the v2 white/green vocabulary. Sits behind the
     card via z-index 0; the card has z-index 1 and is opaque
     so the bloom only shows around the card edges. */
  .svc-final-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 880px;
    height: 600px;
    max-width: 95%;
    background: radial-gradient(
      ellipse at 50% 50%,
      rgba(45, 200, 86, 0.18) 0%,
      rgba(45, 200, 86, 0.08) 35%,
      transparent 65%
    );
    filter: blur(60px);
    pointer-events: none;
    z-index: 0;
  }
  .svc-final-card {
    position: relative;
    z-index: 1;
    background:
      radial-gradient(ellipse 90% 60% at 50% 0%, rgba(45, 200, 86, 0.10) 0%, transparent 65%),
      linear-gradient(180deg, #ffffff 0%, #f7fafd 100%);
    border: 1px solid rgba(45, 200, 86, 0.18);
    border-radius: 28px;
    padding: clamp(48px, 6vw, 80px) clamp(24px, 4vw, 56px);
    text-align: center;
    /* Layered shadow stack: 1) tight green ring outline,
       2) brand-green halo for ambient lit feel,
       3) directional drops for grounding,
       4) inner highlight on the top edge. */
    box-shadow:
      0 0 0 1px rgba(45, 200, 86, 0.10),
      0 0 80px rgba(45, 200, 86, 0.12),
      0 1px 2px rgba(13, 28, 36, 0.06),
      0 16px 40px rgba(13, 28, 36, 0.10),
      0 40px 96px rgba(13, 28, 36, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
  }

