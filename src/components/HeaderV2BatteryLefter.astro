---
/**
 * HeaderV2BatteryLefter  (ARCHIVED — NOT IMPORTED ANYWHERE)
 * ─────────────────────────────────────────────────────────
 * This file used to be `HeaderV2.astro`. It is the left-side
 * vertical "battery" nav we built as the second Home v2 sandbox
 * header — a fixed 72 px (56 px mobile) vertical strip with a
 * green-bordered battery body, top-centered nub, Evium logo at
 * the top, and nav items stacked below with `writing-mode:
 * vertical-rl + rotate(180deg)` sideways labels. Dropdowns
 * extended rightward from each item, centered vertically on the
 * trigger and clamped to the viewport via JS. Included a
 * temporary icon-preview mode in the dropdown panes for
 * choosing replacement icons (lightbulb / briefcase / bolt /
 * article / question / envelope).
 *
 * Archived here (not imported by Layout or any page) after we
 * pivoted to HeaderV3 — a solid-color lefter with a burger +
 * MENU sideways, opening a full-screen menu overlay. If we ever
 * want the battery-lefter treatment back, re-import this file
 * via Layout.astro and rewire `headerVariant` (or equivalent).
 *
 * Original rationale + context preserved below for reference.
 * ─────────────────────────────────────────────────────────
 *
 * Nav items + sub-items match Header.astro exactly, so editing
 * the nav structure in one place doesn't get out-of-sync with
 * the other. If we keep iterating and diverge, they'll need to
 * be manually kept in parity OR promoted to a shared data file.
 */

/**
 * Width of the fixed side nav, in pixels. Kept as a single source
 * of truth via a CSS variable at :root (see <style> below), so
 * Layout.astro / home-v2 styling can reference the same token.
 */

// Battery order: Solutions · Services · Products · Blog · (Home v2 / Testing dev) · How It Works · Contact · (Other dev)
const navItems = [
  {
    label: 'Solutions',
    href: '/#solutions',
    iconPreview: 'lightbulb' as const,
    sub: [
      { label: 'Hardware', href: '/products'                   },
      { label: 'Software', href: '/solutions/software'         },
      { label: 'Services', href: '/services'                   },
      { label: 'Profits',  href: '/solutions/generate-profits' },
    ],
  },
  {
    label: 'Services',
    href: '/services',
    iconPreview: 'hammer' as const,
    sub: [
      { label: 'Multifamily Real Estate', href: '/solutions/multifamily'          },
      { label: 'Fleets',                  href: '/solutions/fleets'               },
      { label: 'Highway Fast Charging',   href: '/solutions/highway-fast-charging'},
      { label: 'Commercial',              href: '/solutions/commercial'           },
      { label: 'Retail',                  href: '/solutions/retail'               },
      { label: 'Parking',                 href: '/solutions/parking'              },
      { label: 'Medical',                 href: '/solutions/medical'              },
    ],
  },
  {
    label: 'Products',
    href: '/products',
    iconPreview: 'bolt' as const,
    sub: [
      { label: 'Level 2', href: '/products#panel-l2' },
      { label: 'Level 3', href: '/products#panel-l3' },
    ],
  },
  {
    label: 'Blog',
    href: '/blog',
    iconPreview: 'article' as const,
    sub: [
      { label: 'All Posts',     href: '/blog'                },
      { label: 'News',          href: '/blog/news'           },
      { label: 'Case Studies',  href: '/blog/case-studies'   },
      { label: 'Newsletter',    href: '/blog/newsletter'     },
    ],
  },
  {
    // Site v2 — dropdown index of every v2-sandbox page. See the
    // matching entry in Header.astro for the full rationale.
    label: 'Site v2',
    href: '/home-v2',
    devOnly: true,
    hasChevron: true,
    sub: [
      { label: 'Home v2',     href: '/home-v2'     },
      { label: 'Products v2', href: '/products-v2' },
    ],
  },
  {
    label: 'Testing',
    href: '/testing',
    noNavigate: true,
    devOnly: true,
    sub: [
      { label: 'Mobile Blogs',         href: '/testing/mobile-blogs'       },
      { label: 'Product Portal',       href: '/testing/product-portal'     },
      { label: 'Software (no footer)', href: '/testing/software'           },
      { label: 'Old footer concept',   href: '/testing/footer-concept'     },
    ],
  },
  {
    label: 'How It Works',
    href: '/how-it-works',
    iconPreview: 'question' as const,
    sub: [
      { label: 'Overview',    href: '/how-it-works#overview'  },
      { label: 'Our Process', href: '/how-it-works#process'   },
      { label: 'Financing',   href: '/how-it-works#financing' },
      { label: 'Rebates',     href: '/how-it-works#rebates'   },
      { label: 'FAQ',         href: '/how-it-works#faq'       },
    ],
  },
  {
    label: 'Contact',
    href: '/contact',
    iconPreview: 'envelope' as const,
    sub: [
      { label: 'Schedule a Call',      href: '/contact/schedule'               },
      { label: 'Support',              href: '/contact/support'                },
      { label: 'Referral Program',     href: '/contact/referral'               },
    ],
  },
  {
    label: 'Other',
    href: '#',
    noNavigate: true,
    devOnly: true,
    sub: [
      { label: 'Get a Quote',             href: '/contact/quote'                  },
      { label: 'Electrician Partners',    href: '/solutions/electrician-partners' },
      { label: 'Old Saved Sections',      href: '/ai-bs/old-saved-sections'       },
      { label: 'Old Electrician Partners',href: '/ai-bs/old-electrician-partners' },
      { label: 'Toggle the toggle',       href: '#',                             devSwitch: true },
    ],
  },
];

const currentPath = Astro.url.pathname;
---

<!-- ═════════════════════════════════════════════════════════════════
     LEFTER — fixed vertical side nav along the left edge.
     On viewports ≤860px the top "mobile-header" from Header.astro is
     normally what renders; but HeaderV2 is home-v2-only and treats the
     lefter as the sole nav at all widths. At very narrow phone widths
     the lefter trims to 56px and labels shrink a touch, but stays side-
     mounted (no hamburger panel). If mobile-specific nav work is needed
     later, fork it here.
     ═════════════════════════════════════════════════════════════════ -->
<!-- Battery nub — rendered as a SIBLING of the nav body, not a
     child, so it can sit flush against the viewport's top edge
     while the nav body lives below it. Together they form a
     vertical-battery silhouette: small green nub on top, taller
     bordered body underneath, same visual vocabulary as the
     horizontal battery's nub + body. -->
<div class="lefter-nub" aria-hidden="true"></div>

<aside class="lefter-nav" data-lefter-nav aria-label="Primary navigation">

  <!-- Logo rail at the top, clickable → home. Uses same Evium mark as
       the production header so brand reads consistently. -->
  <a href="/" class="lefter-logo" aria-label="Evium Charging home">
    <img src="/images/logos/evium/logo.webp" alt="Evium Charging" />
  </a>

  <!-- Nav items stack — flex: 1 on the wrapper means items share
       all available space between the logo and the nav's bottom
       edge, so with dev-mode OFF (6 visible items) each is tall,
       with dev-mode ON (9 items) each is tighter — but the font
       is tuned so every label fits in either state. -->
  <nav class="lefter-items" role="navigation">
    {navItems.map((item) => (
      <div
        class:list={['lefter-item', (item as any).devOnly ? 'is-dev-only' : '']}
        data-lefter-item
      >
        {/* Frame wrapper: clips the trigger content during the
            collapse-dev-only animation (max-height → 0 requires
            overflow: hidden to look clean). The item itself stays
            overflow: visible so its dropdown can escape rightward. */}
        <div class="lefter-item-frame">
          <a
            href={item.href}
            data-no-navigate={(item as any).noNavigate ? '' : undefined}
            class:list={[
              'lefter-trigger',
              currentPath.startsWith(item.href) && item.href !== '/' && item.href !== '#' ? 'is-active' : ''
            ]}
            aria-haspopup={item.sub.length > 0 ? 'true' : undefined}
            aria-expanded={item.sub.length > 0 ? 'false' : undefined}
          >
            <span class="lefter-label">{item.label}</span>
            {((item as any).noNavigate || (item as any).hasChevron) && (
              <svg class="lefter-chevron" viewBox="0 0 10 10" width="10" height="10" aria-hidden="true">
                <path d="M3 1l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>
        </div>

        <!-- Dropdown:
               - If the nav item has an `iconPreview` (the 6 non-dev
                 menu items do), show a proposed icon preview pane
                 inside the dropdown in place of the sub-link list —
                 this is an evaluation step for choosing icons to
                 replace the sideways text labels. Temporary; revert
                 to the sub-link list when a decision is made.
               - If the item has sub-links (dev-only items like
                 Testing and Other), render those as usual. -->
        {((item as any).iconPreview || item.sub.length > 0) && (
          <div class="lefter-dropdown" aria-hidden="true">
            {(item as any).iconPreview ? (
              <div class="lefter-icon-preview">
                <div class="lefter-icon-preview-glyph">
                  {(item as any).iconPreview === 'lightbulb' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M9 18h6"/>
                      <path d="M10 22h4"/>
                      <path d="M8 14a6 6 0 1 1 8 0c-.7.7-1 1.5-1 2.4V18H9v-1.6c0-.9-.3-1.7-1-2.4z"/>
                      <path d="M12 5v1"/>
                    </svg>
                  )}
                  {(item as any).iconPreview === 'hammer' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      {/* Lucide hammer — claw-headed construction hammer, handle diagonal. */}
                      <path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9"/>
                      <path d="m18 15 4-4"/>
                      <path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"/>
                    </svg>
                  )}
                  {(item as any).iconPreview === 'bolt' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/>
                    </svg>
                  )}
                  {(item as any).iconPreview === 'article' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="4" y="4" width="16" height="16" rx="1.5"/>
                      <line x1="8" y1="9" x2="16" y2="9"/>
                      <line x1="8" y1="13" x2="16" y2="13"/>
                      <line x1="8" y1="17" x2="13" y2="17"/>
                    </svg>
                  )}
                  {(item as any).iconPreview === 'question' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="12" cy="12" r="9"/>
                      <path d="M9.3 9.3a2.7 2.7 0 1 1 3.9 3.7c-.8.6-1.2 1-1.2 2"/>
                      <circle cx="12" cy="17.5" r="0.5" fill="currentColor"/>
                    </svg>
                  )}
                  {(item as any).iconPreview === 'envelope' && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <rect x="3" y="5" width="18" height="14" rx="1.5"/>
                      <path d="M3 7l9 7 9-7"/>
                    </svg>
                  )}
                </div>
                <div class="lefter-icon-preview-meta">
                  <span class="lefter-icon-preview-eyebrow">Proposed icon for</span>
                  <span class="lefter-icon-preview-name">{item.label}</span>
                </div>
              </div>
            ) : (
              <div class="lefter-dropdown-inner">
                {item.sub.map((sub) => (
                  <a
                    href={sub.href}
                    class="lefter-sub"
                    data-toggle-devswitch={(sub as any).devSwitch ? '' : undefined}
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        )}
      </div>
    ))}
  </nav>
</aside>

<style>
  /* Expose the lefter's width, nub height, and a single radius
     value at :root so page-level adjustments AND every rounded
     corner in this component can reference a shared source of
     truth. One radius — used for battery body (right corners),
     dropdown (right corners), and proportionally scaled for the
     nub — means every corner reads as the same shape. */
  :root {
    --lefter-width: 72px;
    --lefter-nub-h: 12px;
    --lefter-radius: 6px;
  }

  /* ─── Battery nub (sits above the nav body) ───────────────
     Small brand-green rectangle rendered as a sibling of the nav
     body, pinned to y=0 with its width centered on the nav. The
     nub's bottom overlaps the nav's top border by 2 px so the two
     meet with no seam — reads as one continuous battery silhouette
     (nub on top, cell body below, exactly like the horizontal
     battery's right-side nub). */
  .lefter-nub {
    position: fixed;
    top: 0;
    left: calc((var(--lefter-width) - 26px) / 2);
    width: 26px;
    height: calc(var(--lefter-nub-h) + 2px);
    background: var(--nav-border, #2DC856);
    /* Nub's top corners use the same --lefter-radius as the
       battery body's right corners so the whole outer shell has
       a single, consistent rounded vocabulary. Bottom corners
       stay square to meet the battery body's top edge flush. */
    border-radius: var(--lefter-radius) var(--lefter-radius) 0 0;
    box-shadow: 0 2px 8px rgba(45, 200, 86, 0.32);
    z-index: 51;
  }

  /* ─── Battery body ────────────────────────────────────────
     Offset down by the nub's height so the nub stands above it.
     Full green border on all four sides now — including the left
     edge, so the battery's outline reads as a complete closed
     rectangle (no "missing side" where the nav meets the viewport
     edge). `box-sizing: border-box` keeps the total width pinned
     to --lefter-width regardless of border weight. Right-side
     corners have a small radius for the classic battery-cell
     silhouette; left side stays square since it's flush against
     the viewport's left edge. */
  .lefter-nav {
    position: fixed;
    top: var(--lefter-nub-h);
    left: 0;
    bottom: 0;
    width: var(--lefter-width);
    z-index: 50;
    box-sizing: border-box;

    display: flex;
    flex-direction: column;
    align-items: stretch;

    background: var(--nav-bg, rgba(26, 47, 58, 0.92));
    backdrop-filter: blur(var(--nav-blur, 10px));
    -webkit-backdrop-filter: blur(var(--nav-blur, 10px));
    border: 2px solid var(--nav-border, #2DC856);
    /* All four corners rounded with a single --lefter-radius so
       the battery reads as a complete pill-like shape — the
       top-left and bottom-left curve in slightly away from the
       viewport's left wall, matching the already-curved right
       corners. `overflow` stays visible (not hidden) here so
       dropdowns anchored inside items can escape rightward past
       the battery body — the individual corner elements (logo
       top-left/right, last-item bottom-left/right) apply their
       own matching inner radius so hover fills respect the
       rounded corners. */
    border-radius: var(--lefter-radius);
    box-shadow: 2px 0 32px rgba(0, 0, 0, 0.28);
    font-family: 'Maven Pro', sans-serif;
  }

  /* ─── Logo (top of battery body) ──────────────────────── */
  .lefter-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 6px;
    border-bottom: 2px solid var(--nav-border, #2DC856);
    transition: background 0.2s ease;
    flex-shrink: 0;
    /* Inner-corner radius at BOTH top corners — matches the
       battery body's outer top-left/top-right minus the 2px
       border thickness — so the hover fill rounds off cleanly
       at whichever top corner the logo section meets. */
    border-top-left-radius:  calc(var(--lefter-radius) - 2px);
    border-top-right-radius: calc(var(--lefter-radius) - 2px);
  }
  .lefter-logo:hover {
    background: rgba(45, 200, 86, 0.06);
  }
  .lefter-logo img {
    height: 30px;
    width: auto;
    display: block;
  }

  /* ─── Nav items container ─────────────────────────────── */
  .lefter-items {
    flex: 1;
    display: flex;
    flex-direction: column;
    /* `overflow: visible` on BOTH axes. Earlier I had
       `overflow-y: auto; overflow-x: visible` — per the CSS spec,
       when one axis is visible and the other isn't, the visible
       axis is forced to `auto` too, so the dropdowns (which extend
       horizontally past the items container's right edge) were
       actually being clipped. Visible on both axes lets them
       escape cleanly rightward. */
    overflow: visible;
  }

  /* ─── Each nav item (a "cell" in the battery) ─────────────
     `flex: 1 1 0` makes every visible item share the remaining
     vertical space equally. With 6 items (dev-mode off) each
     gets ≈ 140 px; with 9 items (dev-mode on) each gets ≈ 95 px.
     `min-height: 90px` is the floor — if the viewport is short
     enough that the flex share would drop below 90 px, the items
     hold at 90 px and the container becomes scrollable instead
     of clipping. Horizontal divider between items = the battery
     cell separators. */
  .lefter-item {
    position: relative;
    flex: 1 1 0;
    min-height: 90px;
    max-height: 180px;
    border-bottom: 1px solid rgba(45, 200, 86, 0.22);
    opacity: 1;
    /* overflow: visible so the dropdown (child of this element,
       positioned absolutely past the right edge) can escape to
       the right. The inner `.lefter-item-frame` handles the
       collapse clipping so dev-only items still shrink cleanly
       without the dropdown getting accidentally clipped. */
    overflow: visible;
    transition:
      max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      min-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      padding 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.28s ease,
      border-bottom-width 0.3s ease;
  }
  .lefter-item:last-child { border-bottom: 0; }
  /* Last item's frame gets the inner-corner radius at BOTH
     bottom corners (matching the battery body's bottom-left and
     bottom-right minus the 2px border) so its hover fill rounds
     off cleanly against both rounded bottom corners of the
     battery. Same pattern as the logo at the top — consistent
     inner-corner vocabulary all the way round. */
  .lefter-item:last-child .lefter-item-frame {
    border-bottom-left-radius:  calc(var(--lefter-radius) - 2px);
    border-bottom-right-radius: calc(var(--lefter-radius) - 2px);
  }

  /* Frame wrapper — clips the trigger when the item's max-height
     animates down during the dev-mode collapse. Full size of the
     item (height: 100%, width: 100%). overflow: hidden lives here
     so the ancestor `.lefter-item` can stay overflow: visible for
     the dropdown. */
  .lefter-item-frame {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .lefter-trigger {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 100%;
    height: 100%;
    padding: 10px 4px;
    color: var(--nav-text, rgba(255, 255, 255, 0.75));
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .lefter-trigger:hover,
  .lefter-item[data-open] .lefter-trigger,
  .lefter-item:focus-within .lefter-trigger {
    background: rgba(45, 200, 86, 0.08);
    color: #2DC856;
  }
  .lefter-trigger.is-active {
    color: var(--nav-text-active, #2DC856);
    background: rgba(45, 200, 86, 0.06);
  }

  /* Sideways label: starts with `writing-mode: vertical-rl` (which
     gives us a truly vertical layout box — width = glyph height,
     height = label length — so long labels like "HOW IT WORKS"
     fit in a narrow 72 px column without any clipping), then
     `transform: rotate(180deg)` flips the whole element 180° so
     the text reads bottom-to-top with glyphs rotated 90°
     counterclockwise — the natural head-tilt-LEFT orientation for
     a left-mounted side nav. (Equivalent to `writing-mode:
     sideways-lr` but with cross-browser support — sideways-lr is
     Firefox-only as of early 2026.) Font size + letter-spacing
     tuned so the longest label fits in the ≈95 px tall item that
     dev-mode-on produces with 9 items in a standard 900 px
     viewport. */
  .lefter-label {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    white-space: nowrap;
    text-transform: uppercase;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1;
  }
  /* Right-pointing chevron below the label — signals that the
     dropdown opens to the right. Small + centered so it reads
     as secondary punctuation, not competing with the label. */
  .lefter-chevron {
    display: block;
    width: 8px;
    height: 8px;
    color: currentColor;
    opacity: 0.7;
    flex-shrink: 0;
    transition: transform 0.18s ease, opacity 0.18s ease;
  }
  .lefter-item:hover .lefter-chevron,
  .lefter-item[data-open] .lefter-chevron,
  .lefter-item:focus-within .lefter-chevron {
    opacity: 1;
    transform: translateX(2px);
  }

  /* ─── Dropdown (opens to the right, anchored to its item) ────
     Positioned next to the trigger it belongs to: default top is
     `50%` with a `translateY(-50%)` so the dropdown is vertically
     CENTERED on its item (better visual alignment than top-edge
     anchoring). For items near the bottom of the nav where a
     centered-on-item dropdown would overflow off-screen, the JS
     at the bottom of this component overrides `top` at hover
     time to clamp the dropdown's viewport rect to stay fully on
     screen. JS sets an explicit px value which overrides the
     50% default; the translateY(-50%) is only applied via the
     `.is-centered` class (added by JS when no clamping is
     needed) so it doesn't fight an explicit-px `top`.
     Border-radius matches the battery body's right corners so
     the dropdown reads as an extension of the battery. */
  .lefter-dropdown {
    position: absolute;
    top: 50%;
    left: calc(100% + 2px);
    min-width: 220px;
    max-height: 70vh;
    margin: 0;
    padding: 0;
    background: var(--nav-drop-bg, rgba(18, 35, 45, 0.97));
    backdrop-filter: blur(var(--nav-drop-blur, 16px));
    -webkit-backdrop-filter: blur(var(--nav-drop-blur, 16px));
    border: 2px solid var(--nav-border, #2DC856);
    border-left: 0;
    border-radius: 0 var(--lefter-radius) var(--lefter-radius) 0;
    box-shadow:
      6px 10px 38px rgba(0, 0, 0, 0.42),
      0 0 0 1px rgba(45, 200, 86, 0.08);
    opacity: 0;
    pointer-events: none;
    /* Default hidden-state transform has both the horizontal
       slide-in offset AND the -50% vertical centering. JS adds
       `.is-clamped` when it sets an explicit top to prevent the
       dropdown from overflowing the viewport, and the clamped
       rule below drops the -50% so the JS-set top is honored as
       literal pixels. */
    transform: translate(-8px, -50%);
    transition:
      opacity 0.2s ease,
      transform 0.24s cubic-bezier(0.22, 1, 0.36, 1);
    overflow-y: auto;
    scrollbar-width: none;
    z-index: 100;
  }
  .lefter-dropdown::-webkit-scrollbar { display: none; }

  .lefter-item:hover .lefter-dropdown,
  .lefter-item:focus-within .lefter-dropdown,
  .lefter-item[data-open] .lefter-dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translate(0, -50%);
  }

  /* Clamped state: JS has set an explicit px top value, so drop
     the -50% vertical translate so the JS coordinate is used as-is. */
  .lefter-dropdown.is-clamped {
    transform: translateX(-8px);
  }
  .lefter-item:hover .lefter-dropdown.is-clamped,
  .lefter-item:focus-within .lefter-dropdown.is-clamped,
  .lefter-item[data-open] .lefter-dropdown.is-clamped {
    transform: translateX(0);
  }
  .lefter-dropdown-inner {
    padding: 8px 0;
    display: flex;
    flex-direction: column;
  }

  /* ─── Icon-preview pane (temporary evaluation mode) ─────
     Large centered glyph + small caption showing which nav
     item the icon would represent, rendered INSTEAD of the
     sub-link list for the 6 non-dev menu items while we pick
     final icons. Revert by removing the `iconPreview` keys
     from the navItems array at the top of this file. */
  .lefter-icon-preview {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 24px 28px;
    min-width: 220px;
    min-height: 180px;
  }
  .lefter-icon-preview-glyph {
    width: 96px;
    height: 96px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--nav-border, #2DC856);
    background: rgba(45, 200, 86, 0.08);
    border: 1px solid rgba(45, 200, 86, 0.32);
    border-radius: 20px;
  }
  .lefter-icon-preview-glyph svg {
    width: 56px;
    height: 56px;
    display: block;
  }
  .lefter-icon-preview-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
  }
  .lefter-icon-preview-eyebrow {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }
  .lefter-icon-preview-name {
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
  }

  .lefter-sub {
    display: block;
    padding: 11px 20px;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--nav-drop-text, rgba(255, 255, 255, 0.7));
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease, padding-left 0.18s ease;
  }
  .lefter-sub:hover,
  .lefter-sub:focus-visible {
    background: var(--nav-drop-hover-bg, rgba(45, 200, 86, 0.08));
    color: var(--nav-drop-hover, #2DC856);
    padding-left: 24px;
    outline: none;
  }

  /* ─── Nub (bottom accent) ─────────────────────────────── */
  .lefter-nub {
    width: 22px;
    height: 8px;
    background: var(--nav-border, #2DC856);
    border-radius: 0 0 3px 3px;
    margin: 0 auto;
    align-self: center;
    flex-shrink: 0;
    box-shadow: 0 2px 6px rgba(45, 200, 86, 0.25);
  }

  /* ─── Dev-mode gating ─────────────────────────────────────
     Same contract as the production Header: `body.dev-mode-off`
     (set by DevToggle) collapses every `.is-dev-only` item to
     zero height with a smooth vertical animation. Both min-height
     AND max-height animate together so the item fully releases
     its flex share — the remaining visible items automatically
     redistribute the freed space and grow proportionally. */
  body.dev-mode-off .lefter-item.is-dev-only {
    max-height: 0;
    min-height: 0;
    padding: 0;
    opacity: 0;
    border-bottom-width: 0;
    pointer-events: none;
  }

  /* ─── Responsive ──────────────────────────────────────────
     Narrow the rail on small viewports so it doesn't eat too much
     of the screen width. Labels shrink a touch but stay sideways;
     nub width + offset scale down to match. */
  @media (max-width: 860px) {
    :root {
      --lefter-width: 56px;
      --lefter-nub-h: 10px;
    }
    .lefter-nub { width: 22px; left: calc((var(--lefter-width) - 22px) / 2); }
    .lefter-logo img { height: 24px; }
    .lefter-label { font-size: 0.62rem; letter-spacing: 0.04em; }
    .lefter-item { min-height: 82px; }
  }
</style>

<script>
  /* Touch / keyboard support: on tap-only devices and when reaching
     a trigger via the keyboard (Tab), hover won't fire — so we also
     listen for clicks on the trigger of noNavigate items and toggle
     a `data-open` attribute on the wrapping `.lefter-item`, which
     the CSS above uses to reveal the dropdown. */
  (() => {
    const items = document.querySelectorAll<HTMLElement>('[data-lefter-item]');

    /* ─── Dropdown positioning ─────────────────────────────
       Computes each dropdown's top offset so it's:
         (1) vertically CENTERED on its owning item by default;
         (2) CLAMPED inside the viewport if the centered position
             would push part of the dropdown off-screen (top or
             bottom). Specifically the bottom items — whose
             dropdowns would otherwise open below the viewport
             bottom — get their top shifted up just enough to
             make the whole menu fit on screen.
       Adds `.is-clamped` to the dropdown when an explicit top
       is set, so the CSS drops its `translateY(-50%)` and treats
       the JS-set `top` as a literal pixel coordinate. */
    function positionDropdown(item: HTMLElement) {
      const dropdown = item.querySelector<HTMLElement>('.lefter-dropdown');
      if (!dropdown) return;

      const itemRect = item.getBoundingClientRect();
      const dropdownHeight = dropdown.offsetHeight;
      const viewportHeight = window.innerHeight;
      const PAD = 10; // gap between dropdown edge and viewport edge

      // Start: center dropdown on item (viewport coords)
      let desiredViewportTop = itemRect.top + itemRect.height / 2 - dropdownHeight / 2;

      const minTop = PAD;
      const maxTop = viewportHeight - dropdownHeight - PAD;

      // Only override if there's actual overflow — otherwise leave
      // the CSS-default `top: 50%; translateY(-50%)` centering, which
      // survives dev-mode-toggle without needing recomputation.
      const overflowsTop    = desiredViewportTop < minTop;
      const overflowsBottom = desiredViewportTop > maxTop;

      if (!overflowsTop && !overflowsBottom) {
        dropdown.classList.remove('is-clamped');
        dropdown.style.top = '';
        return;
      }

      // Clamp into viewport
      desiredViewportTop = Math.max(minTop, Math.min(desiredViewportTop, maxTop));

      // Convert viewport-coord to item-relative (dropdown is position:absolute inside item)
      const relativeTop = desiredViewportTop - itemRect.top;

      dropdown.classList.add('is-clamped');
      dropdown.style.top = relativeTop + 'px';
    }

    function repositionAll() {
      items.forEach(positionDropdown);
    }

    // Compute once on load, and whenever the window resizes or
    // the body class flips (dev-mode toggle changes item heights).
    // Small timeout after dev-mode class flip so the item-height
    // transitions have time to settle before we measure.
    repositionAll();
    window.addEventListener('resize', repositionAll);

    const bodyClassObserver = new MutationObserver(() => {
      setTimeout(repositionAll, 450);
    });
    bodyClassObserver.observe(document.body, {
      attributes: true,
      attributeFilter: ['class'],
    });

    // Also recompute on each hover/focus — cheap, and guarantees
    // the dropdown lands correctly no matter what else changed.
    items.forEach((item) => {
      item.addEventListener('mouseenter', () => positionDropdown(item));
      item.addEventListener('focusin',    () => positionDropdown(item));
    });

    items.forEach((item) => {
      const trigger = item.querySelector<HTMLAnchorElement>('.lefter-trigger');
      if (!trigger) return;
      const isNoNavigate = trigger.hasAttribute('data-no-navigate');

      if (isNoNavigate) {
        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          const wasOpen = item.hasAttribute('data-open');
          // Close any other open items first (one-open-at-a-time)
          items.forEach((i) => i.removeAttribute('data-open'));
          if (!wasOpen) {
            item.setAttribute('data-open', '');
            positionDropdown(item); // Recompute in case layout shifted
          }
          trigger.setAttribute('aria-expanded', String(!wasOpen));
        });
      }
    });

    // Close open dropdowns on outside click
    document.addEventListener('click', (e) => {
      const target = e.target as Element | null;
      if (!target) return;
      if (target.closest('[data-lefter-item]')) return;
      items.forEach((i) => {
        i.removeAttribute('data-open');
        i.querySelector('.lefter-trigger')?.setAttribute('aria-expanded', 'false');
      });
    });

    // Escape closes all
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      items.forEach((i) => {
        i.removeAttribute('data-open');
        i.querySelector('.lefter-trigger')?.setAttribute('aria-expanded', 'false');
      });
    });

    // Dev-toggle passthrough — clicking a sub-item with
    // data-toggle-devswitch flips the DevToggle pill's visibility
    // (same hook the AI-BS-era "Toggle the toggle" item used on
    // the horizontal battery).
    document.querySelectorAll<HTMLAnchorElement>('[data-toggle-devswitch]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const pill = document.getElementById('dev-toggle');
        if (!pill) return;
        const currentlyHidden = pill.getAttribute('data-hidden') === 'true';
        if (currentlyHidden) {
          pill.style.display = '';
          pill.removeAttribute('data-hidden');
          try { localStorage.removeItem('ev-devswitch-hidden'); } catch {}
        } else {
          pill.style.display = 'none';
          pill.setAttribute('data-hidden', 'true');
          try { localStorage.setItem('ev-devswitch-hidden', '1'); } catch {}
        }
      });
    });
  })();
</script>
