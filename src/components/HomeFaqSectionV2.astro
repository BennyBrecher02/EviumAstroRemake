---
/**
 * HomeFaqSection
 * ──────────────
 * Merged FAQ section on the homepage (property-owner + driver sets
 * combined into one flat list). Styled to match the how-it-works
 * FAQ: dark-teal background, green 4px top accent, white accordion
 * items with green chevrons that rotate on open.
 *
 * Map section above ends in #020608 (near-black). This section opens
 * on #1A2F3A (brand dark teal) with a small bridge vignette at the
 * top so the seam is a short color-ramp rather than a hard edge.
 */

interface QA { q: string; a: string; }
interface FaqGroup { title: string; items: QA[]; }

const faqGroups: FaqGroup[] = [
  {
    title: "The business model",
    items: [
      {
        q: "Does it really cost nothing to install chargers on my property?",
        a: "Under our no-cost model, yes. Evium covers 100% of hardware, installation, permitting, software, and 24/7 operations. The property contributes the site and receives a negotiated share of revenue — typically around 10%. If you'd rather invest capital yourself for a larger share, we also offer Client Investment, Hybrid, and Leasing models.",
      },
      {
        q: "How much revenue can a single charger generate?",
        a: "Based on Evium's NEVI revenue modeling for a 180 kW DC fast charger: roughly $900/month at low utilization, $1,500/month at medium, and $2,100/month at high. Over five years that's $54K–$126K per charger, and most NEVI-eligible sites install 4–6 chargers.",
      },
      {
        q: "What's the contract term?",
        a: "Five years with a 5-year renewal option — the framework we use for NEVI deployments. Long enough to amortize the installation honestly; short enough you're never locked in for a generation.",
      },
      {
        q: "What happens at the end of the 5-year term? Who owns the chargers?",
        a: "At renewal you have three paths: extend under the same terms, switch to a different model (e.g. No-Cost → Client Investment for a bigger revenue share), or decommission. Ownership of the hardware tracks your model: under No-Cost, Evium retains hardware ownership through term; under Client Investment or Leasing you hold ownership throughout.",
      },
      {
        q: "Who pays the electricity bill?",
        a: "Evium does, on every model where we operate the site. Utility bills are metered separately at the station level and run through us, not your building's meter. You pay nothing for the electricity the drivers consume.",
      },
    ],
  },
  {
    title: "Delivery & operations",
    items: [
      {
        q: "What does Evium actually handle?",
        a: "Site survey, electrical and utility coordination, permitting, hardware procurement, installation, network activation, driver payment processing, federal and state rebate filings, 24/7 remote monitoring, firmware updates, and on-site service when needed. Your job is to own the property.",
      },
      {
        q: "How long does installation take?",
        a: "Multifamily or retail sites with existing electrical capacity: 3–6 months from signed agreement to live chargers. NEVI corridor projects with federal compliance work: typically 6–12 months from award.",
      },
      {
        q: "Does my property qualify?",
        a: "Depends on your electrical service capacity, parking geometry, and — for NEVI corridor sites — proximity to a designated Alternative Fuel Corridor. Drop your address into the eligibility tool at the top of this page for a yes/no and a preliminary site profile.",
      },
      {
        q: "How does Evium handle station faults?",
        a: "Every charger on the network is actively monitored 24/7. When we detect a fault — or a driver reports one — our support team attempts a remote fix first, with no owner interaction or hardware changes required. If remote troubleshooting isn't enough, the issue is escalated with a ticket to on-site service.",
      },
      {
        q: "Am I locked into one hardware brand?",
        a: "No. Every charger we deploy speaks OCPP 1.6+, so Siemens, EvoCharge, MaxiCharger, Tellus, and future brands all route through the same Evium backend. You're never stuck with one vendor's ecosystem.",
      },
    ],
  },
  {
    title: "Your Evium account & app",
    items: [
      {
        q: "What can I do with my Evium Charging account?",
        a: "Mission control for your charging experience: start and stop sessions, see real-time station availability, manage payment methods, track usage, discover nearby stations, save favorites, and receive instant notifications. Property managers also get site-level controls and usage analytics. <a href=\"/solutions/software\" class=\"hf-inline-link\">See the full software overview →</a>",
      },
      {
        q: "How do I download the Evium Charging app?",
        a: "Search \"Evium Charging\" in the Apple App Store or Google Play, or scan the QR code on any Evium station. A direct-download link is also at eviumcharging.com/app. Create a free account, enable location services, add a payment method, and you're set. <a href=\"/solutions/software\" class=\"hf-inline-link\">More on the Evium app →</a>",
      },
      {
        q: "What are the device requirements?",
        a: "iOS 13+ (iPhone, iPad, iPod touch) or Android 8+ (Oreo or higher). ~100 MB free storage, Bluetooth 4.0+, location services enabled, and an internet connection (4G LTE recommended, 5G supported). <a href=\"/solutions/software\" class=\"hf-inline-link\">App details →</a>",
      },
      {
        q: "What do the map colors mean?",
        a: "Inside the Evium driver app, each station on the live map is color-coded by real-time status — green for available, blue for in use, and grey for unavailable or offline. Tap any station for live details, pricing, and driver reviews.",
      },
      {
        q: "How do I cancel my account?",
        a: "Email support@eviumcharging.com and our team will walk you through it.",
      },
    ],
  },
  {
    title: "Charging sessions",
    items: [
      {
        q: "How do I start a charging session?",
        a: "Three ways. App: search the station by address or ID, tap More Info, then Remote Start. SMS: enter your registered mobile number on the charger, reply \"Yes\" to the text. RFID fob: plug in, tap your fob. Driver support is live 24/7 at (949) 945-2000. <a href=\"/solutions/software\" class=\"hf-inline-link\">More on the Evium app →</a>",
      },
      {
        q: "How do I locate a charging station?",
        a: "Open the app, allow location services, and view the interactive map. Filter by availability, speed (DC Fast / Level 2), connector type, payment methods, or property amenities. You can also search on plugshare.com, Google Maps (\"Evium Charging\"), or look for Evium signage at partner sites. <a href=\"/solutions/software\" class=\"hf-inline-link\">More on the Evium app →</a>",
      },
      {
        q: "How do I pay for charging?",
        a: "Credit/debit cards, PayPal, Apple Pay, Google Pay, Evium Fleet Cards, and corporate account billing are all supported. Add a method through the app, the Driver Portal, or a Fleet Management Dashboard. Optional Auto-Reload tops up your balance automatically when it drops below a threshold you choose. <a href=\"/solutions/software\" class=\"hf-inline-link\">More on the Evium app →</a>",
      },
      {
        q: "Why do some stations charge fees?",
        a: "Property owners set their own pricing. Most charge a small fee per kWh or per session to recover the cost of electricity, hardware maintenance, and network operations — which is how more stations get built. Some hosts offer free or amenity-only charging as a tenant or customer perk.",
      },
      {
        q: "What if a station isn't working?",
        a: "Evium's 24/7 support team actively monitors every station. If you hit a fault, call driver support at (949) 945-2000 or report through the app. We attempt a remote fix first; if that doesn't close it, we dispatch service.",
      },
    ],
  },
];
---

<!-- Scene wrapper — gives the sticky FAQ a scroll range so it stays
     pinned at viewport top for most of its scroll band, matching the
     "locked section view" pattern used on the portal-solutions and
     locations-map scenes upstream. Height chosen so the sticky
     release (≈60 vh past anchor) lands cleanly into the app-download
     section below. -->
<div class="hf-scene" data-hf-scene>
<section id="home-faq" class="hf">
  <!-- Short bridge vignette: map above ends at #020608, this section's
       base is #1A2F3A. 180px gradient walks between them so the seam is
       a gentle color ramp rather than a hard edge. The FAQ's own 4px
       green top border sits over the gradient's bottom. -->
  <div class="hf-seam" aria-hidden="true"></div>

  <div class="hf-inner">
    {/* Top band: header on the left, category selector on the right.
        FAQ panels live below this band, full-width. */}
    <div class="hf-top">
      <header class="hf-head">
        <p class="hf-brow">
          <span class="hf-brow-mark" aria-hidden="true"></span>
          Common questions
        </p>
        <h2 class="hf-title">
          The questions that come up <span class="hf-accent">first.</span>
        </h2>
        <p class="hf-sub">
          Cost, timelines, revenue, everyday charging. All backed by
          numbers from Evium's own deployment data, not marketing rounding.
        </p>
      </header>

      <nav class="hf-rail-nav" role="tablist" aria-label="FAQ categories" data-hf-tabs>
        {faqGroups.map((group, gi) => (
          <button
            type="button"
            class="hf-rail-link"
            role="tab"
            id={`hf-tab-${gi}`}
            aria-controls={`hf-panel-${gi}`}
            aria-selected={gi === 0 ? 'true' : 'false'}
            tabindex={gi === 0 ? 0 : -1}
            data-hf-tab
          >
            <span class="hf-rail-dot" aria-hidden="true"></span>
            <span class="hf-rail-text">{group.title}</span>
          </button>
        ))}
      </nav>
    </div>

    <div class="hf-panels">
      {faqGroups.map((group, gi) => (
        <section
          class="hf-panel"
          id={`hf-panel-${gi}`}
          role="tabpanel"
          aria-labelledby={`hf-tab-${gi}`}
          hidden={gi !== 0}
          data-hf-panel
        >
          <ul class="hf-list" role="list">
            {group.items.map((item) => (
              <li>
                <details class="hf-item" name="home-faq">
                  <summary class="hf-q">
                    <span class="hf-q-text">{item.q}</span>
                    <span class="hf-q-icon" aria-hidden="true">
                      {/* Plus-to-X: SVG draws a plus; rotating 45° on
                          [open] visually turns it into an X. */}
                      <svg viewBox="0 0 24 24">
                        <path d="M12 4v16m8-8H4" fill="none"
                              stroke="currentColor" stroke-width="2"
                              stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                  </summary>
                  <div class="hf-a-wrap">
                    <p class="hf-a" set:html={item.a}></p>
                  </div>
                </details>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</section>
</div>

<style>
  /* Lifted from the How-It-Works FAQ styling, scoped to .hf so the two
     don't step on each other. Brand palette: #1A2F3A teal, #2DC856 green. */
  /* Scene wrapper: scroll range for the sticky FAQ. Height chosen to
     give ~60 vh of "pinned" scroll before the section releases —
     matches the anchoring feel of the portal/map scenes. The green
     div the section lives inside still gets no background; .hf paints
     its own gradient on top. */
  .hf-scene {
    position: relative;
    height: 160vh;
  }
  .hf {
    position: sticky;
    top: 0;
    /* The content (header + tabs + longest panel ≈ 560 px) fits
       comfortably in 100 vh at standard desktop heights, and the
       accordion expansions don't grow the section past viewport
       height at realistic widths. */
    min-height: 100vh;
    background: linear-gradient(180deg, #1A2F3A 0%, #1c3443 100%);
    color: #fff;
    padding: clamp(90px, 12vh, 140px) 5vw clamp(100px, 12vh, 140px);
    /* Green 4px border-top removed + .hf-seam neutralised. The map
       section now owns the bottom-of-map fade via .map-bottom-vignette
       (fades map's #020608 into this section's #1A2F3A), so a single
       seam handles the handoff cleanly. */
    font-family: 'Maven Pro', sans-serif;
  }

  /* .hf-seam element is still rendered but visually neutralised — its
     gradient would now stack on top of .map-bottom-vignette and muddy
     the handoff. Kept zero-height so the DOM structure is unchanged
     for any downstream references. */
  .hf-seam {
    display: none;
  }

  .hf-inner {
    position: relative;
    z-index: 2;
    max-width: 1180px;
    margin: 0 auto;
  }

  /* ── Top band: header LEFT + group selector RIGHT ──────────── */
  .hf-top {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(240px, 340px);
    gap: clamp(40px, 5vw, 80px);
    align-items: start;
    margin-bottom: clamp(48px, 5.5vw, 72px);
  }
  .hf-head { max-width: 46ch; }

  .hf-brow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 22px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #2DC856;
  }
  .hf-brow-mark {
    display: inline-block;
    width: 22px;
    height: 2px;
    background: #2DC856;
    border-radius: 2px;
  }

  .hf-title {
    margin: 0 0 18px;
    font-size: clamp(2rem, 3.6vw, 2.8rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.012em;
    color: #fff;
    text-wrap: balance;
  }
  .hf-accent { color: #2DC856; }
  .hf-sub {
    margin: 0;
    max-width: 46ch;
    font-size: clamp(0.95rem, 1.05vw, 1.02rem);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.62);
  }

  /* ── Rail nav (dots + line, how-it-works style) ────────────── */
  .hf-rail-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-left: 1px solid rgba(255, 255, 255, 0.18);
    /* Nudged down a hair so the first rail link aligns with the
       headline, not the brow. */
    margin-top: clamp(26px, 3vw, 34px);
  }
  .hf-rail-link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 12px 0 12px 20px;
    margin-left: -1px;
    border: 0;
    border-left: 1px solid transparent;
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    font-family: inherit;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.002em;
    text-align: left;
    cursor: pointer;
    transition: color 0.2s ease, border-left-color 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .hf-rail-link:hover {
    color: #2DC856;
    border-left-color: #2DC856;
  }
  .hf-rail-link:focus-visible {
    outline: 2px solid rgba(45, 200, 86, 0.55);
    outline-offset: 2px;
    border-radius: 2px;
  }
  .hf-rail-link[aria-selected="true"] {
    color: #2DC856;
    border-left-color: #2DC856;
  }
  .hf-rail-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.28);
    transition: background 0.2s ease, box-shadow 0.2s ease;
    flex-shrink: 0;
  }
  .hf-rail-link:hover .hf-rail-dot,
  .hf-rail-link[aria-selected="true"] .hf-rail-dot {
    background: #2DC856;
    box-shadow: 0 0 10px rgba(45, 200, 86, 0.7);
  }

  @media (max-width: 820px) {
    .hf-top { grid-template-columns: 1fr; gap: 32px; }
    .hf-rail-nav { margin-top: 0; }
  }

  /* Panels animate softly on tab switch (JS toggles [hidden]). */
  .hf-panel[hidden] { display: none; }
  .hf-panel:not([hidden]) {
    animation: hf-panel-in 320ms cubic-bezier(.22, 1, .36, 1);
  }
  @keyframes hf-panel-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hf-panel:not([hidden]) { animation: none; }
  }

  /* Each item = a self-contained rounded card on a slightly darker fill
     than the section, with a thin white border — matches the
     generate-profits page FAQ style. Space between cards (gap) instead
     of dividers between items. */
  .hf-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .hf-item {
    background: #152732;
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .hf-item:hover {
    border-color: rgba(255, 255, 255, 0.18);
    background: #17303b;
  }
  .hf-item[open] {
    border-color: rgba(45, 200, 86, 0.35);
  }

  .hf-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: clamp(20px, 2.2vw, 26px) clamp(22px, 2.4vw, 28px);
    cursor: pointer;
    list-style: none;
    font-size: clamp(0.95rem, 1.05vw, 1.02rem);
    font-weight: 600;
    letter-spacing: -0.005em;
    color: #fff;
    transition: color 0.2s ease;
  }
  .hf-q::-webkit-details-marker { display: none; }

  .hf-q-text { flex: 1 1 auto; line-height: 1.4; }

  /* Plus → X icon. The SVG itself draws a plus; rotating the whole icon
     45° turns it into an X. Brand green, no circle enclosure — keeps
     the card feeling uncluttered. */
  .hf-q-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: #2DC856;
    transition: transform 0.28s cubic-bezier(.22, 1, .36, 1);
  }
  .hf-q-icon svg { width: 20px; height: 20px; }
  .hf-item[open] .hf-q-icon { transform: rotate(45deg); }

  /* Answer wrapper — top border acts as the separator between Q and A
     instead of an item-level divider (matches generate-profits). */
  .hf-a-wrap {
    padding: clamp(18px, 2vw, 22px) clamp(22px, 2.4vw, 28px) clamp(22px, 2.4vw, 28px);
    border-top: 1px solid rgba(255, 255, 255, 0.10);
  }
  .hf-a {
    margin: 0;
    font-size: clamp(0.9rem, 0.98vw, 0.98rem);
    font-weight: 500;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.62);
    max-width: 68ch;
  }
  /* Inline link inside an answer — picks up the brand-green accent and
     keeps the arrow inline with the sentence so it reads as a natural
     "learn more" rather than a sidebar CTA. */
  .hf-a :global(.hf-inline-link) {
    display: inline-block;
    margin-left: 4px;
    color: #2DC856;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid rgba(45, 200, 86, 0.4);
    transition: border-bottom-color 0.18s ease, color 0.18s ease;
    white-space: nowrap;
  }
  .hf-a :global(.hf-inline-link:hover) {
    color: #48E672;
    border-bottom-color: #48E672;
  }

  @media (max-width: 640px) {
    .hf-q { gap: 12px; padding: 18px 20px; }
    .hf-a-wrap { padding: 16px 20px 20px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hf-q-icon { transition: none; }
  }
</style>

<script>
  // FAQ tabs — click or keyboard-navigate (←/→/Home/End) to switch
  // which group is visible. Roving tabindex, aria-selected, and the
  // [hidden] attribute on panels keep the state correct for screen
  // readers + keyboard users.
  (() => {
    const tablist = document.querySelector<HTMLElement>('[data-hf-tabs]');
    if (!tablist) return;
    const tabs = Array.from(tablist.querySelectorAll<HTMLButtonElement>('[data-hf-tab]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-hf-panel]'));
    if (tabs.length === 0 || tabs.length !== panels.length) return;

    const activate = (idx: number, setFocus = true) => {
      const i = ((idx % tabs.length) + tabs.length) % tabs.length;
      tabs.forEach((t, ti) => {
        const active = ti === i;
        t.setAttribute('aria-selected', active ? 'true' : 'false');
        t.setAttribute('tabindex', active ? '0' : '-1');
      });
      panels.forEach((p, pi) => {
        if (pi === i) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
      if (setFocus) tabs[i].focus();
    };

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => activate(i, false));
      tab.addEventListener('keydown', (e) => {
        switch (e.key) {
          case 'ArrowRight':
          case 'ArrowDown':
            e.preventDefault();
            activate(i + 1);
            break;
          case 'ArrowLeft':
          case 'ArrowUp':
            e.preventDefault();
            activate(i - 1);
            break;
          case 'Home':
            e.preventDefault();
            activate(0);
            break;
          case 'End':
            e.preventDefault();
            activate(tabs.length - 1);
            break;
        }
      });
    });
  })();

  // ──────────────────────────────────────────────────────────────
  // SNAP-ON-IDLE anchor for the FAQ scene
  //
  // Mirrors the pattern used on the portal-solutions and locations-map
  // scenes: the FAQ is wrapped in a 160 vh `.hf-scene` with the `.hf`
  // section pinned via position:sticky. Snap pulls the user to
  // raw = 0.35 of the scene — a comfortable middle of the sticky
  // band where the FAQ header sits below the nav with the category
  // tabs and first panel items all centered in the viewport.
  //
  //   • Only fires in the animation band (past SNAP_LOW_SKIP, before
  //     SNAP_HIGH_SKIP). Outside those bands the user has either not
  //     yet arrived or is already on their way out — we don't fight
  //     their scroll direction.
  //   • Idle threshold 900 ms so intentional micro-pauses don't fire.
  //   • Respects `prefers-reduced-motion`; won't re-fire while an
  //     in-flight snap is still settling.
  // ──────────────────────────────────────────────────────────────
  (() => {
    const scene = document.querySelector<HTMLElement>('[data-hf-scene]');
    if (!scene) return;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    let snapTimer: number | null = null;
    let snapping = false;

    const SNAP_IDLE_MS = 900;
    const SNAP_LOW_SKIP = 0.06;
    const SNAP_HIGH_SKIP = 0.90;
    const SNAP_ANCHOR = 0.35;

    function scheduleSnap() {
      if (prefersReducedMotion.matches) return;
      if (snapping) return;
      if (snapTimer != null) window.clearTimeout(snapTimer);
      snapTimer = window.setTimeout(runSnap, SNAP_IDLE_MS);
    }

    function runSnap() {
      snapTimer = null;
      if (snapping) return;
      const rect = scene!.getBoundingClientRect();
      const sceneH = scene!.offsetHeight;
      const vh = window.innerHeight;
      const scrollable = Math.max(1, sceneH - vh);
      const scrolled = Math.min(scrollable, Math.max(0, -rect.top));
      const raw = scrolled / scrollable;
      if (raw <= SNAP_LOW_SKIP || raw >= SNAP_HIGH_SKIP) return;
      if (rect.top > 1 || rect.bottom < vh - 1) return;
      const sceneTopAbs = window.scrollY + rect.top;
      const targetY = Math.round(sceneTopAbs + SNAP_ANCHOR * scrollable);
      snapping = true;
      window.scrollTo({ top: targetY, behavior: 'smooth' });
      window.setTimeout(() => { snapping = false; }, 1000);
    }

    window.addEventListener('scroll', scheduleSnap, { passive: true });
    window.addEventListener('resize', scheduleSnap);
  })();
</script>
