---
/**
 * Default placeholder used by every page until real content is built.
 * Shows the Evium logo centred on the brand dark-teal background.
 */
interface Props { title?: string; }
const { title } = Astro.props;
---
<section
  style="
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(ellipse 90% 80% at 50% 46%, #2a4a5e 0%, #1a2f3a 45%, #081420 100%);
  "
>
  <div style="text-align:center; pointer-events:none; user-select:none;">
    <!-- Logo is a home link so users stuck on a placeholder page can
         escape. The wrapper div has pointer-events:none to keep the
         rest of the placeholder non-interactive, so the anchor
         explicitly re-enables its own pointer events. -->
    <a
      href="/"
      aria-label="Return to Evium Charging home"
      style="display:inline-block; pointer-events:auto; transition:opacity 0.2s ease, transform 0.2s ease; cursor:pointer;"
      onmouseenter="this.style.opacity='1'; this.firstElementChild.style.transform='scale(1.02)';"
      onmouseleave="this.style.opacity='0.92'; this.firstElementChild.style.transform='scale(1)';"
    >
      <img
        src="/images/logos/evium/logo.webp"
        alt="Evium Charging"
        style="height:72px; margin:0 auto; display:block; opacity:0.92; transition:transform 0.2s ease;"
      />
    </a>
    {title && (
      <p style="margin-top:18px; font-family:'Maven Pro',sans-serif; font-size:0.72rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; color:rgba(255,255,255,0.25);">
        {title}
      </p>
    )}
  </div>
</section>
