---
/**
 * Full-viewport "Coming Soon" placeholder.
 * MP4 electricity background with the Evium logo that fades to the
 * "Coming Soon" text and back on a 10s loop.
 */
---
<main class="relative min-h-screen overflow-hidden bg-[#081420]">
  <video
    class="absolute inset-0 h-full w-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    aria-label="Abstract dark electric energy background"
  >
    <source src="/images/tesla-hero-vids/dark-electricity.mp4" type="video/mp4" />
  </video>

  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(8,20,32,0.1)_0%,rgba(8,20,32,0.42)_62%,rgba(8,20,32,0.72)_100%)]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(6,14,22,0.48)_0%,rgba(6,14,22,0.14)_28%,rgba(6,14,22,0.32)_100%)]"></div>

  <section class="relative flex min-h-screen items-center justify-center px-6">
    <div class="pointer-events-none select-none text-center relative">
      <!-- Logo is a home link so users hitting a coming-soon page can
           bail out. pointer-events:auto re-enables clicks just for the
           anchor (the wrapper div kills them for everything else). -->
      <a
        href="/"
        aria-label="Return to Evium Charging home"
        class="home-logo-link inline-block cursor-pointer pointer-events-auto"
      >
        <img
          src="/images/logos/evium/logo.webp"
          alt="Evium Charging"
          class="hero-logo mx-auto h-[72px] w-auto md:h-[88px]"
        />
      </a>
      <div
        class="hero-text absolute inset-0 flex flex-col items-center justify-center font-maven text-[2.25rem] md:text-[3rem] font-semibold uppercase text-white/90 leading-tight"
      >
        <span class="tracking-[0.22em]">Coming</span>
        <span class="tracking-[0.42em]">Soon</span>
      </div>
    </div>
  </section>
</main>

<style>
  /*
    Pure CSS loop — 10s total cycle, no JS.
    Timeline:
      0%–40%   logo visible
     40%–48%   logo fades out
     48%–56%   text fades in
     56%–84%   text visible
     84%–92%   text fades out
     92%–100%  logo fades in (loops back to 0%)
  */
  .hero-logo {
    animation: logoLoop 10s ease-in-out infinite;
  }
  .hero-text {
    animation: textLoop 10s ease-in-out infinite;
  }

  @keyframes logoLoop {
    0%, 40%   { opacity: 0.95; filter: blur(0);   transform: translateY(0); }
    48%, 92%  { opacity: 0;    filter: blur(6px);  transform: translateY(-8px); }
    100%      { opacity: 0.95; filter: blur(0);    transform: translateY(0); }
  }

  @keyframes textLoop {
    0%, 48%   { opacity: 0;    filter: blur(6px);  transform: translateY(8px); }
    56%, 84%  { opacity: 0.9;  filter: blur(0);    transform: translateY(0); }
    92%, 100% { opacity: 0;    filter: blur(6px);  transform: translateY(-8px); }
  }
</style>
