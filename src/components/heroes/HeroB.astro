---
// Hero B: "Split Slant" — two-panel layout, split by a diagonal matching navbar angle
---
<section class="relative min-h-screen flex overflow-hidden">

  <!-- Left panel: dark teal with content -->
  <div class="relative flex-1 flex items-center bg-[#1A2F3A] z-10 px-10 md:px-16 py-24"
    style="clip-path: polygon(0 0, 100% 0, calc(100% - 120px) 100%, 0 100%);">
    <div class="max-w-lg">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-8 h-[2px] bg-[#2DC856]"></div>
        <span class="text-[#2DC856] text-xs font-bold tracking-[0.25em] uppercase">Zero Cost. Full Service.</span>
      </div>
      <h1 class="text-white font-black leading-tight mb-6" style="font-size: clamp(2.4rem, 4.5vw, 4.2rem);">
        EV Charging<br/>
        Done For<br/>
        <span class="text-[#2DC856]">Your Property.</span>
      </h1>
      <p class="text-white/55 leading-relaxed mb-10 max-w-sm">
        Evium installs, manages, and maintains EV chargers at no cost to landlords and property owners — turning parking spots into revenue.
      </p>
      <a href="/contact/quote"
        class="inline-flex items-center gap-3 bg-[#2DC856] text-[#0f1e27] font-black text-sm tracking-widest uppercase px-8 py-4 hover:bg-white transition-colors duration-200">
        Start For Free
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>

      <!-- Stat pills -->
      <div class="flex flex-wrap gap-3 mt-10">
        {[['500+','Chargers'], ['$0','To Install'], ['NEVI','Certified'], ['48hr','Quote']].map(([n,l]) => (
          <div class="border border-white/15 px-4 py-2 text-center">
            <div class="text-[#2DC856] font-black text-xl leading-none">{n}</div>
            <div class="text-white/40 text-[10px] tracking-widest uppercase mt-1">{l}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Right panel: charger on near-black -->
  <div class="relative w-[48%] flex items-end justify-center bg-[#0d1a22] overflow-hidden">
    <!-- Subtle green glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_60%,rgba(45,200,86,0.1),transparent)] pointer-events-none"></div>
    <!-- Charger -->
    <img
      src="/images/chargers/tellus/tellus-dc-fast-180kw.png"
      alt="Evium Charger"
      class="relative z-10 h-[85%] object-contain object-bottom drop-shadow-[0_0_80px_rgba(45,200,86,0.3)]"
    />
    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-[#0d1a22] to-transparent pointer-events-none z-20"></div>
  </div>
</section>
