---
/**
 * Portal Carousel — gust-driven wind lines.
 *
 * Each cycle: a gust blows in from ONE side (alternating left → right → left…).
 * 8–11 lines all sweep in from that same side at wildly different speeds —
 * light ones zip through fast, heavy ones drag slowly. One of them decelerates
 * and stops at a portal position; the slit tears open, charger emerges.
 * Then the next gust comes from the opposite side.
 */
const portals = [
  // ── Original 7 ───────────────────────────────────────────────
  { x: 12, y: 38, side: 'left',  img: '/images/chargers/evocharge/evium-evocharge-l2-wallmount.png',                                  label: 'EvoCharge Level 2',       productId: 'evocharge-40a'       },
  { x: 78, y: 52, side: 'right', img: '/images/chargers/maxicharger/maxicharger-dc-fast-60-240kw.png',                               label: 'MaxiCharger DC 60–240kW', productId: 'maxicharger-dc'      },
  { x: 24, y: 62, side: 'left',  img: '/images/chargers/tellus/tellus-dc-fast-180kw.png',                                            label: 'Tellus DC Fast 180kW',    productId: 'evium-180kw'         },
  { x: 68, y: 34, side: 'right', img: '/images/chargers/tellus/tellus-dc-fast-300kw.png',                                            label: 'Tellus DC Fast 300kW',    productId: 'evium-300kw'         },
  { x: 15, y: 60, side: 'left',  img: '/images/chargers/tellus/evium-dc-fast-outdoor-kiosk-combo.png',                               label: 'DC Fast Outdoor Station', productId: 'evium-outdoor'       },
  { x: 80, y: 66, side: 'right', img: '/images/chargers/siemens/siemens-versicharge-ac-variants.png',                                label: 'Siemens VersiCharge AC',  productId: 'versicharge-ac'      },
  { x: 16, y: 76, side: 'left',  img: '/images/chargers/siemens/siemens-versicharge-l2-wallmount.png',                               label: 'Siemens eMobility L2',    productId: 'versicharge-l2'      },
  // ── 8 new entries ────────────────────────────────────────────
  { x:  7, y: 22, side: 'left',  img: '/images/chargers/evocharge/EVOCHARGE-32A-Level-2-Charging-Station-Spec-Sheet-1122-03.png',    label: 'EvoCharge 32A L2',        productId: 'evocharge-32a'       },
  { x: 23, y: 48, side: 'left',  img: '/images/chargers/evocharge/EVOCHARGE-40A-Level-2-Charging-Station-Spec-Sheet-1122.png',       label: 'EvoCharge 40A L2',        productId: 'evocharge-40a'       },
  { x:  8, y: 85, side: 'left',  img: '/images/chargers/tellus/Evium---AC-48A.png',                                                  label: 'Evium AC 12kW 50A',       productId: 'evium-ac-50a'        },
  { x: 32, y: 72, side: 'left',  img: '/images/chargers/tellus/Evium---DC-Fast-Charger-60kw.png',                                    label: 'Evium DC Fast 60kW',      productId: 'evium-60kw'          },
  { x: 86, y: 28, side: 'right', img: '/images/chargers/siemens/Evium---Pedestal-Wallmount-AC-charger.png',                          label: 'VersiCharge AC Pedestal', productId: 'versicharge-pedestal'},
  { x: 76, y: 42, side: 'right', img: '/images/chargers/tellus/evium-dcfc-120kw.png',                                                label: 'Evium DCFC 120kW',        productId: 'evium-120kw'         },
  { x: 86, y: 80, side: 'right', img: '/images/chargers/tellus/Evium---IC80A-Gen-2.png',                                             label: 'Evium AC 19.2kW 80A',     productId: 'evium-ac-80a'        },
  { x: 72, y: 78, side: 'right', img: '/images/chargers/tellus/Evium---Wall-mount-AC-charger.png',                                   label: 'Evium Wall-mount AC',     productId: 'evium-ac-80a'        },
];
---

<section
  id="hero-portal-testing"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Top vignette: fades wind-lines near the fixed navbar so they don't
       visually intrude into the header zone. Sits above wind-field (z:3). -->
  <div style="position:absolute;top:0;left:0;right:0;height:100px;background:linear-gradient(to bottom,rgba(6,14,22,0.82) 0%,transparent 100%);pointer-events:none;z-index:4;"></div>
  <!-- Wind field: JS draws all gust lines here -->
  <div id="wind-field-testing" style="position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:3;"></div>

  <!-- Portal groups: slit + charger only -->
  {portals.map((p, pi) => (
    <div
      class="portal-group"
      data-index={pi}
      data-side={p.side}
      data-product-id={p.productId}
      style={`position:absolute; left:${p.x}%; top:${p.y}%; width:0; height:0; z-index:10;`}
    >
      <div class="portal-slit">
        <div class="portal-top-edge" />
        <div class="portal-interior" />
        <div class="portal-bot-edge" />
      </div>

      <div class="portal-asset">
        <img src={p.img} alt={p.label} width="250" height="350" class="asset-img" />
        <div class="asset-underglow" />
      </div>
      <div class="portal-label">{p.label}</div>
    </div>
  ))}

  <div class="relative z-20 text-center select-none pointer-events-none">
    <img src="/images/logo.webp" alt="Evium Charging" style="height:5rem;margin:0 auto;" />
    <p style="margin-top:1.25rem;font-size:1.1rem;font-weight:700;color:rgba(255,255,255,0.45);letter-spacing:0.04em;">
      Electrifying the future. One property at a time.
    </p>
  </div>
</section>

<style>
  /* ─── Hero background + sizing tokens ────────────────── */
  #hero-portal-testing {
    background: radial-gradient(ellipse 90% 80% at 50% 46%, #2a4a5e 0%, #1a2f3a 45%, #081420 100%);
    /* Single source of truth — change these and everything scales */
    --slit-w: clamp(120px, 20vw, 360px);
    --slit-h: clamp(48px, 6vw, 108px);
    --img-w:  clamp(80px, 15vw, 280px);
  }

  /* ─── Portal slit ─────────────────────────────────── */
  .portal-slit {
    position: absolute;
    width: var(--slit-w);
    height: var(--slit-h);
    left: calc(var(--slit-w) / -2);
    top: calc(var(--slit-h) / -2);
    transform: scaleY(0);
    transform-origin: center center;
    overflow: visible;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .portal-top-edge,
  .portal-bot-edge {
    position: absolute;
    left: 0; right: 0;
    height: 2px;
    background: #2DC856;
    z-index: 2;
  }
  .portal-top-edge { top: 0;    box-shadow: 0 -8px 24px #2DC856, 0 -2px 50px rgba(45,200,86,0.5); }
  .portal-bot-edge { bottom: 0; box-shadow: 0  8px 24px #2DC856, 0  2px 50px rgba(45,200,86,0.5); }

  /* Dark-teal interior — structured depth with thin green edge-bleed */
  .portal-interior {
    position: absolute;
    inset: 2px 0;
    background: linear-gradient(to bottom,
      rgba(45,200,86,0.13)  0%,
      #0d1820              12%,
      #0b151e              50%,
      #0d1820              88%,
      rgba(45,200,86,0.13) 100%
    );
    z-index: 1;
  }

  /* ─── Charger asset ───────────────────────────────── */
  .portal-asset {
    position: absolute;
    bottom: 0;
    left: calc(var(--img-w) / -2);
    opacity: 0;
    transform: translateY(28px) scale(0.6);
    filter: brightness(4) blur(8px);
    transition:
      opacity   0.5s ease,
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      filter    0.65s ease;
    text-align: center;
    pointer-events: none;
    z-index: 15;
  }

  .asset-img {
    position: relative;
    z-index: 1;
    width: var(--img-w);
    height: auto;
    display: block;
  }

  .asset-underglow {
    position: absolute;
    bottom: clamp(16px, 2.5vw, 30px);
    left: 50%;
    transform: translateX(-50%);
    width: calc(var(--img-w) * 0.75);
    height: clamp(8px, 1vw, 14px);
    background: rgba(45,200,86,0.45);
    filter: blur(12px);
    border-radius: 50%;
    z-index: 0;
  }

  /* Label centered inside the slit box */
  .portal-label {
    position: absolute;
    left: calc(var(--slit-w) / -2);
    top: calc(var(--slit-h) / -2);
    width: var(--slit-w);
    height: var(--slit-h);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(0.5rem, 1.1vw, 0.9rem);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    color: rgba(255, 255, 255, 0.95);
    text-shadow:
      0 0 16px rgba(45,200,86,0.95),
      0 0 4px  rgba(45,200,86,0.6);
    opacity: 0;
    z-index: 30;
    pointer-events: none;
    transition: opacity 0.4s ease 0.35s;
  }

  /* ─── Per-portal image sizing overrides ──────────────
     Each portal has a unique image shape — these dial in
     the right width and bottom-offset per charger.
     --img-w re-declared on the group cascades to both
     .portal-asset (left offset) and .asset-img (width).
  ─────────────────────────────────────────────────── */

  /* 0: EvoCharge L2 */
  .portal-group[data-index="0"] { --img-w: clamp(80px, 12vw, 210px); }
  .portal-group[data-index="0"] .asset-img {
    height: calc(var(--img-w) * 1.1);
    object-fit: cover;
    object-position: top center;
  }
  .portal-group[data-index="0"] .portal-asset {
    bottom: calc(var(--slit-h) * -0.4);
  }

  /* 1: MaxiCharger DC — lift image so it doesn't crowd the slit label */
  .portal-group[data-index="1"] { --img-w: clamp(84px, 14vw, 252px); }
  .portal-group[data-index="1"] .portal-asset { bottom: clamp(8px, 1.5vw, 22px); }

  /* 2: Tellus 180kW — dramatic showpiece, give it room */
  .portal-group[data-index="2"] { --img-w: clamp(98px, 18.2vw, 316px); }

  /* 3: Tellus 300kW — sit just above slit with small gap */
  .portal-group[data-index="3"] { --img-w: clamp(96px, 18vw, 310px); }
  .portal-group[data-index="3"] .portal-asset { bottom: clamp(4px, 0.8vw, 14px); }

  /* 4: Outdoor Kiosk Combo — very wide two-item image,
        needs wider allowance to show both objects */
  .portal-group[data-index="4"] { --img-w: clamp(110px, 21vw, 360px); }

  /* 5: Siemens VersiCharge AC — crop to charger bodies + cable section;
        charger bodies float above slit, cable section falls inside slit behind label.
        Cut point hidden by label text (at image bottom = slit center). */
  .portal-group[data-index="5"] { --img-w: clamp(80px, 12.5vw, 220px); }
  .portal-group[data-index="5"] .asset-img {
    height: calc(var(--img-w) * 0.85);
    object-fit: cover;
    object-position: top center;
  }
  .portal-group[data-index="5"] .portal-asset {
    bottom: calc(var(--slit-h) * -0.5);
  }

  /* 6: Siemens eMobility L2 */
  .portal-group[data-index="6"] { --img-w: clamp(65px, 9vw, 160px); }
  .portal-group[data-index="6"] .asset-img {
    height: calc(var(--img-w) * 1.1);
    object-fit: cover;
    object-position: top center;
  }
  .portal-group[data-index="6"] .portal-asset {
    bottom: calc(var(--slit-h) * -0.4);
  }

  /* ─── Portal states ───────────────────────────────── */
  .portal-group.is-open .portal-slit {
    transform: scaleY(1);
    box-shadow: 0 0 40px rgba(45,200,86,0.2), 0 0 90px rgba(45,200,86,0.07);
  }
  .portal-group.is-active .portal-asset {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: brightness(1.05) blur(0);
  }
  .portal-group.is-active .portal-label { opacity: 1; }

  /* ─── Clickable state: enable pointer events on active portals
     so the user can click them to jump to that product. ─────── */
  .portal-group.is-active .portal-asset,
  .portal-group.is-active .portal-label {
    pointer-events: auto;
    cursor: pointer;
  }
  .portal-group.is-active .portal-asset:hover .asset-img {
    filter: brightness(1.15);
    transition: filter 0.15s ease;
  }
  .portal-group.is-active .portal-label:hover {
    text-shadow:
      0 0 20px rgba(45,200,86,1),
      0 0 6px  rgba(45,200,86,0.8);
  }
  .portal-group.is-closing .portal-slit {
    transform: scaleY(0);
    transition: transform 0.3s cubic-bezier(0.7, 0, 0.84, 0);
  }
  .portal-group.is-closing .portal-asset {
    opacity: 0;
    transform: translateY(-15px) scale(0.88);
    filter: brightness(2.5) blur(5px);
    transition: opacity 0.3s, transform 0.35s, filter 0.28s;
  }
  .portal-group.is-closing .portal-label { opacity: 0; transition: opacity 0.15s; }
</style>

<script>
  (() => {
    const section = document.getElementById('hero-portal-testing')!;
    const field   = document.getElementById('wind-field-testing')!;
    const groups  = Array.from(section.querySelectorAll<HTMLElement>('.portal-group'));

    // ── Click-to-navigate: only fires while the portal is "active" ──
    // (CSS gates pointer-events on .is-active; this delegates the clicks
    //  and sends the user to /products#<productId> which auto-selects
    //  the correct L2/L3 tab and scrolls to the matching card.)
    groups.forEach((g) => {
      g.addEventListener('click', () => {
        if (!g.classList.contains('is-active')) return;
        const pid = g.getAttribute('data-product-id');
        if (pid) window.location.href = `/products#${pid}`;
      });
    });

    function wait(ms: number) { return new Promise<void>(r => setTimeout(r, ms)); }
    function rnd(lo: number, hi: number) { return lo + Math.random() * (hi - lo); }

    // Shuffled portal order — cycles through all 7 before repeating, never boring
    let portalQueue: number[] = [];
    function nextPortalIdx() {
      if (!portalQueue.length) {
        portalQueue = Array.from({ length: groups.length }, (_, i) => i)
          .sort(() => Math.random() - 0.5);
      }
      return portalQueue.pop()!;
    }

    // Direction: mostly alternates but occasionally repeats same side
    let lastDir: 'left' | 'right' = 'left';
    function nextDir(): 'left' | 'right' {
      // 20 % chance same side again → back-to-back gusts from one direction
      const flip = Math.random() > 0.20;
      lastDir = flip ? (lastDir === 'left' ? 'right' : 'left') : lastDir;
      return lastDir;
    }

    // ── Spawn one gust line (fire-and-forget) ────────────────────────────
    // clusterY: if set, 40 % chance the line spawns near that y% value
    function spawnGustLine(fromDir: 'left' | 'right', delayMs: number, clusterY?: number) {
      const vw = section.offsetWidth;

      // Line weight — biased toward a mix rather than uniform spread
      const heavy  = Math.random() < 0.25;           // 25 % chance of a "heavy" line
      const w      = heavy ? rnd(180, 310) : rnd(30, 220);
      const alpha  = heavy ? rnd(0.35, 0.60) : rnd(0.04, 0.42);
      const h      = heavy ? 2 : (Math.random() < 0.45 ? 2 : 1);
      const spd    = heavy ? rnd(1800, 4200) : rnd(380, 2600); // wide range = weight variety

      // Height: occasionally cluster near the portal, mostly scattered.
      // Floor at 12 % keeps all lines below the fixed navbar zone (~80 px / 800 px ≈ 10 %).
      let y: number;
      if (clusterY !== undefined && Math.random() < 0.38) {
        y = Math.max(12, Math.min(93, clusterY + rnd(-10, 10)));
      } else {
        y = rnd(12, 93);
      }

      // ~45 % of lines get a directional "comet tail" — bright leading edge, fading trail.
      const comet = Math.random() < 0.45;
      let bg: string;
      if (comet) {
        if (fromDir === 'left') {
          bg = `linear-gradient(to right,
            rgba(45,200,86,0) 0%,
            rgba(45,200,86,${(alpha * 0.3).toFixed(2)}) 35%,
            rgba(45,200,86,${alpha.toFixed(2)}) 82%,
            rgba(45,200,86,${(alpha * 0.5).toFixed(2)}) 93%,
            rgba(45,200,86,0) 100%)`;
        } else {
          bg = `linear-gradient(to right,
            rgba(45,200,86,0) 0%,
            rgba(45,200,86,${(alpha * 0.5).toFixed(2)}) 7%,
            rgba(45,200,86,${alpha.toFixed(2)}) 18%,
            rgba(45,200,86,${(alpha * 0.3).toFixed(2)}) 65%,
            rgba(45,200,86,0) 100%)`;
        }
      } else {
        bg = `linear-gradient(to right,
          rgba(45,200,86,0) 0%,
          rgba(45,200,86,${alpha.toFixed(2)}) 20%,
          rgba(45,200,86,${alpha.toFixed(2)}) 80%,
          rgba(45,200,86,0) 100%)`;
      }

      const el = document.createElement('div');
      Object.assign(el.style, {
        position:   'absolute',
        top:        `${y.toFixed(1)}%`,
        height:     `${h}px`,
        width:      `${w}px`,
        background: bg,
        pointerEvents: 'none',
        willChange: 'transform',
      });
      field.appendChild(el);

      const fromX = fromDir === 'left' ? -(w + 20) : vw + 20;
      const toX   = fromDir === 'left' ?  vw + 20  : -(w + 20);
      el.style.transform = `translateX(${fromX}px)`;

      setTimeout(() => {
        el.animate(
          [{ transform: `translateX(${fromX}px)` }, { transform: `translateX(${toX}px)` }],
          { duration: spd, easing: 'linear', fill: 'forwards' }
        ).onfinish = () => el.remove();
      }, delayMs);
    }

    // ── One full gust + portal cycle ─────────────────────────────────────
    async function doGust() {
      const fromDir  = nextDir();
      const g        = groups[nextPortalIdx()];
      const vw       = section.offsetWidth;
      const sRect    = section.getBoundingClientRect();
      const gRect    = g.getBoundingClientRect();
      const anchorX  = gRect.left - sRect.left;
      const anchorY  = gRect.top  - sRect.top;
      const anchorYpct = (anchorY / section.offsetHeight) * 100;
      // Read actual rendered slit width so trigger line always matches
      const slitW    = g.querySelector<HTMLElement>('.portal-slit')!.offsetWidth;
      const landX    = anchorX - slitW / 2;

      // Per-cycle variance — every gust feels different
      const lineCount     = Math.round(rnd(5, 14));        // light sprinkle → heavy barrage
      const staggerBase   = rnd(18, 65);                   // tight burst vs slow trickle
      const triggerOffset = rnd(80, 560);                  // when trigger fires into gust
      const triggerSpeed  = rnd(300, 680);                 // fast snap vs slow drag
      const holdMs        = rnd(40, 300);                  // brief pause before slit opens
      const slitOpenMs    = rnd(340, 580);                 // wait after slit starts opening
      const chargerDwell  = rnd(1900, 3800);               // how long charger is shown
      const fadeMs        = rnd(350, 500);                 // closing transition time

      // ── 1. Launch decorative gust lines ──────────────────────────────────
      for (let i = 0; i < lineCount; i++) {
        const jitter  = rnd(-20, 20);
        const stagger = i * staggerBase + jitter;
        spawnGustLine(fromDir, Math.max(0, stagger), anchorYpct);
      }

      // ── 2. Portal trigger line ────────────────────────────────────────────
      await wait(triggerOffset);

      const tl = document.createElement('div');
      Object.assign(tl.style, {
        position:   'absolute',
        top:        `${anchorY - 1}px`,
        height:     '2px',
        width:      `${slitW}px`,
        background: 'linear-gradient(to right, rgba(45,200,86,0) 0%, rgba(45,200,86,0.88) 26%, rgba(45,200,86,0.88) 74%, rgba(45,200,86,0) 100%)',
        pointerEvents: 'none',
        willChange: 'transform',
        zIndex:     '8',
      });
      field.appendChild(tl);

      const startX = fromDir === 'left' ? -(slitW + 30) : vw + 30;
      tl.style.transform = `translateX(${startX}px)`;

      await new Promise<void>(resolve => {
        tl.animate(
          [{ transform: `translateX(${startX}px)` }, { transform: `translateX(${landX}px)` }],
          { duration: triggerSpeed, easing: 'cubic-bezier(0.16, 0, 0.06, 1)', fill: 'forwards' }
        ).onfinish = () => resolve();
      });

      // ── 3. Hold, then slit tears open ────────────────────────────────────
      await wait(holdMs);
      // Vary tear speed: some snap open (280ms), some slowly split apart (700ms)
      const tearSpeed = Math.round(rnd(280, 700));
      const slitEl = g.querySelector<HTMLElement>('.portal-slit')!;
      slitEl.style.transition = `transform ${tearSpeed}ms cubic-bezier(0.16, 1, 0.3, 1)`;
      g.classList.add('is-open');
      tl.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 220, fill: 'forwards' });
      await wait(slitOpenMs);

      // ── 4. Charger emerges ────────────────────────────────────────────────
      // Fit label to image width before reveal
      const labelEl = g.querySelector<HTMLElement>('.portal-label');
      if (labelEl) {
        labelEl.style.fontSize = '';
        let fs = parseFloat(getComputedStyle(labelEl).fontSize);
        while (labelEl.scrollWidth > labelEl.offsetWidth && fs > 6) {
          fs -= 0.4;
          labelEl.style.fontSize = fs + 'px';
        }
      }
      g.classList.add('is-active');
      await wait(chargerDwell);

      // ── 5. Close ─────────────────────────────────────────────────────────
      g.classList.remove('is-active');
      // Reset inline transition so the closing CSS rule takes over cleanly
      slitEl.style.transition = '';
      g.classList.add('is-closing');
      await wait(fadeMs);
      g.classList.remove('is-open', 'is-closing');
      tl.remove();
    }

    async function loop() {
      while (true) {
        await doGust();
        // Vary the breath between gusts — sometimes near-instant, sometimes a long pause
        await wait(rnd(120, 950));
      }
    }

    setTimeout(loop, 800);
  })();
</script>
