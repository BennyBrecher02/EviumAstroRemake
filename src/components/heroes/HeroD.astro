---
// Hero D: "Branded Charge" — battery bar motif echoed in hero, very on-brand, kinetic feel
---
<section class="relative min-h-screen flex items-center overflow-hidden bg-[#0d1a22]">

  <!-- Large faint battery outline in background -->
  <div class="absolute inset-0 flex items-center justify-end pr-16 pointer-events-none overflow-hidden">
    <div class="opacity-[0.03] border-4 border-white rounded-lg w-[700px] h-[380px] relative flex-shrink-0">
      <div class="absolute -right-6 top-1/2 -translate-y-1/2 w-5 h-24 border-4 border-white rounded-r-md bg-transparent"></div>
    </div>
  </div>

  <!-- Green sweep -->
  <div class="absolute top-0 left-0 w-1 h-full bg-[#2DC856]"></div>
  <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(45,200,86,0.06)_0%,transparent_40%)] pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-[900px] mx-auto w-full px-12 py-24 grid grid-cols-[1fr_auto] gap-12 items-center">
    <div>
      <!-- Battery charge bar label -->
      <div class="flex items-center gap-2 mb-8">
        <div class="flex gap-[3px]">
          {[1,2,3,4].map(i => (
            <div class={`h-4 w-6 ${i <= 3 ? 'bg-[#2DC856]' : 'bg-white/15'}`}></div>
          ))}
          <div class="w-2 h-2 bg-[#2DC856]/60 self-center ml-1 rounded-sm"></div>
        </div>
        <span class="text-[#2DC856] text-xs tracking-[0.2em] uppercase font-bold ml-2">75% Charged — Join the Network</span>
      </div>

      <h1 class="text-white font-black leading-[1.05] mb-6" style="font-size: clamp(2.6rem, 5vw, 4.8rem);">
        Power Up<br/>
        <span class="text-[#2DC856]">Your Property.</span><br/>
        We Handle the Rest.
      </h1>
      <p class="text-white/50 text-lg max-w-md leading-relaxed mb-10">
        Turnkey EV charging with zero upfront cost. Evium designs, installs, and manages everything — from permits to payout.
      </p>

      <div class="flex gap-4 flex-wrap">
        <a href="/contact/quote"
          class="bg-[#2DC856] text-[#0d1a22] font-black text-sm tracking-widest uppercase px-8 py-4 hover:bg-white transition-colors">
          Get Started Free
        </a>
        <a href="/solutions"
          class="text-[#2DC856] font-bold text-sm tracking-widest uppercase px-8 py-4 border border-[#2DC856]/40 hover:border-[#2DC856] transition-colors">
          View Solutions →
        </a>
      </div>

      <!-- Segment-style stat strip (echoes navbar) -->
      <div class="flex mt-12 border border-white/10 divide-x divide-white/10">
        {[['500+','Deployed'],['$0','To Start'],['NEVI','Ready'],['24/7','Support']].map(([n,l]) => (
          <div class="flex-1 py-4 px-3 text-center group hover:bg-[#2DC856]/10 transition-colors">
            <div class="text-[#2DC856] font-black text-2xl leading-none">{n}</div>
            <div class="text-white/35 text-[9px] tracking-widest uppercase mt-1">{l}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: stacked charger images -->
    <div class="relative hidden lg:flex items-end h-[520px] w-[220px]">
      <img src="/images/chargers/tellus/tellus-dc-fast-180kw.png" alt="" class="absolute bottom-0 right-0 h-[420px] object-contain drop-shadow-[0_0_40px_rgba(45,200,86,0.3)]" />
      <img src="/images/chargers/maxicharger/maxicharger-dc-fast-60-240kw.png" alt="" class="absolute bottom-0 right-32 h-[320px] object-contain opacity-30 drop-shadow-[0_0_20px_rgba(45,200,86,0.15)]" />
    </div>
  </div>
</section>
