---
// Hero E: "Product Lineup" — chargers shown at crisp native-ish size in a spotlight strip.
// Source images are 250×350px. On 2x retina: display at max 160px CSS = 320 physical px = crisp.
const slides = [
  { img: '/images/chargers/evocharge/evium-evocharge-l2-wallmount.png',       label: 'EvoCharge Level 2',        tag: 'L2' },
  { img: '/images/chargers/tellus/tellus-dc-fast-180kw.png',                  label: 'Tellus DC Fast 180kW',     tag: 'DC' },
  { img: '/images/chargers/maxicharger/maxicharger-dc-fast-60-240kw.png',     label: 'MaxiCharger DC 60–240kW',  tag: 'DC' },
  { img: '/images/chargers/tellus/tellus-dc-fast-300kw.png',                  label: 'Tellus DC Fast 300kW',     tag: 'DC' },
  { img: '/images/chargers/tellus/evium-dc-fast-outdoor-kiosk-combo.png',     label: 'DC Fast Outdoor Station',  tag: 'DC' },
  { img: '/images/chargers/siemens/siemens-versicharge-ac-variants.png',      label: 'Siemens VersiCharge AC',   tag: 'L2' },
  { img: '/images/chargers/siemens/siemens-versicharge-l2-wallmount.png',     label: 'Siemens eMobility L2',     tag: 'L2' },
];
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden" style="background-color: #0d1a22;" id="hero-e">

  <!-- Left green edge accent -->
  <div class="absolute top-0 left-0 w-[2px] h-full" style="background: #2DC856; opacity: 0.8;"></div>
  <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to right, rgba(45,200,86,0.06) 0%, transparent 30%);"></div>

  <div class="relative z-10 w-full max-w-[1100px] mx-auto px-10 md:px-16 py-20 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- ── Copy ──────────────────────────────────── -->
    <div>
      <p class="text-xs font-bold tracking-[0.25em] uppercase mb-6" style="color: #2DC856;">
        The Complete EV Charging Lineup
      </p>
      <h1 class="text-white font-black leading-[1.02] mb-6" style="font-size: clamp(2.4rem, 4.5vw, 4.6rem);">
        Your Property.<br/>
        <span style="color: #2DC856;">Fully Charged.</span><br/>
        <span style="color: rgba(255,255,255,0.7);">Zero Cost.</span>
      </h1>
      <p class="text-lg max-w-md leading-relaxed mb-10" style="color: rgba(255,255,255,0.5);">
        From wall-mounted Level 2 to 240kW DC fast chargers — we source, install, and manage the right hardware for every property type.
      </p>
      <div class="flex flex-wrap gap-4 mb-12">
        <a href="/contact/quote" class="font-black text-sm tracking-widest uppercase px-9 py-4 transition-colors" style="background:#2DC856; color:#0d1a22;">
          Get a Free Quote
        </a>
        <a href="/products" class="font-semibold text-sm tracking-widest uppercase px-9 py-4 border transition-colors" style="color:rgba(255,255,255,0.6); border-color:rgba(255,255,255,0.2);">
          See All Products
        </a>
      </div>
      <div class="flex flex-wrap gap-8 pt-6 border-t" style="border-color:rgba(255,255,255,0.08);">
        {[['500+','Chargers'],['$0','Upfront'],['NEVI','Ready'],['24/7','Support']].map(([n,l]) => (
          <div>
            <div class="font-black text-2xl leading-none" style="color:#2DC856;">{n}</div>
            <div class="text-[10px] tracking-widest uppercase mt-1" style="color:rgba(255,255,255,0.3);">{l}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Charger showcase strip ─────────────────── -->
    <div class="flex flex-col items-center gap-8">

      <!-- Spotlight: featured charger centered, neighbors flanking -->
      <div class="relative flex items-end justify-center gap-4 w-full" style="height: 280px;" id="lineup-stage">
        {slides.map((s, i) => (
          <div
            class="lineup-item absolute flex flex-col items-center gap-2 transition-all duration-500"
            data-index={i}
            style={
              i === 0
                ? 'transform: translateX(0) scale(1); opacity: 1; z-index: 10; bottom: 0;'
                : i === 1
                  ? 'transform: translateX(180px) scale(0.75); opacity: 0.35; z-index: 5; bottom: 0;'
                  : i === slides.length - 1
                    ? 'transform: translateX(-180px) scale(0.75); opacity: 0.35; z-index: 5; bottom: 0;'
                    : 'transform: translateX(0) scale(0.5); opacity: 0; z-index: 1; bottom: 0;'
            }
          >
            <!-- Glow under featured -->
            {i === 0 && <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-24 h-8 pointer-events-none" style="background: radial-gradient(ellipse 100% 100% at 50% 100%, rgba(45,200,86,0.35), transparent); filter: blur(8px);"></div>}
            <img
              src={s.img}
              alt={s.label}
              width="250"
              height="350"
              class="select-none pointer-events-none"
              style="width: 160px; height: auto; image-rendering: auto; filter: drop-shadow(0 8px 24px rgba(0,0,0,0.6));"
            />
          </div>
        ))}
      </div>

      <!-- Active label -->
      <div class="text-center">
        <div class="flex items-center justify-center gap-2 mb-1">
          <span id="lineup-tag" class="text-[9px] font-black tracking-widest uppercase px-2 py-[3px]" style="background:rgba(45,200,86,0.15); color:#2DC856; border:1px solid rgba(45,200,86,0.3);">L2</span>
          <span id="lineup-label" class="text-xs tracking-wider uppercase" style="color:rgba(255,255,255,0.45);">{slides[0].label}</span>
        </div>
        <!-- Dot controls -->
        <div class="flex items-center justify-center gap-[6px] mt-3" id="lineup-dots">
          {slides.map((_, i) => (
            <button
              data-dot={i}
              class="lineup-dot rounded-full transition-all duration-300 cursor-pointer"
              style={i === 0
                ? 'width: 24px; height: 3px; background: #2DC856;'
                : 'width: 8px; height: 3px; background: rgba(255,255,255,0.2);'}
            />
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  (() => {
    const SLIDES = (window as any).__eviumSlides = [
      { label: 'Level 2 Wall Unit',    tag: 'L2' },
      { label: 'DC Fast Charger',      tag: 'DC Fast' },
      { label: 'Maxi DC Fast 60–240kW',tag: 'DC Fast' },
      { label: 'Commercial Level 2',   tag: 'L2' },
      { label: 'Dual-Port Station',    tag: 'L2' },
      { label: 'VersiCharge AC',       tag: 'L2' },
      { label: 'eMobility Station',    tag: 'L2' },
    ];
    const n       = SLIDES.length;
    const items   = document.querySelectorAll<HTMLElement>('#hero-e .lineup-item');
    const dots    = document.querySelectorAll<HTMLElement>('#lineup-dots .lineup-dot');
    const label   = document.getElementById('lineup-label')!;
    const tag     = document.getElementById('lineup-tag')!;
    let current   = 0;
    let timer: ReturnType<typeof setInterval>;

    // positions: center=0, right=1, far-right=2… left=-1, far-left=-2…
    function styleForPos(pos: number): string {
      if (pos === 0)  return 'transform:translateX(0) scale(1);    opacity:1;    z-index:10; bottom:0;';
      if (pos === 1)  return 'transform:translateX(180px) scale(0.75); opacity:0.35; z-index:5;  bottom:0;';
      if (pos === -1) return 'transform:translateX(-180px) scale(0.75); opacity:0.35; z-index:5;  bottom:0;';
      return              'transform:translateX(0) scale(0.5);   opacity:0;    z-index:1;  bottom:0;';
    }

    function update() {
      items.forEach((el, i) => {
        // position relative to current, wrapped
        let pos = ((i - current) % n + n) % n;
        if (pos > n / 2) pos -= n; // -half..+half
        el.style.cssText = styleForPos(pos);
      });
      dots.forEach((d, i) => {
        if (i === current) { d.style.width='24px'; d.style.background='#2DC856'; }
        else               { d.style.width='8px';  d.style.background='rgba(255,255,255,0.2)'; }
      });
      label.textContent = SLIDES[current].label;
      tag.textContent   = SLIDES[current].tag;
    }

    function goTo(i: number) { current = (i + n) % n; update(); }

    function startTimer() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 3800);
    }

    update();
    startTimer();

    dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); startTimer(); }));
  })();
</script>
