---
/**
 * Products page hero — professional, brand-themed.
 * Uses brand green #39A733 for accents and primary CTA.
 */
---

<section class="products-hero">
  <!-- Background accents -->
  <div class="bg-glow bg-glow-1" aria-hidden="true"></div>
  <div class="bg-glow bg-glow-2" aria-hidden="true"></div>

  <!-- Geometric accent lines -->
  <svg class="bg-geo" viewBox="0 0 1440 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <linearGradient id="hpLine" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#39A733" stop-opacity="0" />
        <stop offset="50%" stop-color="#39A733" stop-opacity="0.35" />
        <stop offset="100%" stop-color="#39A733" stop-opacity="0" />
      </linearGradient>
    </defs>
    <line x1="0" y1="120" x2="1440" y2="60" stroke="url(#hpLine)" stroke-width="0.8" />
    <line x1="0" y1="480" x2="1440" y2="380" stroke="url(#hpLine)" stroke-width="0.8" />
    <line x1="0" y1="640" x2="1440" y2="560" stroke="url(#hpLine)" stroke-width="0.6" />
    <!-- Accent hexagons -->
    <polygon points="1320,120 1348,104 1376,120 1376,152 1348,168 1320,152" fill="none" stroke="rgba(57,167,51,0.22)" stroke-width="1.2" />
    <polygon points="84,540 100,530 116,540 116,558 100,568 84,558" fill="none" stroke="rgba(57,167,51,0.18)" stroke-width="1" />
  </svg>

  <div class="products-hero-inner">
    <!-- Left: copy + CTAs -->
    <div class="products-hero-copy">
      <div class="eyebrow">
        <span class="eyebrow-bar"></span>
        <span class="eyebrow-text">Evium Product Suite</span>
      </div>

      <h1 class="headline">
        Built to power <span class="headline-em">every property.</span>
      </h1>

      <p class="subtitle">
        From 7.4 kW wall chargers to 300 kW DC fast stations, Evium's hardware lineup spans every need — multifamily, fleet, retail, highway. All supported by our turnkey deployment, monitoring, and revenue-share programs.
      </p>

      <div class="cta-row">
        <button class="btn-primary" data-scroll-to=".tab-bar" type="button">
          Browse Chargers
          <svg class="btn-arrow" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>
        <a href="/contact/quote" class="btn-secondary">Talk to an Expert</a>
      </div>

      <!-- Stat pills -->
      <div class="stat-pills">
        <div class="stat-pill">
          <span class="stat-val">15</span>
          <span class="stat-lbl">Chargers</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-pill">
          <span class="stat-val">L2 &amp; L3</span>
          <span class="stat-lbl">AC + DC Fast</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-pill">
          <span class="stat-val">7.4–300</span>
          <span class="stat-lbl">kW Output</span>
        </div>
      </div>
    </div>

    <!-- Right: featured charger card -->
    <div class="products-hero-visual">
      <div class="visual-card">
        <div class="visual-tag">
          <span class="visual-tag-dot"></span>
          Flagship · DC Fast
        </div>

        <div class="visual-image-wrap">
          <div class="visual-glow"></div>
          <img
            src="/images/chargers/maxicharger/maxicharger-dc-fast-60-240kw.png"
            alt="MaxiCharger DC Fast 60–240kW"
            class="visual-image"
            loading="eager"
          />
        </div>

        <div class="visual-spec-row">
          <div class="visual-spec">
            <span class="visual-spec-lbl">Output</span>
            <span class="visual-spec-val">60–240 kW</span>
          </div>
          <div class="visual-spec">
            <span class="visual-spec-lbl">Connectors</span>
            <span class="visual-spec-val">CCS1 · CHAdeMO</span>
          </div>
          <div class="visual-spec">
            <span class="visual-spec-lbl">Display</span>
            <span class="visual-spec-val">27" Touch</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .products-hero {
    position: relative;
    min-height: 82vh;
    overflow: hidden;
    background:
      radial-gradient(ellipse 100% 80% at 20% 30%, #1a2f3a 0%, #0d1820 60%, #081420 100%);
    padding: 8rem 1.5rem 4rem;
    display: flex;
    align-items: center;
  }

  /* Ambient glows */
  .bg-glow {
    position: absolute;
    pointer-events: none;
    border-radius: 50%;
    filter: blur(90px);
  }
  .bg-glow-1 {
    top: -10%;
    left: -5%;
    width: 45%;
    height: 65%;
    background: radial-gradient(ellipse at center, rgba(57,167,51,0.12) 0%, transparent 65%);
  }
  .bg-glow-2 {
    bottom: -15%;
    right: -8%;
    width: 50%;
    height: 70%;
    background: radial-gradient(ellipse at center, rgba(57,167,51,0.08) 0%, transparent 70%);
  }

  .bg-geo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .products-hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* ── Copy column ─────────────────────────────────────── */
  .eyebrow {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
  }
  .eyebrow-bar {
    width: 2.5rem;
    height: 1px;
    background: #39A733;
    opacity: 0.9;
  }
  .eyebrow-text {
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #7ad273;
  }

  .headline {
    font-family: 'Maven Pro', sans-serif;
    font-size: clamp(2.6rem, 5.5vw, 4.4rem);
    font-weight: 900;
    line-height: 1.02;
    letter-spacing: -0.035em;
    color: white;
    margin: 0;
  }
  .headline-em {
    color: #39A733;
    display: inline-block;
  }

  .subtitle {
    margin-top: 1.5rem;
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.62);
    max-width: 34rem;
  }

  .cta-row {
    margin-top: 2.25rem;
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.7rem;
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
  }

  .btn-primary {
    background: #39A733;
    color: white;
    box-shadow: 0 10px 28px rgba(57, 167, 51, 0.28);
  }
  .btn-primary:hover {
    background: #2d8a28;
    transform: translateY(-1px);
    box-shadow: 0 14px 34px rgba(57, 167, 51, 0.38);
  }

  .btn-arrow {
    width: 1.1rem;
    height: 1.1rem;
    transition: transform 0.2s ease;
  }
  .btn-primary:hover .btn-arrow {
    transform: translateX(3px);
  }

  .btn-secondary {
    background: transparent;
    color: rgba(255, 255, 255, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.18);
  }
  .btn-secondary:hover {
    border-color: #39A733;
    color: #39A733;
  }

  /* ── Stat pills ──────────────────────────────────────── */
  .stat-pills {
    margin-top: 3rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .stat-pill {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-val {
    font-family: 'Maven Pro', sans-serif;
    font-size: 1.55rem;
    font-weight: 800;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .stat-lbl {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }
  .stat-divider {
    width: 1px;
    height: 2.2rem;
    background: rgba(255, 255, 255, 0.1);
  }

  /* ── Visual column ───────────────────────────────────── */
  .products-hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .visual-card {
    position: relative;
    background: linear-gradient(145deg, rgba(26, 47, 58, 0.6) 0%, rgba(13, 24, 32, 0.7) 100%);
    border: 1px solid rgba(57, 167, 51, 0.18);
    border-radius: 1.5rem;
    padding: 1.75rem;
    width: 100%;
    max-width: 480px;
    backdrop-filter: blur(12px);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.03) inset;
  }

  .visual-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.85rem;
    background: rgba(57, 167, 51, 0.12);
    border: 1px solid rgba(57, 167, 51, 0.28);
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #7ad273;
  }
  .visual-tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #39A733;
    box-shadow: 0 0 8px rgba(57, 167, 51, 0.8);
  }

  .visual-image-wrap {
    position: relative;
    margin: 1.25rem 0;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1.2 / 1;
  }
  .visual-glow {
    position: absolute;
    bottom: 8%;
    left: 50%;
    transform: translateX(-50%);
    width: 72%;
    height: 18%;
    background: radial-gradient(ellipse at center, rgba(57, 167, 51, 0.45) 0%, transparent 70%);
    filter: blur(24px);
  }
  .visual-image {
    position: relative;
    z-index: 1;
    max-height: 100%;
    max-width: 100%;
    object-fit: contain;
    filter: drop-shadow(0 12px 28px rgba(0, 0, 0, 0.5));
  }

  .visual-spec-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .visual-spec {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .visual-spec-lbl {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
  }
  .visual-spec-val {
    font-size: 0.8rem;
    font-weight: 700;
    color: white;
    line-height: 1.3;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 900px) {
    .products-hero {
      padding: 7rem 1.25rem 3.5rem;
      min-height: auto;
    }
    .products-hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .stat-pills {
      margin-top: 2rem;
    }
    .visual-card {
      max-width: 420px;
      margin: 0 auto;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const scrollBtn = document.querySelector<HTMLButtonElement>('[data-scroll-to]');
    if (!scrollBtn) return;
    scrollBtn.addEventListener('click', () => {
      const target = document.querySelector(scrollBtn.getAttribute('data-scroll-to')!);
      if (target) (target as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });
</script>
