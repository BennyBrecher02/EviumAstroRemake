---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Footer — Testing — Evium Charging">
  <main class="footer-root" aria-label="Footer">
    <video
      class="footer-video"
      src="/images/tesla-hero-vids/vibey-abstract-header.mp4"
      autoplay
      muted
      loop
      playsinline
    ></video>
  </main>
</Layout>

<style>
  .footer-root {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    background: #000;
    overflow: hidden;
    z-index: 0;
  }
  .footer-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    user-select: none;
    pointer-events: none;
  }
</style>
