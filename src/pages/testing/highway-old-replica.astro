---
/**
 * /testing/highway-old-replica
 *
 * Pixel-faithful recreation of the OLD eviumcharging.com
 * Highway Fast Charging service page (the pre-redesign
 * version) as a sandbox reference surface. Sister of
 * /testing/fleets-old-replica.
 *
 * Layout sections (top → bottom):
 *   1. Dark header band — breadcrumb + page title + lede,
 *      with a diagonal brand-green accent on the right edge
 *   2. Wide rounded hero photo (highway corridor)
 *   3. Four light-sage benefit cards
 *   4. Centered green italic positioning headline + paragraph
 *   5. Two-column band — three sage feature cards + CTA on
 *      the left, vertical highway-charger photo on the right
 *   6. (CTA paragraph + "Learn More" green button live inside
 *      the left column of section 5 in the original layout.)
 */
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Highway Fast Charging — Old Site Replica · Evium Charging"
  description="Replica of the original Evium Charging Highway Fast Charging service page, kept as a reference surface for the redesign."
>
  <main class="ohr">

    <!-- ─── 1. Dark header band ────────────────────────────── -->
    <section class="ohr-header" aria-labelledby="ohr-header-title">
      <div class="ohr-header-inner">
        <p class="ohr-breadcrumb">
          <a href="/">Home</a>
          <span class="ohr-breadcrumb-sep" aria-hidden="true">»</span>
          <span aria-current="page">Highway Fast Charging: Solutions for Long-Distance Travel</span>
        </p>
        <h1 id="ohr-header-title" class="ohr-header-title">
          Highway Fast Charging: Solutions for Long-Distance Travel
        </h1>
        <p class="ohr-header-lede">
          As the number of electric vehicles on the road continues to
          grow, the need for fast-charging stations along highways has
          become essential. We offer Level 3 (DC Fast Charging)
          solutions strategically positioned to serve long-distance
          travelers, ensuring convenience and efficiency.
        </p>
      </div>

      <!-- Decorative angled green accent on the right edge — same
           treatment as fleets-old-replica's header. -->
      <div class="ohr-header-accent" aria-hidden="true"></div>
    </section>

    <!-- ─── 2. Wide rounded hero image ─────────────────────── -->
    <section class="ohr-hero-photo" aria-hidden="true">
      <div class="ohr-hero-photo-frame">
        <img
          src="/images/heroes/highway-hero.jpg"
          alt=""
          loading="lazy"
        />
      </div>
    </section>

    <!-- ─── 3. Four benefit cards ──────────────────────────── -->
    <section class="ohr-benefits" aria-label="Highway charging benefits">
      <div class="ohr-benefits-inner">
        <article class="ohr-card">
          <h3 class="ohr-card-title">Commercial Output</h3>
          <p class="ohr-card-body">
            Our Level 3 stations allow drivers to quickly recharge
            their batteries, adding hundreds of miles of range in
            just 20 to 30 minutes.
          </p>
        </article>

        <article class="ohr-card">
          <h3 class="ohr-card-title">Strategic Placement</h3>
          <p class="ohr-card-body">
            Stations are installed at high-traffic points such as
            rest stops, gas stations, and food courts, providing
            easy and practical access for drivers.
          </p>
        </article>

        <article class="ohr-card">
          <h3 class="ohr-card-title">High Availability</h3>
          <p class="ohr-card-body">
            Robust infrastructure and continuous maintenance ensure
            our stations are always ready to meet demand.
          </p>
        </article>

        <article class="ohr-card">
          <h3 class="ohr-card-title">High Turnover</h3>
          <p class="ohr-card-body">
            Designed to serve large volumes of vehicles with 24/7
            demand, especially during holidays and peak travel
            seasons.
          </p>
        </article>
      </div>
    </section>

    <!-- ─── 4. Centered italic positioning heading ─────────── -->
    <section class="ohr-pitch" aria-label="Partner with Evium">
      <h2 class="ohr-pitch-title">
        Partner With Evium Charging To Elevate Your Property
      </h2>
      <p class="ohr-pitch-body">
        Transform your property into a premium charging destination
        for the rapidly growing number of EV travelers. By partnering
        with Evium Charging, you'll join the next generation of
        highway service providers meeting the critical need for fast,
        reliable charging along major travel corridors.
      </p>
    </section>

    <!-- ─── 5. Two-column: pillar cards + CTA (left) +
             vertical charger photo (right) ────────────────── -->
    <section class="ohr-pillars" aria-label="How we partner with site hosts">
      <div class="ohr-pillars-inner">

        <div class="ohr-pillars-left">
          <article class="ohr-card ohr-card--pillar">
            <h3 class="ohr-card-title ohr-card-title--upper">Traffic First Approach</h3>
            <p class="ohr-card-body">
              Charge times designed &amp; optimized to increase (or
              decrease) average visit duration.
            </p>
          </article>

          <article class="ohr-card ohr-card--pillar">
            <h3 class="ohr-card-title ohr-card-title--upper">Sustainability</h3>
            <p class="ohr-card-body">
              Support a cleaner future by offering accessible,
              eco-friendly refueling alternatives.
            </p>
          </article>

          <article class="ohr-card ohr-card--pillar">
            <h3 class="ohr-card-title ohr-card-title--upper">Trusted Partnership</h3>
            <p class="ohr-card-body">
              We work alongside state D.O.T &amp; government to
              deliver a superior solution.
            </p>
          </article>

          <!-- CTA paragraph + button — sits at the bottom of the
               left column in the original layout, aligned to the
               vertical photo on the right. -->
          <div class="ohr-pillars-cta">
            <p class="ohr-pillars-cta-body">
              Want to know how to implement fast-charging stations in
              your area? Contact us today and learn how we can help
              expand the electric mobility infrastructure.
            </p>
            <a class="ohr-cta-btn" href="/contact">
              <span>Learn More</span>
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path
                  d="M4 10h12M11 5l5 5-5 5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </a>
          </div>
        </div>

        <div class="ohr-pillars-photo">
          <img
            src="/images/heroes/highway-charging-station.png"
            alt="Evium-equipped highway charging station alongside a corridor location"
            loading="lazy"
          />
        </div>

      </div>
    </section>

  </main>
</Layout>

<style>
  /* ─── Page tokens ─────────────────────────────────────────
     Same palette as fleets-old-replica so the two replica
     pages feel like part of one set. */
  .ohr {
    --ohr-green:        #2DC856;
    --ohr-green-deep:   #24a347;
    --ohr-sage:         #DDE9D6;
    --ohr-sage-2:       #E6EFDD;
    --ohr-sage-border:  #C7D8BD;
    --ohr-ink:          #1A2F3A;
    --ohr-ink-soft:     #3A4A55;
    --ohr-paper:        #FFFFFF;

    --ohr-radius-card:  18px;
    --ohr-radius-photo: 28px;

    --ohr-pad-x:        clamp(20px, 6vw, 96px);
    --ohr-section-gap:  clamp(48px, 7vw, 96px);

    background: var(--ohr-paper);
    color: var(--ohr-ink);
    font-family: 'Maven Pro', system-ui, sans-serif;
  }

  /* ─── 1. Dark header band ─────────────────────────────── */
  .ohr-header {
    position: relative;
    background: var(--ohr-ink);
    color: #fff;
    padding: clamp(32px, 6vw, 72px) var(--ohr-pad-x) clamp(40px, 7vw, 88px);
    overflow: hidden;
  }
  .ohr-header-inner {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
  }
  .ohr-breadcrumb {
    margin: 0 0 clamp(12px, 1.6vw, 18px);
    font-size: 13px;
    letter-spacing: 0.02em;
    color: #cfd5da;
    /* Long page title in breadcrumb — keep on one line where
       possible, otherwise wrap cleanly. */
    line-height: 1.4;
  }
  .ohr-breadcrumb a {
    color: #cfd5da;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .ohr-breadcrumb a:hover {
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.5);
  }
  .ohr-breadcrumb-sep {
    margin: 0 0.45em;
    opacity: 0.55;
  }
  .ohr-header-title {
    margin: 0 0 clamp(16px, 2.4vw, 26px);
    /* Smaller than the fleets header — the title is much
       longer here ("Highway Fast Charging: Solutions for
       Long-Distance Travel") so it gets a tighter scale to
       fit on two lines on desktop. */
    font-size: clamp(30px, 4.6vw, 48px);
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: -0.015em;
    max-width: 920px;
  }
  .ohr-header-lede {
    margin: 0;
    max-width: 760px;
    font-size: clamp(14px, 1.2vw, 16px);
    line-height: 1.55;
    color: #d8dde2;
  }

  /* Diagonal green accent slash on the right edge — same as
     fleets-old-replica. */
  .ohr-header-accent {
    position: absolute;
    top: -40px;
    right: -120px;
    width: 320px;
    height: calc(100% + 80px);
    background: var(--ohr-green);
    transform: skewX(-16deg);
    opacity: 0.92;
    z-index: 1;
  }
  .ohr-header-accent::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.08) 0%,
      rgba(255, 255, 255, 0)   55%
    );
    pointer-events: none;
  }

  /* ─── 2. Wide rounded hero photo ──────────────────────── */
  .ohr-hero-photo {
    padding: clamp(32px, 5vw, 64px) var(--ohr-pad-x) 0;
  }
  .ohr-hero-photo-frame {
    max-width: 1200px;
    margin: 0 auto;
    border-radius: var(--ohr-radius-photo);
    overflow: hidden;
    aspect-ratio: 16 / 6;
    background: #f0f2f4;
    box-shadow:
      0 24px 48px -24px rgba(26, 47, 58, 0.28),
      0 6px 16px -8px rgba(26, 47, 58, 0.14);
  }
  .ohr-hero-photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ─── 3. Benefit cards (4-up) ─────────────────────────── */
  .ohr-benefits {
    padding: var(--ohr-section-gap) var(--ohr-pad-x) 0;
  }
  .ohr-benefits-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(14px, 1.8vw, 24px);
  }
  .ohr-card {
    background: var(--ohr-sage);
    border: 1px solid var(--ohr-sage-border);
    border-radius: var(--ohr-radius-card);
    padding: clamp(20px, 2.2vw, 28px);
    color: var(--ohr-ink);
  }
  .ohr-card-title {
    margin: 0 0 clamp(8px, 1vw, 14px);
    font-size: clamp(17px, 1.5vw, 20px);
    font-weight: 700;
    letter-spacing: -0.005em;
  }
  .ohr-card-title--upper {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: clamp(13px, 1.05vw, 15px);
  }
  .ohr-card-body {
    margin: 0;
    font-size: clamp(13.5px, 1vw, 14.5px);
    line-height: 1.55;
    color: var(--ohr-ink-soft);
  }

  /* ─── 4. Centered italic positioning heading ─────────── */
  .ohr-pitch {
    padding: var(--ohr-section-gap) var(--ohr-pad-x);
    max-width: 1080px;
    margin: 0 auto;
    text-align: center;
  }
  .ohr-pitch-title {
    margin: 0 0 clamp(16px, 2vw, 24px);
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.3;
    font-weight: 700;
    color: var(--ohr-green-deep);
    letter-spacing: -0.005em;
  }
  .ohr-pitch-body {
    margin: 0 auto;
    max-width: 880px;
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.6;
    color: var(--ohr-ink-soft);
  }

  /* ─── 5. Two-column pillars + vertical photo + CTA ────── */
  .ohr-pillars {
    padding: 0 var(--ohr-pad-x) var(--ohr-section-gap);
  }
  .ohr-pillars-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(24px, 3vw, 56px);
    align-items: stretch;
  }
  .ohr-pillars-left {
    display: grid;
    grid-template-rows: auto auto auto auto;
    gap: clamp(14px, 1.6vw, 22px);
  }
  .ohr-card--pillar {
    background: var(--ohr-sage-2);
  }
  .ohr-pillars-cta {
    margin-top: clamp(8px, 1.2vw, 16px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: clamp(16px, 2vw, 24px);
  }
  .ohr-pillars-cta-body {
    margin: 0;
    flex: 1 1 320px;
    font-size: clamp(13px, 1vw, 14.5px);
    line-height: 1.55;
    color: var(--ohr-ink-soft);
  }
  .ohr-pillars-photo {
    border-radius: var(--ohr-radius-photo);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #ecedef;
    box-shadow:
      0 24px 48px -24px rgba(26, 47, 58, 0.28),
      0 6px 16px -8px rgba(26, 47, 58, 0.14);
  }
  .ohr-pillars-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* ─── CTA pill button (shared with footer area) ───────── */
  .ohr-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 24px;
    background: var(--ohr-green);
    color: #fff;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    box-shadow: 0 8px 22px -8px rgba(45, 200, 86, 0.55);
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    flex: 0 0 auto;
  }
  .ohr-cta-btn:hover {
    background: var(--ohr-green-deep);
    transform: translateY(-1px);
    box-shadow: 0 12px 28px -10px rgba(45, 200, 86, 0.7);
  }
  .ohr-cta-btn svg {
    width: 16px;
    height: 16px;
  }

  /* ─── Responsive ─────────────────────────────────────── */
  @media (max-width: 1080px) {
    .ohr-benefits-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 880px) {
    .ohr-benefits-inner {
      grid-template-columns: 1fr;
    }
    .ohr-pillars-inner {
      grid-template-columns: 1fr;
    }
    .ohr-pillars-photo {
      aspect-ratio: 4 / 3;
      max-height: 520px;
    }
    .ohr-hero-photo-frame {
      aspect-ratio: 16 / 9;
    }
    .ohr-header-accent {
      width: 220px;
      right: -90px;
    }
    .ohr-pillars-cta {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }
  }
</style>
