    color: #2DC856;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .c-route:hover .c-route-icon {
    background: #2DC856;
    color: #0d1a22;
    transform: scale(1.05);
  }
  .c-route-icon svg { width: 22px; height: 22px; display: block; }
  .c-route-title {
    margin: 6px 0 0;
    font-size: 1.2rem;
    font-weight: 900;
    letter-spacing: -0.015em;
