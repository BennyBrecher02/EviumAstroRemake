  .c-social:hover {
    background: #2DC856;
    color: #ffffff;
    transform: translateY(-1px);
  }
  .c-social svg { width: 18px; height: 18px; display: block; }

  /* ─── Testimonial carousel ──────────────────────────── */
  .c-testimonial {
    position: relative;
    background: linear-gradient(160deg, rgba(45, 200, 86, 0.14) 0%, rgba(45, 200, 86, 0.06) 100%);
    border: 1px solid rgba(45, 200, 86, 0.32);
    color: #0d1a22;
    overflow: hidden;
  }
  .c-testimonial-quote {
    width: 32px;
    height: 32px;
    color: #2DC856;
    margin-bottom: 10px;
    opacity: 0.85;
  }
  /* Closing quote — same glyph, rotated 180°, pushed to the right
     edge under the testimonial body so the card reads open-then-
     close as a pair. Slightly softer opacity so it feels like a
     close punctuation rather than a second headline. */
  .c-testimonial-quote--close {
    display: block;
    margin: 0 0 14px auto;
    transform: rotate(180deg);
    opacity: 0.55;
  }
  /* Track is a 1×1 CSS grid — every slide is placed at row 1 / col 1,
     so they stack in the same cell. The cell sizes to the tallest
     slide automatically (grid intrinsic sizing). Active slide is
     visible, others fade out in place. No JS height measurement
     needed — no bounce when a shorter quote cycles in. */
  .c-testimonial-track {
    display: grid;
    grid-template-columns: 1fr;
    margin-bottom: 18px;
  }
  .c-testimonial-slide {
    grid-row: 1;
    grid-column: 1;
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition: opacity 380ms ease, transform 380ms cubic-bezier(.22,1,.36,1);
  }
  .c-testimonial-slide.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .c-testimonial-quote-text {
    margin: 0 0 18px;
    font-size: 1.04rem;
    line-height: 1.55;
    font-weight: 600;
    color: #0d1a22;
  }
  .c-testimonial-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 14px;
    border-top: 1px solid rgba(45, 200, 86, 0.24);
  }
  .c-testimonial-name {
    font-size: 0.92rem;
    font-weight: 800;
    color: #0d1a22;
    letter-spacing: -0.005em;
  }
  .c-testimonial-role {
    font-size: 0.78rem;
    color: rgba(13, 26, 34, 0.6);
    letter-spacing: 0.01em;
  }

  .c-testimonial-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding-top: 16px;
    border-top: 1px solid rgba(45, 200, 86, 0.18);
  }
  .c-testimonial-dots {
    display: inline-flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  .c-testimonial-dot {
    width: 7px;
    height: 7px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: rgba(13, 26, 34, 0.2);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease, width 0.25s ease;
  }
  .c-testimonial-dot:hover { background: rgba(45, 200, 86, 0.5); }
  .c-testimonial-dot.is-active {
    background: #2DC856;
    width: 18px;
    border-radius: 4px;
  }
  .c-testimonial-nav {
    display: inline-flex;
    gap: 6px;
  }
  .c-testimonial-arrow {
    width: 28px;
    height: 28px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: rgba(13, 26, 34, 0.06);
    color: rgba(13, 26, 34, 0.6);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .c-testimonial-arrow:hover {
    background: #2DC856;
    color: #ffffff;
  }
  .c-testimonial-arrow svg { width: 14px; height: 14px; display: block; }

  /* ─── Routes grid ────────────────────────────────────── */
  .c-routes {
    background: #0d1a22;
    color: #fff;
    padding: clamp(60px, 8vh, 100px) clamp(24px, 5vw, 80px);
  }
  .c-routes-inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .c-routes-h {
    margin: 0 0 clamp(28px, 3vw, 44px);
    font-family: 'Maven Pro', sans-serif;
    font-size: clamp(1.6rem, 2.4vw, 2.4rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: #fff;
  }
  .c-routes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: clamp(16px, 2vw, 24px);
  }
  .c-route {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: clamp(22px, 2.6vw, 32px);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    text-decoration: none;
    color: #fff;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .c-route:hover,
  .c-route:focus-visible {
    background: rgba(45, 200, 86, 0.08);
    border-color: rgba(45, 200, 86, 0.38);
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.24);
    outline: none;
  }
  .c-route-icon {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
