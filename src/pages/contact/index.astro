  .c-rail-email:hover { color: #2DC856; }
  .c-rail-email--soft { font-size: 0.95rem; color: rgba(13, 26, 34, 0.74); }

  /* Socials */
  .c-socials {
    display: inline-flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .c-social {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(45, 200, 86, 0.08);
    color: #2DC856;
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
