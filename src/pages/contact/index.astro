  .c-route:hover .c-route-cta { gap: 10px; }
  .c-route-cta svg { width: 14px; height: 14px; display: block; }

  /* ─── Responsive ─────────────────────────────────────── */
  @media (max-width: 860px) {
    .c-body-inner {
      grid-template-columns: 1fr;
    }
    .c-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Client-side form handler. No backend wired up yet (matches the
  // current state of /contact/quote where the form just swaps to a
  // success state locally). Validates required fields, adds the
  // invalid state to any that fail, and shows the success card.
  (() => {
    const form = document.getElementById('c-contact-form') as HTMLFormElement | null;
    if (!form) return;
    const successEl = form.querySelector<HTMLElement>('[data-form-success]');
    const fieldsWrap = form;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // Light validation — just required fields
      const required = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
        '[required]'
      );
      let firstInvalid: HTMLElement | null = null;
      required.forEach((el) => {
        const ok = el.value.trim().length > 0 &&
          (el.type !== 'email' || /\S+@\S+\.\S+/.test(el.value.trim()));
        if (!ok) {
          el.setAttribute('aria-invalid', 'true');
          if (!firstInvalid) firstInvalid = el;
        } else {
          el.removeAttribute('aria-invalid');
        }
      });

      if (firstInvalid) {
        (firstInvalid as HTMLElement).focus();
        return;
      }

      // Swap form UI for success message
      const cardEls = form.querySelectorAll<HTMLElement>('.c-row, .c-field:not([hidden]), .c-form-foot');
      cardEls.forEach((el) => {
        if (!el.closest('[data-form-success]')) el.style.display = 'none';
      });
      if (successEl) successEl.hidden = false;
    });

    // Clear invalid state as the user types
    fieldsWrap.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach((el) => {
      el.addEventListener('input', () => el.removeAttribute('aria-invalid'));
    });
  })();

  /* ─── Testimonial carousel ──────────────────────────────
     Auto-rotate every 6s. Pauses on pointer hover / focus-within.
     Prev/next arrows + dot buttons jump directly. Track height is
     governed by CSS grid (tallest slide sets cell height) — no JS
     measurement needed, so no bounce when a shorter quote cycles in. */
  (() => {
    const root = document.querySelector<HTMLElement>('[data-testimonials]');
    if (!root) return;
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-testimonial-slide]'));
    const dots   = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-testimonial-dot]'));
    const prev   = root.querySelector<HTMLButtonElement>('[data-testimonial-prev]');
    const next   = root.querySelector<HTMLButtonElement>('[data-testimonial-next]');
    if (!slides.length) return;

    const INTERVAL = 6000;
    let current = 0;
    let timer: number | null = null;

    function go(i: number) {
      current = ((i % slides.length) + slides.length) % slides.length;
      slides.forEach((s, idx) => {
        const active = idx === current;
        s.classList.toggle('is-active', active);
        s.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
      dots.forEach((d, idx) => {
        const active = idx === current;
        d.classList.toggle('is-active', active);
        d.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    function startAuto() {
      if (timer !== null) return;
      timer = window.setInterval(() => go(current + 1), INTERVAL);
    }
    function stopAuto() {
      if (timer !== null) { window.clearInterval(timer); timer = null; }
    }

    dots.forEach((d, i) => d.addEventListener('click', () => { go(i); stopAuto(); startAuto(); }));
    prev?.addEventListener('click', () => { go(current - 1); stopAuto(); startAuto(); });
    next?.addEventListener('click', () => { go(current + 1); stopAuto(); startAuto(); });

    // Pause on hover / focus within — user is reading, don't move it
    root.addEventListener('mouseenter', stopAuto);
    root.addEventListener('mouseleave', startAuto);
    root.addEventListener('focusin',    stopAuto);
    root.addEventListener('focusout',   startAuto);

    startAuto();
  })();
</script>
