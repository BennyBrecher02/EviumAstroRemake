---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Highway Fast Charging v2 — Evium Charging"
  description="Turn your highway corridor location into a high-utilization EV charging destination. NEVI-compliant, no-cost deployments managed end-to-end by Evium."
  headerVariant="v4"
  bodyClass="page-highway-v2"
>

  <!-- ═══════════════════════════════════════════════════
       1. HERO — full-viewport image with bottom gradient.
       Copy lives at the bottom on the calm pavement zone.
       ═══════════════════════════════════════════════════ -->
  <section class="hwv2-hero relative w-full h-screen min-h-[640px] overflow-hidden bg-evium-dark">
    <img
      src="/images/heroes/highway-hero-fuzzy.png"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center select-none pointer-events-none"
      loading="eager"
      fetchpriority="high"
      draggable="false"
    />

    <!-- Top scrim — keeps the upper-left copy column legible
         against the bright sky / canopy without washing the
         chargers in the center-right of the frame. -->
    <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(ellipse_75%_60%_at_15%_22%,rgba(10,24,34,0.78),transparent_60%)]"></div>

    <!-- Bottom gradient — fades the lower portion to dark
         so the photo transitions smoothly into the page. -->
    <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[#0a1822] via-[#0a1822]/55 to-transparent pointer-events-none"></div>

    <!-- Copy — top-left -->
    <div class="absolute inset-x-0 top-0 px-6 md:px-10 lg:px-16 pt-12 md:pt-16 lg:pt-20">
      <div class="max-w-3xl">
        <!-- Editorial brow — short hairline rule + tracked caps.
             Magazine convention that reads as confident and
             editorial without resorting to a backdrop pill. -->
        <div class="flex items-center gap-4 mb-7">
          <div class="w-10 h-px bg-evium-green flex-shrink-0"></div>
          <span class="text-evium-green text-xs font-extrabold tracking-[0.34em] uppercase [text-shadow:0_1px_2px_rgba(10,24,34,1),0_2px_14px_rgba(10,24,34,0.95),0_4px_24px_rgba(10,24,34,0.7)]">The new fuel stop</span>
        </div>
        <h1 class="font-black leading-[0.95] tracking-tight mb-9 [text-shadow:0_2px_24px_rgba(10,24,34,0.85),0_1px_4px_rgba(10,24,34,0.7)]" style="font-size: clamp(2.2rem, 5.4vw, 4.75rem);">
          <span class="text-white">Your highway exit.</span><br /><span class="text-evium-green">Our gear and grid.</span>
        </h1>
        <a
          href="/contact/quote"
          class="group inline-flex items-center gap-3 text-white font-semibold text-sm tracking-[0.12em] uppercase border-b border-evium-green pb-2 hover:text-evium-green transition-colors duration-200 [text-shadow:0_1px_8px_rgba(10,24,34,0.7)]"
        >
          See if your site qualifies
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Pavement-band action — primary CTA on the lower
         portion of the photo (the parking-lot pavement band).
         Mirrors the fleets-v2 hero pattern: skewed green
         parallelogram face + counter-skewed inner text + arrow
         that translates on hover. data-hwv2-scroll triggers
         the rAF-eased smooth scroll to #revenue-projections. -->
    <div class="hwv2-hero-actions">
      <a
        class="hwv2-cta-primary"
        href="#revenue-projections"
        data-hwv2-scroll
        aria-label="See the revenue projections"
      >
        <span class="hwv2-cta-primary-face" aria-hidden="true"></span>
        <span class="hwv2-cta-primary-inner">
          <span>See what you'd earn</span>
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path d="M8 3v10M4 9l4 4 4-4" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       2. AUDIENCE BRIDGE — sage benefit cards on white.
       Lift of /testing/highway-old-replica §3 (Highway
       charging benefits). Card visual style is verbatim
       from the replica per request — the layout enforces
       a square aspect ratio per card and adds a centered
       eyebrow above the grid that ties back to the hero's
       "The new fuel stop" framing.
       ═══════════════════════════════════════════════════ -->
  <section class="hwv2-bridge" aria-labelledby="hwv2-bridge-icp">
    <div class="hwv2-bridge-inner">

      <header class="hwv2-bridge-head">
        <p class="hwv2-bridge-eyebrow">
          <span class="hwv2-bridge-eyebrow-rule" aria-hidden="true"></span>
          <span>For Highway Hosts</span>
          <span class="hwv2-bridge-eyebrow-rule" aria-hidden="true"></span>
        </p>
        <!-- Headline — same role + sizing as fleets-v2's
             .fv2-bridge-icp. Synthesized from the replica's
             page title + Partner pitch + 3 pillars (premium
             destination, next-gen highway service, state DOTs,
             dwell-time tuning). Italic clause carries the
             rhetorical lift. -->
        <p id="hwv2-bridge-icp" class="hwv2-bridge-icp">
          Premium fast-charging destinations along major travel
          corridors —
          <em>built alongside state DOTs, tuned to dwell time.</em>
        </p>
      </header>

      <div class="hwv2-bridge-grid">

        <!-- Card 1 — Commercial Output. Lightning bolt watermark
             in the lower-right corner; speed / energy motif. -->
        <article class="hwv2-card" data-hwv2-card="output">
          <svg class="hwv2-card-mark" viewBox="0 0 64 64" aria-hidden="true">
            <path d="M37 4 L18 36 L30 36 L25 60 L48 26 L34 26 L37 4 Z" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linejoin="round" />
          </svg>
          <div class="hwv2-card-body-wrap">
            <h3 class="hwv2-card-title">Commercial Output</h3>
            <p class="hwv2-card-body">
              Our Level 3 stations allow drivers to quickly recharge
              their batteries, adding hundreds of miles of range in
              just 20 to 30 minutes.
            </p>
          </div>
        </article>

        <!-- Card 2 — Strategic Placement. Map pin watermark
             upper-right; location / placement motif. -->
        <article class="hwv2-card" data-hwv2-card="placement">
          <svg class="hwv2-card-mark" viewBox="0 0 64 64" aria-hidden="true">
            <path d="M32 4 C19 4, 9 14, 9 27 C9 44, 32 60, 32 60 C32 60, 55 44, 55 27 C55 14, 45 4, 32 4 Z" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linejoin="round" />
            <circle cx="32" cy="25" r="7" fill="none" stroke="currentColor" stroke-width="2.6" />
          </svg>
          <div class="hwv2-card-body-wrap">
            <h3 class="hwv2-card-title">Strategic Placement</h3>
            <p class="hwv2-card-body">
              Stations are installed at high-traffic points such as
              rest stops, gas stations, and food courts, providing
              easy and practical access for drivers.
            </p>
          </div>
        </article>

        <!-- Card 3 — High Availability. Shield + check watermark
             lower-right; reliability motif. -->
        <article class="hwv2-card" data-hwv2-card="availability">
          <svg class="hwv2-card-mark" viewBox="0 0 64 64" aria-hidden="true">
            <path d="M32 4 L8 12 L8 32 C8 47 32 60 32 60 C32 60 56 47 56 32 L56 12 Z" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linejoin="round" />
            <path d="M20 32 L29 41 L44 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <div class="hwv2-card-body-wrap">
            <h3 class="hwv2-card-title">High Availability</h3>
            <p class="hwv2-card-body">
              Robust infrastructure and continuous maintenance ensure
              our stations are always ready to meet demand.
            </p>
          </div>
        </article>

        <!-- Card 4 — High Turnover. Clock watermark, lower-right;
             24/7 demand / time-on-clock motif. -->
        <article class="hwv2-card" data-hwv2-card="turnover">
          <svg class="hwv2-card-mark" viewBox="0 0 64 64" aria-hidden="true">
            <circle cx="32" cy="32" r="27" fill="none" stroke="currentColor" stroke-width="2.6" />
            <path d="M32 13 L32 32 L46 40" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="32" cy="32" r="2" fill="currentColor" />
          </svg>
          <div class="hwv2-card-body-wrap">
            <h3 class="hwv2-card-title">High Turnover</h3>
            <p class="hwv2-card-body">
              Designed to serve large volumes of vehicles with 24/7
              demand, especially during holidays and peak travel
              seasons.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       3. HOW NEVI WORKS — and Why Evium Is Your CPO
       Layout lifted from fleets-v2's "Engineered for Your
       Operation" section: full-viewport split with a left
       editorial column (kicker → dual-color headline →
       pull-quote lede → numbered list → bottom GSA anchor)
       and a flush-right full-bleed photo on lg+. All v1
       content preserved verbatim — only the layout vehicle
       has changed.
       ═══════════════════════════════════════════════════ -->
  <section id="opportunity" class="bg-[#0d1f2b] min-h-screen flex items-stretch">

    <!-- Left: content column. Header → lede → credentials →
         numbered list → GSA bottom anchor. Mirrors the
         fleets section's vertical regions. -->
    <div class="flex-1 flex min-w-0">
      <div class="w-full max-w-3xl mx-auto px-6 md:px-10 lg:px-10 py-8 flex flex-col">

        <!-- ── HEADER ─────────────────────────────────── -->
        <header>
          <!-- Kicker label with fading hairline that bleeds
               toward the column edge. Same magazine-style
               header marker as fleets. -->
          <div class="flex items-center gap-4 mb-4">
            <span class="text-evium-green text-xs font-extrabold tracking-[0.22em] uppercase whitespace-nowrap">Federal Grant Program</span>
            <span class="flex-1 h-px bg-gradient-to-r from-evium-green/35 to-transparent"></span>
          </div>

          <!-- Headline (h2) — two lines, dual color. Sized so
               the longer green line "and Why Evium Is Your CPO."
               holds on a single line within the wider max-w-3xl
               column. whitespace-nowrap on each line guarantees
               no wrap regardless of viewport breakpoint. -->
          <h2 class="text-white font-black text-[1.85rem] md:text-[2.05rem] leading-[1.05] tracking-[-0.022em] mb-3">
            <span class="block whitespace-nowrap">How NEVI Works —</span>
            <span class="block whitespace-nowrap text-evium-green">and Why Evium Is Your CPO.</span>
          </h2>

          <!-- Deck — third headline line at smaller scale so the
               full triplet ("One federal program. One operator.
               Zero cost to you.") holds on a single line. Three
               phrases, alternating white / green / white so the
               middle clause (Evium's identity) reads as the
               visual hinge. -->
          <p class="font-black text-base md:text-lg leading-tight tracking-[-0.014em] whitespace-nowrap mb-6">
            <span class="text-white">One federal program.</span>
            <span class="text-evium-green">One operator.</span>
            <span class="text-white">Zero cost to you.</span>
          </p>

          <!-- Lede framed as a pull-quote (thin brand-green
               left rule). Carries the NEVI program definition
               from v1 verbatim. -->
          <div class="border-l-2 border-evium-green/55 pl-5 mb-3">
            <p class="text-white/75 text-[15px] leading-snug">
              The National Electric Vehicle Infrastructure (NEVI) Formula Program distributes $7.5 billion in federal funding to build a national charging network. States issue grants to qualified Charging Point Operators (CPOs) to deploy hardware on designated Alternative Fuel Corridors (AFCs) — with a station required at least every 50 miles along major U.S. travel routes.
            </p>
          </div>

          <!-- Credentials paragraph — Evium's CPO awards
               (NM, CEC, NJ BPU). v1 verbatim. -->
          <p class="text-white/65 text-[13px] leading-snug">
            Evium is a federally recognized CPO and has already secured NEVI site awards in New Mexico, grants from the California Energy Commission ($6MM+), and funding through the New Jersey BPU program. We've navigated every level of this bureaucracy — so you don't have to.
          </p>
        </header>

        <!-- ── EDITORIAL LIST ─────────────────────────── -->
        <!-- 5 numbered entries, each as a row with a ringed
             number badge (fleets uses checkmarks; sequential
             steps want numerals). Same hairline divider
             treatment as fleets. -->
        <ul class="my-4 space-y-0">
          <li class="grid grid-cols-[1.75rem_1fr] gap-x-4 py-3.5 border-t border-white/[0.07]">
            <span class="w-7 h-7 rounded-full border border-evium-green/40 flex items-center justify-center flex-shrink-0 mt-0.5 text-evium-green text-xs font-black">1</span>
            <div>
              <h4 class="text-white font-bold text-base mb-0.5 leading-tight">Evium assesses your corridor location</h4>
              <p class="text-white/65 text-sm leading-tight">We evaluate your site's AFC corridor status, utility access, traffic patterns, and grant eligibility in a single consult.</p>
            </div>
          </li>

          <li class="grid grid-cols-[1.75rem_1fr] gap-x-4 py-3.5 border-t border-white/[0.07]">
            <span class="w-7 h-7 rounded-full border border-evium-green/40 flex items-center justify-center flex-shrink-0 mt-0.5 text-evium-green text-xs font-black">2</span>
            <div>
              <h4 class="text-white font-bold text-base mb-0.5 leading-tight">We submit the NEVI application on your behalf</h4>
              <p class="text-white/65 text-sm leading-tight">All federal, state, and utility paperwork is handled entirely by Evium. You sign where needed — nothing more.</p>
            </div>
          </li>

          <li class="grid grid-cols-[1.75rem_1fr] gap-x-4 py-3.5 border-t border-white/[0.07]">
            <span class="w-7 h-7 rounded-full border border-evium-green/40 flex items-center justify-center flex-shrink-0 mt-0.5 text-evium-green text-xs font-black">3</span>
            <div>
              <h4 class="text-white font-bold text-base mb-0.5 leading-tight">Hardware is installed at no cost to you</h4>
              <p class="text-white/65 text-sm leading-tight">Grant funding covers the full cost of DC fast hardware, installation, and utility work. Zero capital expenditure for the site host.</p>
            </div>
          </li>

          <li class="grid grid-cols-[1.75rem_1fr] gap-x-4 py-3.5 border-t border-white/[0.07]">
            <span class="w-7 h-7 rounded-full border border-evium-green/40 flex items-center justify-center flex-shrink-0 mt-0.5 text-evium-green text-xs font-black">4</span>
            <div>
              <h4 class="text-white font-bold text-base mb-0.5 leading-tight">5-year contract + 5-year renewal option</h4>
              <p class="text-white/65 text-sm leading-tight">You secure long-term infrastructure at your site with renewal rights, ensuring competitive advantage well into the decade.</p>
            </div>
          </li>

          <li class="grid grid-cols-[1.75rem_1fr] gap-x-4 py-3.5 border-t border-white/[0.07]">
            <span class="w-7 h-7 rounded-full border border-evium-green/40 flex items-center justify-center flex-shrink-0 mt-0.5 text-evium-green text-xs font-black">5</span>
            <div>
              <h4 class="text-white font-bold text-base mb-0.5 leading-tight">You earn a percentage of every charging session</h4>
              <p class="text-white/65 text-sm leading-tight">Site hosts receive a share of charging revenue. Evium handles billing, settlements, and compliance reporting — you receive a monthly payment.</p>
            </div>
          </li>
        </ul>

        <!-- ── BOTTOM ANCHOR ──────────────────────────── -->
        <!-- GSA / NEVI-compliant credential, pinned to the
             bottom of the column via mt-auto. Replaces the
             fleets section's plain "Design. Install. Operate."
             tagline with the v1 GSA shield-badge content,
             rebuilt in the same fleets bottom-anchor pattern
             so we don't lose the GSA / qualified-hands line. -->
        <div class="mt-auto flex items-center gap-4 pt-4 border-t border-white/[0.10]">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-evium-green flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="text-white/70 text-[11px] tracking-[0.18em] uppercase font-bold leading-[1.55]">
            GSA-Approved · NEVI-Compliant CPO<br />
            Your Site Is in Qualified Hands
          </span>
          <span class="flex-1 h-px bg-gradient-to-r from-white/15 to-transparent"></span>
        </div>

      </div>
    </div>

    <!-- Right: flush-right full-bleed photo. object-cover so the
         image touches the top and bottom of the section and fills
         the entire column vertically. Wider than the fleets truck
         column (62% / 60%) so a much larger portion of the photo's
         horizontal extent shows while still preserving the
         cover-fill behavior at top and bottom. -->
    <div class="hidden lg:block flex-shrink-0 w-[63%] xl:w-[61%]">
      <img
        src="/images/heroes/highway-charging-station.png"
        alt="Evium-equipped highway charging station alongside a corridor location"
        class="block w-full h-full object-cover object-center"
        loading="lazy"
      />
    </div>

  </section>

  <!-- ═══════════════════════════════════════════════════
       4. HARDWARE — DC Fast Hardware for Every Corridor.
       Lifted from /solutions/highway-fast-charging (v1).
       Section sized to a full viewport (min-h-screen) with
       content vertically centered via flex. Card body keeps
       v2's tighter typography. Cards seat v1 product images
       on a multifamily-v3-style "showroom" stage.
       ═══════════════════════════════════════════════════ -->
  <section class="hwv2-hardware-section bg-evium-dark-light min-h-screen flex flex-col justify-center py-8 lg:py-12">
    <div class="max-w-7xl mx-auto w-full px-6 lg:px-12">

      <!-- Header — v1 content, centered. Compressed to fit
           the section in a single viewport. -->
      <div class="text-center max-w-3xl mx-auto mb-7 lg:mb-9">
        <div class="text-evium-green text-xs font-bold uppercase tracking-[0.22em] mb-3">DC Fast Hardware</div>
        <h2 class="text-3xl lg:text-[2.4rem] font-black text-white leading-[1.05] mb-4">
          Infrastructure-Grade Hardware
          <span class="text-evium-green">for Every Corridor.</span>
        </h2>
        <p class="text-[15px] text-white/60 leading-snug max-w-2xl mx-auto">
          Highway charging demands more than a standard EV install. Every unit Evium deploys is a high-power DC fast charger built for continuous-duty, multi-vehicle throughput with NEVI compliance baked in.
        </p>
      </div>

      <!-- Grid uses explicit column ratios so the middle card
           is ~15% wider than its siblings — gives the central
           card visual weight without resorting to a transform
           scale that would break grid alignment. -->
      <div class="hwv2-hardware-grid">

        <!-- Tellus 180kW -->
        <article class="hwv2-hardware-card group">
          <div class="hwv2-hardware-stage">
            <img
              src="/images/chargers/tellus/tellus-dc-fast-180kw.png"
              alt="Tellus DC Fast 180kW"
              class="hwv2-hardware-img"
              loading="lazy"
            />
          </div>
          <div class="hwv2-hardware-body">
            <span class="hwv2-hardware-tag">Tellus Series</span>
            <div class="text-4xl font-black text-white mb-2 leading-none">180<span class="text-2xl text-white/55 ml-1">kW</span></div>
            <p class="text-white/55 text-[13px] leading-snug mb-4">The corridor workhorse. Dual CCS + CHAdeMO connectors, weatherproof outdoor enclosure, OCPP 1.6+ connectivity, and NEVI uptime compliance built in. Adds 100+ miles in under 20 minutes.</p>
            <div class="flex flex-wrap gap-2 mt-auto">
              <span class="text-xs font-semibold text-evium-green bg-evium-green/10 border border-evium-green/25 rounded-full px-3 py-1">180kW Output</span>
              <span class="text-xs font-semibold text-white/70 bg-white/5 border border-white/10 rounded-full px-3 py-1">CCS + CHAdeMO</span>
              <span class="text-xs font-semibold text-white/70 bg-white/5 border border-white/10 rounded-full px-3 py-1">NEVI Compliant</span>
            </div>
          </div>
        </article>

        <!-- MaxiCharger 60–240kW (now MIDDLE — promoted to the
             center slot per request, sized slightly larger via
             the wider middle column. Showroom floor card. -->
        <article class="hwv2-hardware-card hwv2-hardware-card--middle group">
          <div class="hwv2-hardware-stage">
            <img
              src="/images/chargers/maxicharger/maxicharger-dc-fast-60-240kw.png"
              alt="MaxiCharger DC Fast 60–240kW"
              class="hwv2-hardware-img"
              loading="lazy"
            />
          </div>
          <div class="hwv2-hardware-body">
            <span class="hwv2-hardware-tag">MaxiCharger Series</span>
            <div class="text-4xl font-black text-white mb-2 leading-none">60–240<span class="text-2xl text-white/55 ml-1">kW</span></div>
            <p class="text-white/55 text-[13px] leading-snug mb-4">Scalable modular architecture for sites with growing demand. Deploy at 60kW and upgrade to 240kW without replacing hardware. Ideal for sites entering the corridor market with room to scale.</p>
            <div class="flex flex-wrap gap-2 mt-auto">
              <span class="text-xs font-semibold text-evium-green bg-evium-green/10 border border-evium-green/25 rounded-full px-3 py-1">60–240kW</span>
              <span class="text-xs font-semibold text-white/70 bg-white/5 border border-white/10 rounded-full px-3 py-1">Modular</span>
              <span class="text-xs font-semibold text-white/70 bg-white/5 border border-white/10 rounded-full px-3 py-1">Upgradeable</span>
            </div>
          </div>
        </article>

        <!-- Tellus 300kW (featured "Top Spec" — now on the right) -->
        <article class="hwv2-hardware-card hwv2-hardware-card--featured group">
          <span class="hwv2-hardware-flag" aria-label="Top spec">
            <span class="hwv2-hardware-flag-dot" aria-hidden="true"></span>
            <span class="hwv2-hardware-flag-text">Top Spec</span>
          </span>
          <div class="hwv2-hardware-stage">
            <img
              src="/images/chargers/tellus/tellus-dc-fast-300kw.png"
              alt="Tellus DC Fast 300kW"
              class="hwv2-hardware-img"
              loading="lazy"
            />
          </div>
          <div class="hwv2-hardware-body">
            <span class="hwv2-hardware-tag">Tellus Series</span>
            <div class="text-4xl font-black text-white mb-2 leading-none">300<span class="text-2xl text-white/55 ml-1">kW</span></div>
            <p class="text-white/55 text-[13px] leading-snug mb-4">Maximum throughput for high-traffic corridors. Supports dynamic power sharing across multiple vehicles simultaneously, ultra-fast 10-minute sessions for capable vehicles, and future-proof power delivery.</p>
            <div class="flex flex-wrap gap-2 mt-auto">
              <span class="text-xs font-semibold text-evium-green bg-evium-green/10 border border-evium-green/25 rounded-full px-3 py-1">300kW Output</span>
              <span class="text-xs font-semibold text-white/70 bg-white/5 border border-white/10 rounded-full px-3 py-1">Dynamic Sharing</span>
