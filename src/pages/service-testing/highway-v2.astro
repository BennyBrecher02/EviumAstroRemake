</Layout>

<style>
  /* ═══════════════════════════════════════════════════════
     Audience bridge section
     ───────────────────────────────────────────────────────
     Lift of /testing/highway-old-replica §3 styling. The
     card visuals (sage fill, hairline border, ink title +
     soft-ink body) are verbatim from the replica's `.ohr-card`
     so this beat reads as a faithful transplant. The layout
     above adds a white surface, centered tracked-caps
     eyebrow with flanking hairline rules (mirrors the
     fleets-v2 bridge pattern), and forces each card to a
     1:1 square at desktop / tablet widths.
  ═══════════════════════════════════════════════════════ */
  .hwv2-bridge {
    --hwv2-sage:        #DDE9D6;
    --hwv2-sage-border: #C7D8BD;
    --hwv2-ink:         #1A2F3A;
    --hwv2-ink-soft:    #3A4A55;
    --hwv2-green:       #2DC856;

    background: #ffffff;
    padding: clamp(48px, 7vw, 96px) clamp(20px, 6vw, 96px);
    font-family: 'Maven Pro', system-ui, sans-serif;
  }
  .hwv2-bridge-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Header wrapper — eyebrow + headline together. */
  .hwv2-bridge-head {
    margin: 0 auto clamp(36px, 4.4vw, 64px);
    text-align: center;
  }

  /* Centered eyebrow with flanking hairline rules — same
     editorial pattern as fleets-v2's bridge. */
  .hwv2-bridge-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(12px, 1.4vw, 20px);
    margin: 0 0 clamp(20px, 2.2vw, 30px);
    color: var(--hwv2-green);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }
  .hwv2-bridge-eyebrow-rule {
    display: block;
    width: clamp(28px, 4vw, 56px);
    height: 1px;
    background: currentColor;
  }

  /* Headline — sized + styled exactly like fleets-v2's
     .fv2-bridge-icp. Italic em clause carries the
     rhetorical lift in green-deep. */
  .hwv2-bridge-icp {
    margin: 0 auto;
    max-width: 940px;
    text-align: center;
    font-size: clamp(24px, 2.7vw, 38px);
    line-height: 1.22;
    font-weight: 500;
    color: var(--hwv2-ink);
    letter-spacing: -0.018em;
  }
  .hwv2-bridge-icp em {
    color: #24a347;
    font-style: italic;
    font-weight: 500;
  }

  .hwv2-bridge-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(14px, 1.8vw, 24px);
  }

  /* Card visuals — verbatim from replica .ohr-card. The
     aspect-ratio: 1 / 1 + position:relative + overflow:hidden
     additions support the background watermark + body-wrap
     pattern below. */
  .hwv2-card {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: var(--hwv2-sage);
    border: 1px solid var(--hwv2-sage-border);
    border-radius: 18px;
    padding: clamp(20px, 2.2vw, 28px);
    color: var(--hwv2-ink);
    aspect-ratio: 1 / 1;
    display: flex;
    flex-direction: column;
  }

  /* Background watermark — large, low-opacity ink-color
     glyph that anchors each card as a visual motif. Partially
     clipped by the card edge (negative offsets) so it reads
     as background decoration rather than a UI icon. Per-card
     placement varies via [data-hwv2-card] selectors below to
     prevent the four cards from looking like a literal
     repeating template. */
  .hwv2-card-mark {
    position: absolute;
    pointer-events: none;
    color: var(--hwv2-ink);
    opacity: 0.10;
    z-index: 0;
  }

  /* Card 1: bolt — lower-right, mostly clipped by the
     bottom edge so it reads as a faint motif under the
     reading column. */
  .hwv2-card[data-hwv2-card="output"] .hwv2-card-mark {
    width: clamp(140px, 14vw, 200px);
    height: clamp(140px, 14vw, 200px);
    bottom: -32px;
    right:  -28px;
  }
  /* Card 2: pin — upper-right, anchored against the
     headline so it reads as a subtle place-marker. */
  .hwv2-card[data-hwv2-card="placement"] .hwv2-card-mark {
    width: clamp(130px, 13vw, 180px);
    height: clamp(130px, 13vw, 180px);
    top:    -36px;
    right:  -32px;
  }
  /* Card 3: shield — lower-right, slightly larger so the
     enclosing form reads cleanly even at the corner clip. */
  .hwv2-card[data-hwv2-card="availability"] .hwv2-card-mark {
    width: clamp(150px, 15vw, 210px);
    height: clamp(150px, 15vw, 210px);
    bottom: -40px;
    right:  -36px;
  }
  /* Card 4: clock — upper-right. Different corner from the
     other three so the four watermarks feel composed rather
     than identical. */
  .hwv2-card[data-hwv2-card="turnover"] .hwv2-card-mark {
    width: clamp(140px, 14vw, 200px);
    height: clamp(140px, 14vw, 200px);
    top:    -28px;
    right:  -32px;
  }

  /* Foreground text wrapper — sits above the watermark via
     z-index, with a constrained measure so the body copy
     doesn't run into the icon corner. */
  .hwv2-card-body-wrap {
    position: relative;
    z-index: 1;
    max-width: 24ch;
  }
  .hwv2-card-title {
    margin: 0 0 clamp(8px, 1vw, 14px);
    font-size: clamp(17px, 1.5vw, 20px);
    font-weight: 700;
    letter-spacing: -0.005em;
  }
  .hwv2-card-body {
    margin: 0;
    font-size: clamp(13.5px, 1vw, 14.5px);
    line-height: 1.55;
    color: var(--hwv2-ink-soft);
  }

  /* Responsive — squares hold at desktop and tablet, then
     drop to a single-column flow on phones (where forcing
     a 1:1 ratio at full-width gives absurdly tall cards). */
  @media (max-width: 1080px) {
    .hwv2-bridge-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .hwv2-bridge-grid { grid-template-columns: 1fr; }
    .hwv2-card { aspect-ratio: auto; }
  }

  /* ═══════════════════════════════════════════════════════
     Hardware cards — showroom treatment
     ───────────────────────────────────────────────────────
     Pattern adapted from multifamily-v3's "Recommended
     Hardware" section. Each charger reads as a hero product
     on a lit stage, not a UI tile. Image well gets an
     overhead spotlight (radial light from above) and a
     contact shadow under the unit (radial darken on the
     stage floor). Image gets a real product-shoot drop
     shadow so it feels grounded. Cards float on multi-
     layer depth shadows. A green hairline accent at the
     top edge animates in on hover. Featured card carries
     a strong baseline glow + a more editorial outlined
     ribbon (replaces the previous solid-fill pill).
  ═══════════════════════════════════════════════════════ */

  /* Grid — three equal columns. align-items: center is the
     "podium" pattern: the middle card's extra height extends
     symmetrically above and below the side cards instead of
     hanging awkwardly off only the bottom edge. Rises and
     sinks equally, reads as a featured display. */
  .hwv2-hardware-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    gap: clamp(16px, 1.6vw, 24px);
  }

  /* Spotlight pattern — when any card in the grid is hovered,
     all NON-hovered siblings dim and subtly shrink. This keeps
     the hovered card the unambiguous focus regardless of which
     card is hovered (without it, the at-rest tallness of the
     middle card could compete with a hovered side card for
     visual dominance). */
  .hwv2-hardware-grid:has(.hwv2-hardware-card:hover) .hwv2-hardware-card:not(:hover) {
    transform: scale(0.965);
    opacity: 0.55;
    filter: saturate(0.85);
    transition:
      transform 0.45s cubic-bezier(.2, .9, .25, 1),
      opacity 0.4s ease,
      filter 0.4s ease,
      border-color 0.4s ease,
      box-shadow 0.45s cubic-bezier(.2, .9, .25, 1);
  }

  .hwv2-hardware-card {
    --hwv2-hardware-bg: #0f2330;
    position: relative;
    background: var(--hwv2-hardware-bg);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 18px;
    overflow: hidden;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.04) inset,
      0 2px 4px rgba(0, 0, 0, 0.18),
      0 14px 28px -10px rgba(0, 0, 0, 0.40),
      0 28px 56px -16px rgba(0, 0, 0, 0.32);
    transition:
      transform 0.5s cubic-bezier(.2, .9, .25, 1),
      border-color 0.4s ease,
      box-shadow 0.5s cubic-bezier(.2, .9, .25, 1);
    transform-origin: center bottom;
    will-change: transform;
  }

  /* Hover — strong lift + full-card scale + 4-layer green
     glow that radiates from the card (matches the featured
     card's hover treatment so all three cards bloom equally
     on interaction). The previous green hairline at the top
     edge has been retired in favor of the glow alone. */
  .hwv2-hardware-card:hover {
    transform: translateY(-12px) scale(1.025);
    border-color: rgba(45, 200, 86, 0.55);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 8px 16px rgba(0, 0, 0, 0.30),
      0 30px 56px -14px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(45, 200, 86, 0.22),
      0 0 40px rgba(45, 200, 86, 0.26),
      0 0 96px rgba(45, 200, 86, 0.16),
      0 40px 76px -14px rgba(45, 200, 86, 0.40);
  }

  /* Middle card — taller via stage height + body min-height.
     No baseline transform: the grid's align-items: center
     vertically centers the row, so the extra height already
     extends symmetrically above and below the side cards.
     A baseline lift here would just break that symmetry. */
  .hwv2-hardware-card--middle {
    border-color: rgba(255, 255, 255, 0.10);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 2px 4px rgba(0, 0, 0, 0.20),
      0 18px 36px -10px rgba(0, 0, 0, 0.46),
      0 36px 72px -18px rgba(0, 0, 0, 0.36);
  }
  .hwv2-hardware-card--middle:hover {
    transform: translateY(-16px) scale(1.030);
    border-color: rgba(45, 200, 86, 0.62);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 10px 20px rgba(0, 0, 0, 0.32),
      0 36px 64px -14px rgba(0, 0, 0, 0.60),
      0 0 0 1px rgba(45, 200, 86, 0.26),
      0 0 48px rgba(45, 200, 86, 0.30),
      0 0 120px rgba(45, 200, 86, 0.18),
      0 48px 88px -16px rgba(45, 200, 86, 0.44);
  }

  /* Featured (Top Spec) card — stronger baseline border +
     ambient green halo always-on; both intensify on hover. */
  .hwv2-hardware-card--featured {
    border-color: rgba(45, 200, 86, 0.32);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.05) inset,
      0 2px 4px rgba(0, 0, 0, 0.18),
      0 14px 28px -10px rgba(0, 0, 0, 0.40),
      0 28px 56px -16px rgba(0, 0, 0, 0.32),
      0 0 0 1px rgba(45, 200, 86, 0.10),
      0 24px 60px -20px rgba(45, 200, 86, 0.20);
  }
  .hwv2-hardware-card--featured:hover {
    transform: translateY(-14px) scale(1.025);
    border-color: rgba(45, 200, 86, 0.70);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 8px 16px rgba(0, 0, 0, 0.30),
      0 32px 60px -14px rgba(0, 0, 0, 0.58),
      0 0 0 1px rgba(45, 200, 86, 0.32),
      0 0 44px rgba(45, 200, 86, 0.30),
      0 0 104px rgba(45, 200, 86, 0.20),
      0 44px 84px -14px rgba(45, 200, 86, 0.48);
  }

  /* Image stage — well with a soft overhead spotlight
     (radial light from top) and a contact shadow on the
     "floor" so the charger feels grounded. Sized to keep
     the whole hardware section in a single viewport. */
  .hwv2-hardware-stage {
    position: relative;
    height: 212px;
    overflow: hidden;
    background:
      radial-gradient(ellipse 70% 55% at 50% 0%, rgba(255, 255, 255, 0.085) 0%, transparent 70%),
      linear-gradient(180deg, #142a38 0%, #0d1f2b 100%);
  }
  /* Middle card gets a markedly taller stage so it reads
     as the focal "podium" card. Since the grid uses
     align-items: start, this extra stage height extends
     the card downward past its siblings. */
  .hwv2-hardware-card--middle .hwv2-hardware-stage {
    height: 268px;
  }
  /* Middle body min-height keeps the middle card from
     visually shrinking when its shorter pills wrap onto
     fewer rows than the side cards'. Tuned so the whole
     section still fits in a single viewport. */
  .hwv2-hardware-card--middle .hwv2-hardware-body {
    min-height: 250px;
  }
  /* Contact shadow under the charger. */
  .hwv2-hardware-stage::after {
    content: '';
    position: absolute;
    bottom: 7%;
    left: 18%;
    right: 18%;
    height: 14%;
    background: radial-gradient(ellipse 70% 100% at 50% 0%, rgba(0, 0, 0, 0.55) 0%, transparent 75%);
    pointer-events: none;
    z-index: 1;
  }
  /* Bottom fade so the image dissolves into the body section
     rather than meeting it on a hard line. */
  .hwv2-hardware-stage::before {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 56px;
    background: linear-gradient(to top, var(--hwv2-hardware-bg) 0%, transparent 100%);
    z-index: 2;
    pointer-events: none;
  }

  .hwv2-hardware-img {
    position: relative;
    z-index: 3;
    display: block;
    margin: 0 auto;
    max-width: 76%;
    max-height: 86%;
    width: auto;
    height: 100%;
    object-fit: contain;
    padding: 24px 0 18px;
    filter:
      drop-shadow(0 14px 22px rgba(0, 0, 0, 0.55))
      drop-shadow(0 4px 8px rgba(0, 0, 0, 0.35));
    transition: transform 0.55s cubic-bezier(.2, .9, .25, 1), filter 0.4s ease;
    will-change: transform;
  }
  .hwv2-hardware-card:hover .hwv2-hardware-img {
    transform: translateY(-3px) scale(1.04);
    filter:
      drop-shadow(0 20px 28px rgba(0, 0, 0, 0.65))
      drop-shadow(0 6px 12px rgba(0, 0, 0, 0.4));
  }

  /* Body wrapper — flex column so the pill row can pin to
     the bottom via mt-auto on the inline pill container. */
  .hwv2-hardware-body {
    padding: 18px 22px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* Series tag — outlined editorial pill (replaces the
     prior plain green eyebrow). Same shape as mf-v3's
     .svc-hw-tag, brand-green palette. */
  .hwv2-hardware-tag {
    align-self: flex-start;
    margin-bottom: 12px;
    padding: 4px 11px;
    border: 1px solid rgba(45, 200, 86, 0.40);
    border-radius: 999px;
    background: rgba(45, 200, 86, 0.08);
    color: #2DC856;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    line-height: 1;
  }

  /* Featured ribbon — outlined editorial badge that replaces
     the previous solid-fill pill ("Top Spec"). Reads as a
     credentialed mark rather than a sticker. Sits top-left
     so it doesn't overlap the product silhouette on the
     right edge of the stage. */
  .hwv2-hardware-flag {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 5;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 11px 5px 9px;
    border: 1px solid rgba(45, 200, 86, 0.55);
    border-radius: 4px;
    background: rgba(15, 35, 48, 0.78);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 4px 12px -4px rgba(0, 0, 0, 0.45);
  }
  .hwv2-hardware-flag-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #2DC856;
    box-shadow: 0 0 6px rgba(45, 200, 86, 0.65);
  }
  .hwv2-hardware-flag-text {
    color: #7DFA9F;
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    line-height: 1;
  }

  /* ═══════════════════════════════════════════════════════
     Revenue projection flip cards
     ───────────────────────────────────────────────────────
     3D flip on hover (desktop) and on click (touch). Front
     shows the headline projection, back shows the math
     breakdown + source. Both faces are absolutely
     positioned within an inner wrapper that rotates 180°
     in Y. backface-visibility:hidden hides the away-facing
     face during the rotation.
  ═══════════════════════════════════════════════════════ */
  .hwv2-rev-flip {
    perspective: 1400px;
    min-height: 405px;
    position: relative;
    cursor: pointer;
    outline: none;
  }
  .hwv2-rev-flip:focus-visible .hwv2-rev-flip-inner {
    outline: 2px solid rgba(45, 200, 86, 0.6);
    outline-offset: 4px;
    border-radius: 18px;
  }
  .hwv2-rev-flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: inherit;
    transform-style: preserve-3d;
    transition: transform 0.7s cubic-bezier(.4, .0, .2, 1);
    will-change: transform;
  }
  /* Flip on hover, on focus, or when JS adds is-flipped */
  .hwv2-rev-flip:hover .hwv2-rev-flip-inner,
  .hwv2-rev-flip.is-flipped .hwv2-rev-flip-inner {
    transform: rotateY(180deg);
  }
  .hwv2-rev-face {
    position: absolute;
    inset: 0;
    height: 100%;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hwv2-rev-back {
    transform: rotateY(180deg);
  }

  /* Subtle "tap to flip" hint at the bottom of the front face. */
  .hwv2-rev-flip-hint {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.30);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    transition: opacity 0.3s ease;
  }
  .hwv2-rev-flip:hover .hwv2-rev-flip-hint {
    opacity: 0;
  }

  /* Back-face breakdown list — each row is dt (label, left)
     + dd (value, right) with a faint divider above. */
  .hwv2-rev-back-list {
    margin: 0;
    padding: 0;
    text-align: left;
  }
  .hwv2-rev-back-list > div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 9px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }
  .hwv2-rev-back-list > div:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .hwv2-rev-back-list dt {
    color: rgba(255, 255, 255, 0.50);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .hwv2-rev-back-list dd {
    margin: 0;
    color: #ffffff;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.01em;
  }
  .hwv2-rev-back-list dd.is-accent {
    color: #2DC856;
  }

  /* ═══════════════════════════════════════════════════════
     Hero pavement-band CTA — adapted from fleets-v2's
     .fv2-cta-primary. Skewed green parallelogram face sits
     behind a counter-skewed inner span so the type reads
     upright while the shape stays slanted. Pinned to the
     lower-left corner of the hero, on the photo's pavement.
  ═══════════════════════════════════════════════════════ */
  .hwv2-hero {
    --hwv2-cta-skew: -14deg;
  }
  /* Pushed right so the button no longer sits over the red
     car on the left of the photo. Same right-of-center
     placement as fleets-v2's hero action. Fills the open
     pavement zone to the right of the chargers. */
  .hwv2-hero-actions {
    position: absolute;
    left: clamp(440px, 54vw, 760px);
    bottom: clamp(40px, 6vw, 80px);
    z-index: 5;
  }
  .hwv2-cta-primary {
    position: relative;
    display: inline-flex;
    padding: 0;
    background: transparent;
    border: 0;
    text-decoration: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    isolation: isolate;
    transition: transform 0.4s cubic-bezier(.22, 1, .36, 1);
  }
  .hwv2-cta-primary-face {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(180deg, #3bd866 0%, #2DC856 50%, #25b04d 100%);
    transform: skewX(var(--hwv2-cta-skew));
    border-radius: 4px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.65),
      inset 0 -1px 0 rgba(0, 0, 0, 0.22),
      inset 1px 0 0 rgba(255, 255, 255, 0.10),
      inset -1px 0 0 rgba(0, 0, 0, 0.10),
      0 22px 50px rgba(45, 200, 86, 0.45),
      0 8px 22px rgba(0, 0, 0, 0.5);
    transition:
      background 0.32s ease,
      box-shadow 0.4s cubic-bezier(.22, 1, .36, 1),
      transform 0.4s cubic-bezier(.22, 1, .36, 1);
  }
  .hwv2-cta-primary-inner {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: clamp(16px, 1.7vw, 22px) clamp(30px, 3.4vw, 46px);
    color: #0a1822;
    font-family: 'Maven Pro', sans-serif;
    font-size: clamp(0.78rem, 0.92vw, 0.92rem);
    font-weight: 900;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: gap 0.32s cubic-bezier(.22, 1, .36, 1);
  }
  .hwv2-cta-primary-inner svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(.22, 1, .36, 1);
  }
  .hwv2-cta-primary:hover,
  .hwv2-cta-primary:focus-visible {
    transform: translateY(-3px);
    outline: none;
  }
  .hwv2-cta-primary:hover .hwv2-cta-primary-face,
  .hwv2-cta-primary:focus-visible .hwv2-cta-primary-face {
    background: linear-gradient(180deg, #4ae07a 0%, #38d562 50%, #2DC856 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.82),
      inset 0 -1px 0 rgba(0, 0, 0, 0.22),
      inset 1px 0 0 rgba(255, 255, 255, 0.14),
      inset -1px 0 0 rgba(0, 0, 0, 0.10),
      0 30px 64px rgba(45, 200, 86, 0.6),
      0 12px 30px rgba(0, 0, 0, 0.55);
  }
  .hwv2-cta-primary:hover .hwv2-cta-primary-inner,
  .hwv2-cta-primary:focus-visible .hwv2-cta-primary-inner {
    gap: 16px;
  }
  .hwv2-cta-primary:hover svg,
  .hwv2-cta-primary:focus-visible svg {
    transform: translateY(3px);
  }
  .hwv2-cta-primary:active {
    transform: translateY(-1px);
  }

  /* ═══════════════════════════════════════════════════════
     Final CTA — bottom-of-page button reactivity
     ───────────────────────────────────────────────────────
     Both buttons get cubic-bezier easing, lift on hover,
     and meaningful feedback. Primary gets a pumped halo
     and brightness boost; secondary fades in its arrow,
     fills with a green tint, and brightens border + text.
  ═══════════════════════════════════════════════════════ */
  .hwv2-final-cta-primary {
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.30) inset,
      0 14px 32px -10px rgba(45, 200, 86, 0.45),
      0 6px 16px -4px rgba(0, 0, 0, 0.35);
    transition:
      transform 0.35s cubic-bezier(.22, 1, .36, 1),
      box-shadow 0.45s cubic-bezier(.22, 1, .36, 1),
      filter 0.3s ease;
    will-change: transform;
  }
  .hwv2-final-cta-primary:hover,
  .hwv2-final-cta-primary:focus-visible {
    transform: translateY(-3px);
    filter: brightness(1.08);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.40) inset,
      0 22px 48px -12px rgba(45, 200, 86, 0.65),
      0 12px 28px -6px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(45, 200, 86, 0.30);
    outline: none;
  }
  .hwv2-final-cta-primary:active {
    transform: translateY(-1px);
    filter: brightness(1.02);
  }

  .hwv2-final-cta-secondary {
    background-color: rgba(10, 24, 34, 0.30);
    transition:
      transform 0.35s cubic-bezier(.22, 1, .36, 1),
      background-color 0.3s ease,
      border-color 0.3s ease,
      color 0.3s ease,
      box-shadow 0.45s cubic-bezier(.22, 1, .36, 1);
    will-change: transform;
  }
  .hwv2-final-cta-secondary:hover,
  .hwv2-final-cta-secondary:focus-visible {
    transform: translateY(-3px);
    background-color: rgba(45, 200, 86, 0.12);
    border-color: rgba(45, 200, 86, 0.65);
    color: #ffffff;
    box-shadow:
      0 14px 32px -10px rgba(45, 200, 86, 0.30),
      0 6px 16px -4px rgba(0, 0, 0, 0.35),
      0 0 0 1px rgba(45, 200, 86, 0.20);
    outline: none;
  }
  .hwv2-final-cta-secondary:active {
    transform: translateY(-1px);
  }
</style>

<script>
  /* Revenue card flip — tap-to-toggle for touch / non-hover
     environments. Hover handles desktop via CSS. Clicking
     anywhere inside the card toggles is-flipped, which the
     CSS picks up to rotate the inner wrapper 180°.
     Keyboard: Enter / Space also toggles when the card is
     focused. */
  function initHwv2RevFlip() {
    const cards = document.querySelectorAll('.hwv2-rev-flip');
    cards.forEach((card) => {
      const toggle = (e) => {
        // Don't intercept clicks on actual links/buttons inside.
        if (e.target.closest('a, button')) return;
        card.classList.toggle('is-flipped');
      };
      card.addEventListener('click', toggle);
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          card.classList.toggle('is-flipped');
        }
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHwv2RevFlip);
  } else {
    initHwv2RevFlip();
  }

  /* ─── Hero pavement-CTA → Revenue section animated scroll ─
     Mirrors the fleets-v2 smooth-scroll handler. Intercepts
     clicks on a[data-hwv2-scroll], runs an rAF-eased cubic
     ease-in-out animation (~900ms) to the target's top.
     Falls back to native anchor jump if prefers-reduced-motion
     is on. ────────────────────────────────────────────────── */
  (function () {
    var triggers = document.querySelectorAll('a[data-hwv2-scroll]');
    if (!triggers.length) return;

    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function easeInOutCubic(t) {
      return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }

    function animateScrollTo(targetY, duration) {
      duration = duration || 900;
      var startY = window.scrollY;
      var distance = targetY - startY;
      if (Math.abs(distance) < 2) return;
      var startT = performance.now();
      function step(now) {
        var elapsed = now - startT;
        var t = Math.min(elapsed / duration, 1);
        var eased = easeInOutCubic(t);
        window.scrollTo(0, startY + distance * eased);
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    triggers.forEach(function (a) {
      a.addEventListener('click', function (e) {
        var hash = a.getAttribute('href');
        if (!hash || hash.charAt(0) !== '#') return;
        var target = document.querySelector(hash);
        if (!target) return;
        e.preventDefault();
        if (reduceMotion) {
          window.scrollTo(0, target.getBoundingClientRect().top + window.scrollY);
          return;
        }
        var targetY = target.getBoundingClientRect().top + window.scrollY;
        animateScrollTo(targetY, 900);
      });
    });
  })();
</script>
