      right: -64px;
    }
    .fv2-bridge-card[data-fv2-card="future"] .fv2-bridge-card-mark {
      width: clamp(190px, 18.5vw, 270px);
      /* viewBox 64×48 → 4:3 aspect ratio */
      height: clamp(143px, 13.9vw, 203px);
      bottom: -28px;
      right:  -42px;
    }

    /* Foreground text wrapper — sits above the watermark
       (z-index) at the natural top of the card and is
       constrained to a comfortable reading measure so the
       body doesn't run into the icon corner. */
    .fv2-bridge-card-body-wrap {
      position: relative;
      z-index: 1;
      max-width: 30ch;
    }
    .fv2-bridge-card-title {
      margin: 0 0 clamp(12px, 1.4vw, 18px);
