      gap: clamp(16px, 2vw, 22px);
      align-items: stretch;
      grid-template-columns: 1fr;
    }
    @media (min-width: 880px) {
      .fv2-fin-grid {
        grid-template-columns: 1.25fr 1fr;
      }
    }

    /* ── Card base ──────────────────────────────────── */
    .fv2-fin-card {
      position: relative;
      background: #ffffff;
      border: 1px solid rgba(13, 28, 36, 0.08);
      border-radius: 22px;
      padding: clamp(22px, 2.4vw, 32px);
      box-shadow:
        0 1px 2px rgba(13, 28, 36, 0.04),
        0 6px 16px rgba(13, 28, 36, 0.06),
        0 22px 48px rgba(13, 28, 36, 0.10);
      display: flex;
      flex-direction: column;
      transition:
        transform 0.4s var(--fin-ease),
        box-shadow 0.4s var(--fin-ease),
        border-color 0.4s var(--fin-ease);
    }
    .fv2-fin-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: #2DC856;
      transform: scaleX(0);
      transform-origin: 50% 50%;
      transition: transform 0.45s var(--fin-ease);
      z-index: 2;
      pointer-events: none;
      border-top-left-radius: 22px;
      border-top-right-radius: 22px;
    }
    .fv2-fin-card:hover {
      transform: translateY(-9px);
      box-shadow:
        /* Pure-glow halos (no offset) */
        0 0 0 1px rgba(45, 200, 86, 0.32),
        0 0 22px rgba(45, 200, 86, 0.34),
        0 0 56px rgba(45, 200, 86, 0.22),
