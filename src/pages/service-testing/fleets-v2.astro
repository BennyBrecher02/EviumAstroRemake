    /* Per-card icon placement — anchored to different corners
       so the three cards don't read as visual triplets. Card 1
       lower-right, Card 2 upper-right (so the eye finds the
       money sigil where it expects a "header"), Card 3
       lower-right but on a slightly different aspect ratio. */
    .fv2-bridge-card[data-fv2-card="capacity"] .fv2-bridge-card-mark {
