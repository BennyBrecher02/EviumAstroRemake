      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: #2DC856;
      line-height: 1;
    }
    .fv2-fin-eyebrow-dash {
      display: inline-block;
      flex: 0 0 auto;
      width: clamp(22px, 2.4vw, 32px);
      height: 1.5px;
      background: linear-gradient(90deg, #2DC856, rgba(45, 200, 86, 0));
      border-radius: 1px;
    }
    .fv2-fin-eyebrow-dash:last-child {
      background: linear-gradient(90deg, rgba(45, 200, 86, 0), #2DC856);
    }
    .fv2-fin-title {
      margin: 0 0 clamp(14px, 1.5vw, 20px);
      font-size: clamp(1.8rem, 3.4vw, 2.6rem);
