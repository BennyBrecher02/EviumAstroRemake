      gap: clamp(20px, 2.2vw, 32px);
    }

    /* ─── Card body ───────────────────────────────────────
       Premium editorial card. Content flows from the top with
       no flex-end alignment so titles and bodies fill the card
       without leaving a deadspace cap. Watermark icons sit in
       the lower-right corner, partially clipped — out of the
       reading zone. */
    .fv2-bridge-card {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      display: flex;
      flex-direction: column;
      min-height: clamp(240px, 23vw, 300px);
      padding: clamp(30px, 3.2vw, 44px) clamp(26px, 2.6vw, 36px);
