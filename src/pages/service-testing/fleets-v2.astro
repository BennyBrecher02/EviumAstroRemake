        inset 0 1px 0 rgba(255, 255, 255, 0.9),
        0 1px 0 rgba(26, 47, 58, 0.04),
        0 36px 56px -32px rgba(26, 47, 58, 0.30),
        0 12px 22px -10px rgba(45, 200, 86, 0.18);
    }

    /* The watermark icon — huge, low-opacity brand-green
       outline, partially clipped by the card's overflow so it
       reads as an editorial motif rather than a UI icon. All
       three icons live in the bottom-right so they consistently
       sit *below* the reading zone and don't compete with the
       text up top. */
    .fv2-bridge-card-mark {
      position: absolute;
      pointer-events: none;
      color: rgba(45, 200, 86, 0.11);
      transition: color 0.36s ease, transform 0.5s cubic-bezier(.2, .9, .25, 1);
      z-index: 0;
    }
    .fv2-bridge-card:hover .fv2-bridge-card-mark {
      color: rgba(45, 200, 86, 0.22);
      transform: scale(1.04) rotate(-1.5deg);
