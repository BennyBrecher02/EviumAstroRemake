          <div class="ep-field">
            <label for="ep-last-name" class="ep-label">Last name <span class="ep-req">*</span></label>
            <input id="ep-last-name" name="lastName" type="text" required class="ep-input" placeholder="Rodriguez" />
          </div>

          <div class="ep-field">
            <label for="ep-email" class="ep-label">Email <span class="ep-req">*</span></label>
            <input id="ep-email" name="email" type="email" required class="ep-input" placeholder="jamie@electriccompany.com" />
          </div>

          <div class="ep-field">
            <label for="ep-phone" class="ep-label">Phone <span class="ep-req">*</span></label>
            <input id="ep-phone" name="phone" type="tel" required class="ep-input" placeholder="(555) 123-4567" />
          </div>

          <div class="ep-field md:col-span-2">
