---
/**
 * /ai-bs/old-saved-sections
 * ─────────────────────────
 * Archive of initial AI-generated section drafts from the early
 * home-page concepting phase. The Options A–E home-hero mockups
 * that used to live here have been removed — what remains is the
 * still-useful reference content (solutions index, products hero
 * draft, institutional + client logo strips, etc.). Reachable only
 * via the AI BS dropdown; not surfaced in the main site nav.
 */
import Layout from '../../layouts/Layout.astro';
import HeroProducts from '../../components/heroes/HeroProducts.astro';

const solutions = [
  {
    num: '01',
    name: 'Multifamily Real Estate',
    href: '/solutions/multifamily',
    tag: 'Apartments & Condos',
    desc: 'Turn EV charging into a tenant amenity and passive revenue stream — zero capital required.',
  },
  {
    num: '02',
    name: 'Fleets',
    href: '/solutions/fleets',
    tag: 'Depot Electrification',
    desc: 'Depot charging designed around your vehicles, your shifts, and your grid constraints.',
  },
  {
    num: '03',
    name: 'Highway Fast Charging',
    href: '/solutions/highway-fast-charging',
    tag: 'Corridor Infrastructure',
    desc: 'Capture highway EV traffic. NEVI-ready CPO deployment with zero cost to site hosts.',
  },
  {
    num: '04',
    name: 'Calculate Generated Profits',
    href: '/solutions/generate-profits',
    tag: 'Revenue Modeling',
    desc: 'Understand what EV charging can actually earn for your property before you commit to anything.',
  },
  {
    num: '05',
    name: 'Electrician Partners',
    href: '/solutions/electrician-partners',
    tag: 'Trade Partnerships',
    desc: "Qualified electrical contractors — join Evium's growing installation network.",
  },
  {
    num: '06',
    name: 'Commercial',
    href: '/solutions/commercial',
    tag: 'Office & Mixed-Use',
    desc: "Meet corporate ESG mandates, win tenant negotiations, and modernize your building's parking.",
  },
  {
    num: '07',
    name: 'Retail',
    href: '/solutions/retail',
    tag: 'Strip Centers & Shopping',
    desc: 'Turn your lot into a destination. EV drivers choose where to shop based on where they can charge.',
  },
  {
    num: '08',
    name: 'Parking',
    href: '/solutions/parking',
    tag: 'Lots & Garages',
    desc: 'Activate idle stalls. Manage single sites or full portfolios from one dashboard.',
  },
  {
    num: '09',
    name: 'Medical',
    href: '/solutions/medical',
    tag: 'Hospitals & Clinics',
    desc: '24/7-monitored infrastructure built for environments where reliability is non-negotiable.',
  },
];
---

<Layout title="Old Saved Sections — AI BS — Evium Charging">
  <style>
    .hero-label {
      position: sticky;
      top: 64px;
      z-index: 100;
      background: rgba(45,200,86,0.92);
      color: #0d1a22;
      font-family: 'Maven Pro', sans-serif;
      font-weight: 900;
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 5px 14px;
      width: fit-content;
      margin-left: 24px;
      transform: translateY(-50%);
      pointer-events: none;
    }
  </style>

  <!-- ══════════════════════════════════════════════════════════
       PAGE ORDER (top → bottom)
         1. Old Products Page
         2. Old Solutions Page
         3. Rising Star Badge     — About/Credentials page treatment
         4. Backed By Strip       — Homepage institutional logos
         5. Trusted By Strip      — Homepage client logos
       ══════════════════════════════════════════════════════════ -->

  <!-- ══════════════════════════════════════════════════════════
       1. OLD PRODUCTS PAGE HERO (preserved for reference)
       ══════════════════════════════════════════════════════════ -->
  <div class="relative">
    <div class="hero-label">Old Products Page</div>
    <HeroProducts />
  </div>

  <!-- ══════════════════════════════════════════════════════════
       2. OLD SOLUTIONS PAGE CONTENT (preserved for reference)
       ══════════════════════════════════════════════════════════ -->
  <div class="relative">
    <div class="hero-label">Old Solutions Page</div>

    <!-- ── Hero ─────────────────────────────────────────────── -->
    <section class="relative min-h-[52vh] flex items-end pb-16 pt-32 overflow-hidden">
      <div class="absolute inset-0 bg-evium-dark"></div>
      <div class="absolute inset-0 opacity-[0.03]"
        style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 48px 48px;"></div>
      <div class="absolute top-0 right-0 w-1/2 h-full opacity-20"
        style="background: radial-gradient(ellipse at 80% 30%, #2DC856 0%, transparent 65%);"></div>

      <div class="relative w-full max-w-6xl mx-auto px-6 lg:px-12">
        <p class="text-evium-green text-xs font-semibold tracking-[0.2em] uppercase mb-5 flex items-center gap-2">
          <span class="inline-block w-6 h-px bg-evium-green"></span>
          Evium Solutions
        </p>
        <h1 class="text-5xl lg:text-7xl font-black leading-[0.95] tracking-tight text-white mb-6 max-w-3xl">
          Every property<br/>
          <span class="text-evium-green">type.</span> One partner.
        </h1>
        <p class="text-white/55 text-lg max-w-xl leading-relaxed">
          Hardware, software, installation, rebates, and 24/7 operations — delivered as a single managed service across every segment we serve.
        </p>
      </div>
    </section>

    <!-- ── Divider ────────────────────────────────────────────── -->
    <div class="max-w-6xl mx-auto px-6 lg:px-12">
      <div class="h-px bg-white/10"></div>
    </div>

    <!-- ── Solutions List ─────────────────────────────────────── -->
    <section class="bg-evium-dark py-4">
      <div class="max-w-6xl mx-auto px-6 lg:px-12">
        {solutions.map((s) => (
          <a
            href={s.href}
            class="solution-row group flex items-center gap-6 py-7 border-b border-white/8 hover:border-evium-green/30 transition-all duration-300 relative"
          >
            <span class="text-evium-green text-xs font-bold tracking-widest tabular-nums w-8 shrink-0 group-hover:opacity-100 opacity-40 transition-opacity duration-300">
              {s.num}
            </span>

            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
                <span class="text-white text-2xl lg:text-3xl font-bold tracking-tight group-hover:text-evium-green transition-colors duration-300 leading-tight">
                  {s.name}
                </span>
                <span class="text-white/30 text-xs font-medium tracking-widest uppercase border border-white/10 px-2 py-0.5 rounded-sm group-hover:border-evium-green/25 group-hover:text-evium-green/60 transition-all duration-300">
                  {s.tag}
                </span>
              </div>
              <p class="text-white/45 text-sm mt-1.5 leading-relaxed max-w-xl group-hover:text-white/60 transition-colors duration-300">
                {s.desc}
              </p>
            </div>

            <div class="shrink-0 ml-4 w-10 h-10 rounded-full border border-white/10 flex items-center justify-center group-hover:border-evium-green group-hover:bg-evium-green/10 transition-all duration-300 translate-x-0 group-hover:translate-x-1">
              <svg class="w-4 h-4 text-white/30 group-hover:text-evium-green transition-colors duration-300" fill="none" viewBox="0 0 16 16">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ── One Platform Strip ─────────────────────────────────── -->
    <section class="bg-evium-dark-light border-y border-white/8 py-16">
      <div class="max-w-6xl mx-auto px-6 lg:px-12">
        <div class="flex flex-col lg:flex-row items-start lg:items-center gap-10 lg:gap-20">
          <div class="flex-1">
            <h2 class="text-3xl lg:text-4xl font-black text-white tracking-tight leading-tight mb-3">
              One platform.<br/>
              <span class="text-evium-green">Every segment.</span>
            </h2>
            <p class="text-white/50 text-base leading-relaxed max-w-lg">
              Whether you manage a single apartment complex or a national portfolio, Evium delivers the same hardware, the same software, and the same 24/7 operational standard — at no upfront cost.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row lg:flex-col xl:flex-row gap-6 lg:gap-4 xl:gap-10 shrink-0">
            <div class="text-center lg:text-left">
              <div class="text-4xl font-black text-evium-green">500+</div>
              <div class="text-white/40 text-xs tracking-widest uppercase mt-1">Chargers deployed</div>
            </div>
            <div class="hidden sm:block lg:hidden xl:block w-px bg-white/10 self-stretch"></div>
            <div class="text-center lg:text-left">
              <div class="text-4xl font-black text-evium-green">$0</div>
              <div class="text-white/40 text-xs tracking-widest uppercase mt-1">Upfront under no-cost model</div>
            </div>
            <div class="hidden sm:block lg:hidden xl:block w-px bg-white/10 self-stretch"></div>
            <div class="text-center lg:text-left">
              <div class="text-4xl font-black text-evium-green">24/7</div>
              <div class="text-white/40 text-xs tracking-widest uppercase mt-1">Monitoring & support</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CTA ───────────────────────────────────────────────── -->
    <section class="bg-evium-dark py-20 relative overflow-hidden">
      <div class="absolute inset-0 opacity-15"
        style="background: radial-gradient(ellipse at 50% 100%, #2DC856 0%, transparent 60%);"></div>
      <div class="relative max-w-6xl mx-auto px-6 lg:px-12 text-center">
        <h2 class="text-3xl lg:text-4xl font-black text-white tracking-tight mb-4">
          Not sure which solution fits?
        </h2>
        <p class="text-white/50 text-base mb-8 max-w-md mx-auto">
          Tell us about your property and we'll map out the right approach — hardware, model, and timeline — at no charge.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contact/quote"
            class="inline-flex items-center justify-center gap-2 bg-evium-green text-black font-bold text-sm tracking-wide px-7 py-3.5 hover:bg-white transition-colors duration-200">
            Get a Free Assessment
            <svg class="w-4 h-4" fill="none" viewBox="0 0 16 16">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="/how-it-works"
            class="inline-flex items-center justify-center gap-2 border border-white/20 text-white/70 font-medium text-sm px-7 py-3.5 hover:border-white/40 hover:text-white transition-all duration-200">
            See How It Works
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- ══════════════════════════════════════════════════════════════════
       3–5. LOGO ARCHITECTURE DRAFTS
       Three sections laying out how the Evium logo library should be
       used across the site. Placed in ai-bs for iteration before being
       wired into the homepage / about pages.

         3. RISING STAR BADGE  – About/Credentials page hero treatment
                                  for the ConEd Rising Star sticker.
         4. BACKED BY          – Homepage institutional strip:
                                  government + utility + industry
                                  partner logos, unified muted
                                  treatment on a dark panel.
         5. TRUSTED BY OWNERS  – Homepage client strip: property-
                                  owner logos, full-color treatment
                                  on a light panel to signal
                                  "clients, not credentials."
       ══════════════════════════════════════════════════════════════════ -->

  <!-- ── 3. Rising Star Badge — About / Credentials treatment ───────── -->
  <div class="relative">
    <div class="hero-label">Rising Star Badge — About / Credentials</div>

    <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-evium-dark">
      <!-- Soft green uplight behind the badge -->
      <div class="absolute inset-0 opacity-25"
        style="background: radial-gradient(ellipse 55% 55% at 50% 55%, #2DC856 0%, transparent 70%);"></div>
      <!-- Grid texture -->
      <div class="absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 56px 56px;"></div>

      <div class="relative z-10 max-w-3xl mx-auto px-6 lg:px-12 text-center">
        <!-- Eyebrow -->
        <p class="text-evium-green text-xs font-bold tracking-[0.24em] uppercase mb-10 flex items-center justify-center gap-3">
          <span class="inline-block w-10 h-px bg-evium-green"></span>
          Industry Recognition
          <span class="inline-block w-10 h-px bg-evium-green"></span>
        </p>

        <!-- Badge stack: sticker with its own green halo -->
        <div class="relative inline-block mb-10">
          <div class="absolute inset-0 bg-evium-green/30 blur-[70px] rounded-full scale-110" aria-hidden="true"></div>
          <img
            src="/images/logos/evium/coned-rising-star-2023.png"
            alt="2023 Con Edison E-Mobility Rising Star Award — Evium Charging"
            class="relative w-[clamp(200px,28vw,300px)] h-auto drop-shadow-[0_20px_40px_rgba(0,0,0,0.4)]"
          />
        </div>

        <h2 class="text-4xl lg:text-6xl font-black text-white leading-[0.95] tracking-tight mb-5">
          Recognized by<br/>
          <span class="text-evium-green">the grid.</span>
        </h2>

        <p class="text-white/60 text-base lg:text-lg leading-relaxed max-w-xl mx-auto mb-4">
          Con Edison — New York City's primary electric utility — named
          Evium Charging a <strong class="text-white font-semibold">2023 E-Mobility
          Rising Star</strong> for excellence in electric-vehicle
          infrastructure deployment.
        </p>

        <p class="text-white/30 text-[0.7rem] tracking-[0.22em] uppercase font-semibold">
          Con Edison · 2023 E-Mobility Awards · New York, NY
        </p>
      </div>
    </section>
  </div>

  <!-- ── 4. Backed By — Homepage Institutional Strip ────────────────── -->
  <div class="relative">
    <div class="hero-label">Backed By — Homepage Institutional Strip</div>

    <section class="relative py-20 lg:py-28 bg-evium-dark overflow-hidden">
      <!-- Same subtle grid texture used elsewhere in the brand -->
      <div class="absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 48px 48px;"></div>
      <!-- Faint top/bottom hairlines delineate the strip -->
      <div class="absolute top-0 left-0 right-0 h-px bg-white/[0.06]"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-white/[0.06]"></div>

      <div class="relative max-w-6xl mx-auto px-6 lg:px-12 text-center">
        <p class="text-evium-green text-xs font-bold tracking-[0.24em] uppercase mb-3 flex items-center justify-center gap-3">
          <span class="inline-block w-10 h-px bg-evium-green"></span>
          Backed By
          <span class="inline-block w-10 h-px bg-evium-green"></span>
        </p>
        <p class="text-white/40 text-sm tracking-wide mb-14">
          Federal &amp; state grant programs · Utility + industry partners
        </p>

        <!-- 2 cols on mobile → 7 across on large. -->
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-7 gap-x-8 gap-y-12 items-center justify-items-center">
          <img src="/images/logos/government/cec.png"           alt="California Energy Commission (REACH 2.0 grant)" class="logo-inst" />
          <img src="/images/logos/government/cal-evip.webp"     alt="CALeVIP (CA rebate program)"                    class="logo-inst" />
          <img src="/images/logos/government/nj-bpu.png"        alt="New Jersey Board of Public Utilities"           class="logo-inst" />
          <img src="/images/logos/government/nm-dot.png"        alt="New Mexico Department of Transportation"        class="logo-inst" />
          <img src="/images/logos/government/colorado-cdot.png" alt="Colorado Department of Transportation"          class="logo-inst" />
          <img src="/images/logos/industry/con-edison.webp"     alt="Con Edison"                                     class="logo-inst" />
          <img src="/images/logos/industry/ev-gateway.webp"     alt="EV Gateway (NEVI program partner)"              class="logo-inst" />
        </div>
      </div>
    </section>
  </div>

  <!-- ── 5. Trusted By Property Owners — Homepage Client Strip ──────── -->
  <div class="relative">
    <div class="hero-label">Trusted By Property Owners — Homepage Client Strip</div>

    <section class="relative py-20 lg:py-24 bg-white overflow-hidden">
      <!-- Very faint dark grid keeps the section tied to the brand -->
      <div class="absolute inset-0 opacity-[0.035]"
        style="background-image: linear-gradient(rgba(13,26,34,0.85) 1px, transparent 1px), linear-gradient(90deg, rgba(13,26,34,0.85) 1px, transparent 1px); background-size: 48px 48px;"></div>

      <div class="relative max-w-6xl mx-auto px-6 lg:px-12 text-center">
        <!-- Dark eyebrow to sit on the light panel -->
        <p class="text-evium-dark text-xs font-bold tracking-[0.24em] uppercase mb-3 flex items-center justify-center gap-3">
          <span class="inline-block w-10 h-px bg-evium-dark/40"></span>
          Trusted By Property Owners
          <span class="inline-block w-10 h-px bg-evium-dark/40"></span>
        </p>
        <p class="text-evium-dark/55 text-sm mb-14">
          Multifamily portfolios · Commercial real estate · Capital groups
        </p>

        <!-- Larger logos + wider gaps than the institutional strip:
             signals these are clients, not credentials. -->
        <div class="flex flex-wrap items-center justify-center gap-x-16 gap-y-10">
          <img src="/images/logos/clients/topaz-capital-group.webp"     alt="Topaz Capital Group"     class="logo-client" />
          <img src="/images/logos/clients/miracle-mile-properties.webp" alt="Miracle Mile Properties" class="logo-client" />
          <img src="/images/logos/clients/oakmark.jpg"                  alt="Oakmark Management"      class="logo-client" />
        </div>
      </div>
    </section>
  </div>

  {/* Home-hero concept mockups (Options A–E) previously lived here;
      all five options have been removed entirely. The remaining
      sections above are the still-useful reference content. */}

  <style>
    /* Institutional strip: unify mixed-source logos on the dark panel by
       pulling them toward a lighter monochrome treatment. Hover restores
       the original colors so the user can still read each crest. */
    .logo-inst {
      max-height: 52px;
      width: auto;
      filter: grayscale(1) brightness(1.7) contrast(0.9);
      opacity: 0.62;
      transition: filter 0.3s ease, opacity 0.3s ease, transform 0.3s ease;
    }
    .logo-inst:hover {
      filter: grayscale(0) brightness(1) contrast(1);
      opacity: 1;
      transform: translateY(-2px);
    }

    /* Client strip on the light panel: keep color but tone saturation
       down a touch so the strip reads as unified. Hover restores. */
    .logo-client {
      max-height: 64px;
      width: auto;
      filter: saturate(0.82);
      opacity: 0.9;
      transition: filter 0.3s ease, opacity 0.3s ease, transform 0.3s ease;
    }
    .logo-client:hover {
      filter: saturate(1);
      opacity: 1;
      transform: translateY(-2px);
    }
  </style>
</Layout>
