                    <div class="v2-card-img-wrap">
                      <img src={product.image} alt={product.title} class="v2-card-img" loading="lazy" />
                      <img src={product.image} alt="" aria-hidden="true" class="v2-card-reflection" loading="lazy" />
                    </div>
                  </div>
                  <div class="v2-card-body">
                    <header class="v2-card-head">
                      <span class="v2-card-tag v2-card-tag--dc">DC Fast</span>
                      <h3 class="v2-card-title">{product.title}</h3>
                      <p class="v2-card-sub">{product.subtitle}</p>
                    </header>
                    <div class="v2-card-specs">
                      {product.specs.map((spec) => (
                        <div class="v2-spec">
                          <span class="v2-spec-label">{spec.label}</span>
                          <span class="v2-spec-value">{spec.value}</span>
                        </div>
                      ))}
                    </div>
                    {product.builtFor && product.builtFor.length > 0 && (
                      <div class="v2-card-builtfor">
                        <span class="v2-builtfor-label">Built for</span>
                        <span class="v2-builtfor-pills">
                          {product.builtFor.map((slug) => {
                            const svc = SERVICES[slug];
                            if (!svc) return null;
                            return (
                              <a class="v2-builtfor-pill" href={svc.href}>{svc.label}</a>
