                            <h4 class="v2-mini-title">{product.title}</h4>
                            <p class="v2-mini-power">{powerSummary(product)}</p>
                            <div class="v2-mini-foot">
                              <a class="v2-mini-detail" href={`#${product.id}`} data-mini-detail={product.tier}>
                                Full specs
                                <svg viewBox="0 0 12 12" aria-hidden="true">
                                  <path d="M3 6h6M7 3l2 3-2 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                                </svg>
                              </a>
                              <a class="v2-mini-quote" href="/contact/quote">Request quote</a>
                            </div>
                          </div>
                        </article>
                      ))}
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        </div>

      {/* Tier-mini slot — inside bottom-zone. Both buttons live
          here in the DOM but only one is visible at a time
          (the OTHER tier from whichever is currently active).
          The slot itself is column 2 of the bottom-zone grid;
          its width animates 0fr → 1fr when state becomes l2 / l3. */}
      <div class="v2-tier-mini-slot">
        {/* L2 mini — visible when state is L3. Tells the user
            they've finished the L3 catalog and offers the
            "now see the L2 chargers" branch with an up-arrow. */}
        <button class="v2-tier-mini" type="button" data-tier-mini="l2" aria-label="Jump up to Level 2 chargers">
          <span class="v2-tier-mini-row">
            <span class="v2-tier-mini-tag">Click to see Level 2</span>
            <svg class="v2-tier-mini-arrow" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 13V3M4 7l4-4 4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </span>
          <span class="v2-tier-mini-headline">That's every Level 3 charger we offer.</span>
          <span class="v2-tier-mini-sub">Jump back up to see our Level 2 lineup — daily and overnight charging for multifamily, workplace, and retail.</span>
        </button>
        {/* L3 mini — visible when state is L2. Tells the user
            they've finished the L2 catalog and offers the
            "now see the L3 chargers" branch with an up-arrow. */}
        <button class="v2-tier-mini" type="button" data-tier-mini="l3" aria-label="Jump up to Level 3 chargers">
          <span class="v2-tier-mini-row">
            <span class="v2-tier-mini-tag v2-tier-mini-tag--dc">Click to see Level 3</span>
            <svg class="v2-tier-mini-arrow" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 13V3M4 7l4-4 4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </span>
          <span class="v2-tier-mini-headline">That's our complete Level 2 lineup.</span>
          <span class="v2-tier-mini-sub">Jump back up to explore our Level 3 DC fast chargers — built for fleet depots, highway corridors, and quick-stop retail.</span>
        </button>
      </div>
      </div>
      </div>

    </div>
  </section>

  {/* (Level 2 / Level 3 / Brand catalogs all now live INSIDE the
      mega-section above — inside their respective morph elements.
      There are no separate <section> blocks below the mega; the
      whole page is hero → mega → footer.) */}

  {/* Charging-speed chart overlay — same component behavior as the
      production page, with the overlay's `left` pushed over by the
      lefter's width so it doesn't slide under the rail. Centered
      within the reduced viewport. */}
  <div class="v2-chart-overlay" id="chart-overlay" role="dialog" aria-modal="true" aria-label="Charging speed chart" hidden>
    <div class="v2-chart-backdrop" data-chart-close aria-hidden="true"></div>
    <div class="v2-chart-content">
      <button type="button" class="v2-chart-close" id="chart-close-btn" aria-label="Close chart">
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
      <img
        src="/images/charging-speed-chart-cropped.png"
        alt="Charging speed chart by charger amperage, vehicle battery size, and charging time"
        class="v2-chart-img"
        draggable="false"
      />
    </div>
  </div>

  {/* SAVED PICKS UI — floating chip (bottom-right) + slide-in
      drawer. Both kept OUTSIDE the .v2-selector so the section's
      state machine doesn't touch them. The chip materializes
      only when the user has at least one saved item; the drawer
      slides in from the right when the chip is clicked.
      Storage is localStorage-backed (see `BOOKMARK_KEY` below).
      The list is rendered client-side from existing card DOM
      so we don't need a separate product-data feed. */}
  <button
    type="button"
    class="v2-saved-chip is-empty"
    id="saved-chip"
    aria-label="View saved chargers"
    aria-haspopup="dialog"
  >
    <svg class="v2-saved-chip-icon" viewBox="0 0 16 18" aria-hidden="true">
      <path d="M3.2 2.2h9.6v13.4l-4.8-3.6-4.8 3.6z" fill="currentColor" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
    </svg>
    <span class="v2-saved-chip-label">Saved</span>
    <span class="v2-saved-chip-count" aria-live="polite">0</span>
  </button>

  <aside
    class="v2-saved-drawer"
    id="saved-drawer"
    role="dialog"
    aria-modal="true"
    aria-labelledby="saved-drawer-title"
    aria-hidden="true"
  >
    <div class="v2-saved-drawer-backdrop" data-saved-close aria-hidden="true"></div>
    <div class="v2-saved-drawer-panel">
      <header class="v2-saved-drawer-head">
        <div class="v2-saved-drawer-head-text">
          <span class="v2-saved-drawer-eyebrow">Your picks</span>
          <h2 id="saved-drawer-title" class="v2-saved-drawer-title">
            Saved chargers
            <span class="v2-saved-drawer-title-count" aria-hidden="true">0</span>
          </h2>
        </div>
        <button
          type="button"
          class="v2-saved-drawer-close"
          id="saved-drawer-close"
          aria-label="Close saved chargers"
        >
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </button>
      </header>
      <ul class="v2-saved-list" id="saved-list" aria-live="polite"></ul>
      <p class="v2-saved-empty" id="saved-empty" hidden>
        No saved chargers yet. Tap the bookmark icon on any charger to save it here.
      </p>
      <footer class="v2-saved-drawer-foot">
        <button type="button" class="v2-saved-clear" id="saved-clear-btn">
          Clear all
        </button>
        <a class="v2-saved-quote" href="/contact/quote">
          <span>Request a quote</span>
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none" />
          </svg>
        </a>
      </footer>
    </div>
  </aside>

  <SiteFooter />
</Layout>

<style>
  /* ═══════════════════════════════════════════════════════════════════
     Hero
     The HeroCarouselPedestal uses `width: max(100vw, ...)` for its
     stage. On v2 pages the lefter eats ~80 px of the viewport so
     `100vw` overflows the container width, which subtly pushes the
     pedestal composition off-center under the rail. Override to use
     the container (post-padding) width instead, and swap the dark
     stage background for a slightly warmer near-black to match the
     HeaderV4 palette.
     ═══════════════════════════════════════════════════════════════════ */
  .products-hero-wrap { position: relative; }
  :global(body.page-products-v2) .carousel-root {
    background: #0a1218;
  }
  /* Tell the stage to size against the content box, not the full
     viewport. The aspect-ratio math holds, the pedestal % coords
     are unchanged. */
  :global(body.page-products-v2) .pedestal-stage {
    width:  max(100%, calc(100vh * 1536 / 1024));
  }

  .hero-desktop-only { display: block; }
  .hero-mobile-only  { display: none;  }
  @media (max-width: 860px) {
    .hero-desktop-only { display: none;  }
    .hero-mobile-only  { display: block; }
  }

  /* ═══════════════════════════════════════════════════════════════════
     Shared dark palette — selector, level panels, and brands all
     use the same cockpit-grade backdrop so the flow reads as one
     continuous space under the rail.
     ═══════════════════════════════════════════════════════════════════ */
  /* Override body's padding-left (the rail offset) for THIS page
     only. We're going to handle the rail's visual presence via a
     dedicated grid column on the section instead, so we have
     direct, mathematical control over gutter equality. */
  :global(body.page-products-v2) {
    padding-left: 0;
  }

  .v2-selector {
    /* ── Elevation system ──────────────────────────────────────
       Three resting tiers + matching lifted (hover) tiers.
       Layered like real shadows in a lit scene:
       - contact (1-2px tight): anchors object to its surface
       - close ambient (4-8px blur): immediate dim halo
       - mid ambient (12-24px blur): the body of the shadow
       - far ambient (40-80px blur): gentle bleed
       - atmospheric (100px+ blur): room-scale falloff
       Higher tiers GAIN layers (more reach), they don't just
       darken. Hover variants amplify reach without darkening
       contact — a lifted object's contact LOOSENS from the
       surface.

       Shadow color is a slightly cool near-black (matches the
       darkest brand neutral, #1A2F3A), kept very low alpha so
       the page reads quiet and expensive, not dramatic. */
    --shadow-rgb: 13, 28, 36;

    /* Each token caps its own reach so it can fade fully within
       the layout space its element has below it. The deepest
       layer in every stack ends with a low-alpha (0.03-0.05)
       wisp — that means even if the very tail end is clipped by
       a parent's overflow boundary, the cutoff is imperceptible.
       We lose a touch of "atmospheric" reach vs. an unconstrained
       page, but we gain consistency and zero jarring lines. */

    --elev-1:
      0 1px 1px rgba(var(--shadow-rgb), 0.04),
      0 2px 5px rgba(var(--shadow-rgb), 0.05),
      0 5px 11px rgba(var(--shadow-rgb), 0.05);

    --elev-2:
      0 1px 2px rgba(var(--shadow-rgb), 0.05),
      0 3px 6px rgba(var(--shadow-rgb), 0.05),
      0 7px 14px rgba(var(--shadow-rgb), 0.06),
      0 14px 26px rgba(var(--shadow-rgb), 0.04);

    --elev-3:
      0 2px 3px rgba(var(--shadow-rgb), 0.05),
      0 5px 10px rgba(var(--shadow-rgb), 0.06),
      0 11px 20px rgba(var(--shadow-rgb), 0.07),
      0 22px 36px rgba(var(--shadow-rgb), 0.04);

    --elev-1-hover:
      0 1px 2px rgba(var(--shadow-rgb), 0.04),
      0 3px 8px rgba(var(--shadow-rgb), 0.06),
      0 8px 16px rgba(var(--shadow-rgb), 0.07),
      0 16px 28px rgba(var(--shadow-rgb), 0.04);

    --elev-2-hover:
      0 1px 2px rgba(var(--shadow-rgb), 0.04),
      0 4px 10px rgba(var(--shadow-rgb), 0.06),
      0 11px 20px rgba(var(--shadow-rgb), 0.08),
      0 22px 36px rgba(var(--shadow-rgb), 0.04);

    --elev-3-hover:
      0 1px 2px rgba(var(--shadow-rgb), 0.05),
      0 4px 10px rgba(var(--shadow-rgb), 0.07),
      0 10px 20px rgba(var(--shadow-rgb), 0.09),
      0 18px 32px rgba(var(--shadow-rgb), 0.10),
      0 28px 44px rgba(var(--shadow-rgb), 0.04);

    /* Lift + press distances. Universal across cards so the
       motion language is consistent. */
    --lift-md: -8px;
    --press: -2px;

    /* Borders — single hairline scale + a touch darker on hover
       to give the lifted card a hint more definition. */
    --hairline:       1px solid rgba(0, 0, 0, 0.05);
    --hairline-hover: 1px solid rgba(0, 0, 0, 0.07);

    /* Timing */
    --ease: cubic-bezier(0.25, 0, 0, 1);
    --duration-hover: 0.5s;
    --duration-press: 0.14s;

    position: relative;
    color: #E6F0EC;
    font-family: 'Maven Pro', sans-serif;
    overflow: hidden;
    min-height: 100vh;
    /* CSS GRID with explicit gutter columns. The gutters are
       defined as `1fr` on each side, which means they are
       MATHEMATICALLY EQUAL by definition — no margin-auto
       computation, no flex auto-margin edge cases, no parent-
       padding interaction. Just two equal-fr tracks flanking
       the inner.

       Layout:
         col 1: var(--lefter-width)              ← rail occupies this
         col 2: 1fr                              ← LEFT GUTTER (auto)
         col 3: minmax(0, 1240px)                ← inner content
         col 4: 1fr                              ← RIGHT GUTTER (auto)

       Cols 2 and 4 are both `1fr` so they're guaranteed equal
       in width. The rail visually sits in col 1, the L2/L3 row
       and the brand button (children of inner) sit in col 3,
       and the equal-width gutters bracket them. */
    display: grid;
    grid-template-columns:
      var(--lefter-width)
      clamp(1rem, 4vw, 3rem)
      minmax(0, 1fr)
      clamp(2rem, 5.5vw, 5rem);
    align-items: start;
    padding-block: clamp(1.4rem, 2.5vw, 2.25rem);
    padding-inline: 0;
    /* APPLE-STYLE WHITE MODE — Apple's signature off-white #f5f5f7
       as the section base. Two-stop top-down gradient: brightest
       at top (the light source for the whole scene), dimming
       toward the bottom so the cards' shadows have somewhere to
       fall. The white cards floating inside catch the most light
       and read as the focal layer. */
    background: linear-gradient(180deg, #f8f8fa 0%, #f5f5f7 50%, #efeff2 100%);
    /* Backdrop cross-fade reacts to state so the mega-section's
       own wash deepens slightly when a tier is expanded — reads
       as "the same section, different mode" rather than a new
       page region. */
    transition: padding 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v2-selector.state-l2,
  .v2-selector.state-l3,
  .v2-selector.state-brand {
    padding-top: clamp(2.5rem, 4vw, 3.5rem);
  }

  /* ════════════════════════════════════════════════════════════════════
     STATE-DRIVEN LAYOUT
     The mega-section root carries one of `state-idle | state-l2 |
     state-l3 | state-brand`. CSS selectors off that class drive the
     header fade, tabs reveal, tier-row grid columns, and each morph's
     expand/collapse. Everything animates on a shared ~1.4 s curve so
     the cross-component transitions feel like one unified motion.
     ════════════════════════════════════════════════════════════════════ */

  /* Head — visible in idle + brand states, collapsed away in l2/l3. */
  .v2-selector-head {
    max-height: 420px;
    opacity: 1;
    overflow: hidden;
    transition:
      max-height 1.1s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.7s ease,
      margin 1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v2-selector.state-l2 .v2-selector-head,
  .v2-selector.state-l3 .v2-selector-head {
    max-height: 0;
    opacity: 0;
    margin-top: 0;
    margin-bottom: 0;
  }

  /* ── Tier tabs — sleek v1-style with sliding rail ───────
     Visible only in state-l2 / state-l3. Clean minimal:
       • Tab bar: full width, hairline border-bottom
       • Each tab: equal width (flex 1, max-width 380), bold
         uppercase text with 0.18em letter-spacing
       • Single sliding rail (.v2-tier-tab-rail) absolutely
         positioned at the bottom of the bar, animates between
         tab positions via transform: translateX
       • Inactive tabs: muted ink + soft hover lift
       • Active tab: brand-green text (rail handles the green
         underline beneath via translation, not per-tab ::after)

     Two-tab layout: rail width is exactly half the tab-bar's
     content area. translateX(0%) puts it under L2; 100% puts it
     under L3. The cubic-bezier slide gives the indicator that
     "magnetic" feel — it physically moves between options
     instead of fading on/off. */
  .v2-tier-tabs {
    position: relative;
    display: flex;
    justify-content: center;
    gap: 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition:
      max-height 1.1s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.7s ease,
      margin 1s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.7s ease;
  }
  .v2-selector.state-l2 .v2-tier-tabs,
  .v2-selector.state-l3 .v2-tier-tabs {
    max-height: 80px;
    opacity: 1;
    margin-bottom: clamp(1.75rem, 3vw, 2.5rem);
  }

  .v2-tier-tab {
    flex: 1;
    max-width: 380px;
    padding: clamp(0.85rem, 1.4vw, 1.1rem) clamp(1.5rem, 2vw, 2rem);
    background: none;
    border: 0;
    font-family: 'Maven Pro', sans-serif;
    font-size: clamp(0.78rem, 1vw, 0.88rem);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6e6e73;
    cursor: pointer;
    position: relative;
    transition: color 0.32s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 1;
  }
  .v2-tier-tab:hover:not([aria-pressed="true"]) {
    color: #1d1d1f;
  }
  .v2-tier-tab[aria-pressed="true"] {
    color: #2DC856;
  }
  .v2-tier-tab:focus-visible {
    outline: 2px solid rgba(45, 200, 86, 0.5);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* Sliding underline rail — single element, half the tab-bar's
     usable width, slides between tab positions. translation key:
     translateX(0%)   → under L2 tab
     translateX(100%) → under L3 tab */
  .v2-tier-tab-rail {
    position: absolute;
    bottom: -1px;
    left: 50%;
    width: min(380px, 50%);
    /* Starting transform: half its own width to the left, plus
       the offset for L2 (which is just to the left of center). */
    transform: translateX(-100%);
    height: 3px;
    /* Default = green (L2 color). The state-l3 rule below
       swaps to cyan so the rail color matches the active
       tier's brand. background + box-shadow both transition
       in sync with the slide so the user sees the rail glide
       AND change color in one continuous motion. */
    background: #2DC856;
    border-radius: 2px;
    box-shadow: 0 0 14px rgba(45, 200, 86, 0.5);
    opacity: 0;
    transition:
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.35s ease;
    pointer-events: none;
  }
  .v2-selector.state-l2 .v2-tier-tab-rail {
    opacity: 1;
    transform: translateX(-100%);  /* under L2 (left of center) */
  }
  .v2-selector.state-l3 .v2-tier-tab-rail {
    opacity: 1;
    transform: translateX(0);      /* under L3 (right of center) */
    /* L3 cyan rail — same brightness profile as the green
       version, just shifted to the cyan brand family. */
    background: #68d8e8;
    box-shadow: 0 0 14px rgba(104, 216, 232, 0.55);
  }

  /* ── Tier row — L2 + L3 picker cards side by side ─────────
     Visible only in idle + brand states. In l2/l3 states the
     whole row collapses to zero height — both tier cards
     vanish from the top of the selector to make room for the
     tier-tabs (the new "switch tier" UI). The "alternative tier"
     reappears as a smaller mini-button down in the bottom-zone
     alongside the brand morph. */
  .v2-tier-row {
    /* CSS GRID, THREE COLUMNS:
         col 1: 2fr  → L2 card
         col 2: 1fr  → empty gap (the middle of the row)
         col 3: 2fr  → L3 card

       Cards placed via explicit `grid-column: 1` / `grid-column: 3`.

       SYMMETRIC PADDING on the row inset both edges by the same
       amount, so L2 sits at the same offset INWARD from the
       browse-button's left edge as L3 sits inward from the
       browse-button's right edge. Result: cards are visually
       symmetric about the section's center axis, both offset by
       an equal amount from the row edges. */
    /* The browse-by-brand button (in v2-bottom-zone) stays at
       100% of inner — so it has the section's right gutter
       breathing room from the viewport wall, narrow as the user
       wants.

       The tier-row, however, extends PAST the inner's right edge
       all the way to the viewport's right wall via a negative
       margin-right that exactly matches the section's right
       gutter width. With L3 anchored at row-right via padding-
       right: 0, L3's right edge ends up at the viewport's right
       wall — visibly hanging past where the browse button below
       ends. The row's extra width (matching the gutter amount)
       is purely visual right-edge extension; L2's left edge
       stays inset via padding-left so its position is unchanged. */
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(50px, 5vw, 130px) minmax(0, 1fr);
    gap: 0;
    width: 100%;
    /* SYMMETRIC inset on both sides — L2 and L3 each have the
       same offset from the browse-by-brand button's left and
       right edges respectively. */
    padding-inline: clamp(16px, 2vw, 50px);
    /* Asymmetric padding-block: tight 14px at the top (cards
       hug the head above) and a generous bottom inset so the
       picker cards' lifted hover shadow has room to FADE fully
       within the row before its overflow:hidden boundary clips
       it. Without this, the deepest shadow layer was getting
       hard-cut and reading as a jarring line. */
    padding-block: 14px clamp(36px, 3.5vw, 50px);
    box-sizing: border-box;
    /* Tightened margin-bottom — the row already has generous
       padding-bottom for shadow fade, so a smaller gap to the
       browse-by-brand button below is all that's needed. */
    margin-bottom: clamp(0.5rem, 1vw, 0.9rem);
    max-height: 760px;
    opacity: 1;
    overflow: hidden;
    transition:
      max-height 1.4s cubic-bezier(0.22, 1, 0.36, 1),
      margin 1s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.6s ease;
  }
  .v2-selector.state-l2 .v2-tier-row,
  .v2-selector.state-l3 .v2-tier-row {
    max-height: 0;
    margin-top: 0;
    margin-bottom: 0;
    opacity: 0;
    pointer-events: none;
  }

  /* Tier morphs — placed in explicit grid columns. The cells in
     col 1 and col 3 are at the LEFT and RIGHT edges of the row.
     With `justify-self: stretch` (the default for grid items),
     each card fills its cell completely — L2 spans the entire
     left grid track and L3 spans the entire right grid track.

     NO `overflow: hidden` on the morph — the card inside has its
     own overflow:hidden for its rounded-corner clipping, but the
     morph stays overflow:visible so the card's hover translation
     (translateY(-5px)) doesn't get clipped at the morph's edge. */
  .v2-tier-morph {
    position: relative;
    min-width: 0;
  }
  .v2-tier-morph[data-morph="l2"] {
    /* L2 in col 1 — flush left, including the left edge of the
       row which == the left edge of the browse-by-brand button. */
    grid-column: 1;
  }
  .v2-tier-morph[data-morph="l3"] {
    grid-column: 3;
    /* Visual right-shift on the L3 picker card. transform doesn't
       change the row's layout box, so the browse-by-brand button
       below stays the exact same width — only L3 moves. */
    transform: translateX(clamp(40px, 4vw, 100px));
  }

  /* ── Tier expand zone (shared between L2 and L3) ──────────
     Sits directly below the tier row. When state is l2 or l3,
     its grid-template-rows animates from 0fr → 1fr, unfurling
     the appropriate catalog to full width. Only one catalog is
     rendered visible at a time via the state-class filter
     below, so the height the zone expands to is always the
     currently-active tier's content height. */
  .v2-tier-expand {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 1.4s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.9s ease 0.3s;
  }
  .v2-tier-expand-inner {
    min-height: 0;
    overflow: hidden;
    /* position:relative anchors the inactive tier-catalog (which
       is position:absolute inset:0 — see .v2-tier-catalog below)
       so it overlays the active one in the same space, allowing
       a true cross-fade between the two without any layout
       collapse during the swap. */
    position: relative;
  }
  .v2-selector.state-l2 .v2-tier-expand,
  .v2-selector.state-l3 .v2-tier-expand {
    grid-template-rows: 1fr;
    opacity: 1;
  }
  /* Catalog visibility model — pure CSS cross-fade, no JS class
     toggling needed. Both catalogs ALWAYS render (display:block).
     The INACTIVE one is absolutely positioned (no layout cost).
     The ACTIVE one is in normal flow and drives the parent's
     height. State change swaps which is which in a single frame:
     the new active takes the layout space the old just vacated,
     so .v2-tier-expand-inner's height never collapses → no
     brand-button jumpscare from layout reflow.

     Visual transition runs on opacity + transform (vertical
     drift). When state-* matches, the active catalog fades up
     to opacity:1, translateY:0. The other catalog falls back to
     base (opacity:0, translateY:14px) and fades down/out
     simultaneously — true cross-fade.

     parent .v2-tier-expand-inner has overflow:hidden which
     clips both catalogs in non-l2/l3 states (where the parent
     is collapsed via grid-template-rows:0fr), so there's no
     visual leak when the section is closed. */
  .v2-tier-catalog {
    display: block;
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(14px);
    pointer-events: none;
    transition:
      opacity 0.7s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .v2-selector.state-l2 .v2-tier-catalog[data-tier-catalog="l2"],
  .v2-selector.state-l3 .v2-tier-catalog[data-tier-catalog="l3"] {
    /* Active: take layout space (drives parent height) and
       become fully visible. */
    position: relative;
    inset: auto;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .v2-selector-head,
    .v2-tier-tabs,
    .v2-tier-row,
    .v2-tier-morph,
    .v2-tier-expand {
      transition: none;
    }
  }
  .v2-catalog-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    /* Apple-light mode: ultra-subtle warm-white wash so the
       backdrop has a hint of depth instead of feeling flat. */
    background:
      radial-gradient(ellipse 60% 40% at 8% 88%, rgba(45, 200, 86, 0.025) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 92% 12%, rgba(0, 0, 0, 0.02) 0%, transparent 70%);
  }
  .v2-catalog-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    /* Hairline dot pattern in dark — gives the section a quiet
       structure (Apple-style "whisper" pattern) without becoming
       a feature itself. */
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.025) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 92%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 92%);
  }

  .v2-catalog-inner {
    position: relative;
    z-index: 1;
    max-width: 1220px;
    margin: 0 auto;
  }
  .v2-selector-inner {
    position: relative;
    z-index: 1;
    /* Wired to GRID COLUMN 3 of the section (between the two
       1fr gutters). The grid track itself caps the inner's
       width at 1640 via `minmax(0, 1640px)`. */
    grid-column: 3;
    /* Switched from `display: flex; flex-direction: column;
       align-items: stretch` to plain `display: block`. With
       block layout, every block-level child (head, tabs, tier-
       row, tier-expand, bottom-zone, footnote) naturally fills
       100% of the inner's width with NO ambiguity — there is no
       `align-items: stretch` cross-axis quirk to worry about.
       This was the root of the user's recurring "L3 card right
       edge stops short of the brand button's right edge"
       complaint: in some flex-column contexts, `stretch` was
       leaving the tier-row sized to its grid-cell intrinsic
       content rather than the inner's full width. With block,
       both rows are GUARANTEED identical width. */
    display: block;
  }
  /* Vertical rhythm between selector-inner's children — replaces
     the gap that used to come from the flex container. Tightened
     from 0.7-1.2rem to 0.5-0.9rem to keep the closed-state stack
     within 100vh after the tier-row gained shadow-fade padding. */
  .v2-selector-inner > * + * {
    margin-top: clamp(0.5rem, 0.9vw, 0.9rem);
  }

  /* ── Heads (shared eyebrow/title/sub) ──────────────────── */
  .v2-catalog-head,
  .v2-selector-head {
    text-align: center;
    position: relative;
  }
  .v2-catalog-head { margin-bottom: clamp(2rem, 3vw, 3rem); }
  .v2-eyebrow,
  .v2-catalog-eyebrow {
    display: inline-block;
    padding: 4px 12px;
    border: 1px solid rgba(45, 200, 86, 0.45);
    border-radius: 999px;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #2DC856;
    background: rgba(45, 200, 86, 0.06);
  }
  .v2-catalog-title,
  .v2-selector-title {
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: #1d1d1f;
  }
  .v2-catalog-title { margin: 14px 0 8px; font-size: clamp(1.75rem, 3.6vw, 2.75rem); }
  .v2-selector-title { margin: 6px 0 4px; font-size: clamp(1.55rem, 2.9vw, 2.2rem); }
  .v2-selector-title-or {
    font-weight: 400;
    color: #aeaeb2;
    font-style: italic;
    padding: 0 0.2em;
  }
  .v2-catalog-sub,
  .v2-selector-sub {
    margin: 0 auto;
    max-width: 58ch;
    line-height: 1.55;
    color: #6e6e73;
  }
  .v2-catalog-sub { font-size: 0.98rem; }
  .v2-selector-sub { font-size: 0.92rem; max-width: 52ch; }

  /* "Back to tier selector" pill above the card list — shows
     only when tier-swap is meaningful (i.e. always, on v2). */
  .v2-tier-swap {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 18px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: inherit;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease, transform 0.18s ease;
  }
  .v2-tier-swap svg { width: 12px; height: 12px; }
  .v2-tier-swap:hover {
    color: #2DC856;
    background: rgba(45, 200, 86, 0.08);
    border-color: rgba(45, 200, 86, 0.34);
    transform: translateY(-1px);
  }
  .v2-tier-swap:focus-visible {
    outline: 2px solid rgba(45, 200, 86, 0.65);
    outline-offset: 3px;
  }

  /* ── Selector cards ──────────────────────────────────────
     Layout:
       row 1: [ L2 card ]      [ L3 card ]      — dominant
       row 2: [ Brand card — spans both, short ] — default pick
     Total vertical budget for the card cluster is tight so the
     whole section fits 100vh. Row-1 cards are clamp-sized
     against viewport height (aspect-ratio does most of the
     work) and row-2 is a compact strip. */
  .v2-selector-cards {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(0.8rem, 1.2vw, 1.25rem);
  }
  .v2-selector-card {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
    /* Card height budget: tuned so two row-1 cards + the row-2
       brand strip + head + chart-footnote stay inside 100vh on
       common laptops (720p and up). Trimmed from 280/34vh/380 to
       240/30vh/340 to claw back ~40px after the tier-row gained
       padding-bottom for shadow-fade space. The lower bound (340)
       kicks in when the viewport is very short; the vh-term
       carries it up cleanly on taller monitors. */
    min-height: clamp(240px, 30vh, 340px);
    background: #ffffff;
    border: var(--hairline);
    border-radius: 22px;
    /* Picker is a focal card → tier 2 (medium) at rest, tier 3
       (high) on hover. Tokens are defined on .v2-selector. */
    box-shadow: var(--elev-2);
    color: inherit;
    font-family: inherit;
    cursor: pointer;
    text-align: left;
    transition:
      transform var(--duration-hover) var(--ease),
      box-shadow var(--duration-hover) var(--ease),
      border-color var(--duration-hover) var(--ease);
  }
  /* Top accent — acts as a real LED strip along the card's top
     edge. The line itself is a 3px emitter with a vertical
     gradient from a brightened "filament" tip to the brand color
     body, so it reads as a lit LED viewed at angle (you can see
     its hot core). On top of that, a 7-layer box-shadow casts:
       1) a white-hot pinpoint halo (the brightest core spill)
       2) a vivid color halo (the LED's own bloom)
       3) a bright bloom layer (atmospheric haze)
       4-6) progressively wider downward washes (the light
            cascading down into the card body, like a stage
            lamp lighting the surface below it)
       7) a deep ambient room-light layer (faint colored wash
          through the lower half of the card)
     The parent's overflow:hidden clips every layer to the rounded
     silhouette so the glow lives INSIDE the card surface — never
     floats around the perimeter. The whole stack is anchored to
     the line, so as scaleX grows 0→1 the light grows with it. */
  .v2-selector-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(180deg, #7DFA9F 0%, #2DC856 100%);
    transform: scaleX(0);
    transform-origin: 50% 50%;
    box-shadow:
      0 0 4px rgba(125, 250, 159, 0.95),
      0 0 12px rgba(45, 200, 86, 0.95),
      0 0 24px rgba(45, 200, 86, 0.78),
      0 8px 30px rgba(45, 200, 86, 0.62),
      0 20px 56px rgba(45, 200, 86, 0.40),
      0 40px 100px rgba(45, 200, 86, 0.22),
      0 70px 180px rgba(45, 200, 86, 0.10);
    transition: transform 0.5s cubic-bezier(0.25, 0, 0, 1);
    z-index: 3;
    pointer-events: none;
  }
  /* L3 picker — same LED treatment in cyan. The brand cyan
     `#68d8e8` reads slightly cooler than green so the alpha
     values are bumped a touch in the deeper layers to keep the
     two cards reading at equal optical intensity. */
  .v2-selector-card[data-select-tier="l3"]::before {
    background: linear-gradient(180deg, #C2F4FB 0%, #68d8e8 100%);
    box-shadow:
      0 0 4px rgba(194, 244, 251, 0.95),
      0 0 12px rgba(104, 216, 232, 0.95),
      0 0 24px rgba(104, 216, 232, 0.82),
      0 8px 30px rgba(104, 216, 232, 0.65),
      0 20px 56px rgba(104, 216, 232, 0.44),
      0 40px 100px rgba(104, 216, 232, 0.24),
      0 70px 180px rgba(104, 216, 232, 0.12);
  }
  .v2-selector-card:hover,
  .v2-selector-card:focus-visible {
    transform: translateY(var(--lift-md));
    border: var(--hairline-hover);
    box-shadow: var(--elev-3-hover);
    outline: none;
  }
  .v2-selector-card:hover::before,
  .v2-selector-card:focus-visible::before {
    transform: scaleX(0.6);
  }
  .v2-selector-card:active {
    transform: translateY(var(--press));
    transition: transform var(--duration-press) var(--ease);
  }

  .v2-sel-stage {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: clamp(10px, 1.4vw, 18px);
    /* Stage backdrop — pure white at top (catches the most light
       from the section's overhead source), softening to off-
       white at the floor where the pedestal shadow sits. Reads
       as a real lit alcove, not a flat color block. */
    background: linear-gradient(180deg, #ffffff 0%, #f6f6f8 100%);
    overflow: hidden;
  }
  .v2-sel-img-wrap {
    position: relative;
    z-index: 2;
    max-width: 62%;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .v2-sel-img {
    max-height: clamp(135px, 16vh, 195px);
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    /* Soft realistic shadow on white — Apple-style: diffuse, low-
       opacity. No green glow. */
    filter: drop-shadow(0 18px 14px rgba(0, 0, 0, 0.12)) drop-shadow(0 4px 6px rgba(0, 0, 0, 0.06));
    transition: transform 0.25s cubic-bezier(0.25, 0, 0, 1), filter 0.25s ease;
  }
  .v2-sel-reflection {
    position: absolute;
    top: 100%;
    left: 50%;
    max-height: clamp(60px, 8vh, 90px);
    width: auto;
    height: 40%;
    transform: translateX(-50%) translateY(-6px) scaleY(-1);
    transform-origin: top center;
    opacity: 0.08;
    filter: blur(0.4px);
    mask-image: linear-gradient(to bottom, black 0%, transparent 65%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 65%);
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .v2-selector-card:hover .v2-sel-img,
  .v2-selector-card:focus-visible .v2-sel-img {
    transform: translateY(-6px) scale(1.05);
    filter: drop-shadow(0 28px 22px rgba(0, 0, 0, 0.16)) drop-shadow(0 6px 10px rgba(0, 0, 0, 0.1));
    transition-duration: 0.4s;
  }
  .v2-selector-card:hover .v2-sel-reflection,
  .v2-selector-card:focus-visible .v2-sel-reflection { opacity: 0.12; }

  .v2-sel-body {
    position: relative;
    padding: clamp(1rem, 1.6vw, 1.4rem) clamp(1.5rem, 2.4vw, 2.15rem) clamp(1.15rem, 1.7vw, 1.55rem);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    background: #ffffff;
    z-index: 2;
  }
  .v2-sel-badge {
    display: inline-block;
    padding: 4px 11px;
    border: 1px solid rgba(45, 200, 86, 0.45);
    border-radius: 999px;
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #2DC856;
    background: rgba(45, 200, 86, 0.1);
  }
  .v2-sel-badge--dc {
    border-color: rgba(40, 145, 165, 0.5);
    color: #1d6d7a;
    background: rgba(80, 200, 220, 0.14);
  }
  .v2-sel-title {
    margin: 10px 0 8px;
    font-size: clamp(1.85rem, 2.9vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.022em;
    line-height: 1;
    color: #1d1d1f;
  }
  .v2-sel-stat {
    margin: 0 0 12px;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-family: 'Maven Pro', sans-serif;
    color: #1d1d1f;
  }
  .v2-sel-stat-num {
    font-size: clamp(1.05rem, 1.45vw, 1.25rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #2DC856;
  }
  .v2-selector-card[data-select-tier="l3"] .v2-sel-stat-num {
    color: #1d6d7a;
  }
  .v2-sel-stat-unit {
    font-size: 0.78rem;
    font-weight: 700;
    color: #6e6e73;
  }
  .v2-sel-stat-sep {
    font-size: 0.78rem;
    color: #aeaeb2;
    margin: 0 3px;
  }
  .v2-sel-stat-time {
    font-size: 0.78rem;
    font-weight: 600;
    color: #6e6e73;
  }
  .v2-sel-desc {
    margin: 0 0 16px;
    font-size: 0.9rem;
    line-height: 1.55;
    color: #6e6e73;
    max-width: 50ch;
  }
  .v2-sel-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    border-radius: 999px;
    background: #2DC856;
    color: #ffffff;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    /* Apple-style two-layer shadow on the CTA: tight contact +
       soft drop with a brand-green tinge. Reads as a real
       physical button. */
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.25),
      0 6px 18px rgba(45, 200, 86, 0.32);
    transition:
      background 0.22s cubic-bezier(0.25, 0, 0, 1),
      transform 0.22s cubic-bezier(0.25, 0, 0, 1),
      gap 0.22s cubic-bezier(0.25, 0, 0, 1),
      box-shadow 0.22s cubic-bezier(0.25, 0, 0, 1);
  }
  .v2-sel-cta--dc {
    background: #5dc4d8;
    box-shadow:
      0 1px 2px rgba(80, 200, 220, 0.25),
      0 6px 18px rgba(80, 200, 220, 0.32);
  }
  .v2-sel-cta svg { width: 14px; height: 14px; display: block; }
  /* L2 hover — the button GLOWS BRIGHTER GREEN. Background lifts
     to a more luminous green (above the resting #2DC856), and a
     filament-tipped halo blooms around it via a 4-layer shadow
     stack with brand-color tint. Reads as a real lit emitter
     rather than a darker pressed-down variant. */
  .v2-selector-card:hover .v2-sel-cta,
  .v2-selector-card:focus-visible .v2-sel-cta {
    background: #3DD667;
    transform: translateY(-2px);
    gap: 12px;
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.4),
      0 6px 16px rgba(45, 200, 86, 0.5),
      0 14px 32px rgba(45, 200, 86, 0.5),
      0 0 28px rgba(125, 250, 159, 0.55);
  }
  /* L3 hover — the button GLOWS BRIGHTER BLUE. Same idea as L2
     but in cyan: brighter background + cyan-filament halo bloom.
     Crucially, this rule must override the green hover background
     defined above (the L2 selector matches both buttons), so the
     L3 button stays in its own color family on hover. */
  .v2-selector-card:hover .v2-sel-cta--dc,
  .v2-selector-card:focus-visible .v2-sel-cta--dc {
    background: #82E2F2;
    box-shadow:
      0 1px 2px rgba(80, 200, 220, 0.4),
      0 6px 16px rgba(80, 200, 220, 0.5),
      0 14px 32px rgba(80, 200, 220, 0.55),
      0 0 28px rgba(194, 244, 251, 0.6);
  }

  /* ════════════════════════════════════════════════════════════════════
     BRAND MORPH — IN-SELECTOR, SELF-CONTAINED.

     The `<div class="v2-brand-morph">` lives INSIDE the selector's
     content stack (below the L2 / L3 cards, above the chart button
     footnote). It's the SAME element in both visual forms:

       collapsed  — narrow card / "button" spanning both columns of
                    the selector-cards grid. Header-only: 2x2 icon,
                    eyebrow, title, chevron. ~84 px tall, centered,
                    rounded 16 px corners, dark gradient background
                    with a subtle green ring.

       expanded   — the morph widens to fill the selector content
                    container, loses its card radius, drops its
                    card-only background (letting the selector's
                    own backdrop show through), and unfurls its
                    internal catalog below the header via a
                    grid-template-rows: 0fr → 1fr animation.

     The whole morph animates on a shared ~1.4 s cubic-bezier curve,
     bidirectional — scroll up past the threshold and the exact same
     animation plays in reverse. Because the morph is INSIDE the
     selector, the selector's dark backdrop flows continuously behind
     it in both states — the "page doesn't switch sections", the
     button just grows / shrinks within the selector's space.

     On expansion the selector itself grows taller than 100 vh (the
     morph's content height is added to the selector's natural height).
     When collapsed the selector returns to its compact 100 vh form.

     `.is-hidden` (set when L2 / L3 mode is active) collapses the
     morph to zero height + opacity — "as if brands weren't there"
     when the user has explicitly picked a tier. */
  /* ── Bottom zone — brand-morph + alternative-tier mini ────
     Uses FLEX (not grid) for predictable layout: brand-morph is
     the flex-grow:1 main item that fills available space; the
     tier-mini-slot is a sibling that animates its flex-basis
     from 0 (collapsed, invisible) up to a fixed width when a
     tier is active. The slot sits to the RIGHT of brand and
     never wraps below it.

     States:
       idle / brand   → slot flex-basis: 0     (slot has no width,
                                                brand fills all
                                                available space)
       l2 / l3        → slot flex-basis: 28%   (slot opens to a
                                                square on the
                                                right; brand
                                                shrinks to fill
                                                what's left) */
  /* Bottom-zone — plain block container. The actual side-by-side
     layout lives inside `.v2-bottom-row` (a markup wrapper that
     was added explicitly to guarantee brand-morph and the tier-
     mini slot are flex-row siblings, with no chance of any layout
     calculation putting them on separate lines). */
  .v2-bottom-zone {
    position: relative;
    display: block;
    width: 100%;
  }
  /* Bottom-row — flex row. Brand-morph (left, fills) + tier-mini
     slot (right, animated width 0 → square). `flex-wrap: nowrap`
     PHYSICALLY prevents the slot from dropping to a new line.
     `align-items: flex-start` keeps the slot from stretching to
     the brand-morph's full height when the catalog opens (state-
     brand). */
  .v2-bottom-row {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: flex-start;
    gap: 0;
    width: 100%;
    transition: gap 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v2-selector.state-l2 .v2-bottom-row,
  .v2-selector.state-l3 .v2-bottom-row {
    gap: clamp(0.8rem, 1.5vw, 1.5rem);
  }
  /* Brand-morph — fills row left side. min-width:0 lets it
     shrink so the slot's reserved width on the right is honored. */
  .v2-brand-morph {
    flex: 1 1 0%;
    min-width: 0;
  }
  /* Tier-mini slot — explicit width animation 0 → clamp(...).
     Explicit height keeps it sized to the brand button row only,
     never inflating to match the brand-morph's full expanded
     height (which gets very tall in state-brand). */
  .v2-tier-mini-slot {
    flex: 0 0 auto;
    width: 0;
    height: clamp(150px, 18vh, 200px);
    overflow: hidden;
    transition: width 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v2-selector.state-l2 .v2-tier-mini-slot,
  .v2-selector.state-l3 .v2-tier-mini-slot {
    width: clamp(280px, 32%, 380px);
  }

  /* Tier-mini button — Apple-white, multi-layer shadow. */
  .v2-tier-mini {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 10px;
    width: 100%;
    height: 100%;
    min-height: clamp(96px, 12vh, 132px);
    padding: clamp(1rem, 1.6vw, 1.4rem) clamp(1.1rem, 1.8vw, 1.5rem);
    background: #ffffff;
    border: var(--hairline);
    border-radius: 22px;
    text-align: left;
    cursor: pointer;
    font-family: 'Maven Pro', sans-serif;
    color: inherit;
    /* Tier-mini sits at tier 1 — small/secondary in the
       hierarchy, but still a real surface, not flat. Lifts to
       tier 2 on hover. */
    box-shadow: var(--elev-1);
    transition:
      transform var(--duration-hover) var(--ease),
      box-shadow var(--duration-hover) var(--ease),
      border-color var(--duration-hover) var(--ease);
    position: relative;
  }
  /* Top accent — same 7-layer cinematic LED stack as the picker
     cards. Tier-mini is a smaller card so the deeper ambient
     layers fill more of its body proportionally — that's the
     point: the WHOLE button glows from within. */
  .v2-tier-mini {
    overflow: hidden;
  }
  .v2-tier-mini::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(180deg, #7DFA9F 0%, #2DC856 100%);
    transform: scaleX(0);
    transform-origin: 50% 50%;
    box-shadow:
      0 0 4px rgba(125, 250, 159, 0.95),
      0 0 12px rgba(45, 200, 86, 0.95),
      0 0 24px rgba(45, 200, 86, 0.78),
      0 8px 30px rgba(45, 200, 86, 0.62),
      0 20px 56px rgba(45, 200, 86, 0.40),
      0 40px 100px rgba(45, 200, 86, 0.22),
      0 70px 180px rgba(45, 200, 86, 0.10);
    transition: transform 0.5s cubic-bezier(0.25, 0, 0, 1);
    z-index: 2;
    pointer-events: none;
  }
  .v2-tier-mini[data-tier-mini="l3"]::before {
    background: linear-gradient(180deg, #C2F4FB 0%, #68d8e8 100%);
    box-shadow:
      0 0 4px rgba(194, 244, 251, 0.95),
      0 0 12px rgba(104, 216, 232, 0.95),
      0 0 24px rgba(104, 216, 232, 0.82),
      0 8px 30px rgba(104, 216, 232, 0.65),
      0 20px 56px rgba(104, 216, 232, 0.44),
      0 40px 100px rgba(104, 216, 232, 0.24),
      0 70px 180px rgba(104, 216, 232, 0.12);
  }
  @keyframes v2-tier-mini-enter {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .v2-selector.state-l2 .v2-tier-mini[data-tier-mini="l3"],
  .v2-selector.state-l3 .v2-tier-mini[data-tier-mini="l2"] {
    display: flex;
    animation: v2-tier-mini-enter 0.55s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both;
  }
  .v2-tier-mini:hover,
  .v2-tier-mini:focus-visible {
    transform: translateY(var(--lift-md));
    border: var(--hairline-hover);
    box-shadow: var(--elev-2-hover);
    outline: none;
  }
  .v2-tier-mini:hover::before,
  .v2-tier-mini:focus-visible::before {
    transform: scaleX(0.6);
  }
  .v2-tier-mini:active {
    transform: translateY(var(--press));
    transition: transform var(--duration-press) var(--ease);
  }
  /* Tag-and-arrow row — tier badge on the left, an UP arrow on
     the right edge that visually signals "go back up to the top
     of the new tier". */
  .v2-tier-mini-row {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 10px;
  }
  .v2-tier-mini-tag {
    display: inline-block;
    padding: 5px 12px;
    border: 1px solid rgba(45, 200, 86, 0.4);
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2DC856;
    background: rgba(45, 200, 86, 0.08);
    white-space: nowrap;
  }
  .v2-tier-mini-tag--dc {
    border-color: rgba(80, 200, 220, 0.45);
    color: #68d8e8;
    background: rgba(80, 200, 220, 0.08);
  }
  /* UP arrow — gives a clear visual signal that clicking sends
     the user back UP to the beginning of the OTHER tier's view. */
  .v2-tier-mini-arrow {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: rgba(45, 200, 86, 0.85);
    transition: transform 0.25s ease;
  }
  .v2-tier-mini[data-tier-mini="l3"] .v2-tier-mini-arrow {
    color: rgba(104, 216, 232, 0.9);
  }
  .v2-tier-mini:hover .v2-tier-mini-arrow {
    transform: translateY(-3px);
  }
  .v2-tier-mini-headline {
    font-size: clamp(0.85rem, 1.05vw, 1rem);
    font-weight: 700;
    letter-spacing: -0.005em;
    line-height: 1.25;
    color: #1d1d1f;
  }
  .v2-tier-mini-sub {
    font-size: 0.74rem;
    line-height: 1.45;
    font-weight: 500;
    color: #6e6e73;
    display: block;
  }

  .v2-brand-morph {
    position: relative;
    display: block;
    background: #ffffff;
    border: var(--hairline);
    border-radius: 22px;
    /* Same elevation tier as the picker cards — they sit on the
       same row, same hierarchy, same shadow language. */
    box-shadow: var(--elev-2);
    overflow: hidden;
    cursor: pointer;
    transition:
      background 1s cubic-bezier(0.22, 1, 0.36, 1),
      border-color var(--duration-hover) var(--ease),
      border-radius 1s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow var(--duration-hover) var(--ease),
      transform var(--duration-hover) var(--ease),
      max-height 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.5s ease;
    max-height: 5000px;
    opacity: 1;
  }
  /* Top accent — same 7-layer cinematic LED stack as the picker
     cards. Parent has overflow:hidden so all bleed stays inside
     the morph silhouette. Disappears once the morph opens since
     the header turns into a section header at that point. */
  .v2-brand-morph::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(180deg, #7DFA9F 0%, #2DC856 100%);
    transform: scaleX(0);
    transform-origin: 50% 50%;
    box-shadow:
      0 0 4px rgba(125, 250, 159, 0.95),
      0 0 12px rgba(45, 200, 86, 0.95),
      0 0 24px rgba(45, 200, 86, 0.78),
      0 8px 30px rgba(45, 200, 86, 0.62),
      0 20px 56px rgba(45, 200, 86, 0.40),
      0 40px 100px rgba(45, 200, 86, 0.22),
      0 70px 180px rgba(45, 200, 86, 0.10);
    transition: transform 0.5s cubic-bezier(0.25, 0, 0, 1);
    z-index: 2;
    pointer-events: none;
  }
  .v2-brand-morph:not(.is-open):hover {
    transform: translateY(var(--lift-md));
    border: var(--hairline-hover);
    box-shadow: var(--elev-3-hover);
  }
  .v2-brand-morph:not(.is-open):hover::before {
    transform: scaleX(0.6);
  }
  .v2-brand-morph.is-open::before {
    transform: scaleX(0);
  }
  .v2-brand-morph:not(.is-open):active {
    transform: translateY(var(--press));
    transition: transform var(--duration-press) var(--ease);
  }
  .v2-brand-morph.is-open {
    background: transparent;
    border-color: transparent;
    border-radius: 0;
    box-shadow: none;
    cursor: default;
  }
  /* When L2 / L3 mode is active, the morph collapses to zero and
     fades out — cleaner than leaving the button floating there
     when the user has explicitly picked a tier. */
  .v2-brand-morph.is-hidden {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    margin: 0;
  }

  /* HEADER — always rendered. Acts as the button row when
     collapsed and as the section-header row when expanded.
     Grid columns stay the same; only spacing + typography
     scale between states. */
  .v2-brand-morph-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(0.9rem, 1.6vw, 1.4rem);
    padding: clamp(0.85rem, 1.4vw, 1.2rem) clamp(1.1rem, 1.8vw, 1.6rem);
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition:
      padding 1.2s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.8s ease 0.4s,
      background 0.35s ease;
    outline: none;
  }
  .v2-brand-morph-header:hover,
  .v2-brand-morph-header:focus-visible {
    background: rgba(45, 200, 86, 0.04);
  }
  .v2-brand-morph-header:focus-visible {
    outline: 2px solid rgba(45, 200, 86, 0.55);
    outline-offset: -4px;
  }
  .v2-brand-morph.is-open .v2-brand-morph-header {
    cursor: default;
    padding: clamp(1.75rem, 2.8vw, 2.5rem) 4px clamp(1.25rem, 2vw, 1.75rem);
    border-bottom-color: rgba(0, 0, 0, 0.08);
    background: transparent;
  }
  .v2-brand-morph.is-open .v2-brand-morph-header:hover {
    background: transparent;
  }

  /* 2x2 icon */
  .v2-brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(40px, 4.6vw, 52px);
    height: clamp(40px, 4.6vw, 52px);
    flex-shrink: 0;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.08);
    color: #1d1d1f;
    background: rgba(0, 0, 0, 0.02);
    transition:
      background 0.4s cubic-bezier(0.25, 0, 0, 1),
      border-color 0.4s cubic-bezier(0.25, 0, 0, 1),
      color 0.4s cubic-bezier(0.25, 0, 0, 1),
      transform 0.3s cubic-bezier(0.25, 0, 0, 1);
  }
  .v2-brand-mark svg { width: 58%; height: 58%; display: block; }
  .v2-brand-morph-header:hover .v2-brand-mark {
    background: rgba(45, 200, 86, 0.12);
    border-color: rgba(45, 200, 86, 0.5);
    color: #2DC856;
    transform: scale(1.04);
  }
  .v2-brand-morph.is-open .v2-brand-mark {
    background: rgba(45, 200, 86, 0.14);
    border-color: rgba(45, 200, 86, 0.5);
    color: #2DC856;
  }

  .v2-brand-btn-copy {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }
  .v2-brand-btn-eyebrow {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6e6e73;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.8s ease;
  }
  .v2-brand-morph.is-open .v2-brand-btn-eyebrow {
    color: #2DC856;
  }
  .v2-brand-btn-title {
    margin: 0;
    font-size: clamp(1.1rem, 1.65vw, 1.4rem);
    font-weight: 800;
    letter-spacing: -0.018em;
    line-height: 1.1;
    color: #1d1d1f;
    transition: font-size 1.2s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v2-brand-morph.is-open .v2-brand-btn-title {
    font-size: clamp(1.55rem, 3vw, 2.3rem);
  }
  /* Hint line — subtle "scroll down to explore" prompt that
     sits below the title in the closed state. Reinforces the
     scroll-to-auto-open behavior without competing with the
     title. Fades out when the morph opens (the prompt is no
     longer relevant — the catalog is already revealed). */
  .v2-brand-btn-hint {
    margin-top: 2px;
    font-size: 0.7rem;
    font-weight: 500;
    line-height: 1.3;
    color: #8e8e93;
    letter-spacing: 0.01em;
    transition: opacity 0.5s ease, max-height 0.5s ease;
    opacity: 1;
    max-height: 1.3em;
    overflow: hidden;
  }
  .v2-brand-morph.is-open .v2-brand-btn-hint {
    opacity: 0;
    max-height: 0;
    margin-top: 0;
  }

  .v2-brand-btn-chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    color: #6e6e73;
    transition: color 0.4s ease, transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v2-brand-btn-chevron svg { width: 60%; height: 60%; display: block; }
  .v2-brand-morph-header:hover .v2-brand-btn-chevron {
    color: #2DC856;
  }
  .v2-brand-morph.is-open .v2-brand-btn-chevron {
    color: #2DC856;
    transform: rotate(180deg);
  }

  /* CONTENT — the catalog. Hidden when collapsed, revealed via
     grid-template-rows: 0fr → 1fr (the modern "height: auto"
     animation trick). Padded inside the morph so when expanded
     it visually flows from the header down into a catalog view. */
  .v2-brand-morph-content {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    /* Slowed from 1.4s/0.9s → 1.8s/1.1s for a more graceful
       reveal during the auto-open scroll-down trigger. Same
       cubic-bezier curve so the easing feel stays consistent. */
    transition:
      grid-template-rows 1.8s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 1.1s ease 0.35s;
  }
  .v2-brand-morph-content-inner {
    min-height: 0;
    overflow: hidden;
    padding: clamp(1.5rem, 2.5vw, 2.25rem) clamp(1rem, 3vw, 2rem) clamp(1.5rem, 2.5vw, 2.25rem);
  }
  .v2-brand-morph.is-open .v2-brand-morph-content {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .v2-brand-morph,
    .v2-brand-morph-header,
    .v2-brand-btn-title,
    .v2-brand-btn-chevron,
    .v2-brand-morph-content,
    .v2-brand-mark {
      transition: none !important;
    }
  }

  /* Active-selector highlighting — when the Brand panel (or
     an L2 / L3 panel) is open below, light up the matching
     selector card with a subtle green border + ambient glow
     so the user sees at a glance which view is unfolded.
     Driven by a class toggled from the script; :has() would
     work too but the class is more robust across scroll
     events and viewport sniffs. */
  /* Active state — the picker that the open panel below belongs
     to. Same lifted elevation as :hover plus a fully-revealed
     accent line, so it reads "this one is selected" via real
     elevation + lit LED rather than any colored halo. */
  .v2-selector-card.is-active {
    border: var(--hairline-hover);
    box-shadow: var(--elev-3-hover);
  }
  .v2-selector-card.is-active::before {
    transform: scaleX(1);
  }

  /* Footnote — small "i" info button for the charging speed
     reference. Deliberately understated: a tiny circular icon
     button instead of a wide pill. Only its hover state nudges
     the color up — the resting form should feel like a footnote,
     not a CTA. */
  /* Charging-speed chart trigger — looks like an actual clickable
     CTA, not a passive informational pill. Filled green tint
     with stronger border, accent-colored icon background, and a
     trailing chevron-style arrow signal "click me" clearly. */
  /* Apple-style ghost-button — clean outlined pill with brand
     green accents, no shadow on the rest state. Sits cleanly on
     the off-white section background. */
  .v2-chart-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: clamp(0.65rem, 1.1vw, 1rem);
    padding: 8px 14px 8px 8px;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 999px;
    color: #1d1d1f;
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      color 0.25s cubic-bezier(0.25, 0, 0, 1),
      background 0.25s cubic-bezier(0.25, 0, 0, 1),
      border-color 0.25s cubic-bezier(0.25, 0, 0, 1),
      transform 0.2s cubic-bezier(0.25, 0, 0, 1);
  }
  .v2-chart-btn svg {
    width: 14px;
    height: 14px;
    display: block;
    flex-shrink: 0;
    padding: 4px;
    box-sizing: content-box;
    border-radius: 50%;
    background: rgba(45, 200, 86, 0.12);
    color: #2DC856;
  }
  /* Trailing INFO indicator — clean outlined circle with a
     sans-serif lowercase "i". The button has `text-transform:
     uppercase` for its label, but the pseudo-element MUST stay
     lowercase, so we explicitly reset that. Matches the button's
     text color so it lives within the same value range as the
     rest of the typography. */
  .v2-chart-btn::after {
    content: 'i';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    margin-left: 2px;
    border: 1.5px solid currentColor;
    border-radius: 50%;
    font-family: 'Maven Pro', sans-serif;
    font-style: normal;
    font-weight: 700;
    font-size: 0.7rem;
    line-height: 1;
    /* Critical — overrides the parent button's uppercase rule so
       the 'i' actually renders lowercase. */
    text-transform: none;
    padding-bottom: 1px;
    letter-spacing: -0.02em;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .v2-chart-btn:hover {
    background: #ffffff;
    border-color: #2DC856;
    color: #2DC856;
    transform: translateY(-1px);
  }
  .v2-chart-btn:hover svg {
    background: rgba(45, 200, 86, 0.18);
    color: #2DC856;
  }
  .v2-chart-btn:hover::after {
    border-color: #2DC856;
    color: #2DC856;
  }
  .v2-chart-btn:focus-visible {
    outline: 2px solid rgba(45, 200, 86, 0.55);
    outline-offset: 3px;
  }

  /* (Tab panel CSS removed — level panels are now independent
     collapsible sections, not display:none tabs.) */

  /* ═══════════════════════════════════════════════════════════════════
     Product cards — premium "display bay" lighting.

     Layered lighting stack (painted bottom-up):
       .v2-bay-floor    full-stage darker floor plane, fades
                        from mid-tone up to bottom darkness
       .v2-bay-horizon  hairline where floor meets wall
       .v2-bay-key      soft warm key light from upper-left
                        (studio spotlight)
       .v2-bay-sweep    seamless backdrop sweep — a smooth top-
                        of-wall falloff so there's no hard edge
       .v2-bay-rim      faint brand-green ambient bounce directly
                        behind/below the product (this is the
                        one accent — intentional, tight, not a
                        big green wash)
       .v2-card-reflection  mirrored duplicate of the product
                        image with a mask fade — the real "this
                        is expensive product photography" touch
       .v2-card-img     the product, with a tight professional
                        ground shadow (not a green glow)

     Compared to the earlier pass: no loud radial green blob
     under the charger, no cheesy `filter: blur(12px)` glowing
     ellipse. Every layer is intentional, geometric, and reads
     as a real lit display bay.
     ═══════════════════════════════════════════════════════════════════ */
  .v2-product-cards {
    display: flex;
    flex-direction: column;
    gap: clamp(1.25rem, 2vw, 1.75rem);
  }
  /* PRODUCT DETAIL CARD — Apple-white surface, multi-layer
     shadow stack. Larger spread than mini-cards because product
     detail cards are bigger and need more grounding. */
  .v2-card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(280px, 42%) 1fr;
    background: #ffffff;
    border: var(--hairline);
    border-radius: 22px;
    /* overflow:hidden keeps the rounded silhouette intact — the
       top accent line and its glow are clipped to follow the
       border-radius curve, so the corners stay round. */
    overflow: hidden;
    /* Product detail cards are the focal layer when an L2 / L3
       catalog is open — same elevation as the picker (tier 2),
       lifting to tier 3 on hover. */
    box-shadow: var(--elev-2);
    transition:
      transform var(--duration-hover) var(--ease),
      box-shadow var(--duration-hover) var(--ease),
      border-color var(--duration-hover) var(--ease);
  }
  /* Top accent — same 7-layer cinematic LED stack as the picker
     cards. The shadow grows with the line's scaleX, and the
     parent's overflow:hidden keeps every layer of light inside
     the card silhouette. The deepest ambient layer reaches well
     into the lower half of the card so the white surface picks
     up a faint colored wash — that's what reads as "real glow"
     vs "decal on white". */
  .v2-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(180deg, #7DFA9F 0%, #2DC856 100%);
    transform: scaleX(0);
    transform-origin: 50% 50%;
    box-shadow:
      0 0 4px rgba(125, 250, 159, 0.95),
      0 0 12px rgba(45, 200, 86, 0.95),
      0 0 24px rgba(45, 200, 86, 0.78),
      0 8px 30px rgba(45, 200, 86, 0.62),
      0 20px 56px rgba(45, 200, 86, 0.40),
      0 40px 100px rgba(45, 200, 86, 0.22),
      0 70px 180px rgba(45, 200, 86, 0.10);
    transition: transform 0.5s cubic-bezier(0.25, 0, 0, 1);
    z-index: 4;
    pointer-events: none;
  }
  .v2-card--dc::before {
    background: linear-gradient(180deg, #C2F4FB 0%, #68d8e8 100%);
    box-shadow:
      0 0 4px rgba(194, 244, 251, 0.95),
      0 0 12px rgba(104, 216, 232, 0.95),
      0 0 24px rgba(104, 216, 232, 0.82),
      0 8px 30px rgba(104, 216, 232, 0.65),
      0 20px 56px rgba(104, 216, 232, 0.44),
      0 40px 100px rgba(104, 216, 232, 0.24),
      0 70px 180px rgba(104, 216, 232, 0.12);
  }
  .v2-card:hover {
    transform: translateY(var(--lift-md));
    border: var(--hairline-hover);
    box-shadow: var(--elev-3-hover);
  }
  .v2-card:hover::before {
    transform: scaleX(0.7);
  }
  .v2-card:active {
    transform: translateY(var(--press));
    transition: transform var(--duration-press) var(--ease);
  }

  /* ── Card stage — Apple-white, pedestal shadow under product. */
  .v2-card-stage {
    position: relative;
    min-height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.25rem 1.75rem 2.25rem;
    overflow: hidden;
    /* Same light-from-above gradient as the selector-card stage —
       the alcove behind the product is lit from the top, dimming
       slightly toward the pedestal floor. */
    background: linear-gradient(180deg, #ffffff 0%, #f6f6f8 100%);
  }

  /* Full-stage wall/floor layers — shared with the selector
     card stage via class name. */
  /* APPLE-WHITE STAGE — the dark studio bay is replaced with a
     simple Apple-style pedestal shadow under the product. Per
     the design guide: "Add a subtle radial shadow beneath the
     product (not around it)". The other bay layers
     (sweep/key/horizon/rim) are zeroed out — they were dark-mode
     decorations that don't belong on white surfaces. */
  .v2-bay-sweep,
  .v2-bay-floor,
  .v2-bay-key,
  .v2-bay-horizon,
  .v2-bay-rim {
    position: absolute;
    pointer-events: none;
  }
  /* Sweep / key / horizon / rim — disabled on white. */
  .v2-bay-sweep,
  .v2-bay-key,
  .v2-bay-horizon,
  .v2-bay-rim,
  .v2-bay-rim--dc {
    display: none;
  }
  /* Pedestal shadow — sits BELOW the product, fading down. This
     is the only "bay" element kept on white; it grounds the
     charger image without surrounding it with dark glow. */
  .v2-bay-floor {
    left: 12%;
    right: 12%;
    bottom: 8%;
    height: 30%;
    background: radial-gradient(ellipse 70% 100% at 50% 0%, rgba(0, 0, 0, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .v2-card:hover .v2-bay-rim,
  .v2-selector-card:hover .v2-bay-rim { opacity: 1; }

  /* Image + reflection wrapper — position:relative scopes the
     reflection's top:100% offset. */
  .v2-card-img-wrap {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .v2-card-img {
    max-height: 260px;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    /* Soft Apple-style ground shadow — diffuse, low-opacity. */
    filter:
      drop-shadow(0 20px 16px rgba(0, 0, 0, 0.12))
      drop-shadow(0 4px 8px rgba(0, 0, 0, 0.06));
    transition: transform 0.3s cubic-bezier(0.25, 0, 0, 1), filter 0.3s ease;
  }
  /* Mirrored duplicate — this is the single most "expensive"-
     looking touch. Lives right below the real image, fades
     into nothing via a mask. Slight blur hints at glossy floor
     diffusion. */
  .v2-card-reflection {
    position: absolute;
    top: 100%;
    left: 50%;
    max-height: 90px;
    width: auto;
    height: 38%;
    transform: translateX(-50%) translateY(-8px) scaleY(-1);
    transform-origin: top center;
    opacity: 0.08;
    filter: blur(0.6px);
    mask-image: linear-gradient(to bottom, black 0%, transparent 65%);
    -webkit-mask-image: linear-gradient(to bottom, black 0%, transparent 65%);
    pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .v2-card:hover .v2-card-img {
    transform: translateY(-4px) scale(1.03);
    /* Soft Apple-style hover shadow — slightly more pronounced. */
    filter:
      drop-shadow(0 26px 20px rgba(0, 0, 0, 0.14))
      drop-shadow(0 6px 10px rgba(0, 0, 0, 0.08));
  }
  .v2-card:hover .v2-card-reflection { opacity: 0.12; }

  /* ── Card body (info pane) ────────────────────────────── */
  .v2-card-body {
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 2.2vw, 2rem) clamp(1.5rem, 2.4vw, 2.25rem);
    min-width: 0;     /* let content wrap inside a grid column */
  }
  .v2-card-head {
    margin-bottom: 1.25rem;
  }
  .v2-card-tag {
    display: inline-block;
    /* align-self:flex-start prevents the tag from being stretched
       to cross-axis full-width when its parent is a flex column
       (e.g. .v2-mini-body, where align-items defaults to stretch).
       In non-flex parents like .v2-card-head's <header>, this
       property is ignored — so the rule is safe globally. The tag
       now reads as a proper content-width pill in all contexts. */
    align-self: flex-start;
    text-align: center;
    padding: 4px 12px;
    margin-bottom: 10px;
    border: 1px solid rgba(45, 200, 86, 0.45);
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #2DC856;
    background: rgba(45, 200, 86, 0.1);
  }
  .v2-card-tag--dc {
    border-color: rgba(40, 145, 165, 0.5);
    color: #1d6d7a;
    background: rgba(80, 200, 220, 0.14);
  }
  .v2-card-title {
    margin: 0 0 6px;
    font-size: clamp(1.2rem, 1.8vw, 1.55rem);
    font-weight: 800;
    letter-spacing: -0.015em;
    line-height: 1.12;
    color: #1d1d1f;
  }
  .v2-card-sub {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.5;
    color: #6e6e73;
  }

  .v2-card-specs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.9rem 1.25rem;
    padding: 1.1rem 0 1.2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .v2-spec { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .v2-spec-label {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6e6e73;
  }
  .v2-spec-value {
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.35;
    color: #1d1d1f;
    overflow-wrap: break-word;
  }

  .v2-card-builtfor {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    padding: 0.95rem 0 0;
  }
  .v2-builtfor-label {
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #6e6e73;
    margin-right: 2px;
  }
  .v2-builtfor-pills {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .v2-builtfor-pill {
    display: inline-flex;
    align-items: center;
    padding: 4px 11px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.08);
    font-size: 0.7rem;
    font-weight: 700;
    color: #1d1d1f;
    text-decoration: none;
    transition: background 0.18s ease, border-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .v2-builtfor-pill:hover {
    background: rgba(45, 200, 86, 0.12);
    border-color: rgba(45, 200, 86, 0.5);
    color: #2DC856;
    transform: translateY(-1px);
  }
  .v2-builtfor-pill:focus-visible {
    outline: 2px solid rgba(45, 200, 86, 0.65);
    outline-offset: 2px;
  }

  /* ── CTA ─────────────────────────────────────────────── */
  .v2-card-cta {
    margin-top: auto;
    padding-top: 1.3rem;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ffffff;
  }
  .v2-card-cta > span {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 12px 38px 12px 24px;
    background: #2DC856;
    border-radius: 999px;
    /* Apple two-layer button shadow with brand-green tinge. */
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.25),
      0 6px 18px rgba(45, 200, 86, 0.32);
    transition:
      background 0.22s cubic-bezier(0.25, 0, 0, 1),
      transform 0.22s cubic-bezier(0.25, 0, 0, 1),
      box-shadow 0.22s cubic-bezier(0.25, 0, 0, 1);
  }
  .v2-card-cta svg {
    width: 14px;
    height: 14px;
    display: block;
    margin-left: -28px;
    transform: translateX(0);
    transition: transform 0.22s cubic-bezier(0.25, 0, 0, 1);
    color: currentColor;
    position: relative;
    z-index: 2;
  }
  /* L2 hover — port the GLOWING GREEN treatment from the picker
     CTA (.v2-sel-cta hover) so the request-quote pill on each
     L2 product card gets the same "lit emitter" feel: a brighter
     green background (#3DD667 — above the resting #2DC856) and
     a 4-layer brand-tinted shadow stack ending in a filament-
     tip-color (#7DFA9F at 0.55) bloom. The L3/DC override
     further down already has the cyan equivalent. */
  .v2-card-cta:hover > span {
    background: #3DD667;
    transform: translateY(-2px);
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.4),
      0 6px 16px rgba(45, 200, 86, 0.5),
      0 14px 32px rgba(45, 200, 86, 0.5),
      0 0 28px rgba(125, 250, 159, 0.55);
  }
  .v2-card-cta:hover svg { transform: translateX(3px); }
  .v2-card-cta:active > span {
    transform: translateY(0);
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.25),
      0 4px 12px rgba(45, 200, 86, 0.3);
    transition: transform 0.12s cubic-bezier(0.25, 0, 0, 1);
  }

  /* ── L3 / DC — cyan-themed Request quote button ─────────────
     The L3 detail cards use the cyan family throughout (top
     accent rule, tag pill, power stat). Their quote button
     inherits that vocabulary instead of green. Same elevation
     + falloff shape as the green button — just cyan tints, a
     brighter cyan on hover, and a filament-cyan halo bloom for
     the "lit" effect (matching the L3 picker CTA's hover). */
  .v2-card--dc .v2-card-cta > span {
    background: #5dc4d8;
    box-shadow:
      0 1px 2px rgba(80, 200, 220, 0.25),
      0 6px 18px rgba(80, 200, 220, 0.32);
  }
  .v2-card--dc .v2-card-cta:hover > span {
    background: #82E2F2;
    box-shadow:
      0 1px 2px rgba(80, 200, 220, 0.4),
      0 6px 16px rgba(80, 200, 220, 0.5),
      0 14px 32px rgba(80, 200, 220, 0.55),
      0 0 28px rgba(194, 244, 251, 0.6);
  }
  .v2-card--dc .v2-card-cta:active > span {
    box-shadow:
      0 1px 2px rgba(80, 200, 220, 0.25),
      0 4px 12px rgba(80, 200, 220, 0.3);
  }

  /* ═══════════════════════════════════════════════════════════════════
     Deep-link offset — the shared /products hash links also land
     here; account for the lefter being 80 px wide by leaving an
     ~10 px gap above the targeted card.
     ═══════════════════════════════════════════════════════════════════ */
  .v2-card {
    scroll-margin-top: 24px;
  }

  /* ═══════════════════════════════════════════════════════════════════
     Chart overlay — keeps the selection section visible behind it.
     Subtle backdrop (40% darken + light blur) instead of nearly-
     opaque, smaller content cap (760 px instead of 1100), so the
     chart reads as "an inline reference popping up" rather than
     a full-screen modal that displaces the whole section.
     ═══════════════════════════════════════════════════════════════════ */
  .v2-chart-overlay[hidden] { display: none; }
  .v2-chart-overlay {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    left: var(--lefter-width, 80px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(20px, 4vw, 60px);
    animation: v2-chart-fade-in 0.22s ease-out;
  }
  @keyframes v2-chart-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  /* Lighter backdrop so the selection section stays visible
     (just dimmed + slightly blurred) behind the chart popup. */
  .v2-chart-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(6, 12, 16, 0.42);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    cursor: pointer;
  }
  .v2-chart-content {
    position: relative;
    z-index: 1;
    /* Cap width at 760 px — chart still readable, but the section
       behind it stays visible on a normal-width monitor. */
    max-width: min(760px, 100%);
    max-height: min(80vh, 600px);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: v2-chart-rise 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes v2-chart-rise {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0)    scale(1);    }
  }
  .v2-chart-img {
    display: block;
    width: 100%;
    height: auto;
    max-height: calc(100vh - clamp(40px, 8vw, 120px));
    object-fit: contain;
    border-radius: 14px;
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.55),
      0 4px 16px rgba(0, 0, 0, 0.32),
      0 0 0 1px rgba(45, 200, 86, 0.12);
    user-select: none;
  }
  .v2-chart-close {
    position: absolute;
    top: clamp(-12px, -0.6vw, -8px);
    right: clamp(-12px, -0.6vw, -8px);
    width: clamp(34px, 3.4vw, 42px);
    height: clamp(34px, 3.4vw, 42px);
    padding: 0;
    border: 0;
    background: #2DC856;
    color: #0d1a22;
    border-radius: 50%;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 6px 18px rgba(45, 200, 86, 0.45),
      0 0 0 2px rgba(10, 18, 22, 0.75);
    transition: transform 0.18s ease, background 0.18s ease;
    z-index: 2;
  }
  .v2-chart-close svg { width: 52%; height: 52%; display: block; }
  .v2-chart-close:hover {
    background: #36e464;
    transform: scale(1.08) rotate(90deg);
  }
  :global(body.chart-overlay-open) { overflow: hidden; }

  /* ═══════════════════════════════════════════════════════════════════
     BOOKMARKS
     ───────────────────────────────────────────────────────────────────
     Three pieces of UI:
       1. .v2-bookmark-btn — a glass-pill toggle on each product
          card (top-right of the card stage). Outline icon when
          unsaved; brand-color filled icon when saved.
       2. .v2-saved-chip — fixed-position pill (bottom-right of
          viewport) showing the saved count. Hidden when count is
          zero. Acts as the open-drawer affordance.
       3. .v2-saved-drawer — slide-in panel from the right with
          the saved list. Apple-glass treatment matching the rest
          of the white-mode vocabulary.

     Persistence is localStorage; UI is event-driven (every
     bookmark UI element listens for `evium:bookmarks-changed`).
     ═══════════════════════════════════════════════════════════════════ */

  /* ── BOOKMARK BUTTON ──────────────────────────────────────── */
  .v2-bookmark-btn {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 5;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 50%;
    /* Glass background — matches the card's white surface but
       with a hint of frost so the icon stays legible over the
       lit product image below. */
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(10px) saturate(150%);
    -webkit-backdrop-filter: blur(10px) saturate(150%);
    color: #1d1d1f;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 1px 2px rgba(13, 28, 36, 0.06),
      0 4px 10px rgba(13, 28, 36, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
    transition:
      transform 0.28s cubic-bezier(0.25, 0, 0, 1),
      background 0.22s ease,
      color 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.28s cubic-bezier(0.25, 0, 0, 1);
  }
  .v2-bookmark-btn--mini {
    /* Smaller card → smaller button. */
    top: 10px;
    right: 10px;
    width: 32px;
    height: 32px;
  }
  .v2-bookmark-btn svg {
    width: 50%;
    height: 50%;
    display: block;
    transition:
      transform 0.32s cubic-bezier(0.25, 0, 0, 1),
      fill 0.22s ease;
  }
  .v2-bookmark-btn--mini svg { width: 52%; height: 52%; }

  /* HOVER — lift, brand tint, soft brand glow (matches the
     card-cta vocabulary). */
  .v2-bookmark-btn:hover,
  .v2-bookmark-btn:focus-visible {
    outline: none;
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(45, 200, 86, 0.32);
    color: #2DC856;
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.18),
      0 6px 16px rgba(45, 200, 86, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }
  .v2-bookmark-btn--dc:hover,
  .v2-bookmark-btn--dc:focus-visible {
    border-color: rgba(80, 200, 220, 0.4);
    color: #1d6d7a;
    box-shadow:
      0 1px 2px rgba(80, 200, 220, 0.2),
      0 6px 16px rgba(80, 200, 220, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }

  /* SAVED state — solid brand fill, white icon, filled bookmark
     glyph. The icon's path inherits currentColor for stroke; we
     apply fill via a saved-state rule so the toggle is one
     class change. */
  .v2-bookmark-btn.is-saved {
    background: #2DC856;
    border-color: #2DC856;
    color: #ffffff;
    box-shadow:
      0 1px 2px rgba(45, 200, 86, 0.32),
      0 6px 16px rgba(45, 200, 86, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.35);
  }
  .v2-bookmark-btn--dc.is-saved {
    background: #5dc4d8;
    border-color: #5dc4d8;
    box-shadow:
      0 1px 2px rgba(80, 200, 220, 0.32),
      0 6px 16px rgba(80, 200, 220, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.35);
  }
  .v2-bookmark-btn.is-saved svg path {
    fill: currentColor;
  }

  /* TOGGLE pop — a quick scale spring on the icon when state
     flips. Triggered by a dedicated `.is-popping` class added
     by JS for one animation cycle, so the visual reads as a
     deliberate confirmation rather than just a class swap. */
  .v2-bookmark-btn.is-popping svg {
    animation: v2-bookmark-pop 0.42s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes v2-bookmark-pop {
    0%   { transform: scale(1); }
    35%  { transform: scale(1.35); }
    100% { transform: scale(1); }
  }

  .v2-bookmark-btn:active {
    transform: translateY(-1px) scale(0.96);
    transition: transform 0.12s cubic-bezier(0.25, 0, 0, 1);
  }

  /* ── SAVED CHIP — floating affordance to open the drawer ── */
  .v2-saved-chip {
    position: fixed;
    right: clamp(16px, 2vw, 28px);
    bottom: clamp(16px, 2.4vw, 28px);
    z-index: 800;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px 12px 14px;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(20px) saturate(170%);
    -webkit-backdrop-filter: blur(20px) saturate(170%);
    color: #1d1d1f;
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow:
      0 2px 6px rgba(13, 28, 36, 0.08),
      0 12px 28px rgba(13, 28, 36, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.85);
    /* Default: visible, animated in via the `is-empty` toggle
       below. The class is removed by JS once count > 0. */
    transform: translateY(0) scale(1);
    opacity: 1;
    transition:
      transform 0.42s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.32s ease,
      box-shadow 0.32s cubic-bezier(0.25, 0, 0, 1),
      border-color 0.32s ease,
      color 0.32s ease,
      background 0.32s ease;
  }
  .v2-saved-chip.is-empty {
    /* Hide entirely when the user has no saved items. */
    transform: translateY(20px) scale(0.6);
    opacity: 0;
    pointer-events: none;
  }
  /* DevToggle (the dev-mode pill, position:fixed bottom-right
     of the viewport in Layout.astro) shares the bottom-right
     real estate. When it's present AND not explicitly hidden,
     stack the saved chip ABOVE it so the two don't overlap.
     `:has()` on body matches in modern browsers; if the dev
     toggle is hidden via its own data-hidden attribute or
     entirely absent from the DOM, the chip falls back to its
     default bottom anchor. */
  :global(body:has(#dev-toggle:not([data-hidden="true"]))) .v2-saved-chip {
    bottom: calc(clamp(16px, 2.4vw, 28px) + 56px);
  }
  .v2-saved-chip-icon {
    width: 16px;
    height: 18px;
    flex: 0 0 auto;
    color: #2DC856;
    display: block;
  }
  .v2-saved-chip-label {
    /* small uppercase label — matches the section's eyebrow tone */
  }
  .v2-saved-chip-count {
    /* numerical badge — brand-tinted pill */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 7px;
    border-radius: 999px;
    background: rgba(45, 200, 86, 0.14);
    color: #2DC856;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0;
    font-variant-numeric: tabular-nums;
  }
  .v2-saved-chip:hover,
  .v2-saved-chip:focus-visible {
    outline: none;
    transform: translateY(-3px);
    border-color: rgba(45, 200, 86, 0.32);
    box-shadow:
      0 2px 6px rgba(45, 200, 86, 0.18),
      0 14px 32px rgba(45, 200, 86, 0.32),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
  }
  .v2-saved-chip:active {
    transform: translateY(-1px) scale(0.98);
    transition: transform 0.12s cubic-bezier(0.25, 0, 0, 1);
  }
  /* COUNT BUMP — when a new bookmark is added, the count pill
     gives a brief scale + brand-tint pulse so the user gets a
     visible reward for the action. */
  .v2-saved-chip.is-bumping .v2-saved-chip-count {
    animation: v2-saved-count-bump 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes v2-saved-count-bump {
    0%   { transform: scale(1); background: rgba(45, 200, 86, 0.14); }
    40%  { transform: scale(1.28); background: rgba(45, 200, 86, 0.32); }
    100% { transform: scale(1); background: rgba(45, 200, 86, 0.14); }
  }

  /* ── SAVED DRAWER — slide-in glass panel ───────────────────
     Anchored to the right side of the viewport. Width caps at
     400px on wide screens so it doesn't dominate; slides 100%
     off-screen when closed. The backdrop below it is a tinted
     frost that dims the rest of the page enough to focus
     attention on the panel without going pitch-black.

     Same Apple-glass formula as the chart-overlay panel:
       translucent white surface + strong backdrop blur +
       hairline border + inset top highlight + multi-layer
       neutral shadow. */
  .v2-saved-drawer {
    position: fixed;
    inset: 0;
    z-index: 900;
    pointer-events: none;
    /* Each child sets its own pointer-events when the drawer
       is-open. */
  }
  .v2-saved-drawer-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 24, 32, 0.18);
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
    opacity: 0;
    transition: opacity 0.4s cubic-bezier(0.25, 0, 0, 1);
  }
  .v2-saved-drawer.is-open .v2-saved-drawer-backdrop {
    opacity: 1;
    pointer-events: auto;
    cursor: pointer;
  }
  .v2-saved-drawer-panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: clamp(320px, 32vw, 420px);
    display: flex;
    flex-direction: column;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    border-left: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.55) inset,
      -8px 0 24px rgba(13, 28, 36, 0.08),
      -24px 0 60px rgba(13, 28, 36, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    transform: translateX(100%);
    transition: transform 0.45s cubic-bezier(0.25, 0, 0, 1);
  }
  .v2-saved-drawer.is-open .v2-saved-drawer-panel {
    transform: translateX(0);
    pointer-events: auto;
  }

  .v2-saved-drawer-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding: clamp(20px, 2.2vw, 28px) clamp(20px, 2vw, 24px) clamp(14px, 1.6vw, 18px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    flex: 0 0 auto;
  }
  .v2-saved-drawer-head-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .v2-saved-drawer-eyebrow {
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: #2DC856;
    line-height: 1;
  }
  .v2-saved-drawer-title {
    margin: 0;
    font-family: 'Maven Pro', sans-serif;
    font-size: clamp(1.2rem, 1.5vw, 1.4rem);
    font-weight: 800;
    letter-spacing: -0.018em;
    line-height: 1.15;
    color: #1d1d1f;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .v2-saved-drawer-title-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 26px;
    height: 22px;
    padding: 0 8px;
    border-radius: 999px;
    background: rgba(45, 200, 86, 0.12);
    color: #2DC856;
    font-size: 0.78rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
  }
  .v2-saved-drawer-close {
    flex: 0 0 auto;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    color: #1d1d1f;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 1px 2px rgba(13, 28, 36, 0.06),
      0 4px 10px rgba(13, 28, 36, 0.08);
    transition:
      transform 0.22s cubic-bezier(0.25, 0, 0, 1),
      background 0.22s ease,
      color 0.22s ease,
      border-color 0.22s ease;
  }
  .v2-saved-drawer-close svg { width: 44%; height: 44%; display: block; }
  .v2-saved-drawer-close:hover,
  .v2-saved-drawer-close:focus-visible {
    outline: none;
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(45, 200, 86, 0.3);
    color: #2DC856;
    transform: scale(1.06) rotate(90deg);
  }

  .v2-saved-list {
    list-style: none;
    margin: 0;
    padding: clamp(8px, 1vw, 14px) clamp(12px, 1.6vw, 18px);
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1 1 auto;
    overflow-y: auto;
    overscroll-behavior: contain;
  }
  .v2-saved-row {
    position: relative;
    display: flex;
    align-items: stretch;
    gap: 12px;
    padding: 10px;
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 16px;
    transition:
      transform 0.28s cubic-bezier(0.25, 0, 0, 1),
      box-shadow 0.28s cubic-bezier(0.25, 0, 0, 1),
      border-color 0.22s ease,
      background 0.22s ease;
  }
  .v2-saved-row:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(0, 0, 0, 0.08);
    box-shadow:
      0 1px 2px rgba(13, 28, 36, 0.05),
      0 8px 18px rgba(13, 28, 36, 0.08);
  }
  .v2-saved-row-link {
    flex: 1 1 auto;
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }
  .v2-saved-row-thumb {
    flex: 0 0 auto;
    width: 64px;
    height: 64px;
    border-radius: 12px;
    background: linear-gradient(180deg, #ffffff 0%, #f4f4f7 100%);
    border: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }
  .v2-saved-row-thumb img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    display: block;
  }
  .v2-saved-row-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    flex: 1 1 auto;
  }
  .v2-saved-row-tag {
    align-self: flex-start;
    padding: 2px 8px;
    border-radius: 999px;
    border: 1px solid rgba(45, 200, 86, 0.4);
    background: rgba(45, 200, 86, 0.08);
    color: #2DC856;
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.54rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    line-height: 1.6;
  }
  .v2-saved-row-tag--dc {
    border-color: rgba(80, 200, 220, 0.45);
    background: rgba(80, 200, 220, 0.12);
    color: #1d6d7a;
  }
  .v2-saved-row-title {
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: -0.012em;
    line-height: 1.25;
    color: #1d1d1f;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .v2-saved-row-remove {
    flex: 0 0 auto;
    width: 30px;
    height: 30px;
    align-self: center;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.06);
    background: rgba(255, 255, 255, 0.9);
    color: #6e6e73;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
