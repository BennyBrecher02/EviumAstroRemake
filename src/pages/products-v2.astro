  /* ═══════════════════════════════════════════════════════════════════
     Brands section — brand-grouped view of the full catalog.
     Each brand gets its own heading (wordmark-style name + short
     tagline + model count) and a grid of COMPACT cards underneath.
     The cards share the same bay-lighting language as the level-
     section cards but are simpler: no reflection, smaller image,
     one-line power spec, two-link footer (Full specs / Quote).
     ═══════════════════════════════════════════════════════════════════ */
  .v2-brand-group {
    position: relative;
    margin-top: clamp(3rem, 4.8vw, 4.5rem);
  }
  .v2-brand-group:first-of-type { margin-top: clamp(1.75rem, 2.6vw, 2.5rem); }

  /* BRAND HEAD — full editorial banner.
     A premium magazine-section treatment: a narrow accent rule
     across the full head width, a small uppercase eyebrow with
     an index number ("01 — Manufacturer"), a MASSIVE display-
     weight brand name, a tagline beneath, and a refined count
     pill on the right. The hierarchy reads:
       eyebrow micro-label → BIG NAME → tagline → count pill
     which mirrors high-end editorial layouts (think a magazine
     section opener or premium product spec page). */
  .v2-brand-head {
    position: relative;
    padding: clamp(1.75rem, 2.4vw, 2.25rem) clamp(0.25rem, 0.5vw, 0.75rem) clamp(1.5rem, 2.1vw, 1.85rem);
    margin-bottom: clamp(1.75rem, 2.4vw, 2.25rem);
