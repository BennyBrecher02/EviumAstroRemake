  /* BRAND NAME — display-size editorial headline. On the new
     light theme it's a deep near-black with a refined gradient
     to charcoal for subtle depth. */
  .v2-brand-name {
    grid-column: 1;
    grid-row: 2;
    margin: 0;
    font-size: clamp(2.4rem, 4.1vw, 3.6rem);
    font-weight: 900;
    letter-spacing: -0.035em;
    /* line-height stays tight (1.0) for the editorial display
       feel — the visual rhythm we want is closely-stacked. The
       descender clipping is solved separately via padding-bottom
       below, which extends the GRADIENT-PAINTING BOX without
       loosening the line-height itself. With `background-clip:
       text`, the gradient fills the element's PADDING BOX (not
       the line box) and is then clipped to glyph shapes. So
       padding-bottom = explicit gradient room for descenders. */
    line-height: 1.0;
    padding-bottom: 0.22em;
    background: linear-gradient(180deg, #1d1d1f 0%, #383840 100%);
    -webkit-background-clip: text;
