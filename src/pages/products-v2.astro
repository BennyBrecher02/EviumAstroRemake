          </button>
        </div>
      </div>

      {/* ─── Tier expand zone ─────────────────────────────
          SHARED container below the tier row. Holds both L2 and
          L3 catalogs — one rendered at a time based on state,
          the container itself animates open/closed via the
          grid-template-rows: 0fr → 1fr trick. Lives OUTSIDE the
          tier-row so the expanded catalog can span full width
          regardless of which column the active tier's card
          normally occupies.

          Per spec: when L2 is active, the L2 CARD itself hides
          (grid column goes to 0fr), the L3 card stays visible
          as the "switch to me" alternative. Same idea mirrored
          for L3. The expanded catalog content sits below both,
          dominating the viewport. */}
      <div class="v2-tier-expand" data-tier-expand>
        <div class="v2-tier-expand-inner">
          <div class="v2-tier-catalog" data-tier-catalog="l2">
            <div class="v2-product-cards">
              {l2Products.map((product) => (
                <article id={product.id} data-product-tab="l2" class="v2-card">
                  <div class="v2-card-stage">
                    <div class="v2-bay-sweep" aria-hidden="true"></div>
                    <div class="v2-bay-key" aria-hidden="true"></div>
                    <div class="v2-bay-horizon" aria-hidden="true"></div>
                    <div class="v2-bay-floor" aria-hidden="true"></div>
                    <div class="v2-bay-rim" aria-hidden="true"></div>
                    <button
                      type="button"
                      class="v2-bookmark-btn"
                      data-bookmark-id={product.id}
                      data-bookmark-tier="l2"
                      aria-label={`Save ${product.title}`}
                      aria-pressed="false"
                    >
                      <svg viewBox="0 0 16 18" aria-hidden="true">
                        <path d="M3.2 2.2h9.6v13.4l-4.8-3.6-4.8 3.6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none" />
                      </svg>
                    </button>
                    <div class="v2-card-img-wrap">
                      <img src={product.image} alt={product.title} class="v2-card-img" loading="lazy" />
                      <img src={product.image} alt="" aria-hidden="true" class="v2-card-reflection" loading="lazy" />
                    </div>
                  </div>
                  <div class="v2-card-body">
                    <header class="v2-card-head">
                      <span class="v2-card-tag">Level 2</span>
                      <h3 class="v2-card-title">{product.title}</h3>
                      <p class="v2-card-sub">{product.subtitle}</p>
                    </header>
                    <div class="v2-card-specs">
                      {product.specs.map((spec) => (
                        <div class="v2-spec">
                          <span class="v2-spec-label">{spec.label}</span>
                          <span class="v2-spec-value">{spec.value}</span>
                        </div>
                      ))}
                    </div>
                    {product.builtFor && product.builtFor.length > 0 && (
                      <div class="v2-card-builtfor">
                        <span class="v2-builtfor-label">Built for</span>
                        <span class="v2-builtfor-pills">
                          {product.builtFor.map((slug) => {
                            const svc = SERVICES[slug];
                            if (!svc) return null;
                            return (
                              <a class="v2-builtfor-pill" href={svc.href}>{svc.label}</a>
