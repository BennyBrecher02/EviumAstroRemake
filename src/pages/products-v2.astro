                      <svg viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                      </svg>
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <div class="v2-tier-catalog" data-tier-catalog="l3">
            <div class="v2-product-cards">
              {l3Products.map((product) => (
                <article id={product.id} data-product-tab="l3" class="v2-card v2-card--dc">
                  <div class="v2-card-stage">
                    <div class="v2-bay-sweep" aria-hidden="true"></div>
                    <div class="v2-bay-key" aria-hidden="true"></div>
                    <div class="v2-bay-horizon" aria-hidden="true"></div>
                    <div class="v2-bay-floor" aria-hidden="true"></div>
                    <div class="v2-bay-rim v2-bay-rim--dc" aria-hidden="true"></div>
                    <button
                      type="button"
                      class="v2-bookmark-btn v2-bookmark-btn--dc"
                      data-bookmark-id={product.id}
                      data-bookmark-tier="l3"
                      aria-label={`Save ${product.title}`}
                      aria-pressed="false"
                    >
                      <svg viewBox="0 0 16 18" aria-hidden="true">
                        <path d="M3.2 2.2h9.6v13.4l-4.8-3.6-4.8 3.6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none" />
                      </svg>
