</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    /* `Panel` is the legacy type for deep-link / featured-click
       compat. The modern mental model is `State` (idle | l2 |
       l3 | brand) — see setState below. */
    type Panel = 'l2' | 'l3' | 'brands';

    /** `State` is the mega-section's single source of truth:

          'idle'   — nothing picked, none of the morphs expanded.
                     Default landing — header visible, tier cards
                     side-by-side in normal size, brand morph as
                     a collapsed button.
          'l2'     — L2 morph expanded. L3 hidden (grid column
                     shrinks to 0fr), brand stays collapsed below,
                     tier-tabs visible at top, header hidden.
          'l3'     — mirror of 'l2'.
          'brand'  — brand morph expanded. Tier cards stay in
                     normal side-by-side form above it; header
                     stays visible since it still provides
                     context.

       State transitions happen via explicit actions (selector
       card click, tier tab click) and a scroll watcher that
       auto-opens brand when the user scrolls past the cards
       without picking. Every transition adds or removes
       classes that the CSS animates over ~1.4s curves. */
    type State = 'idle' | 'l2' | 'l3' | 'brand';
    let state: State = 'idle';
    const mega = document.querySelector<HTMLElement>('[data-mega]');
    const brandMorph = document.querySelector<HTMLElement>('[data-morph="brands"]');
    const tierMorphs = document.querySelectorAll<HTMLElement>('.v2-tier-morph');
    const tierTabs = document.querySelectorAll<HTMLButtonElement>('[data-tier-tab]');

    /** Timestamp of the last state change. The scroll-up-close
        watcher reads this to suppress its own trigger for a beat
        after any state change. Without this, the smooth scroll
        that follows a click (scrollToSelector) fires upward-
        scroll events that the watcher would otherwise interpret
        as "user is scrolling up to close" — and immediately
        reverts the state we just set. That's the classic
        "click did nothing, only worked the second time"
        symptom: the click DID work, but a self-induced scroll
        event reset it before the user saw the result. */
    let lastStateChange = 0;

    function setState(s: State) {
      state = s;
      lastStateChange = performance.now();
      /* STRONG ANCHOR — every state change activates the
         hold-pullback for a window after the click. The pull-
         back only fires when the user has drifted UPWARD past
         the section top (megaRect.top > 60), so this never
         fights deliberate downward scrolling INTO the catalog;
         it just catches upward momentum overshoot after the
         click's smooth-scroll lands. Skipped for brand state
         since brand's anchor is below the section top — the
         pull-back would yank the user out of the catalog
         view they just opened. Math.max keeps the longer
         existing hold (e.g. the extended hold the brand-close
         pre-sets) when one is already active. */
      if (s !== 'brand') {
        holdAtSelectorUntil = Math.max(
          holdAtSelectorUntil,
          performance.now() + HOLD_AT_SELECTOR_MS,
        );
      }
      if (mega) {
        mega.classList.remove('state-idle', 'state-l2', 'state-l3', 'state-brand');
        mega.classList.add(`state-${s}`);
      }
      /* Each tier morph opens only if its data-morph matches the
         state. Brand morph follows the same rule. */
      tierMorphs.forEach((m) => {
        const id = m.getAttribute('data-morph');
        const match = id === s;
        m.classList.toggle('is-open', match);
        m.setAttribute('aria-hidden', match ? 'false' : 'true');
      });
      if (brandMorph) {
        const match = s === 'brand';
        brandMorph.classList.toggle('is-open', match);
        brandMorph.setAttribute('aria-hidden', match ? 'false' : 'true');
      }
      /* Sync tier-tab aria-pressed for the l2/l3 states. */
      tierTabs.forEach((tab) => {
        const id = tab.getAttribute('data-tier-tab');
        tab.setAttribute('aria-pressed', id === s ? 'true' : 'false');
      });
      syncSelectorActive();
    }

    /** Legacy shim — `openPanel('l2'|'l3'|'brands')` was the old
        API name, kept for deep-link / featured-click compat. */
    function openPanel(target: Panel | 'brands') {
      if (target === 'brands') setState('brand');
      else if (target === 'l2' || target === 'l3') setState(target);
    }

    function syncSelectorActive() {
      document.querySelectorAll<HTMLElement>('.v2-selector-card').forEach((c) => {
        const tier = c.getAttribute('data-select-tier');
        let active = false;
        if (tier === 'l2' || tier === 'l3') active = state === tier;
        c.classList.toggle('is-active', active);
      });
    }

    /** Scroll-up-close-at-anchor: when the user is in an open
        state (L2 / L3 / brand) AND they've scrolled back up to
        the TOP of the selector section AND they're still pulling
        upward, collapse the open view AND smooth-scroll them
        back DOWN to the selector anchor.

        That last bit is critical: without the deliberate scroll-
        back-to-anchor, the user's continuing upward scroll would
        immediately gravitate them past selector and into the
        pedestal anchor in ONE motion. The brief calls for two
        separate scroll gestures: scroll up once → collapse and
        rest at the selector anchor; scroll up again → travel
        back to pedestal. Pinning them at selector after the
        collapse achieves that two-step rhythm. */
    let prevScrollY = window.scrollY;
    /* Cooldown after every state change before scroll-up-close
       can fire. Long enough to cover the scrollToSelector smooth
       scroll that runs right after a state change (~300-500ms in
       practice) plus a comfort buffer for the CSS transitions to
       settle visually. */
    const STATE_CHANGE_COOLDOWN_MS = 900;

    /* Hold-at-selector pin. After a scroll-up-close fires we
       SHOULD land at the selector anchor and stay there until the
       user makes a NEW upward gesture. Problem: momentum scrolling
       (especially on macOS trackpads) keeps emitting upward scroll
       events for a few hundred ms after the gesture has logically
       ended. Without a pin those leftover frames keep drifting the
       page above the selector — sometimes far enough to land in
       the pedestal hero in a single motion. The pin clamps the
       scroll position back to the selector anchor for a window
       AFTER scroll-up-close fires, until momentum has fully
       decayed. The user can still swipe up AGAIN once the pin
       window expires (or aggressively past it) to travel to
       pedestal — that's the two-step rhythm we want. */
    let holdAtSelectorUntil = 0;
    let lastHoldPullbackAt = 0;
    const HOLD_AT_SELECTOR_MS = 1100;
    /* Pull-back threshold — drift past which the page snaps the
       user back to the section anchor while in the hold window.
       Tightened from 60 → 24 so the user genuinely cannot peek
       into the pedestal hero above the section: even a small
       trackpad-momentum overshoot (a typical 30-50px drift) is
       caught and corrected. The previous 60 was tuned higher
       specifically to avoid firing during smooth-scroll's near-
       anchor frames; now that all programmatic scrolls go
       through smoothScrollTo (which lands EXACTLY on target,
       no oscillation), 24 is safe. */
    const HOLD_PULLBACK_THRESHOLD = 24;
    /* Debounce between consecutive pull-backs. 220ms was chosen
       to prevent rapid pull-back loops during reflow. Trimmed to
       180ms — fast enough to catch sustained momentum quickly,
       slow enough to not stutter visibly. */
    const HOLD_PULLBACK_DEBOUNCE_MS = 180;

    /* `snapping` flag: programmatic smooth-scrolls (the rAF
       anchor-scroll below) set this for their duration so any
       follow-up scroll handlers can identify and ignore the
       scroll events the smooth-scroll itself emits. */
    let snapping = false;

    /* FIRST-ARRIVAL ANCHOR GRAB
       ───────────────────────────────────────────────────────
       When the user scrolls down from the pedestal hero into
       the products section for the first time, the section
       should "grab" them at the closed/idle state for a moment
       before they can scroll past it. Without this grab, a
       long-momentum scroll from the hero blasts straight
       through the picker and trips the brand auto-open before
       the user has had a chance to register the closed state.
       The grab works two ways during its hold window:
         (1) Brand auto-open is gated off — even if megaRect.top
             goes well past -40, the brand catalog won't open.
         (2) A downward pull-back catches drift past the anchor
             (megaRect.top < -28) and snaps it back to ~0, so
             the picker stays in the user's perfect viewport
             until the hold expires.
       After the hold expires, normal behavior resumes — they
       can scroll down to trigger brand auto-open or click any
       picker card directly. */
    let firstArrivalUntil = 0;
    let lastFirstArrivalPullAt = 0;
    /* Hold duration after first arrival. ~700ms is long enough
       for the user to perceive the picker as the rest position
       even on a fast trackpad fling, short enough that a
       deliberate downward scroll doesn't feel sticky. */
    const FIRST_ARRIVAL_HOLD_MS = 700;
    /* Drift threshold during first-arrival pull-back. Looser
       than the upward HOLD_PULLBACK_THRESHOLD (24) because the
       user is actively scrolling down — we don't want to fight
       small downward motion, only catch them when they've
       clearly overshot. */
    const FIRST_ARRIVAL_PULL_THRESHOLD = -28;
    const FIRST_ARRIVAL_PULL_DEBOUNCE_MS = 180;
    /* Section top must be within this band on first arrival
       for the grab to engage — the user has to ACTUALLY land
       at the section, not just be passing somewhere above. */
    const FIRST_ARRIVAL_DETECT_TOP = 24;
    /* Once the user scrolls clearly back UP past this, the
       grab resets so a return-trip from pedestal triggers
       a fresh anchor. */
    const FIRST_ARRIVAL_RESET_TOP = 240;

    /* rAF-driven smooth scroll with cubic ease-in-out. Used by
       scrollToAnchor for click-driven anchor travel; gives more
       deliberate easing than native behavior:'smooth'. */
    function smoothScrollTo(targetY: number, durationMs: number) {
      const startY = window.scrollY;
      const dist = targetY - startY;
      if (Math.abs(dist) < 1) return;
      const startTs = performance.now();
      function step(ts: number) {
        const t = Math.min(1, (ts - startTs) / durationMs);
        const eased = t < 0.5
          ? 2 * t * t
          : 1 - Math.pow(-2 * t + 2, 2) / 2;
        window.scrollTo(0, Math.round(startY + dist * eased));
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function onScrollAll() {
      const now = window.scrollY;
      const scrollingUp = now < prevScrollY;
      const scrollingDown = now > prevScrollY;
      prevScrollY = now;

      /* Active hold: if we recently fired a state-change-close,
         lock the page near the selector anchor for the hold
         window. We only pull DOWN (i.e. when momentum has carried
         the user too far up), never push up — so a deliberate
         downward scroll into the catalog still works.

         GATING:
           - `snapping` skip: while a programmatic smoothScrollTo
             is running it lands the page on its target each
             frame; pull-back firing during that would fight the
             smooth-scroll and produce stutter.
           - threshold + debounce: drift must be >24px past the
             anchor and at least 180ms since the last pull-back.
             Together these turn a sustained momentum overshoot
             into ONE clean correction rather than a rapid loop. */
      if (
        mega &&
        !snapping &&
        performance.now() < holdAtSelectorUntil
      ) {
        const megaRect = mega.getBoundingClientRect();
        const sinceLastPullback = performance.now() - lastHoldPullbackAt;
        if (
          megaRect.top > HOLD_PULLBACK_THRESHOLD &&
          sinceLastPullback > HOLD_PULLBACK_DEBOUNCE_MS
        ) {
          const absoluteTop = window.pageYOffset + megaRect.top;
          window.scrollTo({ top: Math.max(0, absoluteTop - 8), behavior: 'auto' });
          prevScrollY = window.scrollY;
          lastHoldPullbackAt = performance.now();
        }
      }

      /* FIRST-ARRIVAL DETECTION + RESET. Engages when the user
         scrolls DOWN into the section from above and the section
         top first reaches the detect band. Resets when the user
         scrolls clearly back UP past the reset band so a return-
         trip can trigger a fresh grab. */
      if (mega && state === 'idle') {
        const megaRectFA = mega.getBoundingClientRect();
        if (
          firstArrivalUntil === 0 &&
          scrollingDown &&
          megaRectFA.top <= FIRST_ARRIVAL_DETECT_TOP &&
          megaRectFA.top > -40
        ) {
          firstArrivalUntil = performance.now() + FIRST_ARRIVAL_HOLD_MS;
        }
        if (megaRectFA.top > FIRST_ARRIVAL_RESET_TOP) {
          firstArrivalUntil = 0;
        }
      }

      /* FIRST-ARRIVAL PULL-BACK. During the grab window, pull the
         user back to the section anchor if their downward
         momentum has carried them past it. Same `snapping` /
         debounce gating as the upward pull-back so it doesn't
         fight any programmatic scrolls or stutter on rapid
         momentum frames. */
      if (
        mega &&
        !snapping &&
        performance.now() < firstArrivalUntil
      ) {
        const megaRectFA = mega.getBoundingClientRect();
        const sinceLastPull = performance.now() - lastFirstArrivalPullAt;
        if (
          megaRectFA.top < FIRST_ARRIVAL_PULL_THRESHOLD &&
          sinceLastPull > FIRST_ARRIVAL_PULL_DEBOUNCE_MS
        ) {
          const absoluteTop = window.pageYOffset + megaRectFA.top;
          window.scrollTo({ top: Math.max(0, absoluteTop - 8), behavior: 'auto' });
          prevScrollY = window.scrollY;
          lastFirstArrivalPullAt = performance.now();
        }
      }

      /* SCROLL-DOWN AUTO-OPEN BRAND. When the user is in idle
         (the closed/picker state) and starts scrolling DOWN past
         the section anchor, the brand morph auto-opens — they
         get the full brand catalog instead of scrolling into
         whatever is below. Trigger fires as soon as megaRect.top
         passes -40 going negative, the moment the user is clearly
         past the picker. Cooldown gate prevents the post-click
         smooth-scroll from re-triggering it.

         GATED BY FIRST-ARRIVAL HOLD: when the user has just
         arrived at the section from above, we hold them at the
         picker for FIRST_ARRIVAL_HOLD_MS before allowing the
         auto-open. Without this gate, a long-momentum scroll
         from the pedestal hero would blast past the picker and
         open brand instantly, bypassing the closed state. */
      if (
        scrollingDown &&
        state === 'idle' &&
        mega &&
        performance.now() - lastStateChange >= STATE_CHANGE_COOLDOWN_MS &&
        performance.now() >= firstArrivalUntil
      ) {
        const megaRect = mega.getBoundingClientRect();
        if (megaRect.top < -40) {
          setState('brand');
          setTimeout(() => {
            scrollToAnchor('[data-lv4-anchor="products-brands"]');
          }, 280);
          return;
        }
      }

      if (!scrollingUp) return;
      if (state === 'idle' || !mega) return;
      /* Critical guard — see lastStateChange comment above. The
         post-click smooth-scroll that runs after every setState
         fires upward-scroll events; without this gate the
         watcher would self-trigger and revert the user's pick. */
      if (performance.now() - lastStateChange < STATE_CHANGE_COOLDOWN_MS) return;

      /* BRAND state close — anchor the check to the brand-morph's
         own position rather than the section's top. The brand-open
         section is very tall (the full catalog), so by the time
         mega.top approaches the viewport top the brand button is
         already off-screen and the user can't see the collapse.
         Firing while the morph header is still visible in the
         upper portion of the viewport keeps the close animation
         readable. */
      if (state === 'brand' && brandMorph) {
        const brandRect = brandMorph.getBoundingClientRect();
        if (brandRect.top > 40 && brandRect.top < window.innerHeight * 0.6) {
          setState('idle');
          /* SMOOTHNESS: stagger the scroll-back to AFTER the
             collapse has begun, so the user sees the catalog
             animate before the page moves. */
          const scrollDelay = 320;
          holdAtSelectorUntil = performance.now() + HOLD_AT_SELECTOR_MS + scrollDelay;
          setTimeout(scrollToSelector, scrollDelay);
        }
        return;
      }

      /* L2/L3 state close — scroll-up brings them back to idle.
         Fires when the section top has reached the trigger band
         (-100 ≈ section essentially at top of viewport). The
         cooldown above gates against the post-click anchor scroll;
         from there a deliberate upward scroll closes the catalog.

         STAGED ANIMATION (matches the brand-close pattern):
           1. setState('idle') — kicks off the .v2-tier-row's
              max-height: 0 → 760px transition (1.4s in CSS) so
              the picker cards visibly grow back into view.
           2. holdAtSelectorUntil set FIRST, before the scroll
              starts, with a generous window covering both the
              scroll and lingering trackpad momentum afterward.
           3. scrollToSelector delayed by `scrollDelay` so the
              picker cards have started growing IN before the
              page begins moving. Without the delay, the page
              scrolls to anchor while the row is still mostly
              collapsed — visually empty and choppy.
           4. Scroll uses the slower CLOSE duration so its
              landing roughly syncs with the row's expansion
              completing.

         Anti-peek: the hold window is intentionally long
         (CLOSE_SCROLL_DURATION_MS + scrollDelay + buffer) so
         that momentum overshooting the anchor gets caught by
         the pull-back rather than letting the user briefly
         "peek" into the pedestal hero above the section. */
      const megaRect = mega.getBoundingClientRect();
      if (megaRect.top > -100) {
        setState('idle');
        /* scrollDelay 500ms — picker cards have ~half their
           1.4s grow-in animation visible before the page begins
           to move. Combined with the 1500ms close-scroll, the
           total close sequence runs ~2s and feels deliberate. */
        const scrollDelay = 500;
        holdAtSelectorUntil =
          performance.now() +
          scrollDelay +
          CLOSE_SCROLL_DURATION_MS +
          HOLD_AT_SELECTOR_MS;
        setTimeout(() => scrollToSelector(CLOSE_SCROLL_DURATION_MS), scrollDelay);
      }
    }
    window.addEventListener('scroll', onScrollAll, { passive: true });

    /* ─── Brand morph — entire card is the button ─────────
       Click handler is delegated to the whole `.v2-brand-morph`
       element, not just the header strip inside it. That way
       clicking ANY part of the visible collapsed card (including
       the outer border region and any padding around the header)
       toggles. When expanded, real interactive children —
       sub-links, mini-card "Quote" buttons, tier-swap pills,
       "Full specs" links — short-circuit the toggle so the user
       can still interact with the catalog normally. Keyboard
       trigger stays bound to the header's role="button" for
       standard Enter/Space activation. */
    function toggleBrandFromClick() {
      if (state === 'brand') {
        setState('idle');
        scrollToSelector();
        return;
      }

      const wasInTier = state === 'l2' || state === 'l3';

      if (wasInTier) {
        /* L2/L3 → BRAND — open in place, no flinging.

           The user clicks brand at the bottom of an L2/L3
           catalog. We do NOT scroll them up to section top
           first (that "rocket up then back down" round-trip
           reads as jarring). We just change state. The layout
           reflow happens around the user from their current
           scroll position:
             - tier-expand grid-rows collapses 1fr → 0fr (1.4s)
             - active tier-catalog cross-fades out (0.7s) —
               smooth, in-place dissolve via the always-rendered
               position-swap pattern (no layout collapse, no
               brand-button flash)
             - selector-head + tier-row grow back in above
             - brand-morph below unfurls its catalog content
               (1.8s grid-rows on .v2-brand-morph-content)

           Crucially, the brand catalog when fully unfurled is
           much TALLER than where the user was scrolled within
           the l2/l3 catalog. Because their scroll position is
           preserved, the user's viewport — which was previously
           inside the L2/L3 catalog — naturally ends up inside
           the brand catalog content after the reflow finishes.
           No explicit scroll is required to "bring them down
           into the brands" — they're already there once the
           layout settles around their stationary viewport.

           Anyone who wants to scroll back up to the brand-morph
           header can; the rest of the brand catalog is below
           them ready to be explored. */
        setState('brand');
      } else {
        /* From idle: the picker is at the top, brand-morph is
           below it. Direct flow — change state, brief stage,
           scroll down to the brand anchor. */
        setState('brand');
        window.setTimeout(() => {
          scrollToAnchor('[data-lv4-anchor="products-brands"]');
        }, 280);
      }
    }
    brandMorph?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      /* Two-mode click gating:

           1. COLLAPSED: any click anywhere on the morph card
              opens it. Even clicks on the eyebrow text, the icon
              SVG, the chevron — the whole card is one big button.

           2. EXPANDED: ONLY clicks on the header strip (the
              [data-brand-trigger] block) close the morph.
              Clicks on the catalog content below — mini-cards,
              brand headers, blank space between cards, every-
              thing else — are ignored by this handler so the
              user can interact with the catalog without
              accidentally closing it. Real interactive children
              (links, Quote pills, Full-specs links) keep their
              own native behavior; this gating is just about
              whether the *toggle* itself fires. */
      if (brandMorph.classList.contains('is-open')) {
        if (!target?.closest('[data-brand-trigger]')) return;
      }
      toggleBrandFromClick();
    });
    const brandTrigger = document.querySelector<HTMLElement>('[data-brand-trigger]');
    brandTrigger?.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      e.preventDefault();
      toggleBrandFromClick();
    });

    /* ─── Tier tab clicks (swap between L2 and L3 once a tier
         is open) ──────────────────────────────────────────── */
    tierTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.getAttribute('data-tier-tab') as 'l2' | 'l3' | null;
        if (!id) return;
        setState(id);
      });
    });

    /* ─── Tier-mini clicks ─────────────────────────────────
       Bottom-zone "switch tier" mini buttons. Visible only
       when the OPPOSITE tier is currently active (data-tier-
       mini matches the tier you'd switch TO). Clicking one
       fires setState() with that tier id — same animation as
       clicking the top tabs. */
    document.querySelectorAll<HTMLButtonElement>('[data-tier-mini]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-tier-mini') as 'l2' | 'l3' | null;
        if (!id) return;
        /* TIER-MINI SWAP — three-phase sequence:
             1. scroll to top  (TIER_MINI_SCROLL_MS)
             2. settle at top  (TIER_MINI_SETTLE_MS)
             3. setState swaps which catalog is active; pure CSS
                cross-fade plays out — both catalogs are always
                rendered, so the moment of state change does the
                full visual job (outgoing fades down + away from
                its position:relative slot, incoming rises into
                the same slot from translateY(14px) opacity:0).
                No JS class toggling, no rAF dance, no layout
                collapse → no brand-button jumpscare.
           Cooldown is pushed forward to cover the entire window
           so scroll-up-close can't fire mid-swap. */
        const TIER_MINI_SCROLL_MS = 1200;
        const TIER_MINI_SETTLE_MS = 500;
        const TIER_MINI_FADE_MS = 720;
        const TIER_MINI_TOTAL_MS =
          TIER_MINI_SCROLL_MS + TIER_MINI_SETTLE_MS + TIER_MINI_FADE_MS;

        lastStateChange =
          performance.now() + TIER_MINI_TOTAL_MS - STATE_CHANGE_COOLDOWN_MS;

        scrollToSelector(TIER_MINI_SCROLL_MS);

        const swapAt = TIER_MINI_SCROLL_MS + TIER_MINI_SETTLE_MS;
        window.setTimeout(() => setState(id), swapAt);
      });
    });

    /* Legacy shim — other scripts (e.g. hero featured-click
       deep-link) looked this up by name. Kept for backward
       compat; only accepts the two tier keys since brands
       isn't a "tier" in the old vocabulary. */
    function activateTab(target: string) {
      if (target === 'l2' || target === 'l3') {
        openPanel(target);
        scrollToPanel(target);
      }
    }
    (window as any).__productsV2ActivateTab = activateTab;

    /* ─── Smooth-scroll helpers ────────────────────────────
       Each anchor in HeaderV4's list corresponds to a DOM
       element with a `data-lv4-anchor` attribute; we target
       them the same way here so the manual scrolls land on
       the exact same pixel the rail would. */
    /* Default anchor-scroll duration for click-driven travel.
       Slower than native ~300ms for a deliberate glide, but fast
       enough to feel responsive after a click. The L2/L3 close
       overrides this with a longer duration to sync visually
       with the .v2-tier-row's 1.4s max-height expansion (so the
       page doesn't finish moving long before the picker cards
       finish growing back into view) — and the close gets even
       more time on top via the staged scrollDelay. */
    const ANCHOR_SCROLL_DURATION_MS = 700;
    const CLOSE_SCROLL_DURATION_MS = 1500;

    function scrollToAnchor(selector: string, durationMs?: number) {
      const el = document.querySelector<HTMLElement>(selector);
      if (!el) return;
      const duration = durationMs ?? ANCHOR_SCROLL_DURATION_MS;
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          const rect = el.getBoundingClientRect();
          const absoluteTop = window.pageYOffset + rect.top;
          const targetY = Math.max(0, Math.round(absoluteTop - 8));
          /* `snapping` blocks any future scroll-watcher branches
             from re-entering during the smooth scroll. Hold it for
             the full duration plus a small buffer so the very
             last-frame momentum events don't leak past. */
          snapping = true;
          smoothScrollTo(targetY, duration);
          window.setTimeout(
            () => { snapping = false; },
            duration + 120,
          );
        });
      });
    }
    function scrollToPanel(panel: Panel) {
      scrollToAnchor(`[data-lv4-anchor="products-${panel}"]`);
    }
    function scrollToSelector(durationMs?: number) {
      scrollToAnchor('[data-lv4-anchor="products-selector"]', durationMs);
    }

    /* ─── Tier card clicks ────────────────────────────────
       Clicking the L2 or L3 card header expands that tier's
       morph — which takes over the viewport via the grid
       column animation + content unfurl. Scrolls the page
       up to the mega-section's top so the expanded tier lands
       in a comfortable spot in the viewport. */
    const selectorCards = document.querySelectorAll<HTMLButtonElement>('.v2-selector-card');
    selectorCards.forEach((card) => {
      card.addEventListener('click', () => {
        const target = card.getAttribute('data-select-tier') as Panel | null;
        if (target !== 'l2' && target !== 'l3') return;
        setState(target);
        scrollToSelector();
      });
    });

    /* ─── Tier-swap pills (closes whichever view is open and
         returns the user to the selector's resting state) ─── */
    document.querySelectorAll<HTMLButtonElement>('[data-tier-swap]').forEach((btn) => {
      btn.addEventListener('click', () => {
        setState('idle');
        scrollToSelector();
      });
    });

    /* ─── Brand-section mini card → Full specs ─────────────
       Clicking "Full specs" on a brand-grid card switches the
       active tier (l2/l3) and scrolls the specific product
       card into view in that tier's catalog. This is the
       shortest path from the brand-organised view back to the
       detailed spec sheet for one product. */
    document.querySelectorAll<HTMLAnchorElement>('[data-mini-detail]').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const owningTier = link.getAttribute('data-mini-detail') as Panel | null;
        if (!owningTier || (owningTier !== 'l2' && owningTier !== 'l3')) return;
        const href = link.getAttribute('href') || '';
        const id = href.startsWith('#') ? href.slice(1) : '';
        /* Switch tier state first so the catalog starts opening. */
        openPanel(owningTier);
        if (!id) { scrollToPanel(owningTier); return; }
        /* Hold the scroll-up-close watcher off for an extended
           window. Without this, the smooth scroll to the target
           card was occasionally being interpreted as an upward
           gesture (during layout reflows from the tier-expand
           transition + brand-morph collapse), tripping
           scroll-up-close and snapping the user back to the
           idle state immediately after they landed on the
           charger. Pinning lastStateChange forward by 2.2s gives
           the smooth scroll AND the layout transitions both
           plenty of time to complete before close logic resumes. */
        const FULL_SPECS_HOLD_MS = 2200;
        lastStateChange = performance.now() + FULL_SPECS_HOLD_MS - STATE_CHANGE_COOLDOWN_MS;
        setTimeout(() => {
          const target = document.getElementById(id);
          if (!target) { scrollToPanel(owningTier); return; }
          const rect = target.getBoundingClientRect();
          const absoluteTop = window.pageYOffset + rect.top;
          const targetScroll = absoluteTop - Math.max(40, (window.innerHeight - rect.height) / 2);
          window.scrollTo({ top: Math.max(0, targetScroll), behavior: 'smooth' });
        }, 700);
      });
    });

    /* ─── Deep-link support ─────────────────────────────────
       URL hash shapes accepted:
         • #panel-l2 / #panel-l3 / #panel-brands
             → open panel + scroll to it
         • #<product-id>
             → open owning tier + center card
       Same contract the hero carousel's featured-click uses. */
    function handleHash() {
      const id = window.location.hash.slice(1);
      if (!id) return;

      if (id === 'panel-l2' || id === 'panel-l3' || id === 'panel-brands') {
        const target = id.replace('panel-', '') as Panel;
        openPanel(target);
        scrollToPanel(target);
        return;
      }

      const card = document.getElementById(id);
      if (!card) return;
      const owningTier = card.getAttribute('data-product-tab') as Panel | null;
      if (owningTier === 'l2' || owningTier === 'l3') openPanel(owningTier);
      /* Give the max-height transition a beat to start before
         we measure and scroll — otherwise the card's Y is
         still inside the collapsed box. */
      setTimeout(() => {
        const rect = card.getBoundingClientRect();
        const absoluteTop = window.pageYOffset + rect.top;
        const targetScroll = absoluteTop - (window.innerHeight - rect.height) / 2;
        window.scrollTo({ top: Math.max(0, targetScroll), behavior: 'smooth' });
      }, 140);
    }

    handleHash();
    window.addEventListener('hashchange', handleHash);

    /* ─── Chart overlay ───────────────────────────────────── */
    const chartBtn      = document.querySelector<HTMLButtonElement>('.v2-chart-btn');
    const chartOverlay  = document.getElementById('chart-overlay');
    const chartCloseEls = document.querySelectorAll<HTMLElement>('[data-chart-close], #chart-close-btn');
    let lastChartTrigger: HTMLElement | null = null;

    function openChart(fromEl: HTMLElement | null) {
      if (!chartOverlay) return;
      lastChartTrigger = fromEl;
      chartOverlay.hidden = false;
      document.body.classList.add('chart-overlay-open');
      (document.getElementById('chart-close-btn') as HTMLElement | null)?.focus();
    }
    function closeChart() {
      if (!chartOverlay) return;
      chartOverlay.hidden = true;
      document.body.classList.remove('chart-overlay-open');
      lastChartTrigger?.focus();
    }

    chartBtn?.addEventListener('click', () => openChart(chartBtn));
    chartCloseEls.forEach((el) => el.addEventListener('click', closeChart));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && chartOverlay && !chartOverlay.hidden) closeChart();
    });

    /* ─── Bookmarks ───────────────────────────────────────────
       LocalStorage-backed bookmark system. Three pieces of UI
       sync to a single source of truth (an array of product
       IDs) via a custom event. No accounts, no server — when
       accounts arrive, the storage layer can be swapped for a
       server-backed equivalent and every UI listener keeps
       working.

       Storage:
         BOOKMARK_KEY     versioned key for clean future migration
         getBookmarks()   read array of IDs
         setBookmarks()   write + dispatch sync event
         toggleBookmark() add or remove
         isBookmarked()   membership check

       UI:
         .v2-bookmark-btn   per-card toggle (top-right of card stage)
         .v2-saved-chip     fixed-position floating "Saved (N)" pill
         .v2-saved-drawer   slide-in panel listing saved items

       Each is wired by listening for `evium:bookmarks-changed`
       so they stay in sync without a framework. */
    const BOOKMARK_KEY = 'evium_bookmarks_v1';
    const BOOKMARK_EVENT = 'evium:bookmarks-changed';

    function getBookmarks(): string[] {
      try {
        const raw = window.localStorage.getItem(BOOKMARK_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed)
          ? parsed.filter((x): x is string => typeof x === 'string')
          : [];
      } catch {
        return [];
      }
    }
    function setBookmarks(ids: string[]) {
      try {
        window.localStorage.setItem(BOOKMARK_KEY, JSON.stringify(ids));
      } catch {
        /* private mode / quota exceeded — silently no-op so the
           feature degrades gracefully. UI events still fire so
           the in-page state stays consistent for the session. */
      }
      window.dispatchEvent(
        new CustomEvent(BOOKMARK_EVENT, { detail: ids.slice() }),
      );
    }
    function toggleBookmark(id: string): boolean {
      const list = getBookmarks();
      const idx = list.indexOf(id);
      const willSave = idx < 0;
      if (willSave) list.push(id);
      else list.splice(idx, 1);
      setBookmarks(list);
      return willSave;
    }
    function isBookmarked(id: string): boolean {
      return getBookmarks().includes(id);
    }

    /* ─── Bookmark button — per-card toggle ──────────────────
       One delegated click handler at the document level catches
       every .v2-bookmark-btn. The button is inside an interactive
       <article> wrapper in some contexts (the mini-card has its
       own click behavior), so we also stop propagation + default
       to keep this a pure local toggle. */
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      const btn = target?.closest<HTMLButtonElement>('.v2-bookmark-btn');
      if (!btn) return;
      e.stopPropagation();
      e.preventDefault();
      const id = btn.getAttribute('data-bookmark-id');
      if (!id) return;
      const nowSaved = toggleBookmark(id);
      /* Pop animation — one-shot via the .is-popping class. We
         remove it on `animationend` so the next toggle restarts
         cleanly. */
      btn.classList.remove('is-popping');
      // force reflow so the animation re-fires when re-added
      void btn.offsetWidth;
      btn.classList.add('is-popping');
      btn.addEventListener(
        'animationend',
        () => btn.classList.remove('is-popping'),
        { once: true },
      );
      btn.setAttribute('aria-pressed', nowSaved ? 'true' : 'false');
    });

    /* ─── Saved chip + drawer — global listener for sync ─── */
    const savedChip = document.getElementById('saved-chip');
    const savedDrawer = document.getElementById('saved-drawer');
    const savedList = document.getElementById('saved-list');
    const savedEmpty = document.getElementById('saved-empty');
    const savedClearBtn = document.getElementById('saved-clear-btn');
    const savedDrawerCloseBtn = document.getElementById('saved-drawer-close');

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    /* Render a saved-row from the existing card DOM. The detail
       cards (.v2-card) and the brand-section mini cards
       (.v2-mini-card) are both always present in the DOM (only
       their visibility/active-state changes by section state),
       so we can read product info directly from the DOM rather
       than maintaining a parallel data feed. We prefer the
       full-detail .v2-card when present (better metadata) and
       fall back to the mini if needed. */
    function findCardById(id: string): HTMLElement | null {
      // The full-detail card has id={product.id}.
      const detail = document.getElementById(id);
      if (detail) return detail;
      // Fall back to the mini-card with matching data attribute.
      return document.querySelector<HTMLElement>(
        `.v2-mini-card[data-product-detail-id="${CSS.escape(id)}"]`,
      );
    }

    function renderSavedRow(id: string): string {
      const card = findCardById(id);
      if (!card) return '';
      const tier = card.getAttribute('data-product-tab') ?? 'l2';
      const isDc = tier === 'l3';
      const img = card.querySelector<HTMLImageElement>(
        '.v2-card-img, .v2-mini-img',
      );
      const titleEl = card.querySelector<HTMLElement>(
        '.v2-card-title, .v2-mini-title',
      );
      const imgSrc = img?.getAttribute('src') ?? '';
      const imgAlt = img?.getAttribute('alt') ?? '';
      const title = titleEl?.textContent?.trim() ?? id;
      const tagText = isDc ? 'DC Fast' : 'Level 2';
      return `
        <li class="v2-saved-row" data-saved-id="${escapeHtml(id)}">
          <a class="v2-saved-row-link" href="#${escapeHtml(id)}" data-saved-link="${escapeHtml(tier)}">
            <span class="v2-saved-row-thumb">
              <img src="${escapeHtml(imgSrc)}" alt="${escapeHtml(imgAlt)}" loading="lazy" />
            </span>
            <span class="v2-saved-row-meta">
              <span class="v2-saved-row-tag${isDc ? ' v2-saved-row-tag--dc' : ''}">${tagText}</span>
              <span class="v2-saved-row-title">${escapeHtml(title)}</span>
            </span>
          </a>
          <button
            type="button"
            class="v2-saved-row-remove"
            data-saved-remove="${escapeHtml(id)}"
            aria-label="Remove ${escapeHtml(title)} from saved"
          >
            <svg viewBox="0 0 16 16" aria-hidden="true">
              <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
          </button>
        </li>
      `;
    }

    /* Mark a row removed before re-render so the layout settles
       cleanly even if the user does multiple removals quickly. */
    function syncBookmarkUI(ids: string[], opts: { bump?: boolean } = {}) {
      /* 1. Per-card buttons */
      document
        .querySelectorAll<HTMLButtonElement>('.v2-bookmark-btn')
        .forEach((btn) => {
          const id = btn.getAttribute('data-bookmark-id');
          const saved = !!id && ids.includes(id);
          btn.classList.toggle('is-saved', saved);
          btn.setAttribute('aria-pressed', saved ? 'true' : 'false');
        });

      /* 2. Floating chip */
      if (savedChip) {
        savedChip.classList.toggle('is-empty', ids.length === 0);
        const countEl = savedChip.querySelector('.v2-saved-chip-count');
        if (countEl) countEl.textContent = String(ids.length);
        if (opts.bump && ids.length > 0) {
          savedChip.classList.remove('is-bumping');
          void (savedChip as HTMLElement).offsetWidth;
          savedChip.classList.add('is-bumping');
          savedChip.addEventListener(
            'animationend',
            () => savedChip.classList.remove('is-bumping'),
            { once: true },
          );
        }
      }

      /* 3. Drawer (only re-render its list if the drawer DOM
            exists; otherwise skip silently). */
      if (savedList) {
        if (ids.length === 0) {
          savedList.innerHTML = '';
        } else {
          savedList.innerHTML = ids.map(renderSavedRow).join('');
        }
      }
      const drawerCount = document.querySelector(
        '.v2-saved-drawer-title-count',
      );
      if (drawerCount) drawerCount.textContent = String(ids.length);
      if (savedEmpty) savedEmpty.hidden = ids.length > 0;
      if (savedClearBtn) (savedClearBtn as HTMLButtonElement).disabled = ids.length === 0;
    }

    /* Compare arrays so we know whether an event is an addition
       (count increased) and should pop/bump the chip. */
    let lastBookmarkCount = getBookmarks().length;
    window.addEventListener(BOOKMARK_EVENT, (e: Event) => {
      const detail = (e as CustomEvent<string[]>).detail ?? [];
      const bump = detail.length > lastBookmarkCount;
      lastBookmarkCount = detail.length;
      syncBookmarkUI(detail, { bump });
    });

    /* Initial sync — read storage on page load and propagate to
       every listener. Done in a microtask so any DOMContentLoaded
       listeners that registered after this can still receive it. */
    queueMicrotask(() => {
      const initial = getBookmarks();
      lastBookmarkCount = initial.length;
      syncBookmarkUI(initial, { bump: false });
    });

    /* ─── Drawer open/close ──────────────────────────────────
       Triggered by the chip; closed by the X button, the
       backdrop, or Escape. Body gets `saved-drawer-open` class
       to lock background scroll while the drawer is up. */
    let lastSavedTrigger: HTMLElement | null = null;
    function openSavedDrawer(fromEl: HTMLElement | null) {
      if (!savedDrawer) return;
      lastSavedTrigger = fromEl;
      savedDrawer.classList.add('is-open');
      savedDrawer.setAttribute('aria-hidden', 'false');
      document.body.classList.add('saved-drawer-open');
      (savedDrawerCloseBtn as HTMLElement | null)?.focus();
    }
    function closeSavedDrawer() {
      if (!savedDrawer) return;
      savedDrawer.classList.remove('is-open');
      savedDrawer.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('saved-drawer-open');
      lastSavedTrigger?.focus();
    }

    savedChip?.addEventListener('click', () => openSavedDrawer(savedChip));
    savedDrawerCloseBtn?.addEventListener('click', closeSavedDrawer);
    savedDrawer
      ?.querySelectorAll<HTMLElement>('[data-saved-close]')
      .forEach((el) => el.addEventListener('click', closeSavedDrawer));
    document.addEventListener('keydown', (e) => {
      if (
        e.key === 'Escape' &&
        savedDrawer &&
        savedDrawer.classList.contains('is-open')
      ) {
        closeSavedDrawer();
      }
    });

    /* Drawer list — delegated handlers for remove + link clicks.
       Remove: surgical bookmark removal without closing the
       drawer. Link click: navigate to the corresponding product
       detail. If the saved item is a tier-l2/l3 detail card we
       also activate that tier so the catalog is open when the
       hash-driven scroll lands. The drawer itself closes either
       way to give the user a clean view of the destination. */
    savedList?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement | null;
      if (!target) return;

      const removeBtn = target.closest<HTMLButtonElement>('[data-saved-remove]');
      if (removeBtn) {
        e.stopPropagation();
        e.preventDefault();
        const id = removeBtn.getAttribute('data-saved-remove');
        if (id) toggleBookmark(id);
        return;
      }

      const link = target.closest<HTMLAnchorElement>('[data-saved-link]');
      if (link) {
        const tier = link.getAttribute('data-saved-link');
        if (tier === 'l2' || tier === 'l3') {
          if (state !== tier) setState(tier);
        }
        closeSavedDrawer();
        /* Let the hash navigation happen naturally after the
           drawer closes — no preventDefault. The browser jumps
           to the #id anchor, the catalog is open, the user
           lands on the right card. */
      }
    });

    savedClearBtn?.addEventListener('click', () => {
      if (getBookmarks().length === 0) return;
      setBookmarks([]);
    });
  });
</script>
