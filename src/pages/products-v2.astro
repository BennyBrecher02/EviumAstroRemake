  /* L3 / DC mini-card quote button — cyan family. Same pattern
     as the larger .v2-card--dc CTA above: resting cyan, brighter
     cyan + filament-cyan bloom on hover, dim cyan on press. */
  .v2-mini-card--dc .v2-mini-quote {
