/*
 * Flatten both tiers into one list with a `tier` tag attached,
 * then bucket by brand for the Brands section's render loop.
 * The Level-section render keeps using l2Products / l3Products
 * directly — this extra structure is just the brand-grouped
 * view. Order within each brand's bucket follows declaration
 * order above.
 */
type AnyProduct = (typeof l2Products[number] | typeof l3Products[number]) & { tier: 'l2' | 'l3' };
const taggedL2: AnyProduct[] = l2Products.map((p) => ({ ...p, tier: 'l2' as const }));
const taggedL3: AnyProduct[] = l3Products.map((p) => ({ ...p, tier: 'l3' as const }));
const allProducts: AnyProduct[] = [...taggedL2, ...taggedL3];

const productsByBrand: Record<BrandKey, AnyProduct[]> = {
  evium:       [],
  evocharge:   [],
  siemens:     [],
  maxicharger: [],
};
for (const p of allProducts) productsByBrand[p.brand].push(p);

/* Short "power" summary for the compact brand-section card.
   Pulls the product's "Output Power" spec (present on every
   entry by convention) so each mini card has a one-line
   signature that's comparable across tiers. Falls back to the
   first spec if Output Power isn't explicitly present. */
function powerSummary(p: AnyProduct): string {
  const pow = p.specs.find((s) => s.label === 'Output Power');
  if (pow) return pow.value;
  return p.specs[0]?.value ?? '';
}
