/**
 * /products-v2 — Products page, v2 (PRNDL-lefter sandbox).
 * ──────────────────────────────────────────────────────────
 * Full parallel of /products/index.astro, rewired for the
 * v2-sandbox Layout that renders HeaderV4 (the Tesla-PRNDL
 * lefter rail) instead of the top-battery Header.
 *
 * Flow (matches the v2 section-anchored rhythm the user
 * requested):
 *   1. HERO        — full-viewport pedestal carousel (same
 *                    HeroCarouselPedestal component as the
 *                    production page, with productLinkBase
 *                    pointed at /products-v2 so in-hero CTAs
 *                    stay on this page).
 *   2. SELECTOR    — Tesla-configurator-style Level 2 vs
 *                    Level 3 picker. Two dramatic cards
 *                    side-by-side. Clicking either sets the
 *                    tab in the cards section AND scrolls
 *                    the user down one anchor to it.
 *   3. CARDS       — the actual charger catalog, showing
 *                    whichever tier the selector activated.
 *                    One anchor regardless of tier so the
 *                    scroll-down animation from the selector
 *                    is THE SAME distance no matter which
 *                    card the user clicked — per spec.
 *   4. FOOTER      — SiteFooter.
 *
 * Anchor wiring (HeaderV4 reads via `body.page-products-v2`):
 *   [data-lv4-anchor="products-hero"]     → hero stop
 *   [data-lv4-anchor="products-selector"] → selector stop
 *   [data-lv4-anchor="products-cards"]    → cards stop
 *
 * Card lighting is a proper product-photography set: soft
 * key light from upper-left, warm ambient fill, seamless
 * dark studio sweep for the floor/wall, duplicated image as
 * a faded reflection below the product, and a tight realistic
 * ground shadow. No scrappy green blobs under the hardware.
 *
 * Original /products/index.astro is NOT touched.
 */
import Layout from '../layouts/Layout.astro';
import HeroCarouselPedestal from '../components/heroes/HeroCarouselPedestal.astro';
import HeroCarouselPedestalMobile from '../components/heroes/HeroCarouselPedestalMobile.astro';
import SiteFooter from '../components/SiteFooter.astro';

