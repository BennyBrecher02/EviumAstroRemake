              <path d="M4 6l4 4 4-4"/>
            </svg>
          </span>
        </div>

        <div class="v2-brand-morph-content">
          <div class="v2-brand-morph-content-inner">
            {BRANDS.map((brand, brandIndex) => {
                const items = productsByBrand[brand.key];
                if (!items || items.length === 0) return null;
                const indexLabel = String(brandIndex + 1).padStart(2, '0');
                return (
                  <article class="v2-brand-group" data-brand={brand.key}>
                    <header class="v2-brand-head">
                      <div class="v2-brand-rule" aria-hidden="true"></div>
                      <span class="v2-brand-eyebrow">
                        <span class="v2-brand-eyebrow-num">{indexLabel}</span>
                        <span class="v2-brand-eyebrow-divider" aria-hidden="true"></span>
