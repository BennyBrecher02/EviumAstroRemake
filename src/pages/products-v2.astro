<Layout title="Products — Evium Charging (v2)" headerVariant="v4" bodyClass="page-products-v2">
  {/* Hero — same carousel component as /products. Desktop uses the
      landscape pedestal backdrop, mobile uses the portrait variant.
      The wrapper carries the data-lv4-anchor so HeaderV4's rail can
      find the hero stop regardless of which inner variant renders.
      CSS rules further down nudge the pedestal stage's internal
      sizing to respect the lefter's padding so the pedestals don't
      sit visually off-center under the rail. */}
  <div class="products-hero-wrap" data-lv4-anchor="products-hero">
    <div class="hero-desktop-only">
      <HeroCarouselPedestal productLinkBase="/products-v2" />
    </div>
    <div class="hero-mobile-only">
      <HeroCarouselPedestalMobile productLinkBase="/products-v2" />
    </div>
  </div>

  {/* ══════════ Mega section ══════════
      The one dark backdrop that carries across everything below
      the hero. Contains the picker (L2 / L3 / Brand buttons) +
      all three expansion states, using a single shared backdrop
      so the user never feels like they've jumped into "a new
      section". A state class on the root (`state-idle`, `state-l2`,
      `state-l3`, `state-brand`) drives:

        • Header visibility (shows in idle + brand, hides in l2/l3)
        • Tier-tabs visibility (hides in idle + brand, shows in l2/l3)
        • Tier-row grid columns (1fr 1fr default → 1fr 0fr / 0fr 1fr
          when one tier dominates)
        • Each morph's is-open state
        • Brand morph's collapsed-button vs expanded-section form

      When L2 or L3 is the active state, the tabs at the top let
      the user swap tiers without returning to the selector. The
      Brand button stays visible below the expanded tier content
      as a collapsed pill so "Browse by brand" remains one click
      away. */}
  <section class="v2-selector state-idle" data-mega data-lv4-anchor="products-selector">
    <div class="v2-catalog-bg" aria-hidden="true"></div>
    <div class="v2-catalog-grid" aria-hidden="true"></div>

    <div class="v2-selector-inner">
      <header class="v2-selector-head" data-mega-head>
        <span class="v2-catalog-eyebrow">Choose your path</span>
        <h2 class="v2-selector-title">Pick a tier<span class="v2-selector-title-or">—or browse by brand.</span></h2>
        <p class="v2-selector-sub">
          Level 2 is the daily overnight workhorse; Level 3 is fast-turn
          highway / fleet. Or scroll past to browse the whole catalog
          by manufacturer.
        </p>
        {/* Charging-speed chart trigger — placed inline beneath the
            subtitle as an integrated, professionally-styled link
            button. Sits where the user is already reading about
            kW differences, so opening the comparison chart from
            here feels natural. */}
        <button
          type="button"
          class="v2-chart-btn"
          aria-label="View charging speed chart"
          title="Charging speed reference"
        >
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path d="M2 13V5M6 13V8M10 13V3M14 13V7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" fill="none"/>
            <path d="M1.5 13.5h13" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" fill="none"/>
          </svg>
          <span>Compare charging speeds</span>
        </button>
      </header>

      {/* Tier tabs — visible only in state-l2 / state-l3.
          Clean minimal v1-style: bold uppercase text + animated
          green underline that slides between tabs. No pill, no
          background, no count badges — just typography + a
          single sliding indicator rail beneath. */}
      <nav class="v2-tier-tabs" aria-label="Switch charging tier">
        <button type="button" class="v2-tier-tab" data-tier-tab="l2" aria-pressed="false">
          Level 2
        </button>
        <button type="button" class="v2-tier-tab" data-tier-tab="l3" aria-pressed="false">
          Level 3
        </button>
        <span class="v2-tier-tab-rail" aria-hidden="true"></span>
      </nav>

      {/* Tier row — holds the two tier morphs side by side. When
          one tier is expanded, its column grows and the other
          column shrinks to 0fr (animated via grid-template-columns).
          Each morph contains its own collapsed card (header) and
          full catalog (content) — same pattern as the brand morph. */}
      <div class="v2-tier-row" data-tier-row>
        <div class="v2-tier-morph" data-morph="l2" data-level-panel="l2" data-lv4-anchor="products-l2">
          <button class="v2-selector-card v2-tier-morph-header" type="button" data-select-tier="l2" aria-label="Explore Level 2 chargers">
            <div class="v2-sel-stage">
              <div class="v2-bay-sweep" aria-hidden="true"></div>
              <div class="v2-bay-key" aria-hidden="true"></div>
              <div class="v2-bay-horizon" aria-hidden="true"></div>
              <div class="v2-bay-floor" aria-hidden="true"></div>
              <div class="v2-bay-rim" aria-hidden="true"></div>
              <div class="v2-sel-img-wrap">
                <img class="v2-sel-img"        src="/images/chargers/evocharge/EVOCHARGE-40A-Level-2-Charging-Station-Spec-Sheet-1122.png" alt="Level 2 wall charger" loading="lazy" />
                <img class="v2-sel-reflection" src="/images/chargers/evocharge/EVOCHARGE-40A-Level-2-Charging-Station-Spec-Sheet-1122.png" alt="" aria-hidden="true" loading="lazy" />
              </div>
            </div>
            <div class="v2-sel-body">
