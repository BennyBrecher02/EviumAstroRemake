  .v2-brand-rule {
    grid-column: 1 / -1;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      #2DC856 0%,
      rgba(45, 200, 86, 0.5) 8%,
      rgba(0, 0, 0, 0.08) 22%,
      rgba(0, 0, 0, 0.05) 100%
