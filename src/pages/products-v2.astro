                    <div class="v2-brand-grid">
                      {items.map((product) => (
                        <article class:list={['v2-mini-card', product.tier === 'l3' ? 'v2-mini-card--dc' : '']} data-product-tab={product.tier} data-product-detail-id={product.id}>
                          <div class="v2-mini-stage">
