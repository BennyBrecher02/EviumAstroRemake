                              data-bookmark-tier={product.tier}
                              aria-label={`Save ${product.title}`}
                              aria-pressed="false"
                            >
                              <svg viewBox="0 0 16 18" aria-hidden="true">
                                <path d="M3.2 2.2h9.6v13.4l-4.8-3.6-4.8 3.6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" fill="none" />
