                            </button>
                            <div class="v2-mini-img-wrap">
                              <img src={product.image} alt={product.title} class="v2-mini-img" loading="lazy" />
                              <img src={product.image} alt="" aria-hidden="true" class="v2-mini-reflection" loading="lazy" />
                            </div>
                          </div>
                          <div class="v2-mini-body">
                            <span class:list={['v2-card-tag', product.tier === 'l3' ? 'v2-card-tag--dc' : '']}>
