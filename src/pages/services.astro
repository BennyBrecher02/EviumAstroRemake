---

<Layout
  title="Services — Evium Charging"
  description="Explore Evium Charging's service verticals across multifamily, fleets, highway fast charging, commercial, retail, parking, medical, and more."
>
  <main class="services-page text-[#182126]">
    <section class="services-hero relative overflow-hidden pt-28 md:pt-36">
      <div class="absolute inset-0 hero-base-bg"></div>

      <!-- Refined ambient lighting -->
      <div class="hero-glow hero-glow-primary"></div>
      <div class="hero-glow hero-glow-secondary"></div>
      <div class="hero-glow hero-glow-accent"></div>

      <!-- SVG geometric network -->
      <svg class="hero-network-svg" viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <defs>
          <radialGradient id="nodeGlow" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#2DC856" stop-opacity="0.35" />
            <stop offset="50%" stop-color="#2DC856" stop-opacity="0.08" />
            <stop offset="100%" stop-color="#2DC856" stop-opacity="0" />
          </radialGradient>
          <radialGradient id="nodeGlowWhite" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="white" stop-opacity="0.12" />
            <stop offset="100%" stop-color="white" stop-opacity="0" />
          </radialGradient>
        </defs>

        <!-- Diagonal grid lines — structured tech depth -->
        <line x1="0" y1="180" x2="1440" y2="60" stroke="rgba(255,255,255,0.04)" stroke-width="0.7" />
        <line x1="0" y1="320" x2="1440" y2="200" stroke="rgba(255,255,255,0.035)" stroke-width="0.7" />
        <line x1="0" y1="480" x2="1440" y2="360" stroke="rgba(255,255,255,0.03)" stroke-width="0.7" />
        <line x1="0" y1="100" x2="1440" y2="500" stroke="rgba(255,255,255,0.03)" stroke-width="0.7" />
        <line x1="200" y1="0" x2="1440" y2="520" stroke="rgba(255,255,255,0.025)" stroke-width="0.7" />
        <line x1="600" y1="0" x2="1440" y2="350" stroke="rgba(255,255,255,0.03)" stroke-width="0.7" />

        <!-- Primary network connection lines — green tint -->
        <line x1="120" y1="140" x2="380" y2="90" stroke="rgba(45,200,86,0.14)" stroke-width="1" />
        <line x1="380" y1="90" x2="620" y2="200" stroke="rgba(45,200,86,0.12)" stroke-width="1" />
        <line x1="620" y1="200" x2="900" y2="120" stroke="rgba(45,200,86,0.09)" stroke-width="0.8" />
        <line x1="900" y1="120" x2="1180" y2="180" stroke="rgba(255,255,255,0.07)" stroke-width="0.8" />
        <line x1="1180" y1="180" x2="1350" y2="80" stroke="rgba(255,255,255,0.05)" stroke-width="0.8" />

        <!-- Secondary network paths -->
        <line x1="200" y1="400" x2="500" y2="340" stroke="rgba(255,255,255,0.05)" stroke-width="0.7" />
        <line x1="500" y1="340" x2="780" y2="430" stroke="rgba(255,255,255,0.045)" stroke-width="0.7" />
        <line x1="780" y1="430" x2="1100" y2="350" stroke="rgba(255,255,255,0.04)" stroke-width="0.7" />

        <!-- Cross connections -->
        <line x1="380" y1="90" x2="500" y2="340" stroke="rgba(255,255,255,0.035)" stroke-width="0.6" />
        <line x1="620" y1="200" x2="780" y2="430" stroke="rgba(255,255,255,0.03)" stroke-width="0.6" />
        <line x1="900" y1="120" x2="1100" y2="350" stroke="rgba(255,255,255,0.035)" stroke-width="0.6" />

        <!-- Node points — large soft glow + small crisp center -->
        <circle cx="120" cy="140" r="22" fill="url(#nodeGlow)" />
        <circle cx="120" cy="140" r="2" fill="rgba(45,200,86,0.55)" />

        <circle cx="380" cy="90" r="28" fill="url(#nodeGlow)" />
        <circle cx="380" cy="90" r="2.5" fill="rgba(45,200,86,0.65)" />

        <circle cx="620" cy="200" r="20" fill="url(#nodeGlow)" />
        <circle cx="620" cy="200" r="2" fill="rgba(45,200,86,0.45)" />

        <circle cx="900" cy="120" r="24" fill="url(#nodeGlowWhite)" />
        <circle cx="900" cy="120" r="2" fill="rgba(255,255,255,0.22)" />

        <circle cx="1180" cy="180" r="18" fill="url(#nodeGlowWhite)" />
        <circle cx="1180" cy="180" r="1.8" fill="rgba(255,255,255,0.18)" />

        <circle cx="1350" cy="80" r="14" fill="url(#nodeGlowWhite)" />
        <circle cx="1350" cy="80" r="1.5" fill="rgba(255,255,255,0.14)" />

        <!-- Secondary nodes -->
        <circle cx="200" cy="400" r="14" fill="url(#nodeGlowWhite)" />
        <circle cx="200" cy="400" r="1.5" fill="rgba(255,255,255,0.14)" />

        <circle cx="500" cy="340" r="18" fill="url(#nodeGlow)" />
        <circle cx="500" cy="340" r="1.8" fill="rgba(45,200,86,0.35)" />

        <circle cx="780" cy="430" r="14" fill="url(#nodeGlowWhite)" />
        <circle cx="780" cy="430" r="1.5" fill="rgba(255,255,255,0.12)" />

        <circle cx="1100" cy="350" r="16" fill="url(#nodeGlowWhite)" />
        <circle cx="1100" cy="350" r="1.5" fill="rgba(255,255,255,0.14)" />

        <!-- Accent hexagons -->
        <polygon points="1280,280 1296,270 1312,280 1312,298 1296,308 1280,298" fill="none" stroke="rgba(45,200,86,0.08)" stroke-width="0.8" />
        <polygon points="160,480 172,472 184,480 184,494 172,502 160,494" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="0.7" />
        <polygon points="720,50 736,40 752,50 752,68 736,78 720,68" fill="none" stroke="rgba(45,200,86,0.06)" stroke-width="0.7" />
      </svg>

      <!-- Top edge light streak -->
      <div class="hero-edge-light"></div>

      <div class="relative mx-auto max-w-[1440px] px-4 pb-28 md:px-8 md:pb-36">
      <div class="grid items-end gap-12 md:grid-cols-[minmax(0,1.1fr)_minmax(18rem,24rem)]">
        <div>
          <div class="mb-6 flex items-center gap-3">
            <span class="h-px w-12 bg-[#2DC856]/65"></span>
            <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-[#7DDEA1]">
              Service Architecture v2.4
            </span>
          </div>

          <h1 class="max-w-[9ch] text-[3.5rem] font-black leading-[0.9] tracking-[-0.055em] text-white md:text-[5.75rem]">
            Infrastructure as a Service
          </h1>

          <p class="mt-8 max-w-xl text-lg leading-8 text-white/64">
            Evium deploys and operates charging ecosystems for real estate, fleets, public corridors, and commercial sites without pushing owners into hardware, permitting, or operational complexity.
          </p>
        </div>

        <div class="flex flex-col items-start gap-4 md:items-end">
          <div class="uptime-panel w-full max-w-[24rem] border border-white/12 px-7 py-6">
            <div class="flex items-center justify-between gap-4">
              <div class="text-[10px] font-medium uppercase tracking-[0.16em] text-white/44">
                Network Reliability
              </div>
              <div class="w-[8.9rem] text-center text-[10px] font-medium uppercase tracking-[0.16em] text-white/34">
                Status
              </div>
            </div>

            <div class="mt-7 grid grid-cols-[minmax(0,1fr)_8.9rem] gap-8 items-center">
              <div class="flex min-w-0 flex-col items-center">
                <div class="meter-track" aria-hidden="true">
                  <svg viewBox="0 0 180 108" class="meter-svg" role="presentation">
                    <defs>
                      <linearGradient id="eviumReliabilityArc" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%" stop-color="#7f2f35" />
                        <stop offset="18%" stop-color="#b04937" />
                        <stop offset="40%" stop-color="#d87d32" />
                        <stop offset="58%" stop-color="#e2c233" />
                        <stop offset="78%" stop-color="#7cb446" />
                        <stop offset="100%" stop-color="#2DC856" />
                      </linearGradient>
                    </defs>
                    <path
                      d="M24 86 A66 66 0 0 1 156 86"
                      fill="none"
                      stroke="rgba(255,255,255,0.08)"
                      stroke-width="18"
                      stroke-linecap="round"
                      opacity="0.35"
                    />
                    <path
                      d="M24 86 A66 66 0 0 1 156 86"
                      fill="none"
                      stroke="url(#eviumReliabilityArc)"
                      stroke-width="14"
                      stroke-linecap="round"
                    />
                    <line x1="90" y1="86" x2="154" y2="64" stroke="#ecf6ef" stroke-width="3.5" stroke-linecap="round" />
                    <circle cx="90" cy="86" r="6.5" fill="#ecf6ef" />
                    <circle cx="90" cy="86" r="2.4" fill="#1A2F3A" />
                  </svg>
                </div>
                <span class="uptime-value mt-1 block text-[2.7rem] leading-none text-white">99.2%</span>
                <span class="mt-2 block text-center text-[11px] font-medium uppercase tracking-[0.14em] text-white/38">
                  Rolling 30-day uptime
                </span>
              </div>

              <div class="border-l border-white/10 pl-6">
                <div class="space-y-3 text-left">
                  <span class="inline-flex items-center gap-2 text-[10px] font-medium uppercase tracking-[0.16em] text-white/66">
                    <span class="status-light status-green is-on"></span>
                    Online
                  </span>
                  <span class="inline-flex items-center gap-2 text-[10px] font-medium uppercase tracking-[0.16em] text-white/42">
                    <span class="status-light status-yellow is-off"></span>
                    Under Maintenance
                  </span>
                  <span class="inline-flex items-center gap-2 text-[10px] font-medium uppercase tracking-[0.16em] text-white/42">
                    <span class="status-light status-red is-off"></span>
                    Offline
                  </span>
                </div>

                <div class="mt-5 border-t border-white/10 pt-4">
                  <div class="text-[10px] font-medium uppercase tracking-[0.14em] text-white/30">Current State</div>
                  <div class="mt-1 text-sm font-semibold tracking-[0.01em] text-white/76">Nominal</div>
                </div>
              </div>
            </div>

            <div class="mt-7 h-px w-full bg-white/10"></div>

            <dl class="mt-5 grid grid-cols-[auto_1fr] gap-x-6 gap-y-3 text-left">
              <dt class="text-[10px] font-medium uppercase tracking-[0.14em] text-white/30">Monitoring</dt>
              <dd class="text-sm font-semibold text-right text-white/72">24/7 active</dd>

              <dt class="text-[10px] font-medium uppercase tracking-[0.14em] text-white/30">Last outage</dt>
              <dd class="text-sm font-semibold text-right text-white/72">17 days ago</dd>

              <dt class="text-[10px] font-medium uppercase tracking-[0.14em] text-white/30">Open exceptions</dt>
              <dd class="text-sm font-semibold text-right text-white/72">0</dd>
            </dl>
          </div>
          <span class="text-[10px] font-medium uppercase tracking-[0.14em] text-white/40">
            Est. 2024 Precision Unit
          </span>
        </div>
      </div>
      </div>

      <div class="services-transition-panel pointer-events-none absolute inset-x-0 bottom-[-1px] h-32"></div>
    </section>

    <section class="relative z-10 mx-auto -mt-10 max-w-[1440px] px-4 pb-24 md:-mt-14 md:px-8 md:pb-32">
      <div class="services-content-shell rounded-t-[2rem] bg-[#f7f7f4] px-0 pt-6 shadow-[0_-24px_60px_rgba(12,20,28,0.08)] md:rounded-t-[2.5rem] md:pt-8">
      <div class="grid grid-cols-1 gap-4 md:grid-cols-12 md:auto-rows-[255px]">
        {topCards.map((card) => (
          <a
            href={card.href}
            class="group relative overflow-hidden rounded-2xl md:col-span-4"
          >
            <img
              src={card.image}
              alt={card.title}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-[linear-gradient(to_top,rgba(16,24,29,0.82),rgba(16,24,29,0.18))]"></div>
            <div class="absolute inset-0 ring-1 ring-inset ring-white/10"></div>
            <div class="relative flex h-full flex-col justify-between p-5">
              <span class="text-[10px] font-medium uppercase tracking-[0.14em] text-white/70">{card.code}</span>
              <div>
                <h2 class="text-[1.72rem] font-bold leading-none tracking-[-0.03em] text-white">{card.title}</h2>
                <p class="mt-1 text-sm font-medium text-white/72">{card.subtitle}</p>
              </div>
            </div>
          </a>
        ))}

        <a
          href="/solutions/generate-profits"
          class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white px-6 py-7 shadow-[0_28px_60px_rgba(10,20,28,0.08)] md:col-span-6 md:row-span-2 md:px-10 md:py-9"
        >
          <div class="absolute right-6 top-6 flex h-14 w-14 items-center justify-center rounded-xl bg-[#ededec] text-[#a7aaaa] transition-colors duration-300 group-hover:bg-[#dfe8e1] group-hover:text-[#17883c] md:right-8 md:top-8 md:h-16 md:w-16">
            <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" aria-hidden="true">
              <rect x="5" y="4.5" width="14" height="15" rx="2.5" stroke="currentColor" stroke-width="1.7"></rect>
              <path d="M8.5 8h7M8.5 11.5h2.2M13.2 11.5h2.3M8.5 15h2.2M13.2 15h2.3" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"></path>
            </svg>
          </div>

          <div class="max-w-md">
            <span class="block text-[10px] font-medium uppercase tracking-[0.14em] text-[#7a8a8f]">
              Profitability Terminal
            </span>
            <h2 class="mt-5 text-[2.1rem] font-bold leading-[1.02] tracking-[-0.04em] text-[#11181d] md:text-[2.45rem]">
              Calculate Generated Profits
            </h2>

            <div class="mt-9 max-w-sm space-y-8">
              <div>
                <div class="flex items-center justify-between text-[10px] font-medium uppercase tracking-[0.14em] text-[#7a8a8f]">
                  <span>Station Count</span>
                  <span class="font-bold text-[#182126]">12 Units</span>
