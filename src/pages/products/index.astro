---

<Layout title="Products — Evium Charging">
  <HeroCarouselPedestal />

  <!-- Product Catalog -->
  <section class="product-catalog">
    <div class="catalog-inner">

      <!-- Tab bar -->
      <div class="tab-bar">
        <button class="tab-btn is-active" data-tab="l2">Level 2 Charger</button>
        <button class="tab-btn" data-tab="l3">Level 3 Charger</button>
      </div>

      <!-- L2 Section -->
      <div class="tab-panel is-visible" id="panel-l2">
        <div class="tab-intro">
          <p class="intro-question">
            What is a Level 2 Charger?
            <button
              type="button"
              class="chart-info-btn"
              aria-label="View charging speed chart"
              title="View charging speed chart"
            >
              <svg viewBox="0 0 16 16" aria-hidden="true">
                <circle cx="8" cy="8" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="8" cy="4.4" r="0.9" fill="currentColor"/>
                <path d="M8 7v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </button>
          </p>
          <p class="intro-answer">A Level 2 EV charging station (L2) is the optimal charging solution for daily to weekly use. On average, L2s will charge an EV from 10% to full battery in 5-7 hours.</p>
        </div>

        <div class="product-cards">
          {l2Products.map((product, i) => (
            <div id={product.id} data-product-tab="l2" class={`product-card ${i % 2 !== 0 ? 'card-reversed' : ''}`}>
              <div class="card-image-col">
                <img src={product.image} alt={product.title} class="card-product-img" loading="lazy" />
              </div>
              <div class="card-content-col">
                <h3 class="card-title">{product.title}</h3>
                <p class="card-subtitle">{product.subtitle}</p>
                <div class="card-specs">
                  {product.specs.map((spec) => (
                    <div class="spec-item">
                      <span class="spec-label">{spec.label}</span>
                      <span class="spec-value">{spec.value}</span>
                    </div>
                  ))}
                </div>
                <a href="/contact/quote" class="card-cta">Request a Quote <span class="cta-arrow">→</span></a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- L3 Section -->
      <div class="tab-panel" id="panel-l3">
        <div class="tab-intro">
          <p class="intro-question">
            What is a Level 3 Charger?
            <button
              type="button"
              class="chart-info-btn"
              aria-label="View charging speed chart"
              title="View charging speed chart"
            >
              <svg viewBox="0 0 16 16" aria-hidden="true">
                <circle cx="8" cy="8" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="8" cy="4.4" r="0.9" fill="currentColor"/>
                <path d="M8 7v5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            </button>
          </p>
          <p class="intro-answer">A Level 3 EV charging station (L3) is the optimal charging solution for daily to weekly use. On average, L3s will charge an EV from 10% to 90% of battery capacity in 15-90 minutes depending on power.</p>
        </div>

        <div class="product-cards">
          {l3Products.map((product, i) => (
            <div id={product.id} data-product-tab="l3" class={`product-card ${i % 2 !== 0 ? 'card-reversed' : ''}`}>
              <div class="card-image-col">
                <img src={product.image} alt={product.title} class="card-product-img" loading="lazy" />
              </div>
              <div class="card-content-col">
                <h3 class="card-title">{product.title}</h3>
                <p class="card-subtitle">{product.subtitle}</p>
                <div class="card-specs">
                  {product.specs.map((spec) => (
                    <div class="spec-item">
                      <span class="spec-label">{spec.label}</span>
                      <span class="spec-value">{spec.value}</span>
                    </div>
                  ))}
                </div>
                <a href="/contact/quote" class="card-cta">Request a Quote <span class="cta-arrow">→</span></a>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- Charging-speed chart overlay (hidden by default) -->
  <div class="chart-overlay" id="chart-overlay" role="dialog" aria-modal="true" aria-label="Charging speed chart" hidden>
    <div class="chart-overlay-backdrop" data-chart-close aria-hidden="true"></div>
    <div class="chart-overlay-content">
      <button type="button" class="chart-close" id="chart-close-btn" aria-label="Close chart">
        <svg viewBox="0 0 16 16" aria-hidden="true">
          <path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
      <img
        src="/images/charging-speed-chart-cropped.png"
        alt="Charging speed chart: charger amperage, charging speed, battery size, and charging time by vehicle type"
        class="chart-overlay-img"
        draggable="false"
      />
    </div>
  </div>
</Layout>

<style>
  /* ── Catalog section ───────────────────────────────────── */
  .product-catalog {
    background: #f7f7f4;
    padding: 4rem 1rem 5rem;
  }

  .catalog-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Tab bar ───────────────────────────────────────────── */
  .tab-bar {
    display: flex;
    justify-content: center;
    gap: 0;
    border-bottom: 1px solid #d4d7d5;
    margin-bottom: 3rem;
  }

  .tab-btn {
    flex: 1;
    max-width: 320px;
    padding: 1rem 2rem;
    background: none;
    border: none;
    font-family: 'Maven Pro', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8b989c;
    cursor: pointer;
    position: relative;
    transition: color 0.25s ease;
  }

  .tab-btn::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    transition: background 0.25s ease;
  }

  .tab-btn.is-active {
    color: #2DC856;
  }

  .tab-btn.is-active::after {
    background: #2DC856;
  }

  .tab-btn:hover:not(.is-active) {
    color: #55656d;
  }

  /* ── Tab panels ────────────────────────────────────────── */
  .tab-panel {
    display: none;
  }

  .tab-panel.is-visible {
    display: block;
  }

  /* ── Intro ─────────────────────────────────────────────── */
  .tab-intro {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
    padding: 0 0.5rem;
  }

  .intro-question {
    font-size: 1rem;
    font-weight: 500;
    color: #33444c;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .intro-answer {
    font-size: 0.95rem;
    line-height: 1.7;
    color: #55656d;
  }

  /* ── Chart info icon ─────────────────────────────────────
     Subtle circular "i" button next to the question text. Clicking opens
     the charging-speed chart in a modal overlay. ───────────────────── */
  .chart-info-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    padding: 0;
    border: 0;
    background: transparent;
    color: #2DC856;
    cursor: pointer;
    border-radius: 50%;
    transition: color 0.18s ease, background 0.18s ease, transform 0.18s ease;
    flex-shrink: 0;
  }
  .chart-info-btn svg {
    width: 18px;
    height: 18px;
    display: block;
  }
  .chart-info-btn:hover {
    color: #25b048;
    background: rgba(45, 200, 86, 0.12);
    transform: scale(1.08);
  }
  .chart-info-btn:focus-visible {
    outline: 2px solid rgba(45, 200, 86, 0.7);
    outline-offset: 2px;
  }

  /* ── Chart overlay modal ─────────────────────────────────
     Full-screen dark backdrop, centered chart image with brand-styled
     close button. Shown when the info icon is clicked. ──────────────── */
  .chart-overlay[hidden] { display: none; }
  .chart-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(20px, 4vw, 60px);
    /* Fade in */
    animation: chart-fade-in 0.22s ease-out;
  }
  @keyframes chart-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  .chart-overlay-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 18, 22, 0.82);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: pointer;
  }
  .chart-overlay-content {
    position: relative;
    z-index: 1;
    max-width: min(1100px, 100%);
    max-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Subtle rise-in */
    animation: chart-rise 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes chart-rise {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0)    scale(1);    }
  }
  .chart-overlay-img {
    display: block;
    width: 100%;
    height: auto;
    max-height: calc(100vh - clamp(40px, 8vw, 120px));
    object-fit: contain;
    border-radius: 14px;
    box-shadow:
      0 24px 80px rgba(0, 0, 0, 0.55),
      0 4px 16px rgba(0, 0, 0, 0.32),
      0 0 0 1px rgba(255, 255, 255, 0.06);
    user-select: none;
  }
  /* Close button — sits in the top-right corner of the chart, using brand
     tokens so it reads as part of the Evium site. */
  .chart-close {
    position: absolute;
    top: clamp(-12px, -0.6vw, -8px);
    right: clamp(-12px, -0.6vw, -8px);
    width: clamp(34px, 3.4vw, 42px);
    height: clamp(34px, 3.4vw, 42px);
    padding: 0;
    border: 0;
    background: #2DC856;
    color: #0d1a22;
    border-radius: 50%;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow:
      0 6px 18px rgba(45, 200, 86, 0.45),
      0 0 0 2px rgba(10, 18, 22, 0.75);
    transition: transform 0.18s ease, background 0.18s ease, box-shadow 0.18s ease;
    z-index: 2;
  }
  .chart-close svg {
    width: 52%;
    height: 52%;
    display: block;
  }
  .chart-close:hover {
    background: #36e464;
    transform: scale(1.08) rotate(90deg);
    box-shadow:
      0 8px 22px rgba(45, 200, 86, 0.55),
      0 0 0 2px rgba(10, 18, 22, 0.85);
  }
  .chart-close:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }
  /* Disable page scroll while the overlay is open */
  :global(body.chart-overlay-open) { overflow: hidden; }

  /* ── Product cards ─────────────────────────────────────── */
  .product-cards {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .product-card {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    background: #1a2a34;
    border-radius: 1.25rem;
    overflow: hidden;
    min-height: 380px;
  }

  .product-card.card-reversed {
    direction: rtl;
  }

  .product-card.card-reversed > * {
    direction: ltr;
  }

  /* ── Image column ──────────────────────────────────────── */
  .card-image-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
  }

  .card-product-img {
    max-height: 300px;
    max-width: 100%;
    object-fit: contain;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.3));
  }

  /* ── Content column ────────────────────────────────────── */
  .card-content-col {
    padding: 2.5rem 2.5rem 2.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .product-card.card-reversed .card-content-col {
    padding: 2.5rem 1.5rem 2.5rem 2.5rem;
  }

  .card-title {
    font-size: 1.65rem;
    font-weight: 700;
    color: white;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .card-subtitle {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  /* ── Specs grid ────────────────────────────────────────── */
  .card-specs {
    margin-top: 1.75rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem 1.5rem;
  }

  .spec-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .spec-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .spec-value {
    font-size: 0.82rem;
    font-weight: 600;
    color: white;
    line-height: 1.35;
  }

  /* ── CTA button ────────────────────────────────────────── */
  .card-cta {
    margin-top: 2rem;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: #2DC856;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    color: white;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .card-cta:hover {
    background: #24a848;
    transform: translateY(-1px);
  }

  .cta-arrow {
    font-size: 0.9rem;
    transition: transform 0.2s ease;
  }

  .card-cta:hover .cta-arrow {
    transform: translateX(3px);
  }

  /* ── Mobile ────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .product-catalog {
      padding: 2.5rem 1rem 3rem;
    }

    .tab-intro {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .product-card,
    .product-card.card-reversed {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .product-card.card-reversed > * {
      direction: ltr;
    }

    .card-image-col {
      padding: 2rem 1.5rem 0.5rem;
    }

    .card-product-img {
      max-height: 220px;
    }

    .card-content-col,
    .product-card.card-reversed .card-content-col {
      padding: 1.5rem;
    }

    .card-specs {
      grid-template-columns: repeat(2, 1fr);
    }

    .card-title {
      font-size: 1.35rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const panels = document.querySelectorAll<HTMLElement>('.tab-panel');

    function activateTab(target: string) {
      tabs.forEach((t) => t.classList.toggle('is-active', t.getAttribute('data-tab') === target));
      panels.forEach((p) => p.classList.remove('is-visible'));
      document.getElementById(`panel-${target}`)?.classList.add('is-visible');
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');
        if (target) activateTab(target);
      });
    });

    // ── Deep-link support: scroll to product and auto-switch tab ──
    // Supports two URL-hash shapes:
    //   • `#panel-l2` / `#panel-l3`  — the nav "Products → Level 2/3" links
    //     switch the tab and scroll to the top of the catalog.
    //   • `#<product-id>`            — deep links from the pedestal portal
    //     carousel — switch to the right tab and center the card.
    function handleHash() {
      const id = window.location.hash.slice(1);
      if (!id) return;

      // Panel-level link: scroll to the catalog section and activate the tab.
      if (id === 'panel-l2' || id === 'panel-l3') {
        const tab = id.replace('panel-', '');
        activateTab(tab);
        const panel = document.getElementById(id);
        if (panel) {
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              const rect = panel.getBoundingClientRect();
              const absoluteTop = window.pageYOffset + rect.top;
              // Leave some room for the fixed nav (~80px) above the panel.
              window.scrollTo({ top: Math.max(0, absoluteTop - 80), behavior: 'smooth' });
            });
          });
        }
        return;
      }

      // Product-card deep link.
      const card = document.getElementById(id);
      if (!card) return;
      const tab = card.getAttribute('data-product-tab');
      if (tab) activateTab(tab);
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          const rect = card.getBoundingClientRect();
          const absoluteTop = window.pageYOffset + rect.top;
          const targetScroll = absoluteTop - (window.innerHeight - rect.height) / 2;
          window.scrollTo({ top: Math.max(0, targetScroll), behavior: 'smooth' });
        });
      });
    }

    handleHash();
    window.addEventListener('hashchange', handleHash);

    // ── Charging-speed chart modal ─────────────────────────
    // Every `.chart-info-btn` on the page opens the same overlay — both
    // the L2 and L3 intro sections have one.
    const chartBtns    = document.querySelectorAll<HTMLButtonElement>('.chart-info-btn');
    const chartOverlay = document.getElementById('chart-overlay');
    const chartCloseEls = document.querySelectorAll<HTMLElement>('[data-chart-close], #chart-close-btn');
    // Remember which trigger opened the overlay so we can return focus there on close
    let lastChartTrigger: HTMLElement | null = null;

    function openChart(fromEl: HTMLElement | null) {
      if (!chartOverlay) return;
      lastChartTrigger = fromEl;
      chartOverlay.hidden = false;
      document.body.classList.add('chart-overlay-open');
      (document.getElementById('chart-close-btn') as HTMLElement | null)?.focus();
    }
    function closeChart() {
      if (!chartOverlay) return;
      chartOverlay.hidden = true;
      document.body.classList.remove('chart-overlay-open');
      lastChartTrigger?.focus();
    }

    chartBtns.forEach((btn) => btn.addEventListener('click', () => openChart(btn)));
    chartCloseEls.forEach((el) => el.addEventListener('click', closeChart));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && chartOverlay && !chartOverlay.hidden) closeChart();
    });
  });
</script>
