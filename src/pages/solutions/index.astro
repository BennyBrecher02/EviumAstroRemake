---
// The standalone /solutions page has been retired — its layout now lives
// inside the homepage scroll scene (src/components/heroes/HeroPortalSolutionsScene.astro)
// as the final state of the portal → solutions transition. Clicking
// "Solutions" in the navbar goes to /#solutions, and the scene's hash
// handler drops the user into that final state centered in view.
//
// This file stays only as a redirect so any direct hits on /solutions
// (external links, bookmarks) still land on the right content.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Evium Charging — Solutions</title>
    <meta http-equiv="refresh" content="0; url=/#solutions" />
    <link rel="canonical" href="/#solutions" />
    <meta name="robots" content="noindex" />
    <script is:inline>
      // Client-side fallback in case meta-refresh is disabled.
      window.location.replace('/#solutions');
    </script>
  </head>
  <body>
    <p style="font-family: 'Maven Pro', sans-serif; padding: 2rem; color: #0d1a22;">
      Redirecting to <a href="/#solutions">Evium Charging — Solutions</a>…
    </p>
  </body>
</html>
