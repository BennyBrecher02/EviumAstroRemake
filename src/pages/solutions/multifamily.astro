---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="EV Charging for Multifamily Real Estate — Evium Charging"
  description="Add EV charging to your apartment or condo property at zero upfront cost. Attract tenants, earn revenue, and stay ahead of competing properties. Fully managed by Evium."
>
  <main>

    <!-- ═══════════════════════════════════════════════════════
         HERO
    ════════════════════════════════════════════════════════ -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
      <!-- Deep atmospheric background gradient -->
      <div class="absolute inset-0 bg-evium-dark">
        <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 60% 30%, rgba(45,200,86,0.10) 0%, transparent 70%), radial-gradient(ellipse 50% 80% at 0% 100%, rgba(26,47,58,0.9) 0%, transparent 60%);"></div>
        <!-- Subtle grid overlay -->
        <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(45,200,86,1) 1px, transparent 1px), linear-gradient(90deg, rgba(45,200,86,1) 1px, transparent 1px); background-size: 60px 60px;"></div>
      </div>

      <!-- Green accent line top -->
      <div class="absolute top-0 left-0 right-0 h-px bg-evium-green opacity-30"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-10 py-24 grid lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Copy -->
        <div>
          <div class="inline-flex items-center gap-2 mb-6 px-3 py-1.5 rounded-full border border-evium-green/30 bg-evium-green/10">
            <span class="w-1.5 h-1.5 rounded-full bg-evium-green"></span>
            <span class="text-evium-green text-xs font-semibold tracking-widest uppercase">Multifamily Real Estate</span>
          </div>

          <h1 class="text-5xl lg:text-6xl font-black leading-[1.05] tracking-tight text-white mb-6">
            The Amenity Your<br/>
            <span class="text-evium-green">Tenants Are</span><br/>
            Already Asking For.
          </h1>

          <p class="text-white/65 text-lg leading-relaxed mb-8 max-w-lg">
            EV ownership is rising fast — and residents are choosing properties based on charging access. Add a premium amenity, earn a new revenue stream, and outpace competing buildings. Evium handles everything. You pay nothing upfront.
          </p>

          <div class="flex flex-wrap gap-4">
            <a
              href="/contact/quote"
              class="inline-flex items-center gap-2 bg-evium-green text-evium-dark font-bold text-sm tracking-widest uppercase px-7 py-4 rounded hover:bg-white transition-colors duration-200"
            >
              Get a Free Site Assessment
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
            <a
              href="#financial-models"
              class="inline-flex items-center gap-2 border border-white/20 text-white/70 font-semibold text-sm tracking-wider uppercase px-7 py-4 rounded hover:border-evium-green hover:text-evium-green transition-colors duration-200"
            >
              See Financing Options
            </a>
          </div>

          <!-- Social proof strip -->
          <div class="mt-10 pt-8 border-t border-white/10 flex flex-wrap gap-8">
            <div>
              <div class="text-3xl font-black text-evium-green">500+</div>
              <div class="text-white/50 text-xs uppercase tracking-widest mt-0.5">Chargers Installed</div>
            </div>
            <div>
              <div class="text-3xl font-black text-white">$0</div>
              <div class="text-white/50 text-xs uppercase tracking-widest mt-0.5">Upfront Cost</div>
            </div>
            <div>
              <div class="text-3xl font-black text-white">24/7</div>
              <div class="text-white/50 text-xs uppercase tracking-widest mt-0.5">Managed Support</div>
            </div>
          </div>
        </div>

        <!-- Right: Charger image -->
        <div class="relative flex items-center justify-center lg:justify-end">
          <div class="relative">
            <!-- Glow behind image -->
            <div class="absolute inset-0 scale-110 rounded-3xl" style="background: radial-gradient(ellipse at 50% 50%, rgba(45,200,86,0.18) 0%, transparent 70%); filter: blur(24px);"></div>
            <img
              src="/images/evium-evocharge-l2-wallmount.png"
              alt="EVOCHARGE Level 2 Wall-Mount EV Charger"
              class="relative z-10 w-full max-w-sm lg:max-w-md drop-shadow-2xl"
              loading="eager"
            />
          </div>
        </div>
      </div>

      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-32" style="background: linear-gradient(to bottom, transparent, #1A2F3A);"></div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         WHY EV CHARGING FOR MULTIFAMILY
    ════════════════════════════════════════════════════════ -->
    <section class="relative bg-evium-dark py-24 overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px bg-evium-green/20"></div>

      <div class="max-w-6xl mx-auto px-6 lg:px-10">
        <div class="max-w-2xl mb-16">
          <p class="text-evium-green text-xs font-semibold tracking-widest uppercase mb-4">The Market Reality</p>
          <h2 class="text-4xl lg:text-5xl font-black text-white leading-tight mb-5">
            EV Charging Isn't Optional Anymore.
          </h2>
          <p class="text-white/60 text-lg leading-relaxed">
            The shift is already underway. Properties without charging infrastructure are losing leases. Properties with it are winning them.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-evium-dark-light rounded-xl p-8 border border-white/5 hover:border-evium-green/30 transition-colors duration-300">
            <div class="w-12 h-12 rounded-lg bg-evium-green/15 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-evium-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <h3 class="text-white font-bold text-lg mb-3">EV Adoption Is Accelerating</h3>
            <p class="text-white/55 text-sm leading-relaxed">
              Millions of new EVs hit the road every year. By 2030, EV drivers will be the norm, not the exception. Residents without home charging are frustrated residents looking to move.
            </p>
          </div>

          <div class="bg-evium-dark-light rounded-xl p-8 border border-white/5 hover:border-evium-green/30 transition-colors duration-300">
            <div class="w-12 h-12 rounded-lg bg-evium-green/15 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-evium-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            </div>
            <h3 class="text-white font-bold text-lg mb-3">Tenants Search for Charging</h3>
            <p class="text-white/55 text-sm leading-relaxed">
              Apartment-hunting EV drivers filter by charging availability the same way they filter by parking or laundry. Your listing without it is invisible to a growing slice of the renter market.
            </p>
          </div>

          <div class="bg-evium-dark-light rounded-xl p-8 border border-white/5 hover:border-evium-green/30 transition-colors duration-300">
            <div class="w-12 h-12 rounded-lg bg-evium-green/15 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-evium-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            </div>
            <h3 class="text-white font-bold text-lg mb-3">Competitors Are Already Moving</h3>
            <p class="text-white/55 text-sm leading-relaxed">
              Across NJ, NY, and the rest of the country, forward-thinking property owners are locking in charging before their neighbors do. The time to act is now — not when you're playing catch-up.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         PAIN POINTS ADDRESSED
    ════════════════════════════════════════════════════════ -->
    <section class="relative bg-evium-dark-light py-24 overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px bg-evium-green/15"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-evium-green/15"></div>
      <!-- Decorative background shape -->
      <div class="absolute right-0 top-0 bottom-0 w-1/2 opacity-5" style="background: radial-gradient(ellipse at 100% 50%, rgba(45,200,86,1) 0%, transparent 60%);"></div>

      <div class="max-w-6xl mx-auto px-6 lg:px-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-evium-green text-xs font-semibold tracking-widest uppercase mb-4">Every Objection, Handled</p>
            <h2 class="text-4xl lg:text-5xl font-black text-white leading-tight mb-6">
              We Know What's Been<br/>Holding You Back.
            </h2>
            <p class="text-white/60 text-lg leading-relaxed mb-8">
              Property owners come to us with the same concerns every time. Upfront cost. Electrical complexity. Permits. Liability. Ongoing maintenance. Resident billing headaches. Here's how Evium eliminates all of it.
            </p>
            <a href="/contact/quote" class="inline-flex items-center gap-2 text-evium-green font-semibold text-sm tracking-wider uppercase hover:text-white transition-colors duration-200">
              Talk to Our Team
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>

          <div class="space-y-4">
            {[
              {
                problem: "Upfront capital costs are prohibitive",
                solution: "Under our no-cost model, Evium covers 100% of hardware, installation, and electrical work. Zero capital required from you."
              },
              {
                problem: "Electrical infrastructure is complicated",
                solution: "Our engineers assess your property's electrical capacity, design the optimal layout, and handle every aspect of the upgrade or new installation."
              },
              {
                problem: "Permits and compliance are a maze",
                solution: "We manage all permits, inspections, utility coordination, and code compliance from start to finish. You sign once — we handle the rest."
              },
              {
                problem: "Ongoing maintenance is a burden",
                solution: "Evium provides 24/7 remote monitoring, preventative maintenance, and on-site repair service. If a charger goes down, we fix it — not you."
              },
              {
                problem: "Resident billing and access are complex",
                solution: "Our software platform handles resident access control, usage tracking, and billing automatically. Residents pay per session. You see the revenue."
              },
            ].map((item) => (
              <div class="bg-evium-dark rounded-xl p-6 border border-white/5 group hover:border-evium-green/20 transition-colors duration-300">
                <div class="flex gap-4">
                  <div class="flex-shrink-0 w-5 h-5 rounded-full bg-evium-green/20 border border-evium-green/40 flex items-center justify-center mt-0.5">
                    <svg class="w-3 h-3 text-evium-green" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <div>
                    <p class="text-white/40 text-xs font-semibold tracking-wide uppercase mb-1 line-through decoration-white/20">{item.problem}</p>
                    <p class="text-white/80 text-sm leading-relaxed">{item.solution}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         WHAT EVIUM DELIVERS — TURNKEY SCOPE
    ════════════════════════════════════════════════════════ -->
    <section class="relative bg-evium-dark py-24 overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px bg-evium-green/20"></div>

      <div class="max-w-6xl mx-auto px-6 lg:px-10">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <p class="text-evium-green text-xs font-semibold tracking-widest uppercase mb-4">The Full Scope</p>
          <h2 class="text-4xl lg:text-5xl font-black text-white leading-tight mb-5">
            Truly Turnkey.<br/>One Partner. Everything Covered.
          </h2>
          <p class="text-white/60 text-lg leading-relaxed">
            From the initial site walk to day-1,000 of operations, Evium owns the entire process so you never have to.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {[
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6-3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>`,
              title: "Site Assessment & Engineering",
              desc: "We evaluate your electrical capacity, parking layout, and resident density to design the right charging footprint for your property."
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>`,
              title: "Hardware Selection",
              desc: "We match Level 2 chargers to your property type, resident profile, and parking configuration — no guessing, no oversizing."
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
              title: "Full Electrical Installation",
              desc: "Licensed electricians handle all panel work, conduit, wiring, and equipment mounting. We work around your residents with minimal disruption."
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
              title: "Permits & Utility Coordination",
              desc: "All permitting, inspections, utility applications, and compliance paperwork managed end-to-end. You stay focused on your property."
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 6v1m0 5v-1m-3.599-1.401A2 2 0 0012 18c.667 0 1.282-.18 1.799-.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
              title: "Rebate Processing",
              desc: "We identify and file applicable utility rebates, state incentives, and NEVI-aligned programs to maximize value for every project."
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>`,
              title: "Ongoing Operations & Support",
              desc: "24/7 remote monitoring, resident support line, preventative maintenance, and on-site repair service. We never hand you the keys and disappear."
            },
          ].map((item) => (
            <div class="bg-evium-dark-light rounded-xl p-7 border border-white/5 hover:border-evium-green/25 transition-colors duration-300 group">
              <div class="w-11 h-11 rounded-lg bg-evium-green/15 flex items-center justify-center mb-5 group-hover:bg-evium-green/25 transition-colors duration-300">
                <svg class="w-5 h-5 text-evium-green" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" set:html={item.icon}></svg>
              </div>
              <h3 class="text-white font-bold text-base mb-2">{item.title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         RECOMMENDED HARDWARE
    ════════════════════════════════════════════════════════ -->
    <section class="relative bg-evium-dark-light py-24 overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px bg-evium-green/15"></div>
      <div class="absolute bottom-0 left-0 right-0 h-px bg-evium-green/15"></div>

      <div class="max-w-6xl mx-auto px-6 lg:px-10">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Image -->
          <div class="relative order-2 lg:order-1 flex justify-center">
            <div class="relative">
              <div class="absolute -inset-8 rounded-3xl opacity-20" style="background: radial-gradient(ellipse at 50% 50%, rgba(45,200,86,0.6) 0%, transparent 70%); filter: blur(30px);"></div>
              <img
                src="/images/evium-evocharge-l2-wallmount.png"
                alt="EVOCHARGE Level 2 Wall-Mount Charger — ideal for multifamily residential"
                class="relative z-10 w-72 lg:w-96 drop-shadow-2xl"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Copy -->
          <div class="order-1 lg:order-2">
            <p class="text-evium-green text-xs font-semibold tracking-widest uppercase mb-4">Recommended Hardware</p>
            <h2 class="text-4xl lg:text-5xl font-black text-white leading-tight mb-6">
              Level 2 Is the Right<br/>Fit for Residential.
            </h2>
            <p class="text-white/60 text-lg leading-relaxed mb-8">
              Your residents plug in when they get home and wake up to a full charge. Level 2 wall-mount chargers deliver 20–30 miles of range per hour — more than enough for overnight replenishment. No need for the speed of DC fast charging; your garage is their home base.
            </p>

            <div class="space-y-5 mb-10">
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-8 h-8 rounded-md bg-evium-green/15 flex items-center justify-center">
                  <svg class="w-4 h-4 text-evium-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div>
                  <h4 class="text-white font-semibold text-sm mb-1">EVOCHARGE by Evium</h4>
                  <p class="text-white/50 text-sm leading-relaxed">Our in-house branded Level 2 wall-mount charger. ENERGY STAR certified, OCPP 1.6 compatible, built for shared-access residential environments.</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-8 h-8 rounded-md bg-evium-green/15 flex items-center justify-center">
                  <svg class="w-4 h-4 text-evium-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div>
                  <h4 class="text-white font-semibold text-sm mb-1">Siemens VersiCharge</h4>
                  <p class="text-white/50 text-sm leading-relaxed">A proven commercial-grade Level 2 charger from our Siemens eMobility partnership. Configurable for dedicated or shared use with durable all-weather construction.</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-8 h-8 rounded-md bg-evium-green/15 flex items-center justify-center">
                  <svg class="w-4 h-4 text-evium-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <h4 class="text-white font-semibold text-sm mb-1">GSA-Approved & Code Compliant</h4>
                  <p class="text-white/50 text-sm leading-relaxed">All hardware is sourced from GSA-approved manufacturers. UL-listed, NEC compliant, and warranted against defects. No surprises at inspection.</p>
                </div>
              </div>
            </div>

            <a href="/products/level-2" class="inline-flex items-center gap-2 text-evium-green font-semibold text-sm tracking-wider uppercase hover:text-white transition-colors duration-200">
              View All Level 2 Products
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════
         FINANCIAL MODELS
    ════════════════════════════════════════════════════════ -->
    <section id="financial-models" class="relative bg-evium-dark py-24 overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px bg-evium-green/20"></div>
      <!-- Subtle green glow bottom-left -->
      <div class="absolute bottom-0 left-0 w-96 h-96 opacity-10" style="background: radial-gradient(ellipse at 0% 100%, rgba(45,200,86,1) 0%, transparent 60%); filter: blur(40px);"></div>

      <div class="max-w-6xl mx-auto px-6 lg:px-10">
        <div class="text-center max-w-2xl mx-auto mb-16">
          <p class="text-evium-green text-xs font-semibold tracking-widest uppercase mb-4">Financial Models</p>
          <h2 class="text-4xl lg:text-5xl font-black text-white leading-tight mb-5">
            You Choose How<br/>You Want to Work With Us.
          </h2>
          <p class="text-white/60 text-lg leading-relaxed">
            Most multifamily owners start with our no-cost model. But if you want more control — or more upside — we have options for that too.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
          <!-- No-Cost: Featured -->
          <div class="lg:col-span-2 relative bg-evium-dark-light rounded-xl p-8 border border-evium-green/40 overflow-hidden">
            <div class="absolute top-0 right-0 px-4 py-1.5 bg-evium-green text-evium-dark text-xs font-black tracking-widest uppercase rounded-bl-xl">
              Most Popular
            </div>
            <div class="absolute -bottom-8 -right-8 w-48 h-48 rounded-full opacity-10" style="background: radial-gradient(circle, rgba(45,200,86,1) 0%, transparent 70%);"></div>
            <div class="relative z-10">
              <div class="w-12 h-12 rounded-lg bg-evium-green/20 flex items-center justify-center mb-6">
                <svg class="w-6 h-6 text-evium-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 6v1m0 5v-1m-3.599-1.401A2 2 0 0012 18c.667 0 1.282-.18 1.799-.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
