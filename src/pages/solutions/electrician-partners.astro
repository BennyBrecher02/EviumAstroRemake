      </div>

      {/* Hero stripped down to its essentials — eyebrow + headline +
          subtitle + two CTAs. The old 4-stat grid (500+ / NEVI /
          $6MM+ / NJ·NY·CA) and the Siemens + pipeline trust band
          both lived here; removed entirely. Credibility numbers
          can come back as a dedicated section later if we want —
          for now the hero reads as a clean, confident intro. */}
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════
       HOW THE PARTNERSHIP WORKS  — now FIRST after the hero so
       the process arc (Apply → Vet → Install → Repeat) sets
       expectations before the value-prop cards explain why.
       Includes a scroll-in animation that plays to the 1-2-3-4
       structure: the connector line draws west-to-east, each step
       circle fades + scales in on stagger, step numbers pulse on
       arrival, and a subtle green comet runs along the connector
       in a slow loop once everything has landed.
  ═══════════════════════════════════════════════════ -->
  <section id="how-it-works" class="hiw-section bg-evium-dark-light py-24 relative overflow-hidden" data-hiw>
    {/* Background atmosphere — faint dot-grid + a soft green
        radial centered behind the step row so the section reads as
        a designed stage, not a flat slab of color. */}
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(rgba(45,200,86,1) 1px, transparent 1px); background-size: 28px 28px;" aria-hidden="true"></div>
    <div class="absolute inset-x-0 top-[58%] -translate-y-1/2 flex justify-center pointer-events-none" aria-hidden="true">
      <div class="w-[900px] h-[280px] rounded-full bg-evium-green opacity-[0.05] blur-3xl"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <div class="inline-flex items-center gap-2 mb-4 justify-center">
          <div class="h-px w-8 bg-evium-green"></div>
          <span class="text-evium-green text-sm font-semibold tracking-widest uppercase">The Process</span>
          <div class="h-px w-8 bg-evium-green"></div>
        </div>
        <h2 class="text-4xl font-black text-white mb-4">How It Works.</h2>
        <p class="text-white/60 text-lg">Simple process, clear expectations, ongoing relationship.</p>
      </div>

      <div class="relative">
        {/* Connector line — on desktop, runs west-to-east between
            the step circles. Pre-animation it has scaleX(0); when
            .is-revealed lands on the section it draws in fully,
            then a traveling green comet slides across it forever. */}
        <div class="hiw-line" aria-hidden="true">
          <div class="hiw-line-base"></div>
          <div class="hiw-line-comet"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { step: "01", title: "Apply",            body: "Submit your contractor profile — license info, service area, crew size, and relevant experience." },
            { step: "02", title: "Get Vetted",       body: "Evium reviews your credentials and conducts a brief introductory call to discuss scope and expectations." },
            { step: "03", title: "Match & Install",  body: "Get matched to upcoming projects that fit your geography and capacity. Receive site specs and materials, mobilize, and coordinate commissioning with Evium." },
            { step: "04", title: "Get Paid. Repeat.",body: "Milestone-based payment on completion. Strong performers get early access to the next pipeline." },
          ].map((s, i) => (
            <div class="hiw-step relative flex flex-col items-center text-center" style={`--hiw-i: ${i};`}>
              <div class="hiw-circle relative z-10 w-20 h-20 rounded-full bg-evium-dark border-2 border-evium-green/40 flex items-center justify-center mb-5">
                <span class="text-evium-green font-black text-lg">{s.step}</span>
              </div>
              <h3 class="text-white font-bold text-base mb-2">{s.title}</h3>
              <p class="text-white/50 text-sm leading-relaxed">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <style>
      /* Animated flare — ties into the 1-2-3-4 arc. The whole
         section starts un-revealed; IntersectionObserver in the
         script below adds `.is-revealed` when the section enters
         the viewport, which triggers the choreography:
           1. Each step's circle + text fades + scales in, staggered
              via `--hiw-i` so the west-to-east reveal mirrors the
              left-to-right process arc.
           2. The connector line draws from left (scaleX 0→1).
           3. Step circles get a one-off green glow pulse as they
              arrive.
           4. A thin green "comet" slides along the connector in a
              slow infinite loop once the draw-in has finished —
              the steady-state flourish. */
      .hiw-section .hiw-step {
        opacity: 0;
        transform: translateY(18px) scale(0.94);
        transition:
          opacity 0.6s ease,
          transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        transition-delay: calc(var(--hiw-i) * 140ms + 200ms);
      }
      .hiw-section.is-revealed .hiw-step {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
      .hiw-circle {
        transition:
          box-shadow 0.4s ease,
          border-color 0.4s ease;
      }
      .hiw-section.is-revealed .hiw-circle {
        animation: hiw-circle-pulse 900ms cubic-bezier(0.34, 1.56, 0.64, 1) both;
        animation-delay: calc(var(--hiw-i) * 140ms + 400ms);
      }
      @keyframes hiw-circle-pulse {
        0%   { box-shadow: 0 0 0 0 rgba(45, 200, 86, 0.7); border-color: rgba(45, 200, 86, 0.4); }
        40%  { box-shadow: 0 0 0 14px rgba(45, 200, 86, 0); border-color: rgba(45, 200, 86, 1); }
        100% { box-shadow: 0 0 0 0 rgba(45, 200, 86, 0);   border-color: rgba(45, 200, 86, 0.4); }
      }

      /* Connector line — only visible on desktop (where the steps
         actually sit in a single row). Lives on top of the step
         circles' top edge (top:40 px to match the 80 px circle).
         Starts / ends at 4 % from each edge of the grid (was
         calc(10% + 2rem), which put the endpoints basically flush
         with the outer two step circles' centers). 4 % leaves a
         meaningful runway extending past step 01 on the left and
         past step 04 on the right — the comet travels visibly out
         beyond the numbered circles on both ends instead of
         stopping at them. */
      .hiw-line {
        display: none;
        position: absolute;
        top: 40px;
        left: 4%;
        right: 4%;
        height: 2px;
        pointer-events: none;
      }
      @media (min-width: 1024px) {
        .hiw-line { display: block; }
      }
      .hiw-line-base {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to right,
          transparent 0%,
          rgba(45, 200, 86, 0.35) 15%,
          rgba(45, 200, 86, 0.35) 85%,
          transparent 100%
        );
        transform-origin: left center;
        transform: scaleX(0);
        transition: transform 1s cubic-bezier(0.4, 0, 0.2, 1);
        transition-delay: 300ms;
      }
      .hiw-section.is-revealed .hiw-line-base {
        transform: scaleX(1);
      }
      /* Traveling comet — starts hidden, reveals once the line has
         drawn in, then sweeps between the line's ends on a slow
         infinite ping-pong. Geometry revised:
           • Previously the comet's keyframes went from `left:-140px`
             (fully off-screen) to `left:calc(100%+20px)` (fully past
             the right end). That over-travel caused the comet to
             visibly "sever" at the line's right endpoint when it
             hit the turnaround with its body half past the line.
           • New keyframes: `0: left:0` → `100: left:calc(100%-140px)`.
             At every point in the cycle the comet's full body sits
             INSIDE the line's bounds (the comet is 140 px wide;
             at each endpoint one of its edges is flush with a line
             endpoint). Never severed, always complete.
           • Easing switched from `linear` to `ease-in-out` so the
             comet decelerates into each end and accelerates back
             out — a soft swing feel instead of a hard bounce.
           • Duration 7 s → 9 s per direction so the gentler motion
             gets room to breathe. */
      .hiw-line-comet {
        position: absolute;
        top: -1px;
        left: 0;
        width: 140px;
        height: 4px;
        border-radius: 4px;
        background: linear-gradient(
          to right,
          rgba(45, 200, 86, 0) 0%,
          rgba(45, 200, 86, 0.5) 40%,
          rgba(45, 200, 86, 1) 50%,
          rgba(45, 200, 86, 0.5) 60%,
          rgba(45, 200, 86, 0) 100%
        );
        filter: drop-shadow(0 0 8px rgba(45, 200, 86, 0.6));
        opacity: 0;
      }
      .hiw-section.is-revealed .hiw-line-comet {
        opacity: 1;
        animation: hiw-comet 9s ease-in-out infinite alternate;
        animation-delay: 1.4s;
      }
      @keyframes hiw-comet {
        0%   { left: 0;                     }
        100% { left: calc(100% - 140px);    }
      }

      @media (prefers-reduced-motion: reduce) {
        .hiw-section .hiw-step,
        .hiw-section.is-revealed .hiw-step {
          opacity: 1;
          transform: none;
          transition: none;
        }
        .hiw-section.is-revealed .hiw-circle { animation: none; }
        .hiw-section.is-revealed .hiw-line-base { transform: scaleX(1); transition: none; }
        .hiw-section.is-revealed .hiw-line-comet { animation: none; opacity: 0; }
      }
    </style>

    <script>
      // Trigger the How-It-Works reveal choreography the first time
      // the section comes meaningfully into view. Uses
      // IntersectionObserver with threshold 0.3 so the animation
      // doesn't fire before the user can actually see the steps.
      (() => {
        const section = document.querySelector<HTMLElement>('[data-hiw]');
        if (!section) return;
        if (!('IntersectionObserver' in window)) {
          section.classList.add('is-revealed');
          return;
        }
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              section.classList.add('is-revealed');
              io.disconnect();
              break;
            }
          }
        }, { threshold: 0.3, rootMargin: '0px 0px -10% 0px' });
        io.observe(section);
      })();
    </script>
  </section>


  <!-- ═══════════════════════════════════════════════════
