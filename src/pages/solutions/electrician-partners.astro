  </style>

  <script>
    // Client-side handler — no backend yet. Validates required fields,
    // surfaces a success banner, and disables the submit button once
    // a submission succeeds so repeated clicks don't spam. When the
    // real endpoint is wired up, swap the setTimeout for a fetch().
    (() => {
      const form   = document.getElementById('ep-register-form') as HTMLFormElement | null;
      const status = document.getElementById('ep-register-status');
      if (!form || !status) return;

      form.addEventListener('submit', (e) => {
        e.preventDefault();

        // Native check for the required fields — browsers handle per-
        // field focus + messaging. With novalidate on the form we call
        // reportValidity() ourselves.
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        // Optimistic UI: hide the banner while the pseudo-request runs.
        status.classList.remove('is-success', 'is-error');
        status.classList.add('hidden');

        // Simulated success. Replace with a real POST when the
        // backend endpoint (e.g. /api/partner-applications) is ready.
        setTimeout(() => {
          status.classList.remove('hidden');
          status.classList.add('is-success');
          status.textContent =
            "Thanks — your application is in. We review submissions weekly and will reach out within a few business days.";
          (form.querySelector('button[type=submit]') as HTMLButtonElement).disabled = true;
          (form.querySelector('button[type=submit]') as HTMLButtonElement).style.opacity = '0.5';
        }, 300);
      });
    })();
  </script>


