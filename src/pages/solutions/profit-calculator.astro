---
import Layout from '../../layouts/Layout.astro';

const presets = [
  { id: 'l2-residential', label: 'L2 — Multifamily',     ports: 4,  sessionsPerPort: 2.5, kwh: 18, price: 0.32 },
  { id: 'l2-commercial',  label: 'L2 — Commercial',      ports: 6,  sessionsPerPort: 3,   kwh: 22, price: 0.38 },
  { id: 'dcfc-retail',    label: 'DC Fast — Retail',     ports: 2,  sessionsPerPort: 8,   kwh: 35, price: 0.49 },
  { id: 'dcfc-highway',   label: 'DC Fast — Highway',    ports: 4,  sessionsPerPort: 12,  kwh: 45, price: 0.55 },
];
---

<Layout
  title="Profit Calculator — Evium Charging"
  description="Estimate the monthly, yearly, and 5-year revenue your property could generate with Evium EV chargers. Real numbers, no signup, results in real time."
>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-evium-dark pt-32 pb-16">
    <!-- Background grid -->
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: linear-gradient(#2DC856 1px, transparent 1px), linear-gradient(90deg, #2DC856 1px, transparent 1px); background-size: 60px 60px;"
    ></div>
    <!-- Radial glow -->
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[1100px] h-[600px] rounded-full opacity-[0.10] pointer-events-none"
      style="background: radial-gradient(ellipse at center, #2DC856 0%, transparent 65%);"
    ></div>

    <div class="relative max-w-6xl mx-auto px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-evium-green/10 border border-evium-green/30 rounded-full px-4 py-1.5 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-evium-green animate-pulse"></span>
        <span class="text-evium-green text-sm font-semibold tracking-widest uppercase">Live Profit Calculator</span>
      </div>

      <h1 class="text-5xl lg:text-7xl font-black leading-[1.05] tracking-tight mb-6">
        Calculate your<br class="hidden sm:block" />
        <span class="text-evium-green">EV charging revenue.</span>
      </h1>

      <p class="text-xl lg:text-2xl text-white/60 leading-relaxed max-w-3xl mx-auto">
        Adjust the inputs below to model the recurring income your property could generate.
        Numbers update in real time — no email, no signup, no commitment.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CALCULATOR
  ═══════════════════════════════════════════════ -->
  <section class="relative bg-evium-dark pb-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">

      <!-- Preset chips -->
      <div class="mb-8">
        <p class="text-evium-green/70 text-xs font-bold tracking-widest uppercase mb-4 text-center">Start With a Scenario</p>
        <div class="flex flex-wrap justify-center gap-2.5">
          {presets.map(p => (
            <button
              type="button"
              data-preset={p.id}
              data-ports={p.ports}
              data-sessions={p.sessionsPerPort}
              data-kwh={p.kwh}
              data-price={p.price}
              class="preset-btn px-5 py-2.5 rounded-full border border-white/10 bg-white/[0.03] text-white/70 text-sm font-semibold hover:border-evium-green/50 hover:text-evium-green hover:bg-evium-green/5 transition-all"
            >
              {p.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Calculator Card -->
      <div class="relative rounded-3xl bg-gradient-to-br from-evium-dark-light to-[#1a3040] border border-white/10 overflow-hidden shadow-2xl shadow-black/40">
        <!-- accent rail -->
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-evium-green/50 to-transparent"></div>
        <!-- corner glow -->
        <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full opacity-20 pointer-events-none"
             style="background: radial-gradient(circle, #2DC856 0%, transparent 70%);"></div>

        <div class="relative grid lg:grid-cols-5 gap-0">

          <!-- INPUTS -->
          <div class="lg:col-span-3 p-8 lg:p-12 lg:border-r lg:border-white/10">
            <div class="flex items-center gap-3 mb-8">
              <div class="w-10 h-10 rounded-lg bg-evium-green/15 border border-evium-green/30 flex items-center justify-center">
                <svg class="w-5 h-5 text-evium-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 17V7m4 10V11m4 6V4M3 21h18" />
                </svg>
              </div>
              <div>
                <p class="text-evium-green/70 text-xs font-bold tracking-widest uppercase">Step 1</p>
                <h2 class="text-2xl font-black text-white">Your Inputs</h2>
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-6">
              <!-- Sessions per port per day -->
              <div>
                <label for="sessions" class="block text-sm font-bold text-white mb-2">
                  Sessions Per Port / Day
                </label>
                <div class="relative">
                  <input
                    id="sessions"
                    type="number"
                    inputmode="decimal"
                    min="0" step="0.5"
                    value="6"
                    class="calc-input w-full bg-evium-dark border border-white/10 rounded-xl px-4 py-3.5 text-white text-lg font-semibold focus:outline-none focus:border-evium-green focus:ring-2 focus:ring-evium-green/20 transition-all"
                  />
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 text-xs font-semibold">/ day</span>
                </div>
                <p class="text-white/40 text-xs mt-2">Typical L2: 2–4 · DC Fast: 8–14</p>
              </div>

              <!-- Number of ports -->
              <div>
                <label for="ports" class="block text-sm font-bold text-white mb-2">
                  Number of Ports
                </label>
                <div class="relative">
                  <input
                    id="ports"
                    type="number"
                    inputmode="numeric"
                    min="1" step="1"
                    value="4"
                    class="calc-input w-full bg-evium-dark border border-white/10 rounded-xl px-4 py-3.5 text-white text-lg font-semibold focus:outline-none focus:border-evium-green focus:ring-2 focus:ring-evium-green/20 transition-all"
                  />
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 text-xs font-semibold">ports</span>
                </div>
                <p class="text-white/40 text-xs mt-2">Each charger has 1–2 ports</p>
              </div>

              <!-- kWh per session -->
              <div>
                <label for="kwh" class="block text-sm font-bold text-white mb-2">
                  kWh Per Session
                </label>
                <div class="relative">
                  <input
                    id="kwh"
                    type="number"
                    inputmode="decimal"
                    min="0" step="1"
                    value="25"
                    class="calc-input w-full bg-evium-dark border border-white/10 rounded-xl px-4 py-3.5 text-white text-lg font-semibold focus:outline-none focus:border-evium-green focus:ring-2 focus:ring-evium-green/20 transition-all"
                  />
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 text-xs font-semibold">kWh</span>
                </div>
                <p class="text-white/40 text-xs mt-2">Typical L2: 15–25 · DC Fast: 30–50</p>
              </div>

              <!-- Price per kWh -->
              <div>
                <label for="price" class="block text-sm font-bold text-white mb-2">
                  Price Per kWh
                </label>
                <div class="relative">
                  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-white/40 text-lg font-semibold">$</span>
                  <input
                    id="price"
                    type="number"
                    inputmode="decimal"
                    min="0" step="0.01"
                    value="0.42"
                    class="calc-input w-full bg-evium-dark border border-white/10 rounded-xl pl-9 pr-16 py-3.5 text-white text-lg font-semibold focus:outline-none focus:border-evium-green focus:ring-2 focus:ring-evium-green/20 transition-all"
                  />
                  <span class="absolute right-4 top-1/2 -translate-y-1/2 text-white/30 text-xs font-semibold">/ kWh</span>
                </div>
                <p class="text-white/40 text-xs mt-2">National average for public charging: $0.30–$0.55</p>
              </div>
            </div>

            <!-- Financial model toggle -->
            <div class="mt-10 pt-8 border-t border-white/10">
              <p class="text-evium-green/70 text-xs font-bold tracking-widest uppercase mb-4">Step 2 · Financial Model</p>
              <div class="grid sm:grid-cols-2 gap-3">
                <label class="model-option cursor-pointer block">
                  <input type="radio" name="model" value="0.10" checked
                         style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;" />
                  <div class="model-card rounded-xl border border-white/10 bg-evium-dark p-5 transition-all hover:border-white/30">
                    <div class="flex items-center justify-between mb-2">
                      <p class="font-bold text-white">No-Cost Model</p>
                      <span class="model-dot w-4 h-4 rounded-full border-2 border-white/30 grid place-items-center transition-colors">
                        <span class="dot-inner w-1.5 h-1.5 rounded-full bg-evium-dark opacity-0 transition-opacity"></span>
                      </span>
                    </div>
                    <p class="text-white/50 text-xs leading-relaxed">$0 capital. Evium covers everything. You receive ~10% revenue share.</p>
                  </div>
                </label>
                <label class="model-option cursor-pointer block">
                  <input type="radio" name="model" value="1.00"
                         style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;" />
                  <div class="model-card rounded-xl border border-white/10 bg-evium-dark p-5 transition-all hover:border-white/30">
                    <div class="flex items-center justify-between mb-2">
                      <p class="font-bold text-white">Client Investment</p>
                      <span class="model-dot w-4 h-4 rounded-full border-2 border-white/30 grid place-items-center transition-colors">
                        <span class="dot-inner w-1.5 h-1.5 rounded-full bg-evium-dark opacity-0 transition-opacity"></span>
                      </span>
                    </div>
                    <p class="text-white/50 text-xs leading-relaxed">You finance & own the equipment. You keep 100% of charging revenue.</p>
                  </div>
                </label>
              </div>
            </div>
          </div>

          <!-- RESULTS -->
          <div class="lg:col-span-2 p-8 lg:p-12 bg-gradient-to-b from-evium-dark/40 to-evium-dark/80 lg:bg-none lg:bg-evium-dark/30">
            <div class="flex items-center gap-3 mb-8">
              <div class="w-10 h-10 rounded-lg bg-evium-green flex items-center justify-center">
                <svg class="w-5 h-5 text-evium-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
                </svg>
              </div>
              <div>
                <p class="text-evium-green/70 text-xs font-bold tracking-widest uppercase">Your Estimate</p>
                <h2 class="text-2xl font-black text-white">Revenue Potential</h2>
              </div>
            </div>

            <!-- Headline result -->
            <div class="rounded-2xl bg-evium-green/[0.07] border border-evium-green/30 p-6 mb-4 relative overflow-hidden">
              <div class="absolute inset-0 opacity-30 pointer-events-none"
                   style="background: radial-gradient(circle at 80% 20%, #2DC856 0%, transparent 60%);"></div>
              <div class="relative">
                <p class="text-evium-green text-xs font-bold tracking-widest uppercase mb-2">Your Monthly Share</p>
                <p id="result-monthly" class="text-5xl lg:text-6xl font-black text-white leading-none mb-1">$0</p>
                <p class="text-white/40 text-xs mt-2">Based on a 30-day month</p>
              </div>
            </div>

            <!-- Secondary results -->
            <div class="grid grid-cols-2 gap-3 mb-6">
              <div class="rounded-xl bg-evium-dark border border-white/10 p-4">
                <p class="text-white/40 text-xs font-semibold uppercase tracking-wider mb-1">Per Year</p>
                <p id="result-yearly" class="text-2xl font-black text-white">$0</p>
              </div>
              <div class="rounded-xl bg-evium-dark border border-white/10 p-4">
                <p class="text-white/40 text-xs font-semibold uppercase tracking-wider mb-1">5-Year Total</p>
                <p id="result-5yr" class="text-2xl font-black text-evium-green">$0</p>
              </div>
            </div>

            <!-- Breakdown -->
            <div class="rounded-xl bg-evium-dark/60 border border-white/5 p-5 space-y-2.5 text-sm">
              <div class="flex justify-between">
                <span class="text-white/50">Gross monthly (all sessions)</span>
                <span id="result-gross" class="text-white font-semibold">$0</span>
              </div>
              <div class="flex justify-between">
                <span class="text-white/50">Sessions per month</span>
                <span id="result-sessions" class="text-white font-semibold">0</span>
              </div>
              <div class="flex justify-between">
                <span class="text-white/50">Energy delivered (kWh / mo)</span>
                <span id="result-energy" class="text-white font-semibold">0</span>
              </div>
              <div class="flex justify-between pt-2.5 border-t border-white/10">
                <span class="text-white/50">Your share</span>
                <span id="result-share" class="text-evium-green font-bold">10%</span>
              </div>
            </div>

            <button
              type="button"
              data-open-estimate
              class="mt-6 w-full inline-flex items-center justify-center gap-2 bg-evium-green text-evium-dark font-bold text-sm px-6 py-4 rounded-xl hover:bg-white transition-colors cursor-pointer"
            >
              Get a Personalized Estimate
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <p class="text-center text-white/30 text-xs mt-6 max-w-3xl mx-auto leading-relaxed">
        Estimates are illustrative and based on the inputs you provide. Actual revenue varies by location,
        traffic, weather, EV adoption in your region, charger uptime, and pricing strategy. For a tailored
        projection grounded in real Evium deployment data, request a personalized estimate.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       BENEFIT CARDS (from original screenshot, polished)
  ═══════════════════════════════════════════════ -->
  <section class="py-28 bg-evium-dark-light">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-evium-green font-semibold text-sm tracking-widest uppercase mb-4">Beyond the Numbers</p>
        <h2 class="text-4xl lg:text-5xl font-black leading-tight mb-5">More than just charging revenue.</h2>
        <p class="text-white/55 text-lg max-w-2xl mx-auto">
          The dollars on screen are only one piece of the upside. Every Evium deployment compounds value across three additional dimensions.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        <div class="relative bg-evium-dark rounded-2xl p-8 border border-white/10 overflow-hidden hover:border-evium-green/30 transition-colors">
          <div class="absolute -top-12 -right-12 w-40 h-40 rounded-full opacity-10 pointer-events-none"
               style="background: radial-gradient(circle, #2DC856 0%, transparent 70%);"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-evium-green/15 border border-evium-green/25 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-evium-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="text-xl font-black text-white mb-3">Grid Monetization</h3>
            <p class="text-white/55 text-sm leading-relaxed">
              Install Evium chargers and turn underused parking into a high-yield asset. Open ADR 2.0b grid services let your site participate in demand-response programs for additional revenue streams.
            </p>
          </div>
        </div>

        <div class="relative bg-evium-dark rounded-2xl p-8 border border-white/10 overflow-hidden hover:border-evium-green/30 transition-colors">
          <div class="absolute -top-12 -right-12 w-40 h-40 rounded-full opacity-10 pointer-events-none"
               style="background: radial-gradient(circle, #2DC856 0%, transparent 70%);"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-evium-green/15 border border-evium-green/25 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-evium-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-black text-white mb-3">Carbon Credit Capture</h3>
            <p class="text-white/55 text-sm leading-relaxed">
              Offset energy costs and align your brand with the clean-energy transition. Eligible deployments qualify for LCFS credits and ESG reporting that strengthens your sustainability story.
            </p>
          </div>
        </div>

        <div class="relative bg-evium-dark rounded-2xl p-8 border border-white/10 overflow-hidden hover:border-evium-green/30 transition-colors">
          <div class="absolute -top-12 -right-12 w-40 h-40 rounded-full opacity-10 pointer-events-none"
               style="background: radial-gradient(circle, #2DC856 0%, transparent 70%);"></div>
          <div class="relative">
            <div class="w-12 h-12 rounded-xl bg-evium-green/15 border border-evium-green/25 flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-evium-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-xl font-black text-white mb-3">Revenue Optimization</h3>
            <p class="text-white/55 text-sm leading-relaxed">
              Dynamic pricing, real-time analytics, and load management — built into the Evium owner portal. Maximize earnings, monitor uptime, and adjust pricing without touching hardware.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       WHAT'S NOT IN THE CALCULATOR
  ═══════════════════════════════════════════════ -->
  <section class="py-28 bg-evium-dark">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-evium-green font-semibold text-sm tracking-widest uppercase mb-4">The Bigger Picture</p>
          <h2 class="text-4xl lg:text-5xl font-black leading-tight mb-6">
            What this calculator <span class="text-evium-green">doesn't</span> show.
          </h2>
          <p class="text-white/60 text-lg leading-relaxed mb-6">
            Charging revenue is the most measurable number — but it's rarely the largest. Evium clients consistently report that the indirect financial impact dwarfs the direct income.
          </p>
          <p class="text-white/55 text-base leading-relaxed">
            One Oakmark client signed three new tenants in their first month following installation — citing EV charging as a deciding factor. That's the kind of upside a calculator can't predict.
          </p>
        </div>

        <div class="space-y-4">
          <div class="bg-evium-dark-light rounded-xl p-6 border border-white/10 flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-evium-green/15 border border-evium-green/25 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-evium-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-white mb-1">Tenant Acquisition & Retention</h3>
              <p class="text-white/55 text-sm leading-relaxed">EV charging is now a leasing-decision factor. Properties with chargers close deals competitors can't.</p>
            </div>
          </div>

          <div class="bg-evium-dark-light rounded-xl p-6 border border-white/10 flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-evium-green/15 border border-evium-green/25 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-evium-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-white mb-1">Property Value Appreciation</h3>
              <p class="text-white/55 text-sm leading-relaxed">EV-ready commercial properties command higher appraisals and rent premiums in active markets.</p>
            </div>
          </div>

          <div class="bg-evium-dark-light rounded-xl p-6 border border-white/10 flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-evium-green/15 border border-evium-green/25 flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-evium-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-white mb-1">Rebates & Grants</h3>
              <p class="text-white/55 text-sm leading-relaxed">NEVI, CEC, BPU, and utility incentives can offset 80%+ of capital costs. Evium handles every application.</p>
            </div>
          </div>

          <div class="bg-evium-dark-light rounded-xl p-6 border border-white/10 flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-evium-green/15 border border-evium-green/25 flex items-center justify-center flex-shrink-0">
