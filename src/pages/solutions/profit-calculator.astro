  <!-- ═══════════════════════════════════════════════
       CALCULATOR SCRIPT
  ═══════════════════════════════════════════════ -->
  <script>
    type Result = {
      gross: number;
      monthly: number;
      yearly: number;
      fiveYr: number;
      sessions: number;
      energy: number;
      share: number;
    };

    const fmtUSD = (n: number) =>
      new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(
        Math.max(0, Math.round(n))
      );
    const fmtNum = (n: number) =>
      new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 }).format(Math.max(0, Math.round(n)));

    const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

    const sessionsEl = $<HTMLInputElement>('sessions');
    const portsEl    = $<HTMLInputElement>('ports');
    const kwhEl      = $<HTMLInputElement>('kwh');
    const priceEl    = $<HTMLInputElement>('price');

    const outMonthly  = $('result-monthly');
    const outYearly   = $('result-yearly');
    const out5yr      = $('result-5yr');
    const outGross    = $('result-gross');
    const outSessions = $('result-sessions');
    const outEnergy   = $('result-energy');
    const outShare    = $('result-share');

    function computeShare(): number {
      const checked = document.querySelector<HTMLInputElement>('input[name="model"]:checked');
      return checked ? parseFloat(checked.value) : 0.10;
    }

    function calc(): Result {
      const sessionsPerPortPerDay = Math.max(0, parseFloat(sessionsEl.value) || 0);
      const ports                 = Math.max(0, parseFloat(portsEl.value)    || 0);
      const kwhPerSession         = Math.max(0, parseFloat(kwhEl.value)      || 0);
      const pricePerKwh           = Math.max(0, parseFloat(priceEl.value)    || 0);

      const sessionsPerMonth = sessionsPerPortPerDay * ports * 30;
      const energyPerMonth   = sessionsPerMonth * kwhPerSession;
      const grossMonthly     = energyPerMonth * pricePerKwh;

      const share   = computeShare();
      const monthly = grossMonthly * share;
      const yearly  = monthly * 12;
      const fiveYr  = yearly * 5;

      return { gross: grossMonthly, monthly, yearly, fiveYr, sessions: sessionsPerMonth, energy: energyPerMonth, share };
    }

    function render() {
      const r = calc();
      outMonthly.textContent  = fmtUSD(r.monthly);
      outYearly.textContent   = fmtUSD(r.yearly);
      out5yr.textContent      = fmtUSD(r.fiveYr);
      outGross.textContent    = fmtUSD(r.gross);
      outSessions.textContent = fmtNum(r.sessions);
      outEnergy.textContent   = fmtNum(r.energy);
      outShare.textContent    = `${Math.round(r.share * 100)}%`;
    }

    [sessionsEl, portsEl, kwhEl, priceEl].forEach(el => {
      el.addEventListener('input', render);
      el.addEventListener('change', render);
    });

    function syncModelCards() {
      document.querySelectorAll<HTMLLabelElement>('.model-option').forEach(label => {
        const input = label.querySelector<HTMLInputElement>('input[type="radio"]');
        const card  = label.querySelector<HTMLElement>('.model-card');
        const dot   = label.querySelector<HTMLElement>('.model-dot');
        const inner = label.querySelector<HTMLElement>('.dot-inner');
        if (!input || !card || !dot || !inner) return;
        const on = input.checked;
        card.classList.toggle('border-evium-green', on);
        card.classList.toggle('bg-evium-green/[0.06]', on);
        card.classList.toggle('border-white/10', !on);
        dot.classList.toggle('border-evium-green', on);
        dot.classList.toggle('bg-evium-green', on);
        dot.classList.toggle('border-white/30', !on);
        inner.classList.toggle('opacity-100', on);
        inner.classList.toggle('opacity-0', !on);
      });
    }

    document.querySelectorAll<HTMLInputElement>('input[name="model"]').forEach(el => {
      el.addEventListener('change', () => { syncModelCards(); render(); });
    });
    syncModelCards();

    document.querySelectorAll<HTMLButtonElement>('.preset-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        sessionsEl.value = btn.dataset.sessions ?? sessionsEl.value;
        portsEl.value    = btn.dataset.ports    ?? portsEl.value;
        kwhEl.value      = btn.dataset.kwh      ?? kwhEl.value;
        priceEl.value    = btn.dataset.price    ?? priceEl.value;

        document.querySelectorAll('.preset-btn').forEach(b =>
          b.classList.remove('!border-evium-green', '!text-evium-green', '!bg-evium-green/10')
        );
        btn.classList.add('!border-evium-green', '!text-evium-green', '!bg-evium-green/10');

        render();
      });
    });

    render();

    /* ─────────────  Estimate modal  ───────────── */
    const modal       = $('estimate-modal');
    const backdrop    = $('estimate-backdrop');
    const panel       = $('estimate-panel');
    const formView    = $('estimate-form-view');
    const successView = $('estimate-success-view');
    const form        = $<HTMLFormElement>('estimate-form');
    const submitBtn   = $<HTMLButtonElement>('ef-submit');
    const submitLabel = $('ef-submit-label');
    const errorEl     = $('ef-error');

    const recapSessions = $('recap-sessions');
    const recapPorts    = $('recap-ports');
    const recapKwh      = $('recap-kwh');
    const recapPrice    = $('recap-price');
    const recapModel    = $('recap-model');
    const recapMonthly  = $('recap-monthly');

    let lastFocus: HTMLElement | null = null;

    function fillRecap() {
      const r = calc();
      recapSessions.textContent = sessionsEl.value || '—';
      recapPorts.textContent    = portsEl.value    || '—';
      recapKwh.textContent      = kwhEl.value      || '—';
      recapPrice.textContent    = `$${parseFloat(priceEl.value || '0').toFixed(2)}`;
      const checked = document.querySelector<HTMLInputElement>('input[name="model"]:checked');
      recapModel.textContent = checked?.value === '1.00' ? 'Client Investment (100%)' : 'No-Cost (~10%)';
      recapMonthly.textContent = fmtUSD(r.monthly) + ' / mo';
    }

    function openModal() {
      lastFocus = document.activeElement as HTMLElement;
      fillRecap();
      // reset to form view in case user reopens after success
      formView.classList.remove('hidden');
      successView.classList.add('hidden');
      errorEl.classList.add('hidden');
      submitBtn.disabled = false;
      submitLabel.textContent = 'Send My Estimate Request';

      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      // next frame for transition
      requestAnimationFrame(() => {
        backdrop.classList.add('opacity-100');
        backdrop.classList.remove('opacity-0');
        panel.classList.add('opacity-100', 'translate-y-0');
        panel.classList.remove('opacity-0', 'translate-y-8', 'sm:translate-y-4');
      });
      setTimeout(() => $<HTMLInputElement>('ef-name').focus(), 120);
    }

    function closeModal() {
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      panel.classList.remove('opacity-100', 'translate-y-0');
      panel.classList.add('opacity-0', 'translate-y-8', 'sm:translate-y-4');
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
        lastFocus?.focus?.();
      }, 200);
    }

    document.querySelectorAll('[data-open-estimate]').forEach(el =>
      el.addEventListener('click', openModal)
    );
    document.querySelectorAll('[data-close-estimate]').forEach(el =>
      el.addEventListener('click', closeModal)
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');

      const honeypot = (form.elements.namedItem('company_website') as HTMLInputElement | null)?.value;
      if (honeypot) return; // bot

      const name    = (form.elements.namedItem('name')    as HTMLInputElement).value.trim();
      const email   = (form.elements.namedItem('email')   as HTMLInputElement).value.trim();
      const address = (form.elements.namedItem('address') as HTMLInputElement).value.trim();
      const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

      if (!name || !emailOk || !address) {
        errorEl.textContent = !emailOk && email
          ? 'Please enter a valid email address.'
          : 'Please complete name, email, and property address.';
        errorEl.classList.remove('hidden');
        return;
      }

      submitBtn.disabled = true;
      submitLabel.textContent = 'Sending…';

      // No backend yet — simulate the round-trip. When the API exists, replace
      // this with a real fetch() to /api/estimate-request including the calc state.
      await new Promise(resolve => setTimeout(resolve, 700));

      formView.classList.add('hidden');
      successView.classList.remove('hidden');
      panel.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>

